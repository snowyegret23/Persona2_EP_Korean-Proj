function START()
{
    sndVoicePlay(sound_7d, 127);
    sndWaitStart();
    ref_2 = dialogAlloc();
    ref_3 = msgShow(msg_0);
/***************************************
[color(yellow)]ニャルラトホテプ[color(white)]
[tab]ふはははは！[tab]実に！[tab]愉快！！
[tab]私にこの姿を晒させたのはお前達が初めてだ…
[tab]最高の賛辞を抱いて死ねぃ！
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_3);
    dialogFree(ref_2);
}
