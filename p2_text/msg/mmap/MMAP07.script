function M701()
{
    ref_0 = dialogAlloc();
    ref_1 = msgShow(msg_0);
/***************************************
[color(yellow)]ハイカー[color(white)]
[tab]この間、山道を散策してたら
[tab]病院の裏手に出ちゃってさ、
[tab]暗くてすごく不気味だったの。[wait][clear][color(yellow)]ハイカー[color(white)]
[tab]あの病院って、なんだかよく解らないわよね。
[tab]患者の出入りも殆どないし、
[tab]どうして潰れないのか不思議だわ。[wait][clear]
***************************************/
    wait(ref_1);
    dialogFree(ref_0);
}

function M702()
{
    bitGet(var_1, TBIT_702_HG);
    bnz(var_1, label_2d);
    ref_7 = dialogAlloc();
    ref_8 = msgShow(msg_1);
/***************************************
[color(yellow)]うさん臭い警備員[color(white)]
[tab]ここから先、事故があって工事中よ。
[tab]ダメね。通れないよ。
[tab]引き返して。引き返して。[wait][clear]
***************************************/
    wait(ref_8);
    dialogFree(ref_7);
    ref_b = bustupLoad(bustup_21);
    bustupWait(ref_b);
    ref_d = bustupAlloc(ref_b, left, rgb(0,0,0));
    bustupFade(ref_d, rgb(128,0,0), 30);
    ref_f = dialogAlloc();
    ref_10 = msgShow(msg_2);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]事故？
[tab]所轄の署に、交通規制の連絡はしてるのか？[wait][clear]
***************************************/
    wait(ref_10);
    dialogFree(ref_f);
    ref_13 = bustupFade(ref_d, rgb(0,0,0), 10);
    bustupWait(ref_13);
    bustupFree(ref_d);
    ref_16 = dialogAlloc();
    ref_17 = msgShow(msg_3);
/***************************************
[color(yellow)]うさん臭い警備員[color(white)]
[tab]いや、急の事故だよ。
[tab]ダメね。通れないよ。[wait][clear]
***************************************/
    wait(ref_17);
    dialogFree(ref_16);
    ref_1a = bustupLoad(bustup_21);
    bustupWait(ref_1a);
    ref_1c = bustupAlloc(ref_1a, left, rgb(0,0,0));
    bustupFade(ref_1c, rgb(128,0,0), 30);
    ref_1e = dialogAlloc();
    ref_1f = msgShow(msg_4);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]…仕方ないな。
[tab]わかった、ありがとう。[wait][clear]
***************************************/
    wait(ref_1f);
    dialogFree(ref_1e);
    ref_22 = bustupFade(ref_1c, rgb(0,0,0), 10);
    bustupWait(ref_22);
    bustupFree(ref_1c);
    bitSet(TBIT_EVT703);
    bitSet(TBIT_702_HG);
    b(label_31);
    ref_28 = dialogAlloc();
    ref_29 = msgShow(msg_5);
/***************************************
[color(yellow)]警備員[color(white)]
[tab]ダミー。[wait][clear]
***************************************/
    wait(ref_29);
    dialogFree(ref_28);
    b(label_31);
  label_2d:
    ref_2d = dialogAlloc();
    ref_2e = msgShow(msg_6);
/***************************************
[color(yellow)]うさん臭い警備員[color(white)]
[tab]工事、時間かかるよ。
[tab]しばらくダメね。[wait][clear]
***************************************/
    wait(ref_2e);
    dialogFree(ref_2d);
  label_31:
}

