function MAYA()
{
    unitMove(maya, 50, -280, face_west, fast);
    unitWait(maya);
    delayClear();
    delayWait(60);
    unitAnimationPlay(maya, animation_28, 1);
    unitWait(maya);
    ref_298 = spriteLoad(sprite_19);
    wait(ref_298);
    call(KATUYA);
    unitMove(maya, 200, -280, face_south, medium);
    unitWait(maya);
    unitMove(maya, 200, -120, face_east, medium);
    unitWait(maya);
    unitMove(maya, 145, -120, face_south, medium);
    unitWait(maya);
    unitMove(maya, 145, -60, face_east, medium);
    unitWait(maya);
    unitMove(maya, 100, -60, face_south, medium);
    unitWait(maya);
    unitMove(maya, 100, -100, face_south, reverse);
    unitWait(maya);
    unitSpriteClear(maya);
    unitSpriteSet(maya, sprite_1);
    unitAnimationPlay(maya, animation_12, 1);
    unitShadowRadius(maya, 0);
}

function KATUYA()
{
    unitSpawn(katsuya, sprite_d, -50, 0, -280, west, fade);
    unitMove(katsuya, 50, -280, face_west, fast);
    unitWait(katsuya);
    delayClear();
    delayWait(60);
    unitAnimationPlay(katsuya, animation_28, 1);
    unitWait(katsuya);
    delayClear();
    delayWait(60);
    call(PAOFU);
    unitMove(katsuya, 200, -280, face_south, medium);
    unitWait(katsuya);
    unitMove(katsuya, 200, -150, face_east, medium);
    unitWait(katsuya);
}

function PAOFU()
{
    unitSpawn(baofu, sprite_13, -50, 0, -280, west, fade);
    unitMove(baofu, 50, -280, face_west, medium);
    unitWait(baofu);
    delayClear();
    delayWait(60);
    unitAnimationPlay(baofu, animation_b, 1);
    delayClear();
    delayWait(60);
    call(URARA);
    unitMove(baofu, 330, -490, face_east, medium);
    unitFace(baofu, west);
    unitWait(baofu);
    unitSpriteClear(baofu);
    unitSpriteSet(baofu, sprite_14);
    unitAnimationPlay(baofu, animation_1f, 1);
    unitShadowRadius(baofu, 0);
}

function URARA()
{
    unitSpawn(ulala, sprite_6, -50, 0, -280, west, fade);
    unitMove(ulala, 50, -280, face_west, medium);
    unitWait(ulala);
    delayClear();
    delayWait(60);
    unitAnimationPlay(ulala, animation_3, 1);
    delayClear();
    delayWait(10);
    unitAnimationPlay(ulala, animation_4, 1);
    delayClear();
    delayWait(60);
    call(TATUYA);
    unitMove(ulala, 120, -280, face_north, medium);
    unitWait(ulala);
    unitMove(ulala, 150, -1050, face_north, medium);
    unitWait(ulala);
    unitAnimationPlay(ulala, animation_31, 1);
}

function TATUYA()
{
    unitSpawn(tatsuya, sprite_18, -50, 0, -280, west, fade);
    unitMove(tatsuya, 50, -280, face_west, medium);
    unitWait(tatsuya);
    delayClear();
    delayWait(60);
    unitAnimationPlay(tatsuya, animation_1, 1);
    delayClear();
