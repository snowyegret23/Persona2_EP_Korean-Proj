/***************************************
[color(yellow)]富樫署長[color(white)]
[tab]や、奴等の…アジト…は…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_db);
    dialogFree(ref_da);
    ref_df = bustupFade(ref_d8, rgb(0,0,0), 10);
    bustupWait(ref_df);
    bustupFree(ref_d8);
    delayClear();
    delayWait(30);
    unitAnimationStop(unit_18);
    unitAnimationPlay(unit_18, animation_4c, 1);
    sndMusicPlay(sound_31f2, 127);
    delayClear();
    delayWait(90);
    unitAnimationPlay(ulala, animation_37, 1);
    unitAnimationPlay(baofu, animation_b, 1);
    unitAnimationHold(elly, animation_1a, -1);
