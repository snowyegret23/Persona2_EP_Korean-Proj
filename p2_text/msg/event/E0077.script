function MAYA_IDO()
{
    unitMove(maya, 900, -610, face_north, medium);
    unitWait(maya);
    unitMove(maya, 900, -850, face_north, medium);
    unitWait(maya);
    unitAnimationPlay(maya, animation_10, 1);
}

function URARA_IDO()
{
    unitMove(ulala, 1150, -920, face_north, medium);
    unitWait(ulala);
    unitAnimationPlay(ulala, animation_32, 1);
}

function PAOFU_IDO()
{
    unitMove(baofu, 840, -920, face_north, medium);
    unitWait(baofu);
    unitAnimationPlay(baofu, animation_10, 1);
}

function ERI_IDO()
{
    unitMove(elly, 1040, -880, face_north, medium);
    unitWait(elly);
    unitAnimationPlay(elly, animation_10, 1);
}

function PAOFU_IDO2()
{
    unitMove(baofu, 780, -630, face_east, medium);
    unitWait(baofu);
    unitMove(baofu, 450, -550, despawn, medium);
}
