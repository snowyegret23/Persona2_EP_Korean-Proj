function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    sndIdGet(var_a);
    bne(var_a, -1, label_5);
    b(label_7);
  label_5:
    sndVolumeFadeOff(var_a, 60);
    b(label_7);
  label_7:
    bitClear(TBIT_MD403);
    cameraSet(northwest, 740, 0, -480);
    ref_9 = spriteLoad(sprite_0);
    wait(ref_9);
    ref_b = spriteLoad(sprite_6);
    wait(ref_b);
    ref_d = spriteLoad(sprite_d);
    wait(ref_d);
    ref_f = spriteLoad(sprite_e);
