    unitAnimationPlay(katsuya, animation_34, 1);
    delayClear();
    delayWait(30);
    unitAnimationPlay(katsuya, animation_0, 1);
    delayClear();
    delayWait(30);
    unitMove(katsuya, 820, -1240, face_west, medium);
