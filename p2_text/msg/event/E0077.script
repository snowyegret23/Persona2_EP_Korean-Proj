    screenFadeInner(rgb(0,0,0), 4, true);
    screenFadeOuter(rgb(0,0,0), 4, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    delayClear();
    delayWait(90);
    ref_3d = bustupLoad(bustup_23);
    bustupWait(ref_3d);
    ref_3f = bustupAlloc(ref_3d, left, rgb(0,0,0));
    bustupFade(ref_3f, rgb(128,0,0), 30);
    ref_41 = dialogAlloc();
    ref_42 = msgShow(msg_0);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]このまま…

***************************************/
    wait(ref_42);
    unitAnimationPlay(katsuya, animation_29, 1);
    ref_45 = msgShow(msg_1);
/***************************************
[tab]公僕のまま、死なせはしない…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_45);
    dialogFree(ref_41);
    ref_49 = bustupFade(ref_3f, rgb(0,0,0), 10);
    bustupWait(ref_49);
    bustupFree(ref_3f);
    unitAnimationPlay(unit_16, animation_51, 1);
    delayClear();
    delayWait(60);
    unitMove(katsuya, 940, -610, face_south, medium);
    unitWait(katsuya);
    unitSpriteClear(katsuya);
    unitSpriteSet(katsuya, sprite_e);
    unitAnimationPlay(katsuya, animation_5, 1);
    unitAnimationPlay(unit_16, animation_52, 1);
    delayClear();
    delayWait(20);
    sndMusicPlay(sound_31f0, 127);
    delayClear();
    delayWait(80);
    unitSpriteClear(katsuya);
    unitSpriteSet(katsuya, sprite_d);
    unitAnimationPlay(katsuya, animation_37, 1);
    delayClear();
    delayWait(30);
    unitAnimationPlay(katsuya, animation_0, 1);
    delayClear();
    delayWait(30);
    unitMove(katsuya, 940, -720, face_south, reverse);
