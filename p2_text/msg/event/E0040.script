    wait(ref_1f2);
    dialogFree(ref_1f1);
    ref_1fb = bustupFade(ref_1ef, rgb(0,0,0), 10);
    bustupWait(ref_1fb);
    bustupFree(ref_1ef);
    unitAnimationPlay(ulala, animation_a, 1);
    delayClear();
    delayWait(30);
    unitAnimationPlay(maya, animation_1, 1);
    unitAnimationPlay(katsuya, animation_a, 1);
    unitAnimationPlay(baofu, animation_a, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(maya, animation_0, 1);
    delayClear();
    delayWait(60);
    bitSet(MBIT_KI_NorETOUJO);
    bitSet(EBIT_E0044);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    bitClear(VBIT_KOEN_HAJIKI);
    mapLoad(aoba, 1, 2);
}

