function MAYA_TOJO()
{
    unitSpawn(maya, sprite_3, 1100, 0, -2320, south, none);
    unitAnimationPlay(maya, animation_1, 1);
    unitJumpTo(maya, 1100, 0, -2020, 10, 0);
    unitWait(maya);
    unitAnimationPlay(maya, animation_0, 1);
}

function URARA_TOJO()
{
    unitSpawn(ulala, sprite_8, 920, 0, -2440, south, none);
    unitAnimationPlay(ulala, animation_1, 1);
    unitJumpTo(ulala, 920, 0, -2140, 10, 0);
    unitWait(ulala);
    unitAnimationPlay(ulala, animation_0, 1);
}

function KATUYA_TOJO()
{
    unitSpawn(katsuya, sprite_f, 1000, 0, -2230, south, none);
    unitAnimationPlay(katsuya, animation_1, 1);
    unitJumpTo(katsuya, 1000, 0, -1930, 10, 0);
    unitWait(katsuya);
    unitAnimationPlay(katsuya, animation_0, 1);
}

function PAOFU_TOJO()
{
    unitSpawn(baofu, sprite_15, 1100, 0, -2470, south, none);
    unitAnimationPlay(baofu, animation_1, 1);
    unitJumpTo(baofu, 1100, 0, -2170, 10, 0);
    unitWait(baofu);
    unitAnimationPlay(baofu, animation_0, 1);
}

function PARTY_TOJO()
{
    call(KATUYA_TOJO);
    delayClear();
    delayWait(10);
    call(MAYA_TOJO);
    call(PAOFU_TOJO);
    delayClear();
    delayWait(10);
    call(URARA_TOJO);
}

function SOUND()
{
    sndVolumeFadeOff(sound_3028, 120);
    delayClear();
    delayWait(90);
    sndMusicPlay(sound_3021, 127);
}
