function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    cameraSet(southeast, 700, 0, -1470);
    ref_3 = spriteLoad(sprite_0);
    wait(ref_3);
    ref_5 = spriteLoad(sprite_6);
    wait(ref_5);
    ref_7 = spriteLoad(sprite_d);
    wait(ref_7);
    ref_9 = spriteLoad(sprite_13);
    wait(ref_9);
    ref_b = spriteLoad(sprite_1f);
    wait(ref_b);
    ref_d = spriteLoad(sprite_23);
    wait(ref_d);
    ref_f = spriteLoad(sprite_18);
    wait(ref_f);
    unitSpawn(maya, sprite_0, 700, 0, -1800, north, none);
    unitSpawn(ulala, sprite_6, 700, 0, -1800, north, none);
    unitSpawn(katsuya, sprite_d, 700, 0, -1800, north, none);
    unitSpawn(baofu, sprite_13, 700, 0, -1800, north, none);
    unitSpawn(tatsuya, sprite_18, 653, 0, -1148, north, none);
    unitFace(tatsuya, south);
    unitAnimationPlay(tatsuya, animation_0, 1);
    unitWait(tatsuya);
    bitGet(var_1, MBIT_HI_NANJOTOUJO);
    bnz(var_1, label_1d);
    unitSpawn(elly, sprite_23, 700, 0, -1800, north, none);
    b(label_1e);
  label_1d:
    unitSpawn(nanjo, sprite_1f, 700, 0, -1800, north, none);
  label_1e:
    screenNarrow(3);
    sndIdGet(var_0);
    sndVolumeFadeOff(var_0, 180);
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 4, true);
    screenFadeOuter(rgb(0,0,0), 4, true);
    call(URARA_IDOU);
    delayClear();
    delayWait(12);
    unitMove(maya, 686, -1287, face_south, medium);
    delayClear();
    delayWait(8);
    call(KATUYA_IDOU);
    delayClear();
    delayWait(5);
    call(PAOFU_IDOU);
    delayClear();
    delayWait(10);
    bnz(var_1, label_36);
    call(ERI_IDOU);
    delayClear();
    delayWait(16);
    unitWait(maya);
    b(label_3a);
  label_36:
    call(NANJO_IDOU);
    delayClear();
    delayWait(16);
    unitWait(maya);
  label_3a:
    unitFace(maya, south);
    unitLook(maya, lookDir_3);
    delayClear();
    delayWait(10);
    unitLook(maya, lookDir_2);
    delayClear();
    delayWait(5);
    unitLook(maya, lookDir_1);
    delayClear();
    delayWait(10);
    unitLook(maya, lookDir_2);
    delayClear();
    delayWait(20);
    cameraMoveTo(700, 0, -600, 120);
    delayClear();
    delayWait(60);
    sndMusicPlay(sound_3260, 127);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), add);
    screenFadeInner(rgb(255,255,255), 4, false);
    screenFadeOuter(rgb(255,255,255), 4, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    op_bd();
    eventLoad(event_cd);
}

function URARA_IDOU()
{
    unitMove(ulala, 500, -1300, face_south, medium);
    unitWait(ulala);
    unitFace(ulala, south);
}

function KATUYA_IDOU()
{
    unitMove(katsuya, 766, -1377, face_south, medium);
    unitWait(katsuya);
    unitFace(katsuya, south);
}

function PAOFU_IDOU()
{
    unitMove(baofu, 832, -1513, face_south, medium);
    unitWait(baofu);
    unitFace(baofu, south);
}

function ERI_IDOU()
{
    unitMove(elly, 600, -1500, face_south, medium);
    unitWait(elly);
    unitFace(elly, south);
}

function NANJO_IDOU()
{
    unitMove(nanjo, 600, -1500, face_south, medium);
    unitWait(nanjo);
    unitFace(nanjo, south);
}
