function START()
{
    msgVar_Item(msgvar_0, magician_card);
    ref_1 = dialogAlloc();
    ref_2 = msgShow(msg_0);
/***************************************
[color(green)]舞耶達は、[var(msg_var_0)]のカードを５０枚
手に入れた。[color(white)]
[wait][clear]
***************************************/
    wait(ref_2);
    partyItemAdd(magician_card, 50);
    ref_5 = msgShow(msg_1);
/***************************************
[color(green)]舞耶達は、理性のトラペゾヘドロンを手に入れ、
理性の塔を後にした。[color(white)]
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_5);
    dialogFree(ref_1);
    bitSet(bit_c7e);
    dngLoad2(kadath_mandala2-3);
}
