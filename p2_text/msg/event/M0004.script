function DOORBOX()
{
    controlDisable();
    objAnimTranslate(obj_1, 80, 0, 0, 30);
    sndMusicPlay(sound_306a, 127);
    objAnimWait(obj_1);
    call(EXITBOX);
}

function EXITBOX()
{
    bitClear(MBIT_EXITBIT);
    mapLoad(rengedai, 0, 0);
}

function warp1()
{
    call(DOORBOX);
}

