    bustupWait(ref_a6);
    ref_a8 = bustupAlloc(ref_a6, left, rgb(0,0,0));
    bustupFade(ref_a8, rgb(128,0,0), 30);
    ref_aa = dialogAlloc();
    ref_ab = msgShow(msg_3);
/***************************************
[color(yellow)]うらら[color(white)]
[tab][suou]さん、弟さんの為に貯金してたんでしょ。
[tab]一体いくら貯めたのかねぇ？
[tab]…いくら貯めたの金ぇ？[tab]アハハ…[delay(15)]はぁ～
[wait][clear]
***************************************/
