    bustupWait(ref_c6);
    ref_c8 = bustupAlloc(ref_c6, left, rgb(0,0,0));
    bustupFade(ref_c8, rgb(128,0,0), 30);
    ref_ca = dialogAlloc();
    ref_cb = msgShow(msg_5);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]あの須藤[tab]竜蔵ってば、自分の息子まで
[tab]ＪＯＫＥＲとして利用したんだよね？
[tab]まったく、なんて親だ！！
