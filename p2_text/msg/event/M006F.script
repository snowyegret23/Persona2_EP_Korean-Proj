function DOORBOX()
{
    controlDisable();
    objAnimRotate(obj_0, 0, -70, 0, 30, 0);
    objAnimWait(obj_0);
    call(EXITBOX);
}

function EXITBOX()
{
    bitClear(MBIT_EXITBIT);
    mapLoad(rengedai, 0, 0);
}

