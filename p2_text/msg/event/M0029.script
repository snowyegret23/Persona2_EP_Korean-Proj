    ref_56d = bustupLoad(bustup_fa);
    bustupWait(ref_56d);
    ref_56f = bustupAlloc(ref_56d, right, rgb(0,0,0));
    bustupFade(ref_56f, rgb(128,0,0), 30);
    choiceSetResult(2);
    ref_572 = dialogAlloc();
    ref_573 = msgShow(msg_105);
/***************************************
[color(yellow)]やる気のないボーイ[color(white)]
[tab]いらっしゃい。
[tab]つーか、こんな昼間からインターネット？
[tab]お客さんって結構ヒマなの？[tab]まぁいいけど。
[choice(4)]食事をする
話をする
やめる
店の外に出る
[end_choice][clear]
***************************************/
    unitAnimationPlay(shopkeeper, animation_21, 1);
    wait(ref_573);
    unitAnimationPlay(shopkeeper, animation_0, 1);
    dialogFree(ref_572);
    shopInventory(12, shopInventory_a);
    shopRate(100);
    b(label_58b);
  label_57b:
    ref_57b = bustupLoad(bustup_fa);
    bustupWait(ref_57b);
    ref_57d = bustupAlloc(ref_57b, right, rgb(0,0,0));
    bustupFade(ref_57d, rgb(128,0,0), 30);
    ref_57f = dialogAlloc();
    ref_580 = msgShow(msg_106);
/***************************************
[color(yellow)]やる気のないボーイ[color(white)]
[tab]あぁ、いらっしゃい。
[tab]つーかお客さんって、ほんとヒマなんだね。
[tab]…なんかこっちが哀しくなるよ。
