function DOORBOX()
{
    controlDisable();
    sndMusicPlay(sound_3078, 127);
    objAnimRotate(obj_4, 0, 70, 0, 30, 0);
    objAnimRotate(obj_3, 0, -70, 0, 30, 0);
    objAnimWait(obj_4);
    objAnimWait(obj_3);
    call(GOOUT);
}

function GOOUT()
{
    bitClear(MBIT_EXITBIT);
    mapLoad(rengedai, 0, 0);
}

function warp1()
{
    call(DOORBOX);
}

