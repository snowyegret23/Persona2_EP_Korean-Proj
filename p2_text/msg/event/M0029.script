function SHOP()
{
    controlDisable();
    ref_564 = shopOverlayInit();
    unitFacePlayer(shopkeeper);
    bitGet(var_0, MBIT_AIS_12);
    bne(var_0, 0, label_56a);
    b(label_56d);
    b(label_56d);
