function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    sndMusicPlay(sound_3059, 127);
    ref_3 = todLoad(tod_b);
    wait(ref_3);
    todRun(tod_b, 1);
    envTriggerSet(DOORBOX, 131, 1, line, coll_32);
    envTriggerSet(PCHIT, 14, 1, line, coll_1f);
    bitGet(var_0, MBIT_W_HATURAITEN);
    bnz(var_0, label_c);
    cameraSet(southwest, 500, 0, -1500);
    b(label_d);
  label_c:
    cameraSet(northwest, 700, 0, -360);
  label_d:
    li(var_0, 0);
    li(var_1, 0);
    partyMemberCheck(var_0, ulala);
    add(var_1, var_1, var_0);
    partyMemberCheck(var_0, katsuya);
    add(var_1, var_1, var_0);
    partyMemberCheck(var_0, baofu);
    add(var_1, var_1, var_0);
    partyMemberCheck(var_0, nanjo);
    add(var_1, var_1, var_0);
    partyMemberCheck(var_0, elly);
    add(var_1, var_1, var_0);
    partyMemberCheck(var_0, tatsuya);
    add(var_1, var_1, var_0);
    boutrange(var_1, 0, 4, label_1e);
    li(var_0, 0);
    b(label_23);
  label_1e:
    ref_1e = dialogAlloc();
    ref_1f = msgShow(msg_0);
/***************************************
パーティの人数が四人を超えています。
このままじゃハングします。
金田・片岡に連絡してください。
[wait][clear]
***************************************/
    wait(ref_1f);
    dialogFree(ref_1e);
    b(label_23);
  label_23:
    bitGet(var_0, EBIT_E009F);
    bnz(var_0, label_28);
    bitGet(var_0, EBIT_E008C);
    bez(var_0, label_2e);
    bnz(var_0, label_2a);
  label_28:
    partyMemberCheck(var_0, tatsuya);
    bez(var_0, label_2e);
  label_2a:
    ref_2a = spriteLoad(sprite_18);
    wait(ref_2a);
    unitSpawn(tatsuya, sprite_18, 650, 0, -1470, east, none);
    unitTriggerSet(tatsuya, B_TATU, 255, 1);
  label_2e:
    bitGet(var_0, EBIT_E009F);
    bnz(var_0, label_41);
    bitGet(var_0, MBIT_HI_NANJOTOUJO);
    bne(var_0, 0, label_39);
    partyMemberCheck(var_0, elly);
    bez(var_0, label_41);
    ref_34 = spriteLoad(sprite_23);
    wait(ref_34);
    unitSpawn(elly, sprite_23, 1110, 0, -1270, east, none);
    unitTriggerSet(elly, B_ERI, 255, 1);
    b(label_41);
  label_39:
    bne(var_0, 1, label_41);
    partyMemberCheck(var_0, nanjo);
    bez(var_0, label_41);
    ref_3c = spriteLoad(sprite_1f);
    wait(ref_3c);
    unitSpawn(nanjo, sprite_1f, 960, 0, -1400, west, none);
    unitTriggerSet(nanjo, B_NANJ, 255, 1);
    b(label_41);
  label_41:
    partyMemberCheck(var_0, ulala);
    bez(var_0, label_47);
    ref_43 = spriteLoad(sprite_6);
    wait(ref_43);
    unitSpawn(ulala, sprite_6, 330, 0, -340, west, none);
    unitTriggerSet(ulala, B_URARATI, 255, 1);
  label_47:
    partyMemberCheck(var_0, katsuya);
    bez(var_0, label_4d);
    ref_49 = spriteLoad(sprite_d);
    wait(ref_49);
    unitSpawn(katsuya, sprite_d, 1050, 0, -440, north, none);
    unitTriggerSet(katsuya, B_KATUYYY, 255, 1);
  label_4d:
    partyMemberCheck(var_0, baofu);
    bez(var_0, label_53);
    ref_4f = spriteLoad(sprite_13);
    wait(ref_4f);
    unitSpawn(baofu, sprite_13, 800, 0, -1200, south, none);
    unitTriggerSet(baofu, B_PAO, 255, 1);
  label_53:
    ref_53 = spriteLoad(sprite_9b);
    wait(ref_53);
    unitSpawn(shopkeeper, sprite_9b, 700, 0, -150, north, none);
    unitTriggerSet(shopkeeper, SHOP, 255, 1);
    envTriggerSet(SHOP, 56, 1, line, coll_0);
    envTriggerSet(SHOP, 112, 1, line, coll_1);
    envTriggerSet(SHOP, 224, 1, line, coll_2);
    envTriggerSet(SHOP, 14, 1, line, coll_3);
    envTriggerSet(SHOP, 28, 1, line, coll_4);
    envTriggerSet(SHOP, 131, 1, line, coll_5);
    ref_5d = spriteLoad(sprite_c8);
    wait(ref_5d);
    unitSpawn(npc1, sprite_c8, 340, 0, -900, north, none);
    unitPalette(npc1, 2);
    unitTriggerSet(npc1, MAN1, 255, 1);
    ref_62 = spriteLoad(sprite_d2);
    wait(ref_62);
    unitSpawn(npc2, sprite_d2, 590, 0, -700, west, none);
    unitPalette(npc2, 2);
    unitTriggerSet(npc2, MAN2, 255, 1);
    ref_67 = spriteLoad(sprite_bd);
    wait(ref_67);
    unitSpawn(unit_58, sprite_bd, 260, 0, -1330, east, none);
    unitTriggerSet(unit_58, GIRL, 255, 1);
    ref_6b = spriteLoad(sprite_0);
    wait(ref_6b);
    ref_6d = spriteLoad(sprite_2);
    wait(ref_6d);
    ref_6f = spriteLoad(sprite_1);
    wait(ref_6f);
    playerInit(south);
    controlDisable();
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    unitIdleOnAll();
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

function B_URARATI()
{
    controlDisable();
    bitGet(var_0, EBIT_E00AF);
    bnz(var_0, label_de);
    bitGet(var_0, EBIT_E009F);
    bnz(var_0, label_ce);
    bitGet(var_0, EBIT_E008C);
    bnz(var_0, label_b6);
    bitGet(var_0, EBIT_E007B);
    bnz(var_0, label_a6);
    bitGet(var_0, EBIT_E007A);
    bnz(var_0, label_96);
    unitFacePlayer(ulala);
    ref_87 = bustupLoad(bustup_1d);
    bustupWait(ref_87);
    ref_89 = bustupAlloc(ref_87, left, rgb(0,0,0));
    bustupFade(ref_89, rgb(128,0,0), 30);
    ref_8b = dialogAlloc();
    ref_8c = msgShow(msg_1);
/***************************************
[color(yellow)]うらら[color(white)]
[tab][suou]さん、一人で行っちゃったけど、
[tab]罠じゃないのかなぁ～
[tab]私、罠だと思うんだよねぇ～
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_1d, 1);
    wait(ref_8c);
    unitAnimationPlay(ulala, animation_a, 1);
    dialogFree(ref_8b);
    ref_91 = bustupFade(ref_89, rgb(0,0,0), 10);
    bustupWait(ref_91);
    bustupFree(ref_89);
    unitRestoreFacing(ulala);
    b(label_ee);
  label_96:
    unitFacePlayer(ulala);
    ref_97 = bustupLoad(bustup_17);
    bustupWait(ref_97);
    ref_99 = bustupAlloc(ref_97, left, rgb(0,0,0));
    bustupFade(ref_99, rgb(128,0,0), 30);
    ref_9b = dialogAlloc();
    ref_9c = msgShow(msg_2);
/***************************************
[color(yellow)]うらら[color(white)]
[tab][suou]さんの弟、色々と訳知りの様だけど、
[tab]自分の父親の事は知ってんのかな？
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2d, 1);
    wait(ref_9c);
    unitAnimationPlay(ulala, animation_a, 1);
    dialogFree(ref_9b);
    ref_a1 = bustupFade(ref_99, rgb(0,0,0), 10);
    bustupWait(ref_a1);
    bustupFree(ref_99);
    unitRestoreFacing(ulala);
    b(label_ee);
  label_a6:
    unitFacePlayer(ulala);
    ref_a7 = bustupLoad(bustup_17);
    bustupWait(ref_a7);
    ref_a9 = bustupAlloc(ref_a7, left, rgb(0,0,0));
    bustupFade(ref_a9, rgb(128,0,0), 30);
    ref_ab = dialogAlloc();
    ref_ac = msgShow(msg_3);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]マーヤ、新世塾の噂ってネット上でも
[tab]話題になってるみたいだよ。
[tab]困っちゃいましたねぇ。
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2d, 1);
    wait(ref_ac);
    unitAnimationPlay(ulala, animation_a, 1);
    dialogFree(ref_ab);
    ref_b1 = bustupFade(ref_a9, rgb(0,0,0), 10);
    bustupWait(ref_b1);
    bustupFree(ref_a9);
    unitRestoreFacing(ulala);
    b(label_ee);
  label_b6:
    unitFacePlayer(ulala);
    ref_b7 = bustupLoad(bustup_17);
    bustupWait(ref_b7);
    ref_b9 = bustupAlloc(ref_b7, left, rgb(0,0,0));
    bustupFade(ref_b9, rgb(128,0,0), 30);
    ref_bb = dialogAlloc();
    bitGet(var_0, EBIT_E0096);
    bne(var_0, 0, label_c2);
    ref_be = msgShow(msg_4);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]あの子の隠している事って、
[tab]マーヤと関係ある事みたいだねぇ。
[tab]…デジャ・ヴュってホントにあんのかも？
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2d, 1);
    wait(ref_be);
    b(label_c7);
  label_c2:
    bne(var_0, 1, label_c7);
    ref_c3 = msgShow(msg_5);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]ねぇマーヤ、「向こう側」って所で何があったの？
[tab]あの子とどんな関係だったのよ？
[tab]ねぇ…思い出せない？
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2d, 1);
    wait(ref_c3);
    b(label_c7);
  label_c7:
    unitAnimationPlay(ulala, animation_a, 1);
    dialogFree(ref_bb);
    ref_c9 = bustupFade(ref_b9, rgb(0,0,0), 10);
    bustupWait(ref_c9);
    bustupFree(ref_b9);
    unitRestoreFacing(ulala);
    b(label_ee);
  label_ce:
    unitFaceUnit(ulala, tatsuya);
    ref_cf = bustupLoad(bustup_1b);
    bustupWait(ref_cf);
    ref_d1 = bustupAlloc(ref_cf, left, rgb(0,0,0));
    bustupFade(ref_d1, rgb(128,0,0), 30);
    ref_d3 = dialogAlloc();
    ref_d4 = msgShow(msg_6);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]なるほどねぇ、「向こう側」との差は
[tab]新世塾の有無くらい…っ！？[delay(30)]
[tab]ちょっと[tatsuya]君！[tab]それって大違いよ！！
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2f, 1);
    wait(ref_d4);
    unitAnimationPlay(ulala, animation_a, 1);
    dialogFree(ref_d3);
    ref_d9 = bustupFade(ref_d1, rgb(0,0,0), 10);
    bustupWait(ref_d9);
    bustupFree(ref_d1);
    unitRestoreFacing(ulala);
    b(label_ee);
  label_de:
    unitFacePlayer(ulala);
    ref_df = bustupLoad(bustup_17);
    bustupWait(ref_df);
    ref_e1 = bustupAlloc(ref_df, left, rgb(0,0,0));
    bustupFade(ref_e1, rgb(128,0,0), 30);
    ref_e3 = dialogAlloc();
    ref_e4 = msgShow(msg_7);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]ＯＫマーヤ！[tab]いつでも行けるよ！
[tab]今の生活って結構刺激的だけど、
[tab]このままって訳には行かないもんね！
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2d, 1);
    wait(ref_e4);
    unitAnimationPlay(ulala, animation_a, 1);
    dialogFree(ref_e3);
    ref_e9 = bustupFade(ref_e1, rgb(0,0,0), 10);
    bustupWait(ref_e9);
    bustupFree(ref_e1);
    unitRestoreFacing(ulala);
    b(label_ee);
  label_ee:
    controlEnable();
}

