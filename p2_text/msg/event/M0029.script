    ref_624 = dialogAlloc();
    ref_625 = msgShow(msg_116);
/***************************************
[color(yellow)]やる気のないボーイ[color(white)]
[tab]とりあえずこっちもヒマだし、また来てよ。
[tab]なんだったら、ごちそう出すからさ。
[tab]まぁ冗談だけどね…いいんだよ、そんなこたぁ。
[wait][clear]
***************************************/
    unitAnimationPlay(shopkeeper, animation_21, 1);
    wait(ref_625);
    unitAnimationPlay(shopkeeper, animation_0, 1);
    shopOverlayInit();
    dialogFree(ref_624);
    ref_62b = bustupFade(ref_622, rgb(0,0,0), 10);
    bustupWait(ref_62b);
    bustupFree(ref_622);
    delayClear();
    delayWait(10);
    bitSet(MBIT_W_HATURAITEN);
    bitGet(var_0, MBIT_EXITBIT);
    bne(var_0, 0, label_636);
    unitRestoreFacing(shopkeeper);
    controlEnable();
    b(label_639);
  label_636:
    bne(var_0, 1, label_639);
    call(GOOUT);
    b(label_639);
  label_639:
}

