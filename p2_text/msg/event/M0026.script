function DECIDE_EAT()
{
    choiceSetResult(1);
    msgVar_Number(msgvar_0, var_6);
    unitFacePlayer(shopkeeper);
    ref_761 = bustupLoad(bustup_f9);
    bustupWait(ref_761);
    ref_763 = bustupAlloc(ref_761, left, rgb(0,0,0));
    bustupFade(ref_763, rgb(128,0,0), 30);
    ref_765 = dialogAlloc();
    choiceSetResult(1);
    ref_767 = msgShow(msg_101);
/***************************************
[color(yellow)]エステティシャン[color(white)]
[tab]そちらの施術料は[var(msg_var_0)]円になるけど、
[tab]よろしいかしら？
[choice(2)]はい
いいえ
[end_choice][clear]
***************************************/
    wait(ref_767);
    choiceGetResult(var_7);
    bne(var_7, 0, label_76e);
    sndMusicPlay(sound_3077, 127);
    li(var_7, 1);
    b(label_771);
  label_76e:
    bne(var_7, 1, label_771);
    li(var_7, 0);
    b(label_771);
  label_771:
    wait(ref_767);
    dialogFree(ref_765);
    ref_773 = bustupFade(ref_763, rgb(0,0,0), 10);
    bustupWait(ref_773);
    bustupFree(ref_763);
    li(var_5, 20);
}
