    ref_74 = spriteLoad(sprite_0);
    wait(ref_74);
    ref_76 = spriteLoad(sprite_2);
    wait(ref_76);
    playerInit(south);
    controlDisable();
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    unitIdleOnAll();
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

