function DOORBOX()
{
    controlDisable();
    sndMusicPlay(sound_3076, 127);
    objAnimRotate(obj_17, 0, 70, 0, 30, 0);
    objAnimRotate(obj_16, 0, -70, 0, 30, 0);
    objAnimWait(obj_16);
    objAnimWait(obj_17);
    call(GOOUT);
}

function warp1()
{
    call(DOORBOX);
}

function GOOUT()
{
    bitClear(MBIT_EXITBIT);
    mapLoad(rengedai, 0, 0);
}

function HA_SHOP_EXPLAIN_0()
{
    choiceSetResult(2);
    ref_710 = dialogChoiceAlloc();
    ref_711 = msgShow(msg_98);
/***************************************
[color(yellow)]エステティシャン[color(white)]
[tab]何について聞きたいのかしら？
[choice(3)][if_all(MBIT_KE_ETEESTHE)]エステティック
回復
やめる
[end_choice][clear]
***************************************/
    wait(ref_711);
    dialogFree(ref_710);
    choiceGetResult(var_0);
    bne(var_0, 0, label_71b);
    ref_716 = dialogAlloc();
    ref_717 = msgShow(msg_99);
/***************************************
[color(yellow)]エステティシャン[color(white)]
[tab]ＯＫ！[tab]「エステティック」についてね。
[wait][clear][color(yellow)]エステティシャン[color(white)]
[tab]「エステティック」を選んでくれたら、
[tab]新開発のエーテルエステであなたたちの魅力の
[tab]「ある一部分」を強調してあげるわ。
[wait][clear][color(yellow)]エステティシャン[color(white)]
[tab]…で、どうなるかっていうと、
[tab]ある特定のタイプにモテモテになるのよ。
[wait][clear][color(yellow)]エステティシャン[color(white)]
[tab]たとえば「老人」とか、たとえば「ギャル」とか…
[tab]ね、ね、すごいでしょ！
[wait][clear][color(yellow)]エステティシャン[color(white)]
[tab]これを生かせばどんなに気難しい人でも…
[tab]いえ、人じゃないものでもイチコロよ！
[wait][clear]
***************************************/
    wait(ref_717);
    dialogFree(ref_716);
    b(label_723);
  label_71b:
    bne(var_0, 1, label_721);
    ref_71c = dialogAlloc();
    ref_71d = msgShow(msg_100);
/***************************************
[color(yellow)]エステティシャン[color(white)]
[tab]ＯＫ！[tab]「回復」についてね。
[wait][clear][color(yellow)]エステティシャン[color(white)]
[tab]「回復してもらう」を選んでくれたら
[tab]エーテルエステの若返り効果で「ＨＰ」と「ＳＰ」
[tab]あと「猛毒」などのステータス異常も回復してあげるわ。
[wait][clear][color(yellow)]エステティシャン[color(white)]
[tab]値段はお安くはないわよ。
[tab]でもね、全員セットの価格なのよ、よく考えてね。
[tab]きっと納得してもらえると思うわ！
[wait][clear]
***************************************/
    wait(ref_71d);
    dialogFree(ref_71c);
    b(label_723);
  label_721:
    bne(var_0, 2, label_723);
    b(label_723);
  label_723:
}

