    unitWait(maya);
    unitMove(maya, 430, -520, face_south, reverse);
    unitWait(maya);
    unitAnimationHold(maya, animation_21, -1);
}

function KATUYA_ODOROKU()
{
    unitAnimationHold(katsuya, animation_21, 60);
    unitWait(katsuya);
    unitSpriteClear(katsuya);
    unitSpriteSet(katsuya, sprite_f);
}

function PAOFU_ODOROKU()
{
    unitAnimationHold(baofu, animation_21, 60);
    unitWait(baofu);
    unitSpriteClear(baofu);
    unitSpriteSet(baofu, sprite_15);
}

function SAGI_ODOROKU()
{
    unitAnimationHold(makimura, animation_1c, 60);
    unitWait(makimura);
    unitAnimationPlay(makimura, animation_2e, 1);
}

function SOUND()
{
