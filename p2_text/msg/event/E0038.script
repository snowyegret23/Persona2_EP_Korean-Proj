function PAOFU_IDO()
{
    unitMove(baofu, 220, -820, face_south, medium);
    unitWait(baofu);
    unitMove(baofu, 270, -350, face_west, medium);
    unitWait(baofu);
    unitAnimationPlay(baofu, animation_a, 1);
}

function KATUYA_IDO()
{
    unitMove(katsuya, 580, -500, face_south, medium);
    delayClear();
    delayWait(60);
    sndMusicPlay(sound_3133, 127);
    objAnimRotate(obj_9, 0, 70, 0, 30, 0);
    ref_1c5 = objAnimRotate(obj_a, 0, -70, 0, 30, 0);
    wait(ref_1c5);
    unitWait(katsuya);
    unitAnimationPlay(katsuya, animation_a, 1);
}

function SAGI_IDO()
{
    unitAnimationPlay(makimura, animation_0, 1);
    delayClear();
    delayWait(30);
    unitMove(makimura, 360, -620, face_south, medium);
    unitWait(makimura);
