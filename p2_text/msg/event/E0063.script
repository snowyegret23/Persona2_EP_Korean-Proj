function EXIT()
{
    controlDisable();
    objAnimRotate(obj_a, 0, -80, 0, 60, 0);
    sndMusicPlay(sound_31ab, 127);
    objAnimWait(obj_a);
    bitSet(EBIT_E0067);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    cameraSetNorth(south);
    dngLoad2(sumaru_tv2-29);
}

function EXIT2()
{
    controlDisable();
    ref_17a = dialogAlloc();
    ref_17b = msgShow(msg_11);
/***************************************
[color(yellow)]モニター室のドア[color(green)]
[tab]ここには入れない。[color(white)]
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_17b);
    dialogFree(ref_17a);
    controlEnable();
}

function MAYAMOVE()
{
    unitSpawn(maya, sprite_0, 850, 0, -1850, south, fade);
    unitMove(maya, 980, -1380, face_south, fast);
    unitWait(maya);
    unitFace(maya, east);
    unitAnimationPlay(maya, animation_a, 1);
}

function URARAMOVE()
{
    unitSpawn(ulala, sprite_6, 850, 0, -1850, south, fade);
    unitMove(ulala, 750, -1400, face_south, fast);
    unitWait(ulala);
    unitFace(ulala, west);
    unitAnimationPlay(ulala, animation_a, 1);
}

function ERIMOVE()
{
    unitSpawn(elly, sprite_23, 850, 0, -1850, south, fade);
    unitMove(elly, 750, -1570, face_south, fast);
    unitWait(elly);
    unitFace(elly, west);
