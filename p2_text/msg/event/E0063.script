function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    objVisible(obj_b, false);
    bitGet(var_0, EBIT_E0066);
    bez(var_0, label_24);
    bitClear(DBIT_TV_ST4DR);
    ref_6 = spriteLoad(sprite_0);
    wait(ref_6);
    ref_8 = spriteLoad(sprite_2);
    wait(ref_8);
    ref_a = spriteLoad(sprite_6);
    wait(ref_a);
    ref_c = spriteLoad(sprite_d);
    wait(ref_c);
    ref_e = spriteLoad(sprite_f);
    wait(ref_e);
    ref_10 = spriteLoad(sprite_13);
    wait(ref_10);
    ref_12 = spriteLoad(sprite_23);
    wait(ref_12);
    sndIdGet(var_0);
    bne(var_0, -1, label_17);
    b(label_19);
  label_17:
    sndVolumeFadeTo(var_0, 90, 60);
    b(label_19);
  label_19:
    sndUnkCF(90);
    bitGet(var_1, EBIT_E0067);
    bne(var_1, 0, label_1f);
    ref_1c = call(KYOUSEI);
    wait(ref_1c);
    b(label_23);
  label_1f:
    bne(var_1, 1, label_23);
    ref_20 = call(FREE);
    wait(ref_20);
    b(label_23);
  label_23:
    b(label_26);
  label_24:
    dngLoad2(sumaru_tv2-7);
    b(label_26);
  label_26:
}

function KYOUSEI()
{
    cameraSet(southeast, 850, 0, -1750);
    envTriggerSet(EXIT, 131, 1, line, coll_6);
    envTriggerSet(EXIT2, 131, 1, line, coll_5);
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    screenEffectUnknown();
    screenFadeWait(inner);
    screenFadeWait(outer);
    delayClear();
    delayWait(60);
    objAnimRotate(obj_a, 0, -80, 0, 60, 0);
    sndMusicPlay(sound_31ab, 127);
    objAnimWait(obj_a);
    unitSpawn(katsuya, sprite_d, 850, 0, -1850, south, fade);
    delayClear();
    delayWait(20);
    unitMove(katsuya, 850, -1750, face_south, fast);
    unitWait(katsuya);
    unitSpriteClear(katsuya);
    unitSpriteSet(katsuya, sprite_f);
    unitAnimationPlay(katsuya, animation_0, 1);
    sndMusicPlay(sound_31ad, 127);
    unitWait(katsuya);
    delayClear();
    delayWait(90);
    unitSpriteClear(katsuya);
    unitSpriteSet(katsuya, sprite_d);
    unitAnimationPlay(katsuya, animation_28, 1);
    unitWait(katsuya);
    delayClear();
    delayWait(30);
    cameraMoveTo(900, 0, -1400, 60);
    unitMove(katsuya, 850, -1220, face_south, fast);
    unitWait(katsuya);
    unitSpriteClear(katsuya);
    unitSpriteSet(katsuya, sprite_f);
    unitAnimationPlay(katsuya, animation_0, 1);
    sndMusicPlay(sound_31ad, 127);
    unitWait(katsuya);
    delayClear();
    delayWait(90);
    unitSpriteClear(katsuya);
    unitSpriteSet(katsuya, sprite_d);
    unitAnimationPlay(katsuya, animation_28, 1);
    unitWait(katsuya);
    delayClear();
    delayWait(30);
    unitFace(katsuya, north);
    unitAnimationPlay(katsuya, animation_a, 1);
    delayClear();
    delayWait(30);
    ref_5b = bustupLoad(bustup_21);
    bustupWait(ref_5b);
    ref_5d = bustupAlloc(ref_5b, left, rgb(0,0,0));
    bustupFade(ref_5d, rgb(128,0,0), 30);
    ref_5f = dialogAlloc();
    ref_60 = msgShow(msg_0);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]大丈夫だ。
[tab]黒猫もあの男もいない。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_60);
    dialogFree(ref_5f);
    ref_64 = bustupFade(ref_5d, rgb(0,0,0), 10);
    bustupWait(ref_64);
    bustupFree(ref_5d);
    call(MAYAMOVE);
    delayClear();
    delayWait(30);
    call(URARAMOVE);
    delayClear();
    delayWait(30);
    call(ERIMOVE);
    delayClear();
    delayWait(30);
    ref_70 = call(PAOFUMOVE);
    delayClear();
    delayWait(30);
    objAnimRotate(obj_a, 0, 80, 0, 60, 0);
    delayClear();
    delayWait(10);
    sndMusicPlay(sound_31ac, 127);
    wait(ref_70);
    delayClear();
    delayWait(30);
    unitAnimationPlay(ulala, animation_d, 1);
    delayClear();
    delayWait(7);
    unitFace(ulala, north);
    unitAnimationPlay(ulala, animation_a, 1);
    delayClear();
    delayWait(30);
    ref_81 = bustupLoad(bustup_17);
    bustupWait(ref_81);
    ref_83 = bustupAlloc(ref_81, left, rgb(0,0,0));
    bustupFade(ref_83, rgb(128,0,0), 30);
    ref_85 = dialogAlloc();
    ref_86 = msgShow(msg_1);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]ねぇ、エリーちゃん…
[tab]あのストーカーが言ってた「アイツ」って、誰…？
[sync][wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2d, 1);
    delayClear();
    delayWait(10);
    unitAnimationPlay(elly, animation_b, 1);
    unitAnimationPlay(baofu, animation_d, 1);
    unitAnimationPlay(katsuya, animation_b, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(elly, animation_c, 1);
    delayClear();
    delayWait(40);
    sync();
    wait(ref_86);
    ref_94 = msgShow(msg_2);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]もしなんか悩んでるなら、話してみ。
[tab]相談に乗るからさ。
[sync][wait][clear]
***************************************/
    delayClear();
    delayWait(60);
    sync();
    wait(ref_94);
    dialogFree(ref_85);
    ref_9a = bustupFade(ref_83, rgb(0,0,0), 10);
    bustupWait(ref_9a);
    bustupFree(ref_83);
    unitAnimationPlay(ulala, animation_a, 1);
    delayClear();
    delayWait(10);
    unitFace(elly, south);
    unitAnimationPlay(elly, animation_a, 1);
    delayClear();
    delayWait(30);
    ref_a4 = bustupLoad(bustup_40);
    bustupWait(ref_a4);
    ref_a6 = bustupAlloc(ref_a4, left, rgb(0,0,0));
    bustupFade(ref_a6, rgb(128,0,0), 30);
    ref_a8 = dialogAlloc();
    ref_a9 = msgShow(msg_3);
/***************************************
[color(yellow)]エリー[color(white)]
[tab]申し訳有りません、ご心配をおかけして…
[tab]あの男が言っていたのは、
[tab]きっと「彼」の事ですわ…
[sync][wait][clear]
***************************************/
    unitAnimationPlay(elly, animation_2d, 1);
    delayClear();
    delayWait(10);
    unitAnimationPlay(baofu, animation_a, 1);
    unitAnimationPlay(maya, animation_b, 1);
    delayClear();
    delayWait(50);
    sync();
    wait(ref_a9);
    ref_b3 = msgShow(msg_4);
/***************************************
[color(yellow)]エリー[color(white)]
[tab]Ｈｉｇｈｓｃｈｏｏｌ時代のＣｌａｓｓｍａｔｅ…
[tab]私、「彼」と約束しましたの…
[tab]夢を掴んだらまた会いましょうって…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_b3);
    dialogFree(ref_a8);
    ref_b7 = bustupFade(ref_a6, rgb(0,0,0), 10);
    bustupWait(ref_b7);
    bustupFree(ref_a6);
    unitAnimationPlay(elly, animation_a, 1);
    delayClear();
    delayWait(30);
    ref_bd = bustupLoad(bustup_17);
    bustupWait(ref_bd);
    ref_bf = bustupAlloc(ref_bd, left, rgb(0,0,0));
    bustupFade(ref_bf, rgb(128,0,0), 30);
    ref_c1 = dialogAlloc();
    ref_c2 = msgShow(msg_5);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]そっか…その彼の事…
[sync][wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_1f, 1);
    delayClear();
    delayWait(10);
    unitAnimationPlay(baofu, animation_d, 1);
    unitAnimationPlay(maya, animation_a, 1);
    delayClear();
    delayWait(50);
    sync();
    wait(ref_c2);
    dialogFree(ref_c1);
    ref_cd = bustupFade(ref_bf, rgb(0,0,0), 10);
    bustupWait(ref_cd);
    bustupFree(ref_bf);
    unitAnimationPlay(ulala, animation_a, 1);
    delayClear();
    delayWait(30);
    ref_d3 = bustupLoad(bustup_40);
    bustupWait(ref_d3);
    ref_d5 = bustupAlloc(ref_d3, left, rgb(0,0,0));
    bustupFade(ref_d5, rgb(128,0,0), 30);
    ref_d7 = dialogAlloc();
    ref_d8 = msgShow(msg_6);
/***************************************
[color(yellow)]エリー[color(white)]
[tab]でも、あの男がどうして「彼」の事を…
[tab]もう、気が狂いそうですわ…
[sync][wait][clear]
***************************************/
    unitAnimationPlay(elly, animation_29, 1);
    delayClear();
    delayWait(10);
    unitAnimationPlay(baofu, animation_a, 1);
    unitAnimationPlay(maya, animation_b, 1);
    unitWait(elly);
    unitAnimationPlay(elly, animation_6, 1);
    delayClear();
    delayWait(50);
    sync();
    wait(ref_d8);
    dialogFree(ref_d7);
    ref_e5 = bustupFade(ref_d5, rgb(0,0,0), 10);
    bustupWait(ref_e5);
    bustupFree(ref_d5);
    unitAnimationPlay(elly, animation_10, 1);
    unitAnimationPlay(maya, animation_a, 1);
    unitAnimationPlay(katsuya, animation_a, 1);
    unitAnimationPlay(ulala, animation_a, 1);
    unitAnimationPlay(baofu, animation_a, 1);
    unitTriggerSet(katsuya, KATUYA, 255, 1);
    unitTriggerSet(ulala, URARA, 255, 1);
    unitTriggerSet(elly, ERI, 255, 1);
    unitTriggerSet(baofu, PAOFU, 255, 1);
    bitSet(EBIT_E0067);
    ref_f2 = cameraLookAtUnit(maya, 0, 30);
    wait(ref_f2);
    unitDespawn(maya, none);
    playerInit(east);
    unitIdleOnAll();
    controlEnable();
}

function FREE()
{
    cameraSetNorth(south);
    cameraSet(southeast, 850, 0, -1750);
    unitSpawn(katsuya, sprite_d, 650, 0, -1350, north, none);
    unitSpawn(ulala, sprite_6, 1050, 0, -1200, east, none);
    unitSpawn(baofu, sprite_13, 500, 0, -1650, west, none);
    unitSpawn(elly, sprite_23, 980, 0, -1580, south, none);
    unitAnimationPlay(katsuya, animation_a, 1);
    unitAnimationPlay(ulala, animation_a, 1);
    unitAnimationPlay(baofu, animation_a, 1);
    unitAnimationPlay(elly, animation_a, 1);
    unitTriggerSet(katsuya, KATUYA, 255, 1);
    unitTriggerSet(ulala, URARA, 255, 1);
    unitTriggerSet(baofu, PAOFU, 255, 1);
    unitTriggerSet(elly, ERI, 255, 1);
    unitIdleOnAll();
    envTriggerSet(EXIT, 131, 1, line, coll_6);
    envTriggerSet(EXIT2, 131, 1, line, coll_5);
    playerInit(south);
    controlDisable();
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

function PAOFU()
{
    controlDisable();
    unitFacePlayer(baofu);
    ref_115 = bustupLoad(bustup_2d);
    bustupWait(ref_115);
    ref_117 = bustupAlloc(ref_115, left, rgb(0,0,0));
    bustupFade(ref_117, rgb(128,0,0), 30);
    ref_119 = dialogAlloc();
    ref_11a = msgShow(msg_7);
/***************************************
[color(yellow)]パオフゥ[color(white)]
[tab]なるほどな…大体読めてきたぜ…
[sync][wait][clear]
***************************************/
    unitAnimationPlay(baofu, animation_2d, 1);
    delayClear();
    delayWait(45);
    sync();
    wait(ref_11a);
    dialogFree(ref_119);
    ref_121 = bustupFade(ref_117, rgb(0,0,0), 10);
    bustupWait(ref_121);
    bustupFree(ref_117);
    unitAnimationPlay(baofu, animation_a, 1);
    unitRestoreFacing(baofu);
    controlEnable();
}

