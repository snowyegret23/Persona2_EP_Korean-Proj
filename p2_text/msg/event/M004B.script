function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    levelFootstepSet(sfx_f);
    sndIdGet(var_0);
    bne(var_0, -1, label_6);
    b(label_8);
  label_6:
    sndVolumeFadeTo(var_0, 90, 60);
    b(label_8);
  label_8:
    sndUnkCF(90);
    envTriggerSet(warp1, 224, 1, line, coll_0);
    envTriggerSet(warp2, 224, 1, line, coll_1);
    unknownVar1(var_0);
    bne(var_0, 21, label_10);
    cameraSetNorth(west);
    cameraSet(northeast, 1070, 0, -252);
    b(label_13);
  label_10:
    cameraSetNorth(west);
    cameraSet(southeast, 1076, 0, -1360);
    b(label_13);
  label_13:
    ref_13 = spriteLoad(sprite_0);
    wait(ref_13);
    ref_15 = spriteLoad(sprite_2);
    wait(ref_15);
    playerInit(east);
    controlDisable();
    ref_19 = spriteLoad(sprite_6);
    wait(ref_19);
    unitSpawn(ulala, sprite_6, 650, 0, -1411, south, none);
    unitTriggerSet(ulala, B_URARATI, 255, 1);
    ref_1d = spriteLoad(sprite_ad);
    wait(ref_1d);
    unitSpawn(npc1, sprite_ad, 476, 0, -800, north, none);
    unitPalette(npc1, 6);
    unitTriggerSet(npc1, TATUYA, 255, 1);
    unitSpawn(npc4, sprite_ad, 381, 0, -500, west, none);
    unitPalette(npc4, 7);
    unitTriggerSet(npc4, SINSETU, 255, 1);
    ref_25 = spriteLoad(sprite_d);
    wait(ref_25);
    unitSpawn(katsuya, sprite_d, 476, 0, -898, south, none);
    unitTriggerSet(katsuya, TATUYA, 255, 1);
    ref_29 = spriteLoad(sprite_ae);
    wait(ref_29);
    unitSpawn(npc2, sprite_ae, 790, 0, -901, east, none);
    unitPalette(npc2, 6);
    unitTriggerSet(npc2, IYASOU, 255, 1);
    ref_2e = spriteLoad(sprite_af);
    wait(ref_2e);
    unitSpawn(npc3, sprite_af, 787, 0, -490, east, none);
    unitPalette(npc3, 6);
    unitTriggerSet(npc3, MONOSIZUKA, 255, 1);
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    unitIdleOnAll();
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

function B_URARATI()
{
    controlDisable();
    unitFacePlayer(ulala);
    ref_3d = bustupLoad(bustup_17);
    bustupWait(ref_3d);
    ref_3f = bustupAlloc(ref_3d, left, rgb(0,0,0));
    bustupFade(ref_3f, rgb(128,0,0), 30);
    ref_41 = dialogAlloc();
    ref_42 = msgShow(msg_0);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]そう言えば、マーヤの言ってた
[tab]デジャ・ヴュの少年。
[tab]ここの制服着てたんでしょ？
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2d, 1);
    wait(ref_42);
    ref_45 = msgShow(msg_1);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]青いネクタイって事は３年生の筈だけど…
[tab]そんな子いた？
[tab]もう帰っちゃったのかな。
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_1a, 1);
    wait(ref_45);
    unitAnimationPlay(ulala, animation_a, 1);
    dialogFree(ref_41);
    ref_4a = bustupFade(ref_3f, rgb(0,0,0), 10);
    bustupWait(ref_4a);
    bustupFree(ref_3f);
    unitRestoreFacing(ulala);
    controlEnable();
}

function TATUYA()
{
    controlDisable();
    ref_51 = dialogAlloc();
    ref_52 = msgShow(msg_2);
/***************************************
[color(yellow)]真面目な男子生徒[color(white)]
[tab]…確かに、他から見れば不良かも知れませんけど…
[tab]でもそんな悪い奴じゃないですよ、杏奈って。

***************************************/
    unitAnimationPlay(npc1, animation_24, 1);
    wait(ref_52);
    unitAnimationPlay(npc1, animation_6, 1);
    ref_56 = msgShow(msg_3);
/***************************************
[tab]あの交通事故さえ無ければ…
[wait][clear]
***************************************/
    wait(ref_56);
    dialogFree(ref_51);
    ref_59 = bustupLoad(bustup_21);
    bustupWait(ref_59);
    ref_5b = bustupAlloc(ref_59, left, rgb(0,0,0));
    bustupFade(ref_5b, rgb(128,0,0), 30);
    ref_5d = dialogAlloc();
    ref_5e = msgShow(msg_4);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]…そうだろうな…分かった。ありがとう。

***************************************/
    unitAnimationPlay(katsuya, animation_6, 1);
    wait(ref_5e);
    ref_61 = msgShow(msg_5);
/***************************************
[tab]…ところで、ここに[tatsuya]という奴がいるだろう？
[tab]アイツの最近の素行はどうだ？
[wait][clear]
***************************************/
    unitAnimationPlay(katsuya, animation_2d, 1);
    wait(ref_61);
    dialogFree(ref_5d);
    ref_65 = bustupFade(ref_5b, rgb(0,0,0), 10);
    bustupWait(ref_65);
    bustupFree(ref_5b);
    unitAnimationPlay(katsuya, animation_a, 1);
    ref_69 = dialogAlloc();
    ref_6a = msgShow(msg_6);
/***************************************
[color(yellow)]真面目な男子生徒[color(white)]
[tab]え？[tab][tatsuya]ですか？
[tab]アイツ、また何かしたんですか？
[wait][clear]
***************************************/
    unitAnimationPlay(npc1, animation_24, 1);
    wait(ref_6a);
    dialogFree(ref_69);
    unitAnimationPlay(npc1, animation_0, 1);
    ref_6f = bustupLoad(bustup_25);
    bustupWait(ref_6f);
    ref_71 = bustupAlloc(ref_6f, left, rgb(0,0,0));
    bustupFade(ref_71, rgb(128,0,0), 30);
    ref_73 = dialogAlloc();
    ref_74 = msgShow(msg_7);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]また！？
[tab]い、いや…そういう訳ではないんだが…
[tab]そうか…
[sync][wait][clear]
***************************************/
    unitAnimationHold(katsuya, animation_21, 30);
    unitWait(katsuya);
    unitAnimationPlay(katsuya, animation_6, 1);
    sync();
    wait(ref_74);
    dialogFree(ref_73);
    ref_7b = bustupFade(ref_71, rgb(0,0,0), 10);
    bustupWait(ref_7b);
    bustupFree(ref_71);
    unitAnimationPlay(katsuya, animation_a, 1);
    controlEnable();
}

function IYASOU()
{
    controlDisable();
    unitFacePlayer(npc2);
    ref_83 = dialogAlloc();
    ref_84 = msgShow(msg_8);
/***************************************
[color(yellow)]嫌そうな男子生徒[color(white)]
[tab]アレ、刑事さんなんでしょ？
[tab]また[tatsuya]の奴事件起こしたのかなぁ…
[tab]アイツも懲りないよなぁ…
[wait][clear]
***************************************/
    unitAnimationPlay(npc2, animation_24, 1);
    wait(ref_84);
    dialogFree(ref_83);
    unitAnimationPlay(npc2, animation_0, 1);
    unitRestoreFacing(npc2);
    controlEnable();
}

function MONOSIZUKA()
{
    controlDisable();
    unitFacePlayer(npc3);
    ref_8e = dialogAlloc();
    ref_8f = msgShow(msg_9);
/***************************************
[color(yellow)]物静かな女子生徒[color(white)]
[tab]最近、[tatsuya]君学校に来ないの。

***************************************/
    unitAnimationPlay(npc3, animation_6, 1);
    wait(ref_8f);
    ref_92 = msgShow(msg_10);
/***************************************
[tab]授業をサボる事はよくあったけど、
[tab]それでも学校にはいつも来てたのよ。
[wait][clear]
***************************************/
    unitAnimationPlay(npc3, animation_24, 1);
    wait(ref_92);
    dialogFree(ref_8e);
    unitAnimationPlay(npc3, animation_0, 1);
    unitRestoreFacing(npc3);
    controlEnable();
}

function SINSETU()
{
    controlDisable();
    unitFacePlayer(npc4);
    ref_9c = dialogAlloc();
    ref_9d = msgShow(msg_11);
/***************************************
[color(yellow)]親切な男子生徒[color(white)]
[tab]教室があるのは３階まで。
[tab]４階には大時計しか無いッス。
[tab]いつも校務員さんが中を掃除してるんスよ。
[wait][clear]
***************************************/
    unitAnimationPlay(npc4, animation_24, 1);
    wait(ref_9d);
    dialogFree(ref_9c);
    unitAnimationPlay(npc4, animation_0, 1);
    unitRestoreFacing(npc4);
    controlEnable();
}

