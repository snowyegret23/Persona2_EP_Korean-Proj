function DOORBOX()
{
    controlDisable();
    sndMusicPlay(sound_306e, 127);
    objAnimRotate(obj_1, 0, -70, 0, 30, 0);
    objAnimRotate(obj_0, 0, 70, 0, 30, 0);
    objAnimWait(obj_1);
    objAnimWait(obj_0);
    call(GOOUT);
}

function GOOUT()
{
    bitClear(MBIT_EXITBIT);
    mapLoad(rengedai, 0, 0);
}

function warp1()
{
    call(DOORBOX);
}

function HA_SHOP_EXPLAIN_0()
{
    bitGet(var_0, MBIT_HI_TOAARM);
    bne(var_0, 0, label_4fc);
    ref_4f7 = dialogAlloc();
    ref_4f8 = msgShow(msg_81);
/***************************************
[color(yellow)]口笛店主[color(white)]
[tab]「売買」についてか…
[tab]うちで「防具を買う」を選べば
[tab]防具を買うことができる。
[wait][clear][color(yellow)]口笛店主[color(white)]
[tab]防具によっては装備できる者に制限がある。
[tab]よく確認してから買えよ。
[tab]返品は受け付けないからな…
[wait][clear][color(yellow)]口笛店主[color(white)]
[tab]あとは、売却の説明か…
[tab]「アイテムを売る」を選ぶと、種類の選択になる。
[tab]売却するものの種類を選択して、売却物を決定しろ。
[wait][clear][color(yellow)]口笛店主[color(white)]
[tab]買い取り価格は元値のおよそ半額くらいだ…
[tab]あと、装備中の物と一部の物は売却することは
[tab]できないからな。
[wait][clear]
***************************************/
    wait(ref_4f8);
    dialogFree(ref_4f7);
    b(label_502);
  label_4fc:
    bne(var_0, 1, label_502);
    ref_4fd = dialogAlloc();
    ref_4fe = msgShow(msg_82);
/***************************************
[color(yellow)]口笛店主[color(white)]
[tab]「売買」についてか…
[tab]うちで「武器を買う」を選べば
[tab]武器を買うことができる。
[wait][clear][color(yellow)]口笛店主[color(white)]
[tab]武器によっては装備できる者に制限がある。
[tab]よく確認してから買えよ。
[tab]返品は受け付けないからな…
[wait][clear][color(yellow)]口笛店主[color(white)]
[tab]…１つだけ武器じゃない？
[tab]理由はわからんが、倉庫に大量にあってな…
[tab]細かいことは気にするな。
[wait][clear][color(yellow)]口笛店主[color(white)]
[tab]あとは、売却の説明か…
[tab]「アイテムを売る」を選ぶと、種類の選択になる。
[tab]売却するものの種類を選択して、売却物を決定しろ。
[wait][clear][color(yellow)]口笛店主[color(white)]
[tab]買い取り価格は元値のおよそ半額くらいだ…
[tab]あと、装備中の物と一部の物は売却することは
[tab]できないからな。
[wait][clear]
***************************************/
    wait(ref_4fe);
    dialogFree(ref_4fd);
    b(label_502);
  label_502:
}

function NOITEM()
{
    unitFacePlayer(shopkeeper);
    ref_504 = bustupLoad(bustup_ed);
    bustupWait(ref_504);
    ref_506 = bustupAlloc(ref_504, right, rgb(0,0,0));
    bustupFade(ref_506, rgb(128,0,0), 30);
    ref_508 = dialogAlloc();
    ref_509 = msgShow(msg_83);
/***************************************
[color(yellow)]口笛店主[color(white)]
[tab]売れる物、持ってねぇじゃねぇか。[wait][clear]
***************************************/
    wait(ref_509);
    dialogFree(ref_508);
    ref_50c = bustupFade(ref_506, rgb(0,0,0), 10);
    bustupWait(ref_50c);
    bustupFree(ref_506);
    li(var_5, 20);
}

