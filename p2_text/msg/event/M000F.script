    ref_513 = bustupLoad(bustup_ed);
    bustupWait(ref_513);
    ref_515 = bustupAlloc(ref_513, left, rgb(0,0,0));
    bustupFade(ref_515, rgb(128,0,0), 30);
    ref_517 = dialogAlloc();
    choiceSetResult(1);
    ref_519 = msgShow(msg_84);
