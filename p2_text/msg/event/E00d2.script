function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    levelFootstepSet(sfx_1a);
    sndIdGet(var_0);
    sndVolumeFadeTo(var_0, 0, 240);
    ref_5 = todLoad(tod_8);
    wait(ref_5);
    cameraSet(northwest, 1450, 0, -2700);
    cameraZoom(-1280, 10);
    ref_9 = spriteLoad(sprite_0);
    wait(ref_9);
    ref_b = spriteLoad(sprite_d);
    wait(ref_b);
    ref_d = spriteLoad(sprite_6);
    wait(ref_d);
    ref_f = spriteLoad(sprite_13);
    wait(ref_f);
    ref_11 = spriteLoad(sprite_18);
    wait(ref_11);
    unitSpawn(maya, sprite_0, 2500, 0, -2470, east, none);
    unitSpawn(katsuya, sprite_d, 2500, 0, -2470, east, none);
    unitSpawn(ulala, sprite_6, 2500, 0, -2470, east, none);
    unitSpawn(baofu, sprite_13, 2500, 0, -2470, east, none);
    unitSpawn(tatsuya, sprite_18, 2500, 0, -2470, east, none);
    unitIdleOffAll();
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 4, true);
    screenFadeOuter(rgb(0,0,0), 4, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    delayClear();
    delayWait(120);
    cameraZoom(0, 420);
    call(MAYAMOVE);
    delayClear();
    delayWait(30);
    call(KATUYAMOVE);
    delayClear();
    delayWait(30);
    call(PAOFUMOVE);
    delayClear();
    delayWait(30);
    call(URARAMOVE);
    delayClear();
    delayWait(30);
    ref_2d = call(TATUYAMOVE);
    wait(ref_2d);
    unitAnimationPlay(tatsuya, animation_5, 1);
    unitWait(tatsuya);
    delayClear();
    delayWait(120);
    li(var_3, 1);
    call(MAYAFURI);
    call(KATUYAFURI);
    call(PAOFUFURI);
    ref_37 = call(URARAFURI);
    wait(ref_37);
    delayClear();
    delayWait(60);
    unitFace(ulala, south);
    unitWait(ulala);
    unitAnimationPlay(maya, animation_0, 1);
    unitAnimationPlay(katsuya, animation_0, 1);
    unitAnimationPlay(baofu, animation_0, 1);
    unitAnimationPlay(ulala, animation_0, 1);
    unitWait(maya);
    unitWait(katsuya);
    unitWait(baofu);
    unitWait(ulala);
    delayClear();
    delayWait(15);
    unitAnimationPlay(maya, animation_5, 1);
    unitAnimationPlay(katsuya, animation_5, 1);
    unitAnimationPlay(baofu, animation_5, 1);
    unitAnimationPlay(ulala, animation_5, 1);
    unitWait(maya);
    unitWait(katsuya);
    unitWait(baofu);
    unitWait(ulala);
    ref_4f = todRun(tod_8, 2);
    wait(ref_4f);
    delayClear();
    delayWait(180);
    ref_53 = screenHorizontalFadeOut();
    wait(ref_53);
    eventLoad(event_e0);
}

