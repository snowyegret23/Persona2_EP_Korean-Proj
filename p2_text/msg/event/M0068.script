    unitAnimationPlay(maya, animation_1, 1);
    delayClear();
    delayWait(30);
    unitAnimationPlay(npc1, animation_6, 1);
    delayClear();
    delayWait(20);
    ref_93 = bustupLoad(bustup_e2);
    bustupWait(ref_93);
    ref_95 = bustupAlloc(ref_93, right, rgb(0,0,0));
    bustupFade(ref_95, rgb(128,0,0), 30);
    ref_97 = dialogAlloc();
    ref_98 = msgShow(msg_2);
/***************************************
[color(yellow)]ベラドンナ[color(white)]
[tab]私はベラドンナ～𝅘𝅥𝅮[delay(30)]
[tab]己という魔物に挑む、もののふ称える歌歌い～𝅘𝅥𝅮[wait][clear]
***************************************/
    wait(ref_98);
    dialogFree(ref_97);
    ref_9b = bustupFade(ref_95, rgb(0,0,0), 10);
    bustupWait(ref_9b);
    bustupFree(ref_95);
    unitAnimationPlay(npc1, animation_7, 1);
