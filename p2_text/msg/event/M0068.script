function KYOUSEIBOX()
{
    sndMusicPlay(sound_3001, 127);
    ref_44 = cameraMoveTo(-414, 0, -918, 5);
    wait(ref_44);
    unitSpawn(unit_76, sprite_a7, 890, -60, -1218, north, none);
    unitFace(unit_76, south);
    unitAnimationPlay(unit_76, animation_4, 1);
    unitAnimationPlay(shopkeeper, animation_1, 1);
    unitAnimationPlay(npc1, animation_7, 1);
    unitAnimationPlay(npc2, animation_0, 1);
    cameraMoveTo(194, 0, -936, 180);
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    delayClear();
    delayWait(120);
    ref_52 = spriteLoad(sprite_0);
    wait(ref_52);
    objAnimRotate(obj_0, 0, -70, 0, 30, 0);
    sndMusicPlay(sound_3006, 127);
    objAnimWait(obj_0);
    delayClear();
    delayWait(30);
    unitSpawn(maya, sprite_0, -15, 0, -989, north, fade);
    unitMove(maya, 125, -996, face_west, medium);
    unitWait(maya);
    delayClear();
    delayWait(60);
    unitAnimationHold(maya, animation_21, -1);
    delayClear();
    delayWait(30);
    ref_61 = cameraMoveTo(1041, 0, -907, 180);
    delayClear();
    delayWait(60);
    unitMove(maya, 1092, -1103, face_south, medium);
    call(ESIKUBI);
    call(IGOKUBI);
    unitWait(maya);
    wait(ref_61);
    delayClear();
    delayWait(60);
    unitAnimationPlay(shopkeeper, animation_7, 1);
    delayClear();
    delayWait(30);
    objAnimRotate(obj_0, 0, 70, 0, 30, 0);
    ref_6f = bustupLoad(bustup_e0);
    bustupWait(ref_6f);
    ref_71 = bustupAlloc(ref_6f, right, rgb(0,0,0));
    bustupFade(ref_71, rgb(128,0,0), 30);
    ref_73 = dialogAlloc();
    ref_74 = msgShow(msg_0);
/***************************************
[color(yellow)]イゴール[color(white)]
[tab]ようこそ、ベルベットルームへ。
[tab]ここは、人の心の様々なる形を呼び覚ます部屋…
[wait][clear]
***************************************/
    wait(ref_74);
    ref_76 = msgShow(msg_1);
/***************************************
[color(yellow)]イゴール[color(white)]
[tab]我らが主、フィレモン様の命により、
[tab]貴方がたをお待ちしておりました。
[tab]我が名は、イゴールと申します。[sync][wait][clear]
***************************************/
    unitAnimationPlay(shopkeeper, animation_8, 1);
    delayClear();
    delayWait(15);
    unitAnimationPlay(shopkeeper, animation_9, 1);
    delayClear();
    delayWait(20);
    unitAnimationPlay(shopkeeper, animation_8, 1);
    delayClear();
    delayWait(10);
    unitAnimationPlay(shopkeeper, animation_a, 1);
    delayClear();
    delayWait(30);
    unitAnimationPlay(shopkeeper, animation_b, 1);
    sync();
    wait(ref_76);
    dialogFree(ref_73);
    ref_87 = bustupFade(ref_71, rgb(0,0,0), 10);
    bustupWait(ref_87);
    bustupFree(ref_71);
