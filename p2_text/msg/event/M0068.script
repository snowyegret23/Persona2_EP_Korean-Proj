    ref_c5 = bustupAlloc(ref_c3, right, rgb(0,0,0));
    bustupFade(ref_c5, rgb(128,0,0), 30);
    ref_c7 = dialogAlloc();
    ref_c8 = msgShow(msg_4);
/***************************************
[color(yellow)]悪魔絵師[color(white)]
[tab]僕は悪魔絵師。[delay(30)]
[tab]人の内に住まう、神と悪魔を描く絵師。[wait][clear]
***************************************/
    unitAnimationPlay(unit_76, animation_8, 1);
    wait(ref_c8);
    dialogFree(ref_c7);
    ref_cc = bustupFade(ref_c5, rgb(0,0,0), 10);
    bustupWait(ref_cc);
    bustupFree(ref_c5);
    unitAnimationPlay(unit_76, animation_0, 1);
    delayClear();
    delayWait(30);
    unitAnimationPlay(unit_76, animation_9, 1);
    ref_d3 = cameraMoveTo(1041, 0, -907, 60);
    unitFaceUnit(maya, shopkeeper);
    wait(ref_d3);
    delayClear();
    delayWait(30);
    unitAnimationPlay(shopkeeper, animation_8, 1);
    delayClear();
    delayWait(20);
    unitAnimationPlay(shopkeeper, animation_b, 1);
    delayClear();
    delayWait(20);
    ref_de = bustupLoad(bustup_e0);
    bustupWait(ref_de);
    ref_e0 = bustupAlloc(ref_de, right, rgb(0,0,0));
    bustupFade(ref_e0, rgb(128,0,0), 30);
    ref_e2 = dialogAlloc();
    ref_e3 = msgShow(msg_5);
/***************************************
[color(yellow)]イゴール[color(white)]
[tab]我ら４人、貴方がたの新たな心、
[tab]新たなペルソナの目覚めをお助けするよう、
[tab]仰せつかっております。以後、お見知りおきを…[wait][clear]
***************************************/
    wait(ref_e3);
    dialogFree(ref_e2);
    ref_e6 = bustupFade(ref_e0, rgb(0,0,0), 10);
    bustupWait(ref_e6);
    bustupFree(ref_e0);
    unitAnimationPlay(shopkeeper, animation_7, 1);
    delayClear();
    delayWait(15);
    unitAnimationPlay(shopkeeper, animation_9, 1);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 8, false);
    screenFadeOuter(rgb(255,255,255), 8, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    unitSpawn(unit_76, sprite_a7, 750, -60, -1250, north, none);
    ref_f4 = cameraLookAtUnit(maya, 0, 5);
    wait(ref_f4);
    unitDespawn(maya, none);
    bitSet(LBIT_0001);
    bitSet(MBIT_BEL_ISATU);
    bitSet(MBIT_BEL_BERADONNA);
    bitSet(MBIT_BEL_NANASI);
    bitSet(MBIT_BEL_IGOUL);
    bitSet(MBIT_BEL_ESI);
    bitSet(LBIT_0000);
    eventLoad(event_67);
}

