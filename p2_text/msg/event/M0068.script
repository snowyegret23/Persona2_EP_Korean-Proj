    ref_ac = dialogAlloc();
    ref_ad = msgShow(msg_3);
/***************************************
[color(yellow)]ナナシ[color(white)]
[tab]俺はナナシ…[delay(30)]
[tab]閉ざされし、心の扉を開くピアノ弾き…[wait][clear]
***************************************/
    wait(ref_ad);
    dialogFree(ref_ac);
    ref_b0 = bustupFade(ref_aa, rgb(0,0,0), 10);
    bustupWait(ref_b0);
    bustupFree(ref_aa);
    call(NANAMODORI);
