function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    levelFootstepSet(sfx_f);
    dngRoomSet(0);
    dngRoomDraw();
    ref_5 = spriteLoad(sprite_c8);
    wait(ref_5);
    unitSpawn(npc1, sprite_c8, 1459, 0, -506, west, none);
    unitTriggerSet(npc1, SOUKA, 255, 1);
    unitPalette(npc1, 0);
    unitSpawn(npc2, sprite_c8, 1298, 0, -940, south, none);
    unitTriggerSet(npc2, ASOU, 255, 1);
    unitPalette(npc2, 1);
    ref_d = spriteLoad(sprite_57);
    wait(ref_d);
    ref_f = spriteLoad(sprite_d);
    wait(ref_f);
    ref_11 = spriteLoad(sprite_d6);
    wait(ref_11);
    ref_13 = spriteLoad(sprite_0);
    wait(ref_13);
    ref_15 = spriteLoad(sprite_2);
    wait(ref_15);
    ref_17 = spriteLoad(sprite_6);
    wait(ref_17);
    ref_19 = spriteLoad(sprite_58);
    wait(ref_19);
    bitGet(var_1, EBIT_E0006);
    bne(var_1, 0, label_20);
    ref_1d = call(KYOUSEI);
    wait(ref_1d);
    b(label_24);
  label_20:
    bne(var_1, 1, label_24);
    ref_21 = call(FREE);
    wait(ref_21);
    b(label_24);
  label_24:
}

function KYOUSEI()
{
