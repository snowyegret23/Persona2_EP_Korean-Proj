function SAEKO()
{
    controlDisable();
    bitGet(var_0, EBIT_E0010);
    bnz(var_0, label_228);
    unitFacePlayer(saeko);
    ref_20e = bustupLoad(bustup_127);
    bustupWait(ref_20e);
    ref_210 = bustupAlloc(ref_20e, right, rgb(0,0,0));
