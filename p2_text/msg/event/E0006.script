function KATUYA()
{
    controlDisable();
    unitFacePlayer(katsuya);
    ref_3ad = bustupLoad(bustup_21);
    bustupWait(ref_3ad);
    ref_3af = bustupAlloc(ref_3ad, left, rgb(0,0,0));
    bustupFade(ref_3af, rgb(128,0,0), 30);
    ref_3b1 = dialogAlloc();
    ref_3b2 = msgShow(msg_40);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]ヘリオス…あれがもう一人の僕だと言うのか…
[tab]自分の知らないもう一人の自分…か。
[tab]しかし、よりによってそれが猫とは皮肉な話だ。
[wait][clear]
***************************************/
    unitAnimationPlay(katsuya, animation_1a, 1);
    wait(ref_3b2);
    unitAnimationPlay(katsuya, animation_a, 1);
    dialogFree(ref_3b1);
    ref_3b7 = bustupFade(ref_3af, rgb(0,0,0), 10);
    bustupWait(ref_3b7);
    bustupFree(ref_3af);
    unitRestoreFacing(katsuya);
    controlEnable();
}
