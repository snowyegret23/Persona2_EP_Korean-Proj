function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    sndIdGet(var_a);
    bne(var_a, -1, label_5);
    b(label_7);
  label_5:
    sndVolumeFadeOff(var_a, 60);
    b(label_7);
  label_7:
    sndMusicPlay(sound_300c, 127);
    cameraSet(northeast, 934, 0, -754);
    levelFootstepSet(sfx_19);
    ref_a = spriteLoad(sprite_0);
    wait(ref_a);
    ref_c = spriteLoad(sprite_3);
    wait(ref_c);
    ref_e = spriteLoad(sprite_6);
    wait(ref_e);
    ref_10 = spriteLoad(sprite_8);
    wait(ref_10);
    ref_12 = spriteLoad(sprite_d);
    wait(ref_12);
    ref_14 = spriteLoad(sprite_f);
    wait(ref_14);
    ref_16 = spriteLoad(sprite_13);
    wait(ref_16);
    ref_18 = spriteLoad(sprite_15);
    wait(ref_18);
    ref_1a = spriteLoad(sprite_23);
    wait(ref_1a);
    ref_1c = spriteLoad(sprite_25);
    wait(ref_1c);
    unitSpawn(maya, sprite_3, 680, 0, -1220, south, none);
    unitSpawn(ulala, sprite_8, 850, 0, -1250, south, none);
    unitSpawn(katsuya, sprite_f, 1000, 0, -1020, east, none);
    unitSpawn(baofu, sprite_15, 700, 0, -950, south, none);
    unitSpawn(elly, sprite_25, 800, 0, -1000, south, none);
    unitAnimationPlay(ulala, animation_15, 1);
    unitAnimationPlay(katsuya, animation_15, 1);
    unitAnimationPlay(elly, animation_15, 1);
    objVisible(obj_17, false);
    objVisible(obj_33, false);
    objVisible(obj_30, false);
    bitSet(EBIT_E0069);
    bitSet(EBIT_TV_KYOMEI);
    bitSet(DBIT_TV_YUKA1);
    bitSet(DBIT_TV_URAOK);
    bitClear(DBIT_TV_ST8DR);
    bitClear(DBIT_TV_HAJIKI);
    bitClear(DBIT_TV_GAKUYA1);
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 4, true);
    screenFadeOuter(rgb(0,0,0), 4, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    delayClear();
    delayWait(60);
    call(MAYA_START);
    call(URARA_START);
    call(KATUYA_START);
    unitAnimationHold(baofu, animation_12, -1);
    unitSpriteClear(elly);
    unitSpriteSet(elly, sprite_23);
    unitAnimationPlay(elly, animation_6, 1);
    delayClear();
    delayWait(200);
    unitAnimationPlay(elly, animation_12, 1);
    unitWait(elly);
    delayClear();
    delayWait(30);
    unitFace_2(elly, north);
    unitAnimationPlay(elly, animation_10, 1);
    ref_46 = bustupLoad(bustup_42);
    bustupWait(ref_46);
    ref_48 = bustupAlloc(ref_46, left, rgb(0,0,0));
    bustupFade(ref_48, rgb(128,0,0), 30);
    ref_4a = dialogAlloc();
    ref_4b = msgShow(msg_0);
/***************************************
[color(yellow)]エリー[color(white)]
[tab]皆さん、申し訳ありませんでした…

***************************************/
    wait(ref_4b);
    unitAnimationStop(ulala);
    call(MAYA_MOVE);
    call(KATUYA_MOVE);
    call(PAOFU_MOVE);
    ref_51 = msgShow(msg_1);
/***************************************
[tab]私の弱さのせいで…
[tab]ご迷惑おかけしてしまって…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_51);
    dialogFree(ref_4a);
    ref_55 = bustupFade(ref_48, rgb(0,0,0), 10);
    bustupWait(ref_55);
    bustupFree(ref_48);
    delayClear();
    delayWait(30);
    unitAnimationPlay(ulala, animation_1b, 1);
    ref_5b = bustupLoad(bustup_18);
    bustupWait(ref_5b);
    ref_5d = bustupAlloc(ref_5b, left, rgb(0,0,0));
    bustupFade(ref_5d, rgb(128,0,0), 30);
    ref_5f = dialogAlloc();
    ref_60 = msgShow(msg_2);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]なぁにそんなこと気にしてんのよぅ。

***************************************/
    wait(ref_60);
    unitAnimationPlay(maya, animation_e, 1);
    unitAnimationPlay(katsuya, animation_d, 1);
    unitAnimationPlay(baofu, animation_a, 1);
    unitAnimationPlay(elly, animation_a, 1);
    unitAnimationPlay(ulala, animation_1f, 1);
    ref_67 = msgShow(msg_3);
/***************************************
[tab]気持ち、なんとなくわかるしさ…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_67);
    unitAnimationPlay(ulala, animation_1e, 1);
    ref_6b = msgShow(msg_4);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]レッツ・ポジティブシンキングよ！

***************************************/
    wait(ref_6b);
    unitAnimationPlay(ulala, animation_c, 1);
    ref_6e = msgShow(msg_5);
/***************************************
[tab]ね、マーヤ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_6e);
    dialogFree(ref_5f);
    ref_72 = bustupFade(ref_5d, rgb(0,0,0), 10);
    bustupWait(ref_72);
    bustupFree(ref_5d);
    delayClear();
    delayWait(30);
    unitAnimationPlay(elly, animation_d, 1);
    unitAnimationPlay(maya, animation_a, 1);
    delayClear();
    delayWait(30);
    unitAnimationPlay(maya, animation_27, 1);
    unitWait(maya);
    delayClear();
    delayWait(30);
    unitAnimationHold(elly, animation_16, -1);
    delayClear();
    delayWait(30);
    unitAnimationPlay(ulala, animation_a, 1);
    unitAnimationPlay(katsuya, animation_a, 1);
    unitAnimationPlay(baofu, animation_2, 1);
    delayClear();
    delayWait(120);
    unitAnimationHold(baofu, animation_11, -1);
    ref_88 = bustupLoad(bustup_2d);
    bustupWait(ref_88);
    ref_8a = bustupAlloc(ref_88, left, rgb(0,0,0));
    bustupFade(ref_8a, rgb(128,0,0), 30);
    ref_8c = dialogAlloc();
    ref_8d = msgShow(msg_6);
/***************************************
[color(yellow)]パオフゥ[color(white)]
[tab]どこぞの誰かみてぇに、
[tab]てめぇがＪＯＫＥＲになっちまうよりは、

***************************************/
    wait(ref_8d);
    unitAnimationPlay(elly, animation_e, 1);
    unitAnimationHold(ulala, animation_21, -1);
    unitAnimationStop(baofu);
    unitAnimationPlay(baofu, animation_1d, 1);
    ref_93 = msgShow(msg_7);
/***************************************
[tab]可愛いもんってこった…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_93);
    dialogFree(ref_8c);
    ref_97 = bustupFade(ref_8a, rgb(0,0,0), 10);
    bustupWait(ref_97);
    bustupFree(ref_8a);
    delayClear();
    delayWait(30);
    unitAnimationStop(ulala);
    ref_9d = bustupLoad(bustup_19);
    bustupWait(ref_9d);
    ref_9f = bustupAlloc(ref_9d, left, rgb(0,0,0));
    bustupFade(ref_9f, rgb(128,0,0), 30);
    ref_a1 = dialogAlloc();
    ref_a2 = msgShow(msg_8);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]グッ…

***************************************/
    wait(ref_a2);
    unitAnimationPlay(maya, animation_e, 1);
    unitAnimationPlay(katsuya, animation_d, 1);
    unitAnimationPlay(baofu, animation_e, 1);
    unitAnimationPlay(elly, animation_a, 1);
    unitAnimationPlay(ulala, animation_1e, 5);
    ref_a9 = msgShow(msg_9);
/***************************************
[tab]悪かったって言ってんじゃないよぅ…
[sync][wait][clear]
***************************************/
    delayClear();
    delayWait(20);
    sndMusicPlay(sound_31b7, 127);
    sync();
    wait(ref_a9);
    dialogFree(ref_a1);
    ref_b0 = bustupFade(ref_9f, rgb(0,0,0), 10);
    bustupWait(ref_b0);
    bustupFree(ref_9f);
    unitAnimationPlay(ulala, animation_1b, 1);
    unitAnimationPlay(maya, animation_23, 1);
    unitAnimationPlay(katsuya, animation_23, 1);
    delayClear();
    delayWait(150);
    unitAnimationPlay(maya, animation_a, 1);
    unitAnimationPlay(katsuya, animation_a, 1);
    delayClear();
    delayWait(60);
    unitAnimationHold(katsuya, animation_11, -1);
    ref_bd = bustupLoad(bustup_21);
    bustupWait(ref_bd);
    ref_bf = bustupAlloc(ref_bd, left, rgb(0,0,0));
    bustupFade(ref_bf, rgb(128,0,0), 30);
    ref_c1 = dialogAlloc();
    ref_c2 = msgShow(msg_10);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]まぁ、これで、敵の術は破れたわけか…

***************************************/
    wait(ref_c2);
    unitAnimationPlay(maya, animation_d, 1);
    unitAnimationPlay(ulala, animation_d, 1);
    unitAnimationPlay(baofu, animation_c, 1);
    unitAnimationPlay(elly, animation_c, 1);
    unitAnimationPlay(katsuya, animation_14, 1);
    ref_c9 = msgShow(msg_11);
/***************************************
[tab]早く表に戻ろう。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_c9);
    dialogFree(ref_c1);
    ref_cd = bustupFade(ref_bf, rgb(0,0,0), 10);
    bustupWait(ref_cd);
    bustupFree(ref_bf);
    unitAnimationPlay(katsuya, animation_a, 1);
    unitAnimationPlay(maya, animation_26, 1);
    unitAnimationPlay(ulala, animation_26, 1);
    unitAnimationPlay(baofu, animation_26, 1);
    unitAnimationPlay(elly, animation_26, 1);
    delayClear();
    delayWait(30);
    call(MAYA_IDO);
    call(KATUYA_IDO);
    call(URARA_IDO);
    delayClear();
    delayWait(60);
    unitMove(baofu, 700, -1650, despawn, medium);
    unitMove(elly, 800, -1650, despawn, medium);
    delayClear();
    delayWait(90);
    ref_e0 = screenHorizontalFadeOut();
    wait(ref_e0);
    eventLoad(event_b8);
}

function MAYA_START()
{
    unitSpriteClear(maya);
    unitSpriteSet(maya, sprite_0);
    delayClear();
    delayWait(30);
    unitAnimationPlay(maya, animation_41, 1);
    delayClear();
    delayWait(30);
    unitAnimationPlay(maya, animation_42, 1);
}

function URARA_START()
{
    unitSpriteClear(ulala);
    unitSpriteSet(ulala, sprite_6);
    delayClear();
    delayWait(30);
    unitAnimationHold(ulala, animation_11, -1);
}

function KATUYA_START()
{
    unitAnimationPlay(katsuya, animation_15, 1);
    delayClear();
    delayWait(30);
    unitAnimationPlay(katsuya, animation_12, 1);
}

function MAYA_MOVE()
{
    unitAnimationPlay(maya, animation_31, 1);
    delayClear();
    delayWait(30);
    unitAnimationPlay(maya, animation_a, 1);
}

function KATUYA_MOVE()
{
    unitSpriteClear(katsuya);
    unitSpriteSet(katsuya, sprite_d);
    unitAnimationPlay(katsuya, animation_a, 1);
}

function PAOFU_MOVE()
{
    unitAnimationStop(baofu);
    unitSpriteClear(baofu);
    unitSpriteSet(baofu, sprite_13);
    unitAnimationPlay(baofu, animation_4, 1);
    delayClear();
    delayWait(30);
    unitFace_2(baofu, north);
    unitAnimationPlay(baofu, animation_b, 1);
}

function MAYA_IDO()
{
    unitAnimationPlay(maya, animation_12, 1);
    unitWait(maya);
    unitFace_2(maya, north);
    unitAnimationPlay(maya, animation_0, 1);
    delayClear();
    delayWait(30);
    unitMove(maya, 680, -1650, despawn, medium);
}

function URARA_IDO()
{
    unitAnimationPlay(ulala, animation_12, 1);
    unitWait(ulala);
    unitFace_2(ulala, north);
    unitAnimationPlay(ulala, animation_0, 1);
    delayClear();
    delayWait(30);
    unitMove(ulala, 850, -1650, despawn, medium);
}

function KATUYA_IDO()
{
    unitAnimationPlay(katsuya, animation_4, 1);
    delayClear();
    delayWait(30);
    unitFace_2(katsuya, north);
    unitAnimationPlay(katsuya, animation_0, 1);
    delayClear();
    delayWait(30);
    unitMove(katsuya, 1000, -1650, despawn, medium);
}
