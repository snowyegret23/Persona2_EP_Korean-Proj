function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    ref_2 = spriteLoad(sprite_0);
    wait(ref_2);
    ref_4 = spriteLoad(sprite_2);
    wait(ref_4);
    ref_6 = spriteLoad(sprite_6);
    wait(ref_6);
    ref_8 = spriteLoad(sprite_d);
    wait(ref_8);
    ref_a = spriteLoad(sprite_13);
    wait(ref_a);
    ref_c = spriteLoad(sprite_18);
    wait(ref_c);
    ref_e = spriteLoad(sprite_79);
    wait(ref_e);
    ref_10 = spriteLoad(sprite_f3);
    wait(ref_10);
    bitGet(var_1, EBIT_E00B2);
    bne(var_1, 0, label_17);
    ref_14 = call(KYOUSEI);
    wait(ref_14);
    b(label_1b);
  label_17:
    bne(var_1, 1, label_1b);
    ref_18 = call(FREE);
    wait(ref_18);
    b(label_1b);
  label_1b:
}

