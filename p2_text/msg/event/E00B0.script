function EXIT()
{
    controlDisable();
    objAnimTranslate(obj_6, 100, 0, 0, 60);
    sndMusicPlay(sound_32a2, 127);
    objAnimTranslate(obj_7, -100, 0, 0, 60);
    objAnimWait(obj_6);
    objAnimWait(obj_7);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    cameraSetNorth(south);
    dngLoad2(sumaru_castle2-12);
}

