function FREE()
{
    sndIdGet(var_0);
    bne(var_0, -1, label_125);
    b(label_127);
  label_125:
    sndVolumeFadeTo(var_0, 90, 60);
    b(label_127);
  label_127:
    sndUnkCF(90);
    unitSpawn(ulala, sprite_6, 700, 0, -900, south, none);
    unitSpawn(katsuya, sprite_d, 300, 0, -1050, south, none);
    unitSpawn(baofu, sprite_13, 850, 0, -1250, south, none);
    unitSpawn(tatsuya, sprite_18, 400, 0, -800, south, none);
    unitAnimationPlay(ulala, animation_a, 1);
    unitAnimationPlay(katsuya, animation_a, 1);
    unitAnimationPlay(baofu, animation_a, 1);
    unitAnimationPlay(tatsuya, animation_0, 1);
    unitIdleOnAll();
    unitTriggerSet(katsuya, KATUYA, 255, 1);
    unitTriggerSet(baofu, PAOFU, 255, 1);
    unitTriggerSet(ulala, URARA, 255, 1);
    unitTriggerSet(tatsuya, TATUYA, 255, 1);
    envTriggerSet(EXIT, 131, 1, line, coll_3);
    cameraSetNorth(south);
    cameraSet(southeast, 520, 0, -1380);
    playerInit(south);
    controlDisable();
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

function KATUYA()
{
    controlDisable();
    unitFacePlayer(katsuya);
    ref_143 = bustupLoad(bustup_21);
    bustupWait(ref_143);
    ref_145 = bustupAlloc(ref_143, left, rgb(0,0,0));
    bustupFade(ref_145, rgb(128,0,0), 30);
    ref_147 = dialogAlloc();
    ref_148 = msgShow(msg_8);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]伝説が、噂となって蘇るか…
[tab]死んだ者まで利用しなければならんとは、
[tab]気が引けるな…
[sync][wait][clear]
***************************************/
    unitAnimationPlay(katsuya, animation_2d, 1);
    delayClear();
    delayWait(60);
    sync();
    wait(ref_148);
    dialogFree(ref_147);
    ref_14f = bustupFade(ref_145, rgb(0,0,0), 10);
    bustupWait(ref_14f);
    bustupFree(ref_145);
    unitAnimationPlay(katsuya, animation_0, 1);
    unitRestoreFacing(katsuya);
    controlEnable();
}

