function DOORBOX()
{
    controlDisable();
    objAnimRotate(obj_6, 0, 80, 0, 30, 0);
    objAnimRotate(obj_7, 0, -80, 0, 30, 0);
    sndMusicPlay(sound_307a, 127);
    objAnimWait(obj_6);
    objAnimWait(obj_7);
    call(EXITBOX);
}

function EXITBOX()
{
    bitClear(MBIT_EXITBIT);
    mapLoad(rengedai, 0, 0);
}

function DEBAGBOX()
{
    b(label_aa1);
    controlDisable();
    choiceSetResult(4);
    ref_a8d = dialogChoiceAlloc();
    ref_a8e = msgShow(msg_163);
/***************************************
えらんで
[choice(5)][color(pink)]ワンロン始めた[color(white)]
[color(blue)]相性占い広めた[color(white)]
[color(green)]パワーアップ[color(white)]
[color(orange)]お金[color(white)]
[color(gray)]終了[color(white)]
[end_choice][clear]
***************************************/
    wait(ref_a8e);
    dialogFree(ref_a8d);
    choiceGetResult(var_0);
    bne(var_0, 0, label_a95);
    bitSet(MBIT_HI_GYPSTART);
    b(label_aa0);
  label_a95:
    bne(var_0, 1, label_a98);
    bitSet(MBIT_HI_GYPAISHO1);
    b(label_aa0);
  label_a98:
    bne(var_0, 2, label_a9b);
    bitSet(MBIT_HI_GYPAISHO2);
    b(label_aa0);
  label_a9b:
    bne(var_0, 3, label_a9e);
    partyMoneyAdd(15000);
    b(label_aa0);
  label_a9e:
    bne(var_0, 4, label_aa0);
    b(label_aa0);
  label_aa0:
    controlEnable();
  label_aa1:
}

function HA_SHOP_EXPLAIN_0()
{
    choiceSetResult(2);
    ref_aa3 = dialogChoiceAlloc();
    ref_aa4 = msgShow(msg_164);
/***************************************
[color(yellow)]珠閒瑠ジニー[color(white)]
[tab]妾に何を聞きたいのだ？
[choice(3)]占い
[if_all(MBIT_HI_GYPAISHO1)]相性占い
やめる
[end_choice][clear]
