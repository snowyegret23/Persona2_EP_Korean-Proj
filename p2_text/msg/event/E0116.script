function START()
{
    msgVar_Item(msgvar_0, empress_card);
    ref_1 = dialogAlloc();
    ref_2 = msgShow(msg_0);
/***************************************
[color(green)]舞耶達は、[var(msg_var_0)]のカードを５０枚
手に入れた。[color(white)]
[wait][clear]
***************************************/
    wait(ref_2);
    partyItemAdd(empress_card, 50);
    ref_5 = msgShow(msg_1);
/***************************************
[color(green)]舞耶達は、感情のトラペゾヘドロンを手に入れ、
感情の塔を後にした。[color(white)]
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_5);
    dialogFree(ref_1);
    bitSet(bit_c81);
    dngLoad2(kadath_mandala3-6);
}
