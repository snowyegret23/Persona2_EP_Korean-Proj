}

function HA_SHOP_EXPLAIN_0()
{
    ref_4e8 = dialogAlloc();
    ref_4e9 = msgShow(msg_71);
/***************************************
[color(yellow)]アルバイター[color(white)]
[tab]「食事」の説明でござるな、承知した。
[tab]当方で「食事をする」を選んでいただければ
[tab]ハンバーガー・ポテト・シェイクなどを提供いたす。
[wait][clear][color(yellow)]アルバイター[color(white)]
[tab]これらの食物には一時的に能力を高める効果がありまして
[tab]その効果は、メニューによって様々でござる。
[tab]如何様な効果が出るかは、色々食されてみるが良かろう。
[wait][clear][color(yellow)]アルバイター[color(white)]
[tab]ひとつ気をつけていただきたいのだが、一度飲食をすると
[tab]その効果が切れるまで次の食事はできないでござる。
[tab]たいしたことではないと思うが…注意されたし。
[wait][clear]
***************************************/
    wait(ref_4e9);
    dialogFree(ref_4e8);
}

function DECIDE_EAT()
{
    choiceSetResult(1);
    msgVar_Number(msgvar_0, var_6);
    unitFacePlayer(shopkeeper);
    ref_4f0 = bustupLoad(bustup_f3);
    bustupWait(ref_4f0);
    ref_4f2 = bustupAlloc(ref_4f0, left, rgb(0,0,0));
    bustupFade(ref_4f2, rgb(128,0,0), 30);
    ref_4f4 = dialogAlloc();
    ref_4f5 = msgShow(msg_72);
/***************************************
[color(yellow)]アルバイター[color(white)]
[tab]そちらは[var(msg_var_0)]円になり申す。
[tab]よろしいでござるか？
[choice(2)]はい
いいえ
[end_choice][clear]
***************************************/
    wait(ref_4f5);
    choiceGetResult(var_7);
    bne(var_7, 0, label_4fb);
    li(var_7, 1);
    b(label_4fe);
  label_4fb:
    bne(var_7, 1, label_4fe);
    li(var_7, 0);
    b(label_4fe);
  label_4fe:
    wait(ref_4f5);
    dialogFree(ref_4f4);
    ref_500 = bustupFade(ref_4f2, rgb(0,0,0), 10);
    bustupWait(ref_500);
    bustupFree(ref_4f2);
    li(var_5, 20);
}
