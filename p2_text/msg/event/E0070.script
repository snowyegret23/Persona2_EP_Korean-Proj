function URARAMOVE()
{
    unitSpawn(ulala, sprite_6, 275, 0, -1550, south, fade);
    unitMove(ulala, 255, -1200, face_south, fast);
    unitWait(ulala);
    unitMove(ulala, 950, -1200, face_west, fast);
    unitWait(ulala);
    unitMove(ulala, 950, -700, face_south, fast);
    unitWait(ulala);
    unitMove(ulala, 250, -700, face_east, fast);
    unitWait(ulala);
    unitAnimationPlay(ulala, animation_5, 1);
}

