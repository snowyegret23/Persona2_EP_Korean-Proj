function URARAMOVE2()
{
    unitMove(ulala, 950, -700, face_west, fast);
    unitWait(ulala);
    unitMove(ulala, 950, -1200, face_north, fast);
    unitWait(ulala);
    cameraRotateTo(7, 30);
    unitMove(ulala, 255, -1200, face_east, fast);
    unitWait(ulala);
    cameraRotateTo(3, 30);
    unitMove(ulala, 255, -1450, face_north, fast);
    unitWait(ulala);
    unitAnimationPlay(ulala, animation_0, 1);
    unitWait(ulala);
    cameraFollow(maya);
}

function MAYAMOVE2()
{
    unitMove(maya, 80, -600, face_east, medium);
    unitWait(maya);
    delayClear();
    delayWait(90);
    objVisible(obj_b, false);
    unitMove(maya, 80, -750, face_north, fast);
    unitWait(maya);
    unitFace(maya, south);
    unitAnimationPlay(maya, animation_a, 1);
    bitGet(var_1, MBIT_HI_NANJOTOUJO);
    bnz(var_1, label_132);
    unitAnimationPlay(elly, animation_c, 1);
    unitWait(elly);
  label_132:
}

