  label_48:
    delayClear();
    delayWait(7);
    unitFace(maya, south);
    unitFace(ulala, west);
    unitAnimationPlay(maya, animation_0, 1);
    unitAnimationPlay(ulala, animation_0, 1);
    delayClear();
    delayWait(7);
    unitFace(maya, west);
    unitFace(ulala, north);
    delayClear();
    delayWait(7);
    unitAnimationPlay(maya, animation_28, 1);
    unitAnimationPlay(ulala, animation_28, 1);
    unitWait(maya);
    unitAnimationPlay(maya, animation_1, 1);
    unitAnimationPlay(ulala, animation_1, 1);
    delayClear();
    delayWait(7);
    unitFace(maya, north);
    unitFace(ulala, west);
    unitAnimationPlay(maya, animation_0, 1);
    unitAnimationPlay(ulala, animation_a, 1);
    delayClear();
    delayWait(7);
    unitFace(ulala, south);
    delayClear();
    delayWait(10);
    ref_64 = bustupLoad(bustup_17);
    bustupWait(ref_64);
    ref_66 = bustupAlloc(ref_64, left, rgb(0,0,0));
