function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    sndMusicPlay(sound_32a1, 127);
    sndIdGet(var_0);
    bne(var_0, -1, label_6);
    b(label_8);
  label_6:
    sndVolumeFadeTo(var_0, 60, 60);
    b(label_8);
  label_8:
    sndUnkCF(60);
    ref_9 = spriteLoad(sprite_0);
    wait(ref_9);
    ref_b = spriteLoad(sprite_2);
    wait(ref_b);
    ref_d = spriteLoad(sprite_d);
    wait(ref_d);
    ref_f = spriteLoad(sprite_13);
    wait(ref_f);
    ref_11 = spriteLoad(sprite_6);
    wait(ref_11);
    ref_13 = spriteLoad(sprite_18);
    wait(ref_13);
    cameraSetNorth(south);
    cameraSet(southwest, 500, 0, -1300);
    unitSpawn(katsuya, sprite_d, 250, 0, -500, east, none);
    unitAnimationPlay(katsuya, animation_a, 1);
    unitSpawn(ulala, sprite_6, 250, 0, -900, east, none);
    unitAnimationPlay(ulala, animation_a, 1);
    unitSpawn(tatsuya, sprite_18, 750, 0, -350, west, none);
    unitAnimationPlay(tatsuya, animation_0, 1);
    unitSpawn(baofu, sprite_13, 750, 0, -1100, west, none);
    unitAnimationPlay(baofu, animation_a, 1);
    unitTriggerSet(katsuya, KATUYA, 255, 1);
    unitTriggerSet(baofu, PAOFU, 255, 1);
    unitTriggerSet(ulala, URARA, 255, 1);
    unitTriggerSet(tatsuya, TATUYA, 255, 1);
    envTriggerSet(EXIT, 131, 1, line, coll_1);
    playerInit(south);
    controlDisable();
    unitIdleOnAll();
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 4, true);
    screenFadeOuter(rgb(0,0,0), 4, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

function KATUYA()
{
    controlDisable();
    unitFacePlayer(katsuya);
    ref_30 = bustupLoad(bustup_25);
    bustupWait(ref_30);
    ref_32 = bustupAlloc(ref_30, left, rgb(0,0,0));
    bustupFade(ref_32, rgb(128,0,0), 30);
    ref_34 = dialogAlloc();
    ref_35 = msgShow(msg_0);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]街の人々から集めた穢れだな…
[tab]どこかへ…送っているようだが…
[sync][wait][clear]
***************************************/
    unitAnimationPlay(katsuya, animation_2d, 1);
    delayClear();
    delayWait(60);
    sync();
    wait(ref_35);
    dialogFree(ref_34);
    ref_3c = bustupFade(ref_32, rgb(0,0,0), 10);
    bustupWait(ref_3c);
    bustupFree(ref_32);
    unitAnimationPlay(katsuya, animation_a, 1);
    unitRestoreFacing(katsuya);
    controlEnable();
}

function PAOFU()
{
    controlDisable();
    unitFacePlayer(baofu);
    ref_45 = bustupLoad(bustup_2c);
    bustupWait(ref_45);
    ref_47 = bustupAlloc(ref_45, left, rgb(0,0,0));
    bustupFade(ref_47, rgb(128,0,0), 30);
    ref_49 = dialogAlloc();
    ref_4a = msgShow(msg_1);
/***************************************
[color(yellow)]パオフゥ[color(white)]
[tab]うかつに壊すわけにもいかねぇしな…
[tab]厄介なもん、溜め込みやがって…
[sync][wait][clear]
***************************************/
    unitAnimationPlay(baofu, animation_2d, 1);
    delayClear();
    delayWait(45);
    unitAnimationPlay(baofu, animation_1d, 1);
    unitWait(baofu);
    delayClear();
    delayWait(5);
    sync();
    wait(ref_4a);
    dialogFree(ref_49);
    ref_55 = bustupFade(ref_47, rgb(0,0,0), 10);
    bustupWait(ref_55);
    bustupFree(ref_47);
    unitAnimationPlay(baofu, animation_a, 1);
    unitRestoreFacing(baofu);
    controlEnable();
}

function URARA()
{
    controlDisable();
    unitFacePlayer(ulala);
    ref_5e = bustupLoad(bustup_17);
    bustupWait(ref_5e);
    ref_60 = bustupAlloc(ref_5e, left, rgb(0,0,0));
    bustupFade(ref_60, rgb(128,0,0), 30);
    ref_62 = dialogAlloc();
    ref_63 = msgShow(msg_2);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]一体、どんくらいあるわけ…？
[tab]奥は霞んで見えないけどさ…
[sync][wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_1f, 45);
    delayClear();
    delayWait(45);
    unitAnimationPlay(ulala, animation_2d, 1);
    delayClear();
    delayWait(20);
    sync();
    wait(ref_63);
    dialogFree(ref_62);
    ref_6d = bustupFade(ref_60, rgb(0,0,0), 10);
    bustupWait(ref_6d);
    bustupFree(ref_60);
    unitAnimationPlay(ulala, animation_a, 1);
    unitRestoreFacing(ulala);
    controlEnable();
}

function TATUYA()
{
    controlDisable();
    unitFacePlayer(tatsuya);
    ref_76 = bustupLoad(bustup_10);
