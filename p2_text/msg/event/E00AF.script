    bustupFade(ref_78, rgb(128,0,0), 30);
    ref_7a = dialogAlloc();
    ref_7b = msgShow(msg_3);
/***************************************
[color(yellow)][tatsuya][color(white)]
[tab]こんな簡単に…
[tab]犯した罪から逃げられるわけはない…
[tab]罪は…自分で償わなければいけないんだ…
[sync][wait][clear]
***************************************/
    unitAnimationPlay(tatsuya, animation_6, 1);
    delayClear();
    delayWait(45);
    unitAnimationPlay(tatsuya, animation_14, 1);
    unitWait(tatsuya);
    delayClear();
    delayWait(20);
    sync();
    wait(ref_7b);
