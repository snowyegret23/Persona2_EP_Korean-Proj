function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    ref_2 = spriteLoad(sprite_0);
    wait(ref_2);
    ref_4 = spriteLoad(sprite_2);
    wait(ref_4);
    ref_6 = spriteLoad(sprite_6);
    wait(ref_6);
    ref_8 = spriteLoad(sprite_d);
    wait(ref_8);
    ref_a = spriteLoad(sprite_13);
    wait(ref_a);
    ref_c = spriteLoad(sprite_18);
    wait(ref_c);
    ref_e = spriteLoad(sprite_7a);
    wait(ref_e);
    bitGet(var_1, EBIT_E00B3);
    bne(var_1, 0, label_15);
    ref_12 = call(KYOUSEI);
    wait(ref_12);
    b(label_19);
  label_15:
    bne(var_1, 1, label_19);
    ref_16 = call(FREE);
    wait(ref_16);
    b(label_19);
  label_19:
}

function KYOUSEI()
{
    cameraSet(northwest, 500, 0, -1400);
    ref_1b = sndLoad(sound_3042);
    wait(ref_1b);
    sndMusicPlay(sound_3042, 127);
    unitSpawn(maya, sprite_0, 500, 0, -750, south, none);
    unitSpawn(ulala, sprite_6, 350, 0, -900, south, none);
    unitSpawn(katsuya, sprite_d, 600, 0, -1000, south, none);
    unitSpawn(baofu, sprite_13, 450, 0, -1100, south, none);
    unitSpawn(tatsuya, sprite_18, 650, 0, -850, south, none);
    unitSpawn(enemy1, sprite_7a, 520, -50, -375, north, none);
    unitIdleOffAll();
    unitTriggerSet(katsuya, KATUYA, 255, 1);
    unitTriggerSet(baofu, PAOFU, 255, 1);
    unitTriggerSet(ulala, URARA, 255, 1);
    unitTriggerSet(tatsuya, TATUYA, 255, 1);
    envTriggerSet(EXIT, 131, 1, line, coll_0);
    ref_2a = cameraMoveTo(500, 0, -600, 180);
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 4, true);
    screenFadeOuter(rgb(0,0,0), 4, true);
    wait(ref_2a);
    delayClear();
    delayWait(60);
    ref_31 = dialogAlloc();
    ref_32 = msgShow(msg_0);
/***************************************
[color(yellow)]天野[tab]舞姫のミイラ[color(white)]
[tab]私を呼ぶのはどなた…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_32);
    dialogFree(ref_31);
    delayClear();
    delayWait(60);
    unitAnimationPlay(maya, animation_2d, 1);
    delayClear();
    delayWait(180);
    unitAnimationPlay(maya, animation_0, 1);
    delayClear();
    delayWait(60);
    ref_3e = dialogAlloc();
    ref_3f = msgShow(msg_1);
/***************************************
[color(yellow)]天野[tab]舞姫のミイラ[color(white)]
[tab]まさか…そのような…あの清忠が…
[tab]分かりました…貴女が清忠を討つと仰るのなら…
[tab]喜んで力を貸しましょう…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_3f);
    dialogFree(ref_3e);
    delayClear();
    delayWait(60);
    ref_45 = efctDummy(effect_d);
    ref_46 = efctLoad(effect_d);
    wait(ref_45);
    wait(ref_46);
    efctPlay(effect_d, efct_0, 520, -50, -375, 520, -50, -375, false);
    sndMusicPlay(sound_32a6, 127);
    unitSpriteEffect(enemy1, 2);
    unitShadowRadius(enemy1, 0);
    unitColorAdjust(enemy1, 1, 1, 1);
    delayClear();
    delayWait(5);
    unitColorAdjust(enemy1, 0.5, 0.5, 0.5);
    delayClear();
    delayWait(5);
    unitColorAdjust(enemy1, 0.25, 0.25, 0.25);
    delayClear();
    delayWait(5);
    unitColorAdjust(enemy1, 0.125, 0.125, 0.125);
    delayClear();
    delayWait(5);
    unitColorAdjust(enemy1, 0.0625, 0.0625, 0.0625);
    delayClear();
    delayWait(5);
    unitColorAdjust(enemy1, 0.03125, 0.03125, 0.03125);
    delayClear();
    delayWait(5);
    unitColorAdjust(enemy1, 0.015625, 0.015625, 0.015625);
    delayClear();
    delayWait(5);
    unitColorAdjust(enemy1, 0.0078125, 0.0078125, 0.0078125);
    delayClear();
    delayWait(5);
    unitColorAdjust(enemy1, 0.00390625, 0.00390625, 0.00390625);
    delayClear();
    delayWait(5);
    unitColorAdjust(enemy1, 0.001953125, 0.001953125, 0.001953125);
    delayClear();
    delayWait(5);
    unitColorAdjust(enemy1, 0.0009765625, 0.0009765625, 0.0009765625);
    delayClear();
    delayWait(5);
    unitColorAdjust(enemy1, 0.00048828125, 0.00048828125, 0.00048828125);
    delayClear();
    delayWait(5);
    unitColorAdjust(enemy1, 0.000244140625, 0.000244140625, 0.000244140625);
    delayClear();
    delayWait(5);
    unitColorAdjust(enemy1, 0, 0, 0);
    unitDespawn(enemy1, none);
    delayClear();
    delayWait(60);
    ref_78 = dialogAlloc();
    ref_79 = msgShow(msg_2);
/***************************************
[color(green)][tab]天野[tab]舞姫のペルソナが、
[tab]ベルベットルームで召喚可能になりました。[color(white)]
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_79);
    dialogFree(ref_78);
    bitSet(EBIT_E00B3);
    ref_7e = sndVolumeFadeTo(sound_3042, 0, 60);
    wait(ref_7e);
    ref_80 = sndLoad(sound_1240);
    wait(ref_80);
    sndMusicPlay(sound_1240, 0);
    sndVolumeFadeTo(sound_1240, 90, 60);
    ref_84 = cameraLookAtUnit(maya, 0, 60);
    wait(ref_84);
    unitDespawn(maya, none);
    playerInit(south);
    controlDisable();
    unitIdleOnAll();
    controlEnable();
}

function FREE()
{
    sndIdGet(var_0);
    bne(var_0, -1, label_8f);
    b(label_91);
  label_8f:
    sndVolumeFadeTo(var_0, 90, 60);
    b(label_91);
  label_91:
    sndUnkCF(90);
    unitSpawn(ulala, sprite_6, 400, 0, -800, south, none);
    unitSpawn(katsuya, sprite_d, 750, 0, -1000, south, none);
    unitSpawn(baofu, sprite_13, 250, 0, -1050, south, none);
    unitSpawn(tatsuya, sprite_18, 500, 0, -1100, south, none);
    unitAnimationPlay(ulala, animation_a, 1);
    unitAnimationPlay(katsuya, animation_a, 1);
    unitAnimationPlay(baofu, animation_a, 1);
    unitAnimationPlay(tatsuya, animation_0, 1);
    unitIdleOnAll();
    unitTriggerSet(katsuya, KATUYA, 255, 1);
    unitTriggerSet(baofu, PAOFU, 255, 1);
    unitTriggerSet(ulala, URARA, 255, 1);
    unitTriggerSet(tatsuya, TATUYA, 255, 1);
    envTriggerSet(EXIT, 131, 1, line, coll_0);
    cameraSetNorth(east);
    cameraSet(southeast, 520, 0, -1380);
    playerInit(south);
    controlDisable();
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

function KATUYA()
{
    controlDisable();
    unitFacePlayer(katsuya);
    ref_ad = bustupLoad(bustup_21);
    bustupWait(ref_ad);
    ref_af = bustupAlloc(ref_ad, left, rgb(0,0,0));
    bustupFade(ref_af, rgb(128,0,0), 30);
    ref_b1 = dialogAlloc();
    ref_b2 = msgShow(msg_3);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]ここまでくると、似てるとかいうレベルの
[tab]問題じゃないな…
[sync][wait][clear]
***************************************/
    unitAnimationPlay(katsuya, animation_2d, 1);
    delayClear();
    delayWait(60);
    sync();
    wait(ref_b2);
    dialogFree(ref_b1);
    ref_b9 = bustupFade(ref_af, rgb(0,0,0), 10);
    bustupWait(ref_b9);
    bustupFree(ref_af);
    unitAnimationPlay(katsuya, animation_a, 1);
    unitRestoreFacing(katsuya);
    controlEnable();
}

