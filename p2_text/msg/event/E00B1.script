function TATUYA()
{
    controlDisable();
    unitFacePlayer(tatsuya);
    ref_ec = bustupLoad(bustup_b);
    bustupWait(ref_ec);
    ref_ee = bustupAlloc(ref_ec, left, rgb(0,0,0));
    bustupFade(ref_ee, rgb(128,0,0), 30);
    ref_f0 = dialogAlloc();
    ref_f1 = msgShow(msg_6);
/***************************************
[color(yellow)][tatsuya][color(white)]
[tab]とても偶然とは思えないな…
[tab]また、ヤツの仕業か…？
[sync][wait][clear]
***************************************/
    unitAnimationPlay(tatsuya, animation_24, 1);
    unitWait(tatsuya);
    unitAnimationPlay(tatsuya, animation_11, 1);
    unitWait(tatsuya);
    delayClear();
    delayWait(20);
    sync();
    wait(ref_f1);
    dialogFree(ref_f0);
    ref_fb = bustupFade(ref_ee, rgb(0,0,0), 10);
    bustupWait(ref_fb);
    bustupFree(ref_ee);
    unitAnimationPlay(tatsuya, animation_0, 1);
    unitRestoreFacing(tatsuya);
    controlEnable();
}

function EXIT()
{
    controlDisable();
    objAnimTranslate(obj_0, 100, 0, 0, 60);
    sndMusicPlay(sound_32a5, 127);
    objAnimTranslate(obj_1, -100, 0, 0, 60);
    objAnimWait(obj_0);
    objAnimWait(obj_1);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    cameraSetNorth(east);
    dngLoad2(sumaru_castle1-26);
}
