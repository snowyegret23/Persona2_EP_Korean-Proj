function OZISAN()
{
    controlDisable();
    bitGet(var_0, EBIT_E0033);
    bnz(var_0, label_3c4);
    bitGet(var_0, EBIT_E002B);
    bnz(var_0, label_3bb);
    unitFacePlayer(npc2);
    ref_3b3 = dialogAlloc();
    ref_3b4 = msgShow(msg_67);
/***************************************
[color(yellow)]おじさん[color(white)]
[tab]どうやら小学生達は、科学館の屋上に飾られた
[tab]飛行船を本物と思っているようですね。
[tab]息子がそう言っていました。[wait][clear][color(yellow)]おじさん[color(white)]
[tab]そう言えば今日は社会見学で、
[tab]その科学館に行くと言っていました。
[tab]今頃、中で大騒ぎしてるでしょう。
[wait][clear]
***************************************/
    unitAnimationPlay(npc2, animation_21, 1);
    wait(ref_3b4);
    unitAnimationPlay(npc2, animation_0, 1);
    dialogFree(ref_3b3);
    unitRestoreFacing(npc2);
    b(label_3cc);
  label_3bb:
    unitFacePlayer(npc2);
    ref_3bc = dialogAlloc();
    ref_3bd = msgShow(msg_68);
/***************************************
[color(yellow)]おじさん[color(white)]
[tab]良かった…本当に良かった…
[tab]科学館に行ってた息子が無事に帰ってきたんです。
[tab]火事と聞いた時は心臓が止まりそうでしたよ。[wait][clear][color(yellow)]おじさん[color(white)]
[tab]しかし、帰ってきた息子はずぶ濡れでしてね、
[tab]飛行船で脱出して海に落ちたと言ってるんです。
[tab]いったい、あそこで何があったのでしょう…
[wait][clear]
***************************************/
    unitAnimationPlay(npc2, animation_21, 1);
    wait(ref_3bd);
    unitAnimationPlay(npc2, animation_0, 1);
    dialogFree(ref_3bc);
    unitRestoreFacing(npc2);
    b(label_3cc);
  label_3c4:
    unitFacePlayer(npc2);
    ref_3c5 = dialogAlloc();
    ref_3c6 = msgShow(msg_69);
/***************************************
[color(yellow)]おじさん[color(white)]
[tab]ワンロン千鶴の言ってたこと、本当でしょうか？
[tab]科学館の火災といい、どうもこの街全体が、
[tab]狂い始めているような気がします。
[wait][clear]
***************************************/
    unitAnimationPlay(npc2, animation_21, 1);
    wait(ref_3c6);
    unitAnimationPlay(npc2, animation_0, 1);
    dialogFree(ref_3c5);
    unitRestoreFacing(npc2);
  label_3cc:
    controlEnable();
}

function DOORBOX()
{
    controlDisable();
    objAnimTranslate(obj_6, 80, 0, 0, 30);
    objAnimTranslate(obj_7, -80, 0, 0, 30);
    sndMusicPlay(sound_306b, 127);
    objAnimWait(obj_6);
    objAnimWait(obj_7);
    call(EXITBOX);
}

function EXITBOX()
{
    bitClear(MBIT_EXITBIT);
    mapLoad(rengedai, 0, 0);
}

function warp1()
{
    call(DOORBOX);
}

function HA_SHOP_EXPLAIN_0()
{
    ref_3db = dialogAlloc();
    ref_3dc = msgShow(msg_70);
/***************************************
[color(yellow)]オバサン・次女[color(white)]
[tab]うひょひょひょ。
[tab]「売買」についてねぇ～。
[wait][clear][color(yellow)]オバサン・次女[color(white)]
[tab]まずは、購入の説明なのねぇ～。
[tab]うちの店で「消費物を買う」を選ぶと
[tab]消費アイテムを買うことができるわよぉ～。
[wait][clear][color(yellow)]オバサン・次女[color(white)]
[tab]あっ、そうそう、アイテムは持てる数が
[tab]決まってるからねぇ～。
[wait][clear][color(yellow)]オバサン・次女[color(white)]
[tab]次に、売却の説明なのねぇ～。
[tab]「アイテムを売る」を選んで、まず種類を決めて、
[tab]次に売りたいものを選んでねぇ～。
[wait][clear][color(yellow)]オバサン・次女[color(white)]
[tab]買取価格は元値の約半額くらいよぉ～。
[tab]あと、装備中の物は売ることができないからねぇ～。
[tab]それと、物によっては買取できない物もあるわよぉ～。
[wait][clear][color(yellow)]オバサン・次女[color(white)]
[tab]こんなとこかしらぁ～。
[tab]うひょひょひょ。
[wait][clear]
***************************************/
    wait(ref_3dc);
    dialogFree(ref_3db);
}

function NOITEM()
{
    unitFacePlayer(shopkeeper);
    ref_3e1 = bustupLoad(bustup_fd);
    bustupWait(ref_3e1);
    ref_3e3 = bustupAlloc(ref_3e1, right, rgb(0,0,0));
    bustupFade(ref_3e3, rgb(128,0,0), 30);
    ref_3e5 = dialogAlloc();
    ref_3e6 = msgShow(msg_71);
/***************************************
[color(yellow)]オバサン・次女[color(white)]
[tab]売れる物、持ってないじゃないの～。[wait][clear]
***************************************/
