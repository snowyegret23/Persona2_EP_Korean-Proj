function PAOFU_TOUJOU()
{
    unitSpawn(baofu, sprite_13, 1000, 0, -1850, south, fade);
    unitMove(baofu, 1025, -1650, face_west, fast);
    unitWait(baofu);
    unitSpriteClear(baofu);
    unitSpriteSet(baofu, sprite_15);
    unitFace(baofu, south);
    unitAnimationPlay(baofu, animation_0, 1);
}

function TATUYA_TOUJOU()
{
    unitSpawn(tatsuya, sprite_18, 1000, 0, -1850, south, fade);
    unitMove(tatsuya, 975, -1650, face_east, fast);
    unitWait(tatsuya);
    unitSpriteClear(tatsuya);
    unitSpriteSet(tatsuya, sprite_1a);
    unitFace(tatsuya, south);
    unitAnimationPlay(tatsuya, animation_0, 1);
}

function KATUYA_HURI()
{
    unitAnimationPlay(katsuya, animation_34, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(katsuya, animation_35, 1);
}

function TATUYA_IDOU()
{
    unitMove(tatsuya, 975, -1580, face_south, fast);
    unitWait(tatsuya);
