function KATUYA_IDOU()
{
    unitAnimationPlay(katsuya, animation_0, 1);
    unitMove(katsuya, 1000, -1600, face_north, fast);
    unitWait(katsuya);
    unitMove(katsuya, 820, -1600, face_east, fast);
    unitWait(katsuya);
