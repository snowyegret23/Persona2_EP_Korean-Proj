function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    disableMap();
    levelFootstepSet(sfx_f);
    envTriggerSet(EXITBOX, 131, 2, line, coll_3);
    envTriggerSet(EXITBOX, 224, 2, line, coll_4);
    ref_6 = spriteLoad(sprite_0);
    wait(ref_6);
    ref_8 = spriteLoad(sprite_2);
    wait(ref_8);
    ref_a = spriteLoad(sprite_6);
    wait(ref_a);
    ref_c = spriteLoad(sprite_d);
    wait(ref_c);
    ref_e = spriteLoad(sprite_4a);
    wait(ref_e);
    ref_10 = spriteLoad(sprite_d6);
    wait(ref_10);
    ref_12 = spriteLoad(sprite_cd);
    wait(ref_12);
    ref_14 = spriteLoad(sprite_cc);
    wait(ref_14);
    ref_16 = spriteLoad(sprite_5d);
    wait(ref_16);
    ref_18 = spriteLoad(sprite_57);
    wait(ref_18);
    bitGet(var_1, EBIT_E0015);
    bne(var_1, 0, label_1f);
    ref_1c = call(KYOUSEI);
    wait(ref_1c);
    b(label_23);
  label_1f:
    bne(var_1, 1, label_23);
    ref_20 = call(FREE);
    wait(ref_20);
    b(label_23);
  label_23:
}

