function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    objCollisionLink(collision_3, coll_0, obj_1);
    objCollisionLink(collision_3, coll_1, obj_1);
    objCollisionLink(collision_3, coll_2, obj_1);
    objCollisionLink(collision_3, coll_3, obj_1);
    objCollisionLink(collision_3, coll_4, obj_1);
    objVisible(obj_1, false);
    objVisible(obj_2, false);
    objVisible(obj_3, false);
    objVisible(obj_4, false);
    objVisible(obj_5, false);
    objVisible(obj_6, false);
    objVisible(obj_7, false);
    objVisible(obj_8, false);
    objVisible(obj_9, false);
    objVisible(obj_a, false);
    objVisible(obj_b, false);
    objVisible(obj_c, false);
    objVisible(obj_d, false);
    objVisible(obj_26, false);
    bitGet(var_0, EBIT_E0085);
    bne(var_0, 0, label_19);
    call(KYOSEI);
    b(label_1c);
  label_19:
    bne(var_0, 1, label_1c);
    call(FREE);
    b(label_1c);
  label_1c:
}

