    screenFadeInner(rgb(255,255,255), 2, false);
    screenFadeOuter(rgb(255,255,255), 2, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    ref_1ad = dialogAlloc();
    ref_1ae = msgShow(msg_30);
/***************************************
Ｔｏ[tab]Ｂｅ[tab]Ｃｏｎｔｉｎｕｅｄ…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_1ae);
    dialogFree(ref_1ad);
    delayClear();
    delayWait(120);
    bitClear(bit_c6d);
    bitClear(bit_c6e);
    bitClear(bit_c6f);
    bitClear(bit_c70);
    bitSet(bit_c64);
    partyHealthRestore(tatsuya);
    partySPRestore(tatsuya);
    partyStatusClear(tatsuya);
    bitClear(bit_c63);
    eventLoad(event_67);
}

function TATUYA()
{
    unitAnimationPlay(tatsuya, animation_1, 1);
    unitMove3d(tatsuya, 335, 0, var_7ffffed4, 10, 0);
    unitWait(tatsuya);
    unitFace_2(tatsuya, south);
    sndMusicPlay(sound_321e, 127);
    unitAnimationPlay(tatsuya, animation_5, 1);
}
