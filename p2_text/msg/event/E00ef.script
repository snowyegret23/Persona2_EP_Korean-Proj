function START()
{
    sndMusicPlay(sound_4067, 127);
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    cameraSet(northwest, 330, 0, -270);
    objAnimRotate(obj_17, 0, 360, 0, 1800, 1);
    objAnimRotate(obj_4c, 0, 360, 0, 900, 1);
    screenColorAdjust(0.48828125, 0.48828125, 0.48828125);
    ref_7 = spriteLoad(sprite_12a);
    wait(ref_7);
    ref_9 = spriteLoad(sprite_18);
    wait(ref_9);
    ref_b = spriteLoad(sprite_1a);
    wait(ref_b);
    ref_d = spriteLoad(sprite_19);
    wait(ref_d);
    ref_f = spriteLoad(sprite_3f);
    wait(ref_f);
    ref_11 = spriteLoad(sprite_12d);
    wait(ref_11);
    unitSpawn(unit_73, sprite_12a, 500, 0, -530, south, none);
    unitSpawn(tatsuya, sprite_1a, 360, 0, -490, south, none);
    unitSpawn(unit_13, sprite_3f, 335, 0, -170, north, none);
    unitAnimationPlay(unit_13, animation_23, 1);
    unitColorAdjust(unit_73, 0.5, 0.5, 0.5);
    unitColorAdjust(tatsuya, 0.5, 0.5, 0.5);
    unitColorAdjust(unit_13, 0.5, 0.5, 0.5);
    ref_1a = efctDummy(effect_18);
    ref_1b = efctLoad(effect_18);
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    screenFadeInner(rgb(0,0,0), 4, true);
    screenFadeOuter(rgb(0,0,0), 4, true);
    screenEffectUnknown();
    screenFadeWait(inner);
    screenFadeWait(outer);
    delayClear();
    delayWait(60);
    call(TATUYA);
    wait(ref_1a);
    wait(ref_1b);
    sndMusicPlay(sound_30f1, 127);
    efctPlay(effect_18, efct_0, 335, -50, -170, 335, -50, -170, false);
    unitSpriteEffect(unit_13, 2);
    ref_2a = unitColor(unit_13, rgb(0,0,0), 60);
    wait(ref_2a);
    unitDespawn(unit_13, fade);
    unitSpriteClear(unit_13);
    unitSpriteSet(unit_13, sprite_12d);
    unitSpriteEffect(unit_13, 0);
    unitColorAdjust(unit_13, 0.5, 0.5, 0.5);
    ref_31 = unitColor(unit_13, rgb(128,128,128), 60);
    wait(ref_31);
    delayClear();
    delayWait(60);
    unitSpriteClear(tatsuya);
    unitSpriteSet(tatsuya, sprite_19);
    unitAnimationPlay(tatsuya, animation_7, 1);
    unitColorAdjust(tatsuya, 0.5, 0.5, 0.5);
    delayClear();
    delayWait(120);
    unitSpriteClear(tatsuya);
    unitSpriteSet(tatsuya, sprite_18);
    unitAnimationPlay(tatsuya, animation_0, 1);
    unitColorAdjust(tatsuya, 0.5, 0.5, 0.5);
    delayClear();
    delayWait(30);
    unitWait(tatsuya);
    unitAnimationPlay(tatsuya, animation_6, 1);
    delayClear();
    delayWait(30);
    ref_45 = dialogAlloc();
    ref_46 = msgShow(msg_0);
/***************************************
焦げ臭い煙が充満するフロアの中央に佇み、
[tatsuya]君は肩を落としてスプリンクラー
から噴き出す水に打たれていた。
[wait][clear]
***************************************/
    wait(ref_46);
    ref_48 = msgShow(msg_1);
/***************************************
目の前の床に突き刺さった須藤の刀が、墓標を思わせた。
雨の中、遠い昔に失った恋人を偲ぶ孤独な影法師。
孤影…[tab]そんな題名の絵画を切り取ったかのような、
寂寞とした姿だ。
[wait][clear]
***************************************/
    wait(ref_48);
    ref_4a = msgShow(msg_2);
/***************************************
先ほど鎮間見せた激情は夢だったのかもしれない。
炎は既に消えていたが、火災報知機は鳴らなかった。
設置していないか切っているのだろう。消防法違反だ。
[wait][clear]
***************************************/
    wait(ref_4a);
    ref_4c = msgShow(msg_3);
/***************************************
須藤は逃げた。
[tatsuya]君の木刀が顔面を突き割る寸前、
空間に開いた丸い闇の中に、
吸い込まれるように掻き消えた。
[wait][clear]
***************************************/
    wait(ref_4c);
    ref_4e = msgShow(msg_4);
/***************************************
それからずっと、[tatsuya]君は立ち尽くしていた。
私もただ、彼を見ていた。
頭の先から爪先までびしょ濡れだ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_4e);
    dialogFree(ref_45);
    cameraMoveTo(350, 0, -250, 60);
    unitFace(tatsuya, south);
    unitMove(tatsuya, 335, -200, face_south, medium);
    unitWait(tatsuya);
    unitAnimationPlay(tatsuya, animation_14, 1);
    delayClear();
    delayWait(60);
    sndMusicPlay(sound_3135, 127);
    unitDespawn(unit_13, none);
    delayClear();
    delayWait(60);
    unitAnimationPlay(tatsuya, animation_6, 1);
    unitFace(unit_73, east);
    ref_5f = unitMove(unit_73, 335, -530, face_north, medium);
    unitAnimationPlay(unit_73, animation_5, 1);
    wait(ref_5f);
    unitMove(unit_73, 335, -300, face_south, medium);
    unitAnimationPlay(unit_73, animation_5, 1);
    ref_64 = dialogAlloc();
    ref_65 = msgShow(msg_5);
/***************************************
やがて彼は、俯いたまま須藤の残した刀を引き抜くと、
ボソっと呟いた。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_65);
    dialogFree(ref_64);
    ref_69 = bustupLoad(bustup_15);
    bustupWait(ref_69);
    ref_6b = bustupAlloc(ref_69, left, rgb(0,0,0));
    bustupFade(ref_6b, rgb(128,0,0), 30);
    ref_6d = dialogAlloc();
    ref_6e = msgShow(msg_6);
/***************************************
[color(yellow)][tatsuya][color(white)]
[tab]弟さんの名前は…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_6e);
    dialogFree(ref_6d);
    ref_72 = bustupFade(ref_6b, rgb(0,0,0), 10);
    bustupWait(ref_72);
    bustupFree(ref_6b);
    unitAnimationPlay(unit_73, animation_3, 1);
    unitWait(unit_73);
    delayClear();
    delayWait(60);
    unitAnimationPlay(unit_73, animation_0, 1);
    unitWait(unit_73);
