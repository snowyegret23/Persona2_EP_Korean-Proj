function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    levelFootstepSet(sfx_10);
    bitClear(DBIT_NYAL_KYOUMEI2);
    objVisible(obj_c, false);
    objVisible(obj_d, false);
    objVisible(obj_9, false);
    objVisible(obj_a, false);
    objVisible(obj_b, false);
    ref_9 = todLoad(tod_15);
    wait(ref_9);
    todRun(tod_15, 1);
    objAnimRotate(obj_0, 0, 360, 0, 2400, 1);
    envTriggerSet(warp1, 131, 2, line, coll_0);
    envTriggerSet(warp2, 56, 2, line, coll_3);
    ref_f = spriteLoad(sprite_0);
    wait(ref_f);
    ref_11 = spriteLoad(sprite_6);
    wait(ref_11);
    ref_13 = spriteLoad(sprite_d);
    wait(ref_13);
    ref_15 = spriteLoad(sprite_13);
    wait(ref_15);
    ref_17 = spriteLoad(sprite_18);
    wait(ref_17);
    bitGet(var_0, EBIT_E00C3);
    bne(var_0, 0, label_1c);
    b(label_25);
  label_1c:
    bne(var_0, 1, label_25);
    cameraSetNorth(south);
    cameraSet(southeast, 1399, 0, -2190);
    ref_1f = spriteLoad(sprite_2);
    wait(ref_1f);
    playerInit(south);
    call(FREEBOX);
    b(label_3b);
    b(label_25);
  label_25:
    ref_25 = sndLoad(sound_3010);
    wait(ref_25);
    sndMusicPlay(sound_3010, 127);
    bitGet(var_0, EBIT_TOMERU);
    bne(var_0, 0, label_38);
    bitGet(var_0, EBIT_ANATA);
    bne(var_0, 0, label_34);
    bitGet(var_0, EBIT_UTU);
    bne(var_0, 0, label_30);
    call(SEIKAI);
    b(label_33);
  label_30:
    bne(var_0, 1, label_33);
    call(SITTPAI);
    b(label_33);
  label_33:
    b(label_37);
  label_34:
    bne(var_0, 1, label_37);
    call(SITTPAI);
    b(label_37);
  label_37:
    b(label_3b);
  label_38:
    bne(var_0, 1, label_3b);
    call(SEIKAI);
    b(label_3b);
  label_3b:
}

function FREEBOX()
{
    cameraSetNorth(south);
    sndIdGet(var_0);
    bne(var_0, -1, label_43);
    ref_3f = sndLoad(sound_1260);
    wait(ref_3f);
    sndMusicPlay(sound_1260, 90);
    b(label_45);
  label_43:
    sndVolumeFadeTo(var_0, 90, 60);
    b(label_45);
  label_45:
    sndUnkCF(90);
    unitSpawn(ulala, sprite_6, 1341, 0, -1766, south, none);
    unitTriggerSet(ulala, URARABOX, 255, 1);
    unitSpawn(baofu, sprite_13, 1503, 0, -1694, south, none);
    unitTriggerSet(baofu, PAOBOX, 255, 1);
    unitSpawn(tatsuya, sprite_18, 1391, 0, -1493, south, none);
    unitTriggerSet(tatsuya, TATUYABOX, 255, 1);
    unitSpawn(katsuya, sprite_d, 1618, 0, -1506, east, none);
    unitTriggerSet(katsuya, KATUYABOX, 255, 1);
    unitAnimationPlay(ulala, animation_a, 1);
    unitAnimationPlay(katsuya, animation_a, 1);
    unitAnimationPlay(baofu, animation_a, 1);
    unitAnimationPlay(tatsuya, animation_a, 1);
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 5, true);
    screenFadeOuter(rgb(0,0,0), 5, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

function URARABOX()
{
    controlDisable();
    unitFacePlayer(ulala);
    ref_5b = bustupLoad(bustup_1a);
    bustupWait(ref_5b);
    ref_5d = bustupAlloc(ref_5b, left, rgb(0,0,0));
    bustupFade(ref_5d, rgb(128,0,0), 30);
    ref_5f = dialogAlloc();
    ref_60 = msgShow(msg_0);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]これが…１８歳の子が背負う運命だっての…？
[tab]惨すぎるよ…
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2e, 1);
    wait(ref_60);
    unitAnimationPlay(ulala, animation_a, 1);
    dialogFree(ref_5f);
    ref_65 = bustupFade(ref_5d, rgb(0,0,0), 10);
    bustupWait(ref_65);
    bustupFree(ref_5d);
    unitRestoreFacing(ulala);
    controlEnable();
}

