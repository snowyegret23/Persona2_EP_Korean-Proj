    unitDespawn(npc2, fade);
    delayClear();
    delayWait(60);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 8, false);
    screenFadeOuter(rgb(255,255,255), 8, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    ref_1e6 = cameraLookAtUnit(maya, 0, 4);
    wait(ref_1e6);
    ref_1e8 = spriteLoad(sprite_2);
    wait(ref_1e8);
    unitDespawn(maya, none);
    playerInit(south);
    controlDisable();
    bitSet(EBIT_E00C3);
    bitSet(EBIT_GINKOOKITA);
    sndStop(sound_3010);
    call(FREEBOX);
}

