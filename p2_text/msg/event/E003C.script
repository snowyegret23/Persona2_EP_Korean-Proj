    unitFace(katsuya, north);
    unitSpawn(enemy1, sprite_da, 200, 0, -585, north, none);
    unitFace(enemy1, west);
    unitSpawn(enemy2, sprite_da, 120, 0, -420, north, none);
    unitPalette(enemy2, 1);
    unitFace(enemy2, west);
    unitIdleOnAll();
    unitTriggerSet(katsuya, KATUYA1, 255, 1);
    unitTriggerSet(ulala, URARA1, 255, 1);
    unitTriggerSet(baofu, PAOFU1, 255, 1);
    unitTriggerSet(enemy1, ENEMY1, 255, 1);
    unitTriggerSet(enemy2, ENEMY2, 255, 1);
    envTriggerSet(EXIT, 56, 1, line, coll_23);
    cameraSetNorth(north);
    cameraSet(northwest, 300, 0, -60);
    playerInit(north);
    controlDisable();
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

