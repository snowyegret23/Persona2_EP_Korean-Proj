    screenFadeOuter(rgb(0,0,0), 6, true);
    screenEffectUnknown();
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

function FREE1()
{
    unitSpawn(ulala, sprite_6, 437, 0, -332, north, none);
    unitFace(ulala, north);
    unitSpawn(baofu, sprite_13, 544, 0, -494, north, none);
