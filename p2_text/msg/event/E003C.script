    bustupWait(ref_219);
    ref_21b = bustupAlloc(ref_219, left, rgb(0,0,0));
    bustupFade(ref_21b, rgb(128,0,0), 30);
    ref_21d = dialogAlloc();
    ref_21e = msgShow(msg_16);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]相当深い根がありそうだな…あいつ。
[sync][wait][clear]
***************************************/
    unitAnimationPlay(katsuya, animation_14, 1);
    unitWait(katsuya);
    delayClear();
    delayWait(30);
    unitAnimationPlay(katsuya, animation_24, 1);
    unitWait(katsuya);
    delayClear();
    delayWait(20);
    sync();
    wait(ref_21e);
    dialogFree(ref_21d);
    ref_22a = bustupFade(ref_21b, rgb(0,0,0), 10);
    bustupWait(ref_22a);
    bustupFree(ref_21b);
    unitAnimationPlay(katsuya, animation_0, 1);
    unitWait(katsuya);
    unitRestoreFacing(katsuya);
    controlEnable();
}

function URARAMOVE()
{
    unitMove(ulala, 515, -80, face_west, fast);
    unitWait(ulala);
    unitMove(ulala, 515, -565, face_north, fast);
    unitWait(ulala);
    unitFace(ulala, east);
    unitWait(ulala);
    unitAnimationHold(ulala, animation_21, 60);
    unitWait(ulala);
    unitAnimationPlay(ulala, animation_0, 1);
    unitWait(ulala);
}

function KATUYAMOVE()
{
    unitMove(katsuya, 515, -80, face_west, fast);
    unitWait(katsuya);
    unitMove(katsuya, 515, -465, face_north, fast);
    unitWait(katsuya);
    unitFace(katsuya, east);
    unitWait(katsuya);
    unitAnimationHold(katsuya, animation_21, 60);
    unitWait(katsuya);
    unitAnimationPlay(katsuya, animation_0, 1);
    unitWait(katsuya);
}

function MAYAMOVE()
{
    unitMove(maya, 450, -200, face_west, fast);
    unitWait(maya);
    unitMove(maya, 450, -400, face_north, fast);
    unitWait(maya);
    unitFace(maya, east);
    unitWait(maya);
    unitAnimationHold(maya, animation_21, 60);
    unitWait(maya);
    unitAnimationPlay(maya, animation_1, 1);
    unitWait(maya);
}

function EXIT()
{
    controlDisable();
    objAnimRotate(obj_5, 0, -80, 0, 60, 0);
    sndMusicPlay(sound_313c, 127);
    objAnimWait(obj_5);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    cameraSetNorth(north);
    bitGet(var_0, MBIT_KE_ZODI2F);
    bne(var_0, 0, label_262);
    dngLoad2(zodiac1-7);
    b(label_265);
  label_262:
    bne(var_0, 1, label_265);
    dngLoad2(zodiac2-14);
    b(label_265);
  label_265:
}

function CHECK()
{
    controlDisable();
    ref_267 = dialogAlloc();
    ref_268 = msgShow(msg_17);
/***************************************
[color(yellow)]チェック用[color(white)]
[tab]合言葉を入手しました。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_268);
    dialogFree(ref_267);
    bitSet(EBIT_E0040);
    controlEnable();
}

