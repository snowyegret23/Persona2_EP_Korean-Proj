    unitAnimationHold(maya, animation_21, -1);
    unitAnimationHold(katsuya, animation_21, -1);
    unitAnimationHold(ulala, animation_21, -1);
    wait(ref_6c);
    delayClear();
    delayWait(30);
    unitAnimationStop(maya);
    unitAnimationStop(katsuya);
    unitAnimationStop(ulala);
    ref_78 = cameraRotateTo(7, 1);
    cameraMoveTo(277, 0, -376, 1);
    call(URARAMOVE);
    call(KATUYAMOVE);
