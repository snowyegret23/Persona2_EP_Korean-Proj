    wait(ref_62);
    dialogFree(ref_61);
    ref_66 = dialogAlloc();
    ref_67 = msgShow(msg_2);
/***************************************
[color(yellow)]マフィアの声[color(white)]
[tab]干什么！？[tab]不行！
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_67);
