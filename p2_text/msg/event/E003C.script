    unitFace(ulala, north);
    unitSpawn(baofu, sprite_13, 325, 0, -160, north, none);
    unitFace(baofu, east);
    unitSpawn(katsuya, sprite_d, 230, 0, -80, north, none);
    unitFace(katsuya, west);
    unitSpawn(enemy1, sprite_da, 200, 0, -585, north, none);
    unitFace(enemy1, east);
    unitAnimationPlay(enemy1, animation_16, 1);
    unitWait(enemy1);
    unitAnimationStop(enemy1);
    unitSpawn(enemy2, sprite_da, 120, 0, -420, north, none);
    unitPalette(enemy2, 1);
    unitFace(enemy2, west);
