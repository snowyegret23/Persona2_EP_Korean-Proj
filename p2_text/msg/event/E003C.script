function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    levelFootstepSet(sfx_11);
    sndIdGet(var_0);
    bne(var_0, -1, label_6);
    b(label_8);
  label_6:
    sndVolumeFadeTo(var_0, 90, 60);
    b(label_8);
  label_8:
    sndUnkCF(90);
    cameraSet(northeast, 1220, 0, -250);
    ref_a = spriteLoad(sprite_0);
    wait(ref_a);
    ref_c = spriteLoad(sprite_2);
    wait(ref_c);
    ref_e = spriteLoad(sprite_6);
    wait(ref_e);
    ref_10 = spriteLoad(sprite_d);
    wait(ref_10);
    ref_12 = spriteLoad(sprite_13);
    wait(ref_12);
    ref_14 = spriteLoad(sprite_da);
    wait(ref_14);
    bitGet(var_1, EBIT_E0040);
    bez(var_1, label_1d);
    bitGet(var_1, EBIT_HANGOROSI);
    bez(var_1, label_20);
    ref_1a = call(FREE2);
    wait(ref_1a);
    b(label_22);
  label_1d:
    ref_1d = call(FREE1);
    wait(ref_1d);
    b(label_22);
  label_20:
    ref_20 = call(KYOUSEI);
    wait(ref_20);
  label_22:
}

function KYOUSEI()
{
    cameraSet(south, 350, 0, -240);
    unitIdleOffAll();
    unitSpawn(maya, sprite_0, 200, 0, -200, north, none);
