    ref_54 = bustupFade(ref_45, rgb(0,0,0), 10);
    bustupWait(ref_54);
    bustupFree(ref_45);
    unitMove(baofu, 490, -165, face_west, fast);
    unitWait(baofu);
    unitMove(baofu, 490, -500, face_north, fast);
    unitWait(baofu);
    unitMove(baofu, 340, -500, face_east, fast);
    unitWait(baofu);
    unitFace(baofu, east);
    unitWait(baofu);
    delayClear();
    delayWait(60);
    ref_61 = dialogAlloc();
    ref_62 = msgShow(msg_1);
/***************************************
[color(yellow)]パオフゥの声[color(white)]
[tab]你坦白吧…我生气了。
[sync][wait][clear]
***************************************/
