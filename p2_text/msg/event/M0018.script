    unitAnimationPlay(shopkeeper, animation_6, 1);
    ref_197 = msgShow(msg_17);
/***************************************
[color(yellow)]アルバイター[color(white)]
[tab]なっ、なんでござる！？[tab]この胸の高鳴りは…
[tab]…何か…只ならぬ縁を感じるでござる。
[tab]ならば、拙者も誠意を持って、お答えせねば！
[wait][clear]
***************************************/
    wait(ref_197);
    unitAnimationPlay(shopkeeper, animation_0, 1);
    dialogFree(ref_195);
    ref_19b = bustupFade(ref_193, rgb(0,0,0), 10);
    bustupWait(ref_19b);
    bustupFree(ref_193);
  label_19e:
    unitFacePlayer(shopkeeper);
    choiceSetResult(2);
