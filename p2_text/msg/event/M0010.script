    wait(ref_91);
    b(label_9a);
  label_95:
    bne(var_0, 1, label_9a);
    ref_96 = msgShow(msg_4);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]南条君、可哀相だよね。
[tab]あれ、帝王学っていうのかな？
[tab]将来の為とはいえ、何もあんな時までねぇ？
[wait][clear]
***************************************/
