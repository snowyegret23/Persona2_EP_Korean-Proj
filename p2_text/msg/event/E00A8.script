function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    ref_2 = spriteLoad(sprite_0);
    wait(ref_2);
    ref_4 = spriteLoad(sprite_2);
    wait(ref_4);
    unitSpawn(maya, sprite_0, 600, 0, -184, north, none);
    unitFace(maya, north);
    cameraSet(north, 600, 0, -184);
    playerInit(west);
    controlDisable();
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    unitIdleOnAll();
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}
