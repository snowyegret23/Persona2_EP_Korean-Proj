    sndWaitStart();
    unitAnimationHold(katsuya, animation_5, -1);
    delayClear();
    delayWait(30);
    sndMusicPlay(sound_30f0, 127);
    wait(ref_16b);
    sync();
    wait(ref_16a);
    dialogFree(ref_169);
    ref_175 = bustupFade(ref_167, rgb(0,0,0), 10);
    bustupWait(ref_175);
    bustupFree(ref_167);
}
