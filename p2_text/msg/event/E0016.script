function PAOFU_TAIJO()
{
    unitMove(baofu, 400, -850, face_north, fast);
    unitWait(baofu);
    unitFace_2(ulala, north);
    unitAnimationPlay(ulala, animation_0, 1);
    unitAnimationPlay(katsuya, animation_a, 1);
    delayClear();
    delayWait(30);
    unitAnimationPlay(baofu, animation_15, 1);
    unitWait(baofu);
    sndMusicPlay(sound_31c8, 127);
    ref_158 = objAnimRotate(obj_3, 0, -70, 0, 30, 0);
    wait(ref_158);
    unitMove(baofu, 400, -930, despawn, fast);
    unitWait(baofu);
    sndMusicPlay(sound_31c9, 127);
    ref_15d = objAnimRotate(obj_3, 0, 70, 0, 30, 0);
    wait(ref_15d);
}

function SOUND()
{
    sndVolumeFadeOff(var_a, 120);
    delayClear();
    delayWait(90);
    sndMusicPlay(sound_301d, 127);
}

function KATUYA_KOGEKI()
{
