function DOORBOX()
{
    controlDisable();
    sndMusicPlay(sound_3074, 127);
    objAnimRotate(obj_10, 0, 70, 0, 30, 0);
    objAnimWait(obj_10);
    call(GOOUT);
}

function GOOUT()
{
    bitClear(MBIT_EXITBIT);
    mapLoad(rengedai, 0, 0);
}

function warp1()
{
    call(DOORBOX);
}

