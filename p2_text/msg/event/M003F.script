function DOORBOX()
{
    controlDisable();
    sndMusicPlay(sound_3084, 127);
    objAnimRotate(obj_3a, 0, -7, 0, 30, 0);
    objAnimRotate(obj_3b, 0, 7, 0, 30, 0);
    objAnimWait(obj_3a);
    objAnimWait(obj_3b);
    call(GOOUT);
}

function warp1()
{
    call(DOORBOX);
}

function GOOUT()
{
    bitClear(MBIT_EXITBIT);
    mapLoad(rengedai, 0, 0);
}

function HA_SHOP_EXPLAIN_0()
{
    choiceSetResult(3);
    ref_7ab = dialogChoiceAlloc();
    ref_7ac = msgShow(msg_138);
/***************************************
[color(yellow)]ジュエリーデザイナー[color(white)]
[tab]何について聞きたいんだ？
[choice(3)][if_all(MBIT_KE_JEWDEVE)]開発依頼
売買
やめる
[end_choice][clear]
***************************************/
    wait(ref_7ac);
    dialogFree(ref_7ab);
    choiceGetResult(var_0);
