    ref_e3 = bustupAlloc(ref_e1, left, rgb(0,0,0));
    bustupFade(ref_e3, rgb(128,0,0), 30);
    ref_e5 = dialogAlloc();
    ref_e6 = msgShow(msg_7);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]な～んかみんな、好き勝手言ってるね。
[tab]こんな状況だから、ホンネが出てるのかも？
[wait][clear]
***************************************/
