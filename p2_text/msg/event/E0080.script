    ref_e5 = dialogAlloc();
    ref_e6 = msgShow(msg_5);
/***************************************
[color(yellow)]パオフゥ[color(white)]
[tab]ここで、悪巧みの算段をしてやがったみてぇだな…
[tab]待ってろ…竜蔵…
[sync][wait][clear]
***************************************/
    unitAnimationPlay(baofu, animation_2d, 1);
    delayClear();
    delayWait(60);
    sync();
    wait(ref_e6);
    dialogFree(ref_e5);
    ref_ed = bustupFade(ref_e3, rgb(0,0,0), 10);
