    controlEnable();
}

function URARA()
{
    controlDisable();
    unitFacePlayer(ulala);
    ref_f6 = bustupLoad(bustup_1f);
    bustupWait(ref_f6);
    ref_f8 = bustupAlloc(ref_f6, left, rgb(0,0,0));
    bustupFade(ref_f8, rgb(128,0,0), 30);
    ref_fa = dialogAlloc();
    ref_fb = msgShow(msg_6);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]マーヤ、約束したお見合いパーティの事憶えてる？
[tab]あれ、船上パーティだったんだよねぇ…
[sync][wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2d, 1);
    delayClear();
    delayWait(60);
    sync();
    wait(ref_fb);
    ref_101 = msgShow(msg_7);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]船は船でも、まさかこんな船に乗ることになる
[tab]なんて、思ってもなかったわ…
[sync][wait][clear]
***************************************/
    delayClear();
    delayWait(30);
    unitAnimationPlay(ulala, animation_1d, 1);
    unitWait(ulala);
    delayClear();
    delayWait(10);
    sync();
    wait(ref_101);
    dialogFree(ref_fa);
    ref_10b = bustupFade(ref_f8, rgb(0,0,0), 10);
    bustupWait(ref_10b);
    bustupFree(ref_f8);
    unitAnimationPlay(ulala, animation_a, 1);
    unitRestoreFacing(ulala);
    controlEnable();
}

