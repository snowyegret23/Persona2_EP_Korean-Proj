function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    levelFootstepSet(sfx_1a);
    sndIdGet(var_0);
    bne(var_0, -1, label_6);
    b(label_8);
  label_6:
    sndVolumeFadeTo(var_0, 90, 60);
    b(label_8);
  label_8:
    sndUnkCF(90);
    ref_9 = spriteLoad(sprite_0);
    wait(ref_9);
    ref_b = spriteLoad(sprite_2);
    wait(ref_b);
    ref_d = spriteLoad(sprite_d);
    wait(ref_d);
    ref_f = spriteLoad(sprite_13);
    wait(ref_f);
    ref_11 = spriteLoad(sprite_6);
    wait(ref_11);
    ref_13 = spriteLoad(sprite_1f);
    wait(ref_13);
    ref_15 = spriteLoad(sprite_23);
    wait(ref_15);
    bitGet(var_1, EBIT_E0083);
    bne(var_1, 0, label_1c);
    ref_19 = call(KYOUSEI);
    wait(ref_19);
    b(label_20);
  label_1c:
    bne(var_1, 1, label_20);
    ref_1d = call(FREE);
    wait(ref_1d);
    b(label_20);
  label_20:
}

function KYOUSEI()
{
    cameraSet(north, 700, 0, -730);
    cameraSetNorth(south);
    unitSpawn(maya, sprite_0, 750, 0, -1000, east, none);
    unitAnimationPlay(maya, animation_10, 1);
    unitSpawn(katsuya, sprite_d, 400, 0, -500, west, none);
    unitAnimationPlay(katsuya, animation_10, 1);
    unitSpawn(baofu, sprite_13, 1000, 0, -500, north, none);
    unitAnimationPlay(baofu, animation_10, 1);
    unitSpawn(ulala, sprite_6, 400, 0, -1200, south, none);
    unitAnimationPlay(ulala, animation_10, 1);
    bitGet(var_1, MBIT_HI_NANJOTOUJO);
    bne(var_1, 0, label_30);
    unitSpawn(elly, sprite_23, 1000, 0, -1200, east, none);
    unitAnimationPlay(elly, animation_10, 1);
    b(label_34);
  label_30:
    bne(var_1, 1, label_34);
    unitSpawn(nanjo, sprite_1f, 1000, 0, -1200, east, none);
    unitAnimationPlay(nanjo, animation_10, 1);
    b(label_34);
  label_34:
    unitIdleOffAll();
    unitTriggerSet(ulala, URARA, 255, 1);
    unitTriggerSet(katsuya, KATUYA, 255, 1);
    unitTriggerSet(baofu, PAOFU, 255, 1);
    envTriggerSet(EXIT, 131, 1, line, coll_0);
    bne(var_1, 0, label_3c);
    unitTriggerSet(elly, ERI, 255, 1);
    b(label_3f);
  label_3c:
    bne(var_1, 1, label_3f);
    unitTriggerSet(nanjo, NANJO, 255, 1);
    b(label_3f);
  label_3f:
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 4, true);
    screenFadeOuter(rgb(0,0,0), 4, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    delayClear();
    delayWait(60);
    ref_46 = bustupLoad(bustup_21);
    bustupWait(ref_46);
    ref_48 = bustupAlloc(ref_46, left, rgb(0,0,0));
    bustupFade(ref_48, rgb(128,0,0), 30);
    ref_4a = dialogAlloc();
    ref_4b = msgShow(msg_0);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]これは、海底の地図のようだな…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_4b);
    dialogFree(ref_4a);
    ref_4f = bustupFade(ref_48, rgb(0,0,0), 10);
    bustupWait(ref_4f);
    bustupFree(ref_48);
    delayClear();
    delayWait(60);
    unitAnimationPlay(baofu, animation_b, 1);
    delayClear();
    delayWait(30);
    ref_57 = bustupLoad(bustup_2c);
    bustupWait(ref_57);
    ref_59 = bustupAlloc(ref_57, left, rgb(0,0,0));
    bustupFade(ref_59, rgb(128,0,0), 30);
    ref_5b = dialogAlloc();
    ref_5c = msgShow(msg_1);
/***************************************
[color(yellow)]パオフゥ[color(white)]
[tab]らしいな…
[tab]海底遺跡ってなどこだ？
[sync][wait][clear]
***************************************/
    delayClear();
    delayWait(60);
    sync();
    wait(ref_5c);
    dialogFree(ref_5b);
    ref_62 = bustupFade(ref_59, rgb(0,0,0), 10);
    bustupWait(ref_62);
    bustupFree(ref_59);
    delayClear();
    delayWait(30);
    unitAnimationHold(katsuya, animation_19, -1);
    delayClear();
    delayWait(30);
    ref_6a = bustupLoad(bustup_21);
    bustupWait(ref_6a);
    ref_6c = bustupAlloc(ref_6a, left, rgb(0,0,0));
    bustupFade(ref_6c, rgb(128,0,0), 30);
    ref_6e = dialogAlloc();
    ref_6f = msgShow(msg_2);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]丁度、天野君が立っている辺りらしい。
[sync][wait][clear]
***************************************/
    delayClear();
    delayWait(30);
    unitAnimationPlay(baofu, animation_a, 1);
    sync();
    wait(ref_6f);
    dialogFree(ref_6e);
    ref_76 = bustupFade(ref_6c, rgb(0,0,0), 10);
    bustupWait(ref_76);
    bustupFree(ref_6c);
    unitAnimationStop(katsuya);
    unitAnimationPlay(katsuya, animation_a, 1);
    delayClear();
    delayWait(30);
    ref_7d = bustupLoad(bustup_2c);
    bustupWait(ref_7d);
    ref_7f = bustupAlloc(ref_7d, left, rgb(0,0,0));
    bustupFade(ref_7f, rgb(128,0,0), 30);
    ref_81 = dialogAlloc();
    ref_82 = msgShow(msg_3);
/***************************************
[color(yellow)]パオフゥ[color(white)]
[tab]ぐずぐずしてられねぇな…急ぐぞ。
[sync][wait][clear]
***************************************/
    unitAnimationPlay(baofu, animation_d, 1);
    delayClear();
    delayWait(60);
    unitAnimationPlay(baofu, animation_a, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(baofu, animation_b, 1);
    delayClear();
    delayWait(20);
    sync();
    wait(ref_82);
    dialogFree(ref_81);
    ref_8f = bustupFade(ref_7f, rgb(0,0,0), 10);
    bustupWait(ref_8f);
    bustupFree(ref_7f);
    unitAnimationPlay(baofu, animation_a, 1);
    delayClear();
    delayWait(30);
    ref_95 = cameraLookAtUnit(maya, 0, 30);
    wait(ref_95);
    unitDespawn(maya, none);
    playerInit(southeast);
    bitSet(EBIT_E0083);
    unitIdleOn(katsuya);
    unitIdleOn(baofu);
    unitIdleOn(ulala);
    bne(var_1, 0, label_a0);
    unitIdleOn(elly);
    b(label_a3);
  label_a0:
    bne(var_1, 1, label_a3);
    unitIdleOn(nanjo);
    b(label_a3);
  label_a3:
    controlEnable();
}

function FREE()
{
    unitSpawn(katsuya, sprite_d, 700, 0, -600, south, none);
    unitAnimationPlay(katsuya, animation_a, 1);
    unitSpawn(baofu, sprite_13, 1000, 0, -850, east, none);
    unitAnimationPlay(baofu, animation_a, 1);
    unitSpawn(ulala, sprite_6, 600, 0, -1350, south, none);
    unitAnimationPlay(ulala, animation_a, 1);
    bitGet(var_1, MBIT_HI_NANJOTOUJO);
    bne(var_1, 0, label_b0);
    unitSpawn(elly, sprite_23, 350, 0, -800, west, none);
    unitAnimationPlay(elly, animation_a, 1);
    b(label_b4);
  label_b0:
    bne(var_1, 1, label_b4);
    unitSpawn(nanjo, sprite_1f, 350, 0, -800, west, none);
    unitAnimationPlay(nanjo, animation_a, 1);
    b(label_b4);
  label_b4:
    unitIdleOnAll();
    unitTriggerSet(katsuya, KATUYA, 255, 1);
    unitTriggerSet(ulala, URARA, 255, 1);
    unitTriggerSet(baofu, PAOFU, 255, 1);
    envTriggerSet(EXIT, 131, 1, line, coll_0);
    bne(var_1, 0, label_bc);
    unitTriggerSet(elly, ERI, 255, 1);
    b(label_bf);
  label_bc:
    bne(var_1, 1, label_bf);
    unitTriggerSet(nanjo, NANJO, 255, 1);
    b(label_bf);
  label_bf:
    cameraSetNorth(south);
    cameraSet(southeast, 700, 0, -1750);
    playerInit(south);
    controlDisable();
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

function KATUYA()
{
    controlDisable();
    unitFacePlayer(katsuya);
    ref_cc = bustupLoad(bustup_21);
    bustupWait(ref_cc);
    ref_ce = bustupAlloc(ref_cc, left, rgb(0,0,0));
    bustupFade(ref_ce, rgb(128,0,0), 30);
    ref_d0 = dialogAlloc();
    ref_d1 = msgShow(msg_4);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]この祠のようなもの…気にならないか。
[tab]一体、誰がその中にいた…？
[sync][wait][clear]
***************************************/
    unitAnimationPlay(katsuya, animation_2d, 1);
    delayClear();
    delayWait(60);
    sync();
    wait(ref_d1);
    dialogFree(ref_d0);
    ref_d8 = bustupFade(ref_ce, rgb(0,0,0), 10);
    bustupWait(ref_d8);
    bustupFree(ref_ce);
    unitAnimationPlay(katsuya, animation_a, 1);
    unitRestoreFacing(katsuya);
    controlEnable();
}

