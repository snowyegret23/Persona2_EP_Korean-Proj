    bustupWait(ref_7f);
    ref_81 = bustupAlloc(ref_7f, left, rgb(0,0,0));
    bustupFade(ref_81, rgb(128,0,0), 30);
    ref_83 = dialogAlloc();
    ref_84 = msgShow(msg_1);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]はぁ～これまたボロッちい神社だわ。
[tab]…おっと、こんなこと言っちゃ罰当たる？
[tab]ま、いいじゃん。どうせ罰だらけの人生だっし。
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2d, 1);
    wait(ref_84);
    unitAnimationPlay(ulala, animation_a, 1);
    dialogFree(ref_83);
    ref_89 = bustupFade(ref_81, rgb(0,0,0), 10);
    bustupWait(ref_89);
    bustupFree(ref_81);
    unitRestoreFacing(ulala);
    b(label_cf);
  label_8e:
    ref_8e = bustupLoad(bustup_1a);
    bustupWait(ref_8e);
    ref_90 = bustupAlloc(ref_8e, left, rgb(0,0,0));
    bustupFade(ref_90, rgb(128,0,0), 30);
    ref_92 = dialogAlloc();
    ref_93 = msgShow(msg_2);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]ＪＯＫＥＲ呪い…
[tab]違うよね…うん、絶対違う！
[tab]そんな事、ホントにある訳ないんだから！
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_10, 1);
    wait(ref_93);
    unitAnimationPlay(ulala, animation_a, 1);
    dialogFree(ref_92);
    ref_98 = bustupFade(ref_90, rgb(0,0,0), 10);
    bustupWait(ref_98);
    bustupFree(ref_90);
    b(label_cf);
  label_9c:
    unitFacePlayer(ulala);
    ref_9d = bustupLoad(bustup_1a);
    bustupWait(ref_9d);
    ref_9f = bustupAlloc(ref_9d, left, rgb(0,0,0));
    bustupFade(ref_9f, rgb(128,0,0), 30);
    ref_a1 = dialogAlloc();
    ref_a2 = msgShow(msg_3);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]ＪＯＫＥＲに成りかけてた時も意識はあったんだ。
[tab]誰かに操られてる感じじゃなかった。
[tab]ただ、無性に悔しくて…腹が立って…
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_6, 1);
    wait(ref_a2);
    unitAnimationPlay(ulala, animation_a, 1);
    ref_a6 = msgShow(msg_4);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]つまり…その…あれが私の本性って訳さ。
[tab]ああなっちゃ言い訳のしようもないよ。
[tab]ホント…情けないったら…
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2e, 1);
    wait(ref_a6);
    unitAnimationPlay(ulala, animation_a, 1);
    dialogFree(ref_a1);
    ref_ab = bustupFade(ref_9f, rgb(0,0,0), 10);
    bustupWait(ref_ab);
    bustupFree(ref_9f);
    unitRestoreFacing(ulala);
    b(label_cf);
  label_b0:
    unitFacePlayer(ulala);
    ref_b1 = bustupLoad(bustup_18);
    bustupWait(ref_b1);
    ref_b3 = bustupAlloc(ref_b1, left, rgb(0,0,0));
    bustupFade(ref_b3, rgb(128,0,0), 30);
    ref_b5 = dialogAlloc();
    ref_b6 = msgShow(msg_5);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]…にしても、あの南条君。
[tab]大したモンだよ、お金持ちだよ、玉の輿だよ！！
[tab]マーヤも、ああいう男狙わなきゃね！
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_30, 1);
    wait(ref_b6);
    unitAnimationPlay(ulala, animation_a, 1);
    dialogFree(ref_b5);
    ref_bb = bustupFade(ref_b3, rgb(0,0,0), 10);
    bustupWait(ref_bb);
    bustupFree(ref_b3);
    unitRestoreFacing(ulala);
    b(label_cf);
  label_c0:
    unitFacePlayer(ulala);
    ref_c1 = bustupLoad(bustup_1c);
    bustupWait(ref_c1);
    ref_c3 = bustupAlloc(ref_c1, left, rgb(0,0,0));
    bustupFade(ref_c3, rgb(128,0,0), 30);
    ref_c5 = dialogAlloc();
    ref_c6 = msgShow(msg_6);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]しっかし、大人気のワンロン占いまで
[tab]奴らの計画の一部だったなんて…
[tab]どっぷりハマッてた私ゃなんておマヌケなの…
[wait][clear]
***************************************/
