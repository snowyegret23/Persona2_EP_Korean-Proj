    ref_1ad = msgShow(msg_27);
/***************************************
[color(yellow)]猫中将ズーラ[color(white)]
[tab]このカダス・マンダラは、
[tab]旧き印たる五芝星を内包した
[tab]六芝星の構造をしておる。
[wait][clear]
***************************************/
    wait(ref_1ad);
    ref_1af = msgShow(msg_28);
/***************************************
[color(yellow)]猫中将ズーラ[color(white)]
[tab]六芝星は大宇宙、マクロコスモスを表し、
[tab]五芝星は人間というミクロコスモスの象徴なのだ。
[wait][clear]
***************************************/
    wait(ref_1af);
    end(ZURAWALK);
    unitFace(unit_58, east);
    unitAnimationPlay(unit_58, animation_0, 1);
    ref_1b4 = msgShow(msg_29);
/***************************************
[color(yellow)]猫中将ズーラ[color(white)]
[tab]その各々の頂点に悪魔たちが座す
[tab]このような塔がある。
[tab]道に迷ったら、星の頂点を目指すのだ。よいな？
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_1b4);
    dialogFree(ref_1aa);
    ref_1b8 = bustupFade(ref_1a8, rgb(0,0,0), 10);
    bustupWait(ref_1b8);
    bustupFree(ref_1a8);
    unitAnimationPlay(maya, animation_24, 1);
    unitWait(maya);
    delayClear();
    delayWait(30);
    ref_1bf = bustupLoad(bustup_1);
    bustupWait(ref_1bf);
    ref_1c1 = bustupAlloc(ref_1bf, left, rgb(0,0,0));
    bustupFade(ref_1c1, rgb(128,0,0), 30);
    ref_1c3 = dialogAlloc();
    ref_1c4 = msgShow(msg_30);
/***************************************
[color(green)]舞耶は、大体わかりましたとばかりに頷いた。[color(white)]
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_1c4);
    dialogFree(ref_1c3);
    ref_1c8 = bustupFade(ref_1c1, rgb(0,0,0), 10);
    bustupWait(ref_1c8);
    bustupFree(ref_1c1);
    unitAnimationPlay(maya, animation_a, 1);
    ref_1cc = bustupLoad(bustup_139);
    bustupWait(ref_1cc);
    ref_1ce = bustupAlloc(ref_1cc, right, rgb(0,0,0));
    bustupFade(ref_1ce, rgb(128,0,0), 30);
    ref_1d0 = dialogAlloc();
    ref_1d1 = msgShow(msg_31);
/***************************************
[color(yellow)]猫中将ズーラ[color(white)]
[tab]心のトラペゾヘドロンを所持する悪魔たちは、
[tab]みな貴様たちより遥かに強大な存在だからな。
[wait][clear]
***************************************/
    wait(ref_1d1);
    ref_1d3 = msgShow(msg_32);
/***************************************
[color(yellow)]猫中将ズーラ[color(white)]
[tab]念のため言っておくが、
[tab]記憶は上書きせず小まめに刻んでおけ。
[tab]どうなっても知らんぞ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_1d3);
    dialogFree(ref_1d0);
    ref_1d7 = bustupFade(ref_1ce, rgb(0,0,0), 10);
    bustupWait(ref_1d7);
    bustupFree(ref_1ce);
    eventFileLoad(E, 269);
}

function ZURAWALK()
{
  label_1dc:
    ref_1dc = unitMove(unit_58, 775, -840, face_north, slowest);
    unitAnimationPlay(unit_58, animation_5, 1);
    wait(ref_1dc);
    unitAnimationPlay(katsuya, animation_16, 1);
    unitAnimationPlay(unit_58, animation_3, 1);
    unitWait(unit_58);
    delayClear();
    delayWait(3);
    unitAnimationPlay(unit_58, animation_4, 1);
    unitWait(unit_58);
    delayClear();
    delayWait(3);
    unitFace(unit_58, west);
    unitAnimationPlay(unit_58, animation_1, 1);
    unitWait(unit_58);
    delayClear();
    delayWait(3);
    unitFace(unit_58, south);
    unitAnimationPlay(unit_58, animation_0, 1);
    unitWait(unit_58);
    ref_1f0 = unitMove(unit_58, 825, -760, face_south, slowest);
    unitAnimationPlay(unit_58, animation_5, 1);
    wait(ref_1f0);
    unitAnimationPlay(katsuya, animation_0, 1);
    unitAnimationPlay(unit_58, animation_3, 1);
    unitWait(unit_58);
    delayClear();
    delayWait(3);
    unitAnimationPlay(unit_58, animation_4, 1);
    unitWait(unit_58);
    delayClear();
    delayWait(3);
    unitFace(unit_58, east);
    unitAnimationPlay(unit_58, animation_1, 1);
    unitWait(unit_58);
    delayClear();
    delayWait(3);
    unitFace(unit_58, north);
    unitAnimationPlay(unit_58, animation_0, 1);
    unitWait(unit_58);
    b(label_1dc);
}
