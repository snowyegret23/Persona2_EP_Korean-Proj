でも、大統領の想いには応えられなかった。
[wait][clear]
***************************************/
    unitAnimationPlay(shopkeeper, animation_21, 1);
    wait(ref_a76);
    ref_a79 = msgShow(msg_156);
/***************************************
あの華やかなステージだけが、アタシの居場所。
偶像…それで良かった。それだけで良かった。
アタシに安住の地が無いコトはわかっていたけど、
もう硝煙に霞む世界にはいられない。それが……
[wait][clear]
***************************************/
    unitAnimationPlay(shopkeeper, animation_21, 1);
    wait(ref_a79);
    ref_a7c = msgShow(msg_157);
/***************************************
[color(yellow)]おばちゃん[color(white)]
[tab]とりあえずここまで。後は買って読んでねェ～
[tab]発行は株式会社キスメット出版。
[tab]１６００円（予）よォ～
[wait][clear]
***************************************/
    unitAnimationPlay(shopkeeper, animation_21, 1);
    wait(ref_a7c);
    unitAnimationPlay(shopkeeper, animation_0, 1);
    dialogFree(ref_a6f);
    ref_a81 = bustupFade(ref_a6d, rgb(0,0,0), 10);
    bustupWait(ref_a81);
    bustupFree(ref_a6d);
    bitSet(LBIT_0011);
    b(label_a94);
  label_a86:
    ref_a86 = bustupLoad(bustup_ec);
    bustupWait(ref_a86);
    ref_a88 = bustupAlloc(ref_a86, right, rgb(0,0,0));
    bustupFade(ref_a88, rgb(128,0,0), 30);
    ref_a8a = dialogAlloc();
    ref_a8b = msgShow(msg_158);
/***************************************
[color(yellow)]おばちゃん[color(white)]
[tab]自叙伝の続き？[tab]もうダメよォ。
[tab]ちゃんと買って読んでよねェ～
[tab]…でも、発売日は未定なのよねェ～
[wait][clear]
***************************************/
    unitAnimationPlay(shopkeeper, animation_21, 1);
    wait(ref_a8b);
    unitAnimationPlay(shopkeeper, animation_0, 1);
    dialogFree(ref_a8a);
    ref_a90 = bustupFade(ref_a88, rgb(0,0,0), 10);
    bustupWait(ref_a90);
    bustupFree(ref_a88);
    bitSet(LBIT_0012);
  label_a94:
}

