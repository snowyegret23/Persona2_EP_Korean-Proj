function DOORBOX()
{
    controlDisable();
    sndMusicPlay(sound_306d, 127);
    objAnimTranslate(obj_0, 100, 0, 0, 30);
    objAnimWait(obj_0);
    call(GOOUT);
}

function warp1()
{
    call(DOORBOX);
}

function GOOUT()
{
    bitClear(MBIT_EXITBIT);
    mapLoad(rengedai, 0, 0);
}

function HA_SHOP_EXPLAIN_0()
{
    choiceSetResult(2);
    ref_b0a = dialogChoiceAlloc();
    ref_b0b = msgShow(msg_172);
/***************************************
[color(yellow)]おばちゃん[color(white)]
[tab]何を聞きたいのかしらぁ～？
[choice(3)][if_all(MBIT_KE_SIRAMAN)]人捜し
食事
やめる
[end_choice][clear]
***************************************/
    wait(ref_b0b);
    dialogFree(ref_b0a);
    choiceGetResult(var_0);
    bne(var_0, 0, label_b15);
    ref_b10 = dialogAlloc();
    ref_b11 = msgShow(msg_173);
/***************************************
[color(yellow)]おばちゃん[color(white)]
[tab]「人捜し」の説明ね～。
[tab]ウチの店で「人捜し」を選んだら
[tab]人捜しの依頼を受けてもらうよォ～。
[wait][clear][color(yellow)]おばちゃん[color(white)]
[tab]人捜しってェ～のは、依頼された「尋ね人」を捜すことよ。
[tab]まず、依頼のリストからどれを受けるか選んでねェ～。
[wait][clear][color(yellow)]おばちゃん[color(white)]
[tab]リストには「尋ね人」の名前と情報、あと受ける際に
[tab]払ってもらう請負料が書いてあるわよォ～。
[tab]でェ～、引き受けたら捜索開始ねェ～。
[wait][clear][color(yellow)]おばちゃん[color(white)]
[tab]捜す方法としては、とにかく人に話しかけることねェ～。
[tab]それでェ～、情報と照らし合わせてこれだ！という
[tab]人がいたら、もう一度話しかけてみるのよォ～！
[wait][clear][color(yellow)]おばちゃん[color(white)]
[tab]捜している本人だったら、用件を聞き返してくるよォ～。
[tab]そこで、相手の名前を言い当てるのよォ～。
[tab]当たっていればめでたく捜索終了ねェ。
[wait][clear][color(yellow)]おばちゃん[color(white)]
[tab]ここへ戻ってくれば、報酬をあげるわ～。
[tab]ひと～つ覚えておいてほしいのは、引き受けた依頼を
[tab]終わらせるまで、次の依頼は受けさせないわよォ～。
[wait][clear][color(yellow)]おばちゃん[color(white)]
[tab]そ～んないい加減、許さないからねェ～！
[wait][clear]
***************************************/
    wait(ref_b11);
    dialogFree(ref_b10);
    b(label_b1d);
  label_b15:
    bne(var_0, 1, label_b1b);
    ref_b16 = dialogAlloc();
    ref_b17 = msgShow(msg_174);
/***************************************
[color(yellow)]おばちゃん[color(white)]
[tab]「食事」の説明ねェ～。
[tab]ウチの店で「食事をする」を選ぶと
[tab]食事をすることができるわ～。
[wait][clear][color(yellow)]おばちゃん[color(white)]
[tab]食事には、一時的に能力を高める効果があるわよォ～。
[tab]効果はメニューによって違うから、色々食べて
[tab]確認してみてねェ～。
[wait][clear][color(yellow)]おばちゃん[color(white)]
[tab]あと、一度食事を取るとその効果が切れるまで
[tab]つぎの食事はできないわよ～。
[tab]こ～んなとこかしら～。
[wait][clear]
***************************************/
    wait(ref_b17);
    dialogFree(ref_b16);
    b(label_b1d);
  label_b1b:
    bne(var_0, 2, label_b1d);
    b(label_b1d);
  label_b1d:
}

