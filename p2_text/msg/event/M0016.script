    ref_5f7 = bustupAlloc(ref_5f5, right, rgb(0,0,0));
    bustupFade(ref_5f7, rgb(128,0,0), 30);
    ref_5f9 = dialogAlloc();
    ref_5fa = msgShow(msg_87);
/***************************************
[color(yellow)]トニー[color(white)]
[tab]ウーン？[tab]キミの持ち物で買い取れるものは
[tab]無さそうだヨ？[wait][clear]
***************************************/
