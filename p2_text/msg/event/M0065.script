function START()
{
    screenHorizontalFadeUnk122();
    delayClear();
    delayWait(60);
    op_107();
    levelFootstepSet(sfx_10);
    cameraSet(northwest, 1041, 0, -907);
    objVisible(obj_29, false);
    objVisible(obj_2a, false);
    ref_8 = todLoad(tod_e);
    wait(ref_8);
    todRun(tod_e, 1);
    ref_b = spriteLoad(sprite_a4);
    wait(ref_b);
    unitSpawn(shopkeeper, sprite_a4, 1088, -60, -968, north, none);
    ref_e = spriteLoad(sprite_a6);
    wait(ref_e);
    unitSpawn(npc1, sprite_a6, 1269, -60, -695, north, none);
    ref_11 = spriteLoad(sprite_a5);
    wait(ref_11);
    unitSpawn(npc2, sprite_a5, 1028, -60, -740, north, none);
    ref_14 = spriteLoad(sprite_a7);
    wait(ref_14);
    unitSpawn(unit_76, sprite_a7, 750, -60, -1250, north, none);
    ref_17 = spriteLoad(sprite_0);
    wait(ref_17);
    unitSpawn(maya, sprite_0, 1092, 0, -1103, south, none);
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 2, true);
    screenFadeOuter(rgb(0,0,0), 2, true);
    bitGet(var_0, bit_c9d);
    bne(var_0, 0, label_23);
    call(NEW_SCENARIO_FIRST);
    b(label_38);
  label_23:
    bne(var_0, 1, label_38);
    bitGet(var_1, bit_c9e);
    bne(var_1, 0, label_2e);
    bitGet(var_2, bit_c9f);
    bne(var_2, 0, label_2a);
    call(NO_CLEAR_1_2);
    b(label_2d);
  label_2a:
    bne(var_2, 1, label_2d);
    call(NO_CLEAR_3);
    b(label_2d);
  label_2d:
    b(label_37);
  label_2e:
    bne(var_1, 1, label_37);
    bitGet(var_2, bit_c9f);
    bne(var_2, 0, label_33);
    call(CLEAR_1_2);
    b(label_36);
  label_33:
    bne(var_2, 1, label_36);
    call(CLEAR_3);
    b(label_36);
  label_36:
    b(label_37);
  label_37:
    b(label_38);
  label_38:
}

function NEW_SCENARIO_FIRST()
{
    sndMusicPlay(sound_3001, 127);
    unitSpawn(unit_76, sprite_a7, 890, -60, -1218, north, none);
    unitFace(unit_76, south);
    unitAnimationPlay(unit_76, animation_4, 1);
    unitAnimationPlay(shopkeeper, animation_1, 1);
    unitAnimationPlay(npc1, animation_7, 1);
    unitAnimationPlay(npc2, animation_0, 1);
    delayClear();
    delayWait(10);
    call(ESIKUBI);
    call(IGOKUBI);
    delayClear();
    delayWait(60);
    unitAnimationPlay(shopkeeper, animation_7, 1);
    delayClear();
    delayWait(30);
    ref_49 = bustupLoad(bustup_e0);
    bustupWait(ref_49);
    ref_4b = bustupAlloc(ref_49, right, rgb(0,0,0));
    bustupFade(ref_4b, rgb(128,0,0), 30);
    ref_4d = dialogAlloc();
    ref_4e = msgShow(msg_0);
/***************************************
[color(yellow)]イゴール[color(white)]
[tab]おや…
[tab]こんな所に、どなたかの記憶のカケラが…
[wait][clear][color(yellow)]イゴール[color(white)]
[tab]これは…[tab]どうやら、[suou][tab][tatsuya]様の
[tab]物のようでございますな。
[wait][clear][color(yellow)]イゴール[color(white)]
[tab][tatsuya]様は、あなたの知らないことを
[tab]たくさん知っていらっしゃるご様子。
[wait][clear][color(yellow)]イゴール[color(white)]
[tab]この記憶のカケラを覗き見ることで、
[tab]それを知ることができましょう。
[wait][clear][color(yellow)]イゴール[color(white)]
[tab]しかしその中には、あなたがまだ知るべきではないことが
[tab]あるやもしれません。
[wait][clear][color(yellow)]イゴール[color(white)]
[tab]覚悟を持って、覗き見ることをお奨めいたしますぞ。
[wait][clear]
***************************************/
    unitAnimationPlay(shopkeeper, animation_8, 1);
    delayClear();
    delayWait(15);
    unitAnimationPlay(shopkeeper, animation_9, 1);
    delayClear();
    delayWait(20);
    unitAnimationPlay(shopkeeper, animation_8, 1);
    delayClear();
    delayWait(10);
    unitAnimationPlay(shopkeeper, animation_a, 1);
    delayClear();
    delayWait(30);
    unitAnimationPlay(shopkeeper, animation_b, 1);
    sync();
    wait(ref_4e);
    dialogFree(ref_4d);
    ref_5f = bustupFade(ref_4b, rgb(0,0,0), 10);
    bustupWait(ref_5f);
    bustupFree(ref_4b);
    unitAnimationPlay(shopkeeper, animation_0, 1);
    bitSet(bit_c9d);
    bitGet(var_0, EBIT_E0077);
    bne(var_0, 0, label_68);
    eventFileLoad(M, 8);
    b(label_6b);
  label_68:
    bne(var_0, 1, label_6b);
    eventFileLoad(M, 9);
    b(label_6b);
  label_6b:
    ref_6b = screenHorizontalFadeOut();
    wait(ref_6b);
}

