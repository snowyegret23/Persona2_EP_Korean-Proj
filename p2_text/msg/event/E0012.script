function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    dngRoomSet(10);
    dngRoomDraw();
    ref_4 = spriteLoad(sprite_0);
    wait(ref_4);
    ref_6 = spriteLoad(sprite_2);
    wait(ref_6);
    ref_8 = spriteLoad(sprite_3);
    wait(ref_8);
    ref_a = spriteLoad(sprite_6);
    wait(ref_a);
    ref_c = spriteLoad(sprite_d);
    wait(ref_c);
    ref_e = spriteLoad(sprite_13);
    wait(ref_e);
    ref_10 = spriteLoad(sprite_da);
    wait(ref_10);
    ref_12 = spriteLoad(sprite_115);
    wait(ref_12);
    bitGet(var_1, EBIT_E0019);
    bne(var_1, 0, label_19);
    ref_16 = call(KYOUSEI);
    wait(ref_16);
    b(label_1d);
  label_19:
    bne(var_1, 1, label_1d);
    ref_1a = call(FREE);
    wait(ref_1a);
    b(label_1d);
  label_1d:
}

function KYOUSEI()
{
    ref_1e = sndLoad(sound_3017);
    wait(ref_1e);
    sndMusicPlay(sound_3017, 127);
