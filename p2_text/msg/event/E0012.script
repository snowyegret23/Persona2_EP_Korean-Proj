    unitSpawn(ulala, sprite_6, 400, 0, -350, north, none);
    unitIdleOffAll();
    unitTriggerSet(enemy1, SITAI, 255, 1);
    unitTriggerSet(enemy2, SITAI, 255, 1);
    unitTriggerSet(katsuya, KATUYA, 255, 1);
    unitTriggerSet(baofu, PAOFU, 255, 1);
    unitTriggerSet(ulala, URARA, 255, 1);
    envTriggerSet(EXIT1, 131, 1, line, coll_6);
    envTriggerSet(EXIT2, 56, 1, line, coll_f);
    envTriggerSet(NO_EXIT, 14, 1, line, coll_2);
    bitGet(var_5, EBIT_E1300);
    bnz(var_5, label_222);
    cameraSet(northwest, 310, 0, -100);
    playerInit(north);
    controlDisable();
    b(label_225);
  label_222:
    cameraSet(southeast, 310, 0, -980);
    playerInit(south);
    controlDisable();
  label_225:
    bitClear(EBIT_E1300);
    bitClear(EBIT_E1301);
    unitIdleOn(baofu);
    delayClear();
    delayWait(23);
    unitIdleOn(katsuya);
    delayClear();
    delayWait(17);
    unitIdleOn(ulala);
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
    cameraControlDisable();
}

