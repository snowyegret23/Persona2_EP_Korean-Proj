    ref_8b = msgShow(msg_8);
/***************************************
[color(yellow)][tatsuya][color(white)]
[tab]善いか悪いかなんて関係ない。
[tab]やらなきゃいけないことをするだけだ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_8b);
    dialogFree(ref_8a);
    ref_8f = bustupFade(ref_88, rgb(0,0,0), 10);
