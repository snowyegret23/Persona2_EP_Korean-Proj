    ref_126 = bustupAlloc(ref_124, left, rgb(0,0,0));
    bustupFade(ref_126, rgb(128,0,0), 30);
    ref_128 = dialogAlloc();
    ref_129 = msgShow(msg_15);
/***************************************
[color(yellow)][tatsuya][color(white)]
[tab]神条…
[tab]神取とかいう男は、この先だと言ったな。
[sync][wait][clear]
***************************************/
