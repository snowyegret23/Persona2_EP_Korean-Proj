    delayWait(60);
    sndMusicPlay(sound_316a, 127);
    ref_16f = dialogAlloc();
    ref_170 = msgShow(msg_20);
/***************************************
神取[tab]鷹久、名前だけは知っている。
[wait][clear]
***************************************/
    wait(ref_170);
    ref_172 = msgShow(msg_21);
/***************************************
３年前、御影町の事件でゆきのさんたちが
