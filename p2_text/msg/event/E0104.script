[wait][clear]
***************************************/
    wait(ref_131);
    ref_133 = msgShow(msg_17);
/***************************************
[color(yellow)]小月[color(white)]
[tab]ＪＳＭ…[tab]ＪＯＫＥＲをＪＯＫＥＲ使いから
[tab]分離するマシンは、この先の通路の突き当たりだ。
[tab]神取はそこにいる。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_133);
    dialogFree(ref_130);
    unitAnimationPlay(tatsuya, animation_1, 1);
    unitWait(tatsuya);
