    screenFadeWait(outer);
    bitSet(EBIT_E008C);
    mapLoad(narumi, 29, 3);
}

function TATUYAMIRU()
{
    unitAnimationPlay(tatsuya, animation_1, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(tatsuya, animation_2, 1);
}

function AWA()
{
    unitAnimationHold(katsuya, animation_22, -1);
    delayClear();
    delayWait(60);
    unitAnimationStop(katsuya);
    unitAnimationPlay(katsuya, animation_2c, 2);
    unitWait(katsuya);
}
