    wait(ref_56e);
    shopOverlayInit();
    dialogFree(ref_56d);
    ref_573 = bustupFade(ref_56b, rgb(0,0,0), 10);
    bustupWait(ref_573);
    bustupFree(ref_56b);
    bitGet(var_0, MBIT_EXITBIT);
    bne(var_0, 0, label_57d);
    unitRestoreFacing(shopkeeper);
    controlEnable();
    unitAnimationPlay(shopkeeper, animation_11, 1);
    cameraControlDisable();
    b(label_580);
  label_57d:
    bne(var_0, 1, label_580);
    call(EXITBOX);
    b(label_580);
  label_580:
}

