function DOORBOX()
{
    controlDisable();
    sndMusicPlay(sound_3070, 127);
    objAnimRotate(obj_d, 0, 80, 0, 30, 0);
    objAnimWait(obj_d);
    call(GOOUT);
}

function GOOUT()
{
    bitClear(MBIT_EXITBIT);
    mapLoad(hirasaka, 3, 2);
}

function MIYABISHOKAI2()
