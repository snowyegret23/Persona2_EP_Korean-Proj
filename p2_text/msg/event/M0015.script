function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    sndMusicPlay(sound_3043, 127);
    levelFootstepSet(sfx_18);
    envTriggerSet(DOORBOX, 131, 1, line, coll_20);
    cameraSet(southwest, 240, -300, -1640);
    li(var_0, 0);
    li(var_1, 0);
    partyMemberCheck(var_0, ulala);
    add(var_1, var_1, var_0);
    partyMemberCheck(var_0, katsuya);
    add(var_1, var_1, var_0);
    partyMemberCheck(var_0, baofu);
    add(var_1, var_1, var_0);
    partyMemberCheck(var_0, nanjo);
    add(var_1, var_1, var_0);
    partyMemberCheck(var_0, elly);
    add(var_1, var_1, var_0);
    partyMemberCheck(var_0, tatsuya);
    add(var_1, var_1, var_0);
    boutrange(var_1, 0, 4, label_17);
    li(var_0, 0);
    b(label_1c);
  label_17:
    ref_17 = dialogAlloc();
    ref_18 = msgShow(msg_0);
/***************************************
パーティの人数が四人を超えています。
このままじゃハングします。
金田・片岡に連絡してください。
[wait][clear]
***************************************/
    wait(ref_18);
    dialogFree(ref_17);
    b(label_1c);
  label_1c:
    bitGet(var_0, EBIT_E009F);
    bnz(var_0, label_21);
    bitGet(var_0, EBIT_E008C);
    bez(var_0, label_27);
    bnz(var_0, label_23);
  label_21:
    partyMemberCheck(var_0, tatsuya);
    bez(var_0, label_27);
  label_23:
    ref_23 = spriteLoad(sprite_18);
    wait(ref_23);
    unitSpawn(tatsuya, sprite_18, 280, 0, -1030, south, none);
    unitTriggerSet(tatsuya, B_TATU, 255, 1);
  label_27:
    bitGet(var_0, EBIT_E009F);
    bnz(var_0, label_3a);
    bitGet(var_0, MBIT_HI_NANJOTOUJO);
    bne(var_0, 0, label_32);
    partyMemberCheck(var_0, elly);
    bez(var_0, label_3a);
    ref_2d = spriteLoad(sprite_23);
    wait(ref_2d);
    unitSpawn(elly, sprite_23, 470, 0, -1540, south, none);
    unitTriggerSet(elly, B_ERI, 255, 1);
    b(label_3a);
  label_32:
    bne(var_0, 1, label_3a);
    partyMemberCheck(var_0, nanjo);
    bez(var_0, label_3a);
    ref_35 = spriteLoad(sprite_1f);
    wait(ref_35);
    unitSpawn(nanjo, sprite_1f, 280, 0, -1230, south, none);
    unitTriggerSet(nanjo, B_NANJ, 255, 1);
    b(label_3a);
  label_3a:
    partyMemberCheck(var_0, ulala);
    bez(var_0, label_40);
    ref_3c = spriteLoad(sprite_6);
    wait(ref_3c);
    unitSpawn(ulala, sprite_6, 800, 0, -900, south, none);
    unitTriggerSet(ulala, B_URARATI, 255, 1);
  label_40:
    partyMemberCheck(var_0, katsuya);
    bez(var_0, label_46);
    ref_42 = spriteLoad(sprite_d);
    wait(ref_42);
    unitSpawn(katsuya, sprite_d, 1160, 0, -1250, west, none);
    unitTriggerSet(katsuya, B_KATUYYY, 255, 1);
  label_46:
    partyMemberCheck(var_0, baofu);
    bez(var_0, label_4c);
    ref_48 = spriteLoad(sprite_13);
    wait(ref_48);
    unitSpawn(baofu, sprite_13, 490, 0, -460, south, none);
    unitTriggerSet(baofu, B_PAO, 255, 1);
  label_4c:
    ref_4c = spriteLoad(sprite_67);
    wait(ref_4c);
    unitSpawn(ken, sprite_67, 1110, 0, -450, north, none);
    unitTriggerSet(ken, KEN, 255, 1);
    ref_50 = spriteLoad(sprite_68);
    wait(ref_50);
    unitSpawn(shogo, sprite_68, 1000, 0, -450, west, none);
    unitTriggerSet(shogo, SHOGO, 255, 1);
    ref_54 = spriteLoad(sprite_69);
    wait(ref_54);
    unitSpawn(takeshi, sprite_69, 1250, 0, -450, north, none);
    unitTriggerSet(takeshi, TAKESI, 255, 1);
    ref_58 = spriteLoad(sprite_60);
    wait(ref_58);
    unitSpawn(miyabi, sprite_60, 1190, 0, -730, east, none);
    unitTriggerSet(miyabi, MIYABI, 255, 1);
    ref_5c = spriteLoad(sprite_0);
    wait(ref_5c);
    ref_5e = spriteLoad(sprite_2);
    wait(ref_5e);
    playerInit(south);
    controlDisable();
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    unitIdleOnAll();
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

function B_URARATI()
{
