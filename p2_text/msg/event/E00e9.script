function START()
{
    sndMusicPlay(sound_406b, 127);
    cameraSet(north, 1000, 0, 1000);
    ref_2 = evtbgLoad(evtbg_15);
    wait(ref_2);
    evtbgInit(evtbg_handle_15, evtbg_15, 0, 0, rgb(0,0,0), true);
    ref_5 = evtbgFade(evtbg_handle_15, rgb(128,128,128), 1, false);
    wait(ref_5);
    ref_7 = spriteLoad(sprite_18);
    wait(ref_7);
    ref_9 = spriteLoad(sprite_1a);
    wait(ref_9);
    unitSpawn(tatsuya, sprite_18, 900, 0, 700, south, none);
    unitAnimationPlay(tatsuya, animation_a, 1);
    ref_d = spriteLoad(sprite_19a);
    wait(ref_d);
    unitSpawn(enemy1, sprite_19a, 1000, 0, 900, north, none);
    unitFace(enemy1, north);
    ref_11 = spriteLoad(sprite_19a);
    wait(ref_11);
    unitSpawn(enemy2, sprite_19a, 1175, 0, 800, north, none);
    unitFace(enemy2, north);
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    screenFadeInner(rgb(0,0,0), 4, true);
    screenFadeOuter(rgb(0,0,0), 4, true);
    screenEffectUnknown();
    screenFadeWait(inner);
    screenFadeWait(outer);
    ref_1d = dialogAlloc();
    ref_1e = msgShow(msg_0);
/***************************************
向こう側では、この廊下の内装はゾディアックという
店の名の通り、星座をあしらった安っぽいものだったが、
こちら側では赤い中華風の内装に変わっていた。
[wait][clear]
***************************************/
    wait(ref_1e);
    ref_20 = msgShow(msg_1);
/***************************************
中村が経営者が変わると言っていたが、
奥を中華レストランにでもしようというのだろうか。
その廊下の天井に、翼の生えた見たことの無い化け物が
何匹かぶら下がっていた。
[wait][clear]
***************************************/
    wait(ref_20);
    ref_22 = msgShow(msg_2);
/***************************************
蝙蝠でもなく、蜂でもなく、蟹でもなく、アリでもない。
なんとも形容のしようがない、不快で恐ろしく
不気味な生き物だ。
[wait][clear]
***************************************/
    wait(ref_22);
    ref_24 = msgShow(msg_3);
/***************************************
ペルソナに覚醒していなければ、見ただけで錯乱し
悲鳴を上げて逃げ出していたかもしれない。
それくらいパンチの効いた奴らだ。
[wait][clear]
***************************************/
    wait(ref_24);
    ref_26 = msgShow(msg_4);
/***************************************
そいつらはバタバタと背中の飛膜をはためかせ、
蜂の腹のように膨らんだケツから、ブンブン呪文のような
音を出しはじめた。頭らしきところに口はついているが、
声はそこから出すらしい。
[wait][clear]
***************************************/
    wait(ref_26);
    ref_28 = msgShow(msg_5);
/***************************************
俺には正確に発音できないが、「ビヤーキー」か
「バイアクヘー」、「イアイアハスタア」などという
音に聞こえた。何にせよ【奴】の差し金だろう。
ここから先は悪魔が出るということだ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_28);
    dialogFree(ref_1d);
    unitSpriteClear(tatsuya);
    unitSpriteSet(tatsuya, sprite_1a);
    sndMusicPlay(sound_32e9, 127);
    ref_2f = bustupLoad(bustup_d);
    bustupWait(ref_2f);
    ref_31 = bustupAlloc(ref_2f, left, rgb(0,0,0));
    bustupFade(ref_31, rgb(128,0,0), 30);
    ref_33 = dialogAlloc();
    ref_34 = msgShow(msg_6);
/***************************************
[color(yellow)][tatsuya][color(white)]
[tab]ウォーミングアップしろってことか？
[tab]悪いがハエじゃ役不足だ。
[tab]さっさとお前が出て来いよ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_34);
    dialogFree(ref_33);
    ref_38 = bustupFade(ref_31, rgb(0,0,0), 10);
    bustupWait(ref_38);
    bustupFree(ref_31);
    ref_3b = dialogAlloc();
    ref_3c = msgShow(msg_7);
/***************************************
俺がどこかで見ている【奴】に呟くと、
そいつらは一斉にケツからいあいあ耳障りな声をあげ、
狭い廊下を物凄い勢いで飛んできた。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_3c);
    dialogFree(ref_3b);
    delayClear();
    delayWait(60);
    encounterLoad(encounter_40);
}
