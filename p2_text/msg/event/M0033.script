    envTriggerSet(SHOP, 56, 1, line, coll_12);
    envTriggerSet(SHOP, 112, 1, line, coll_31);
    envTriggerSet(SHOP, 112, 1, line, coll_3a);
    envTriggerSet(SHOP, 56, 1, line, coll_3b);
    ref_4d = spriteLoad(sprite_ca);
