function DOORBOX()
{
    controlDisable();
    objAnimRotate(obj_b, 0, -70, 0, 30, 0);
    objAnimRotate(obj_a, 0, 70, 0, 30, 0);
    sndMusicPlay(sound_307b, 127);
    objAnimWait(obj_b);
    objAnimWait(obj_a);
    call(EXITBOX);
}

function EXITBOX()
{
    bitClear(MBIT_EXITBIT);
    mapLoad(rengedai, 0, 0);
}

function warp1()
{
    call(DOORBOX);
}

