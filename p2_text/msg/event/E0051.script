function DOOR()
{
    sndMusicPlay(sound_3179, 127);
    objAnimRotate(obj_82, 0, -165, 0, 15, 0);
    objAnimRotate(obj_83, 0, 125, 0, 10, 0);
    objAnimWait(obj_82);
    objAnimWait(obj_83);
    objAnimRotate(obj_82, 0, 20, 0, 60, 0);
    objAnimRotate(obj_83, 0, -20, 0, 60, 0);
}
