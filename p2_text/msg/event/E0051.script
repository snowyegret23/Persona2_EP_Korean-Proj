function MAYA()
{
    unitSpawn(maya, sprite_0, 50, 0, -1700, west, none);
    unitMove(maya, 750, -1700, face_west, fastest);
    unitWait(maya);
    unitAnimationPlay(maya, animation_12, 1);
    unitWait(maya);
    unitFace(maya, east);
    unitAnimationPlay(maya, animation_0, 1);
    unitSpriteClear(maya);
    unitSpriteSet(maya, sprite_3);
}

