function SUGIMOTO()
{
    unitSpawn(sugimoto, sprite_70, -50, 0, -1750, west, fade);
    call(DOOR);
    unitJumpTo(sugimoto, 180, 0, -1750, 10, 0);
    unitAnimationPlay(sugimoto, animation_d, 1);
    unitWait(sugimoto);
    delayClear();
    delayWait(60);
    sndMusicPlay(sound_317d, 127);
    unitAnimationPlay(sugimoto, animation_6, 1);
    unitWait(sugimoto);
}

