    ref_68 = dialogAlloc();
    ref_69 = msgShow(msg_5);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]…そんなん、わかりゃ苦労しないわよぅ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_69);
    dialogFree(ref_68);
    ref_6d = bustupFade(ref_66, rgb(0,0,0), 10);
