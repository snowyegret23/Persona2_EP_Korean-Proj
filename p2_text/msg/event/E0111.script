    ref_7f = bustupAlloc(ref_7d, left, rgb(0,0,0));
    bustupFade(ref_7f, rgb(128,0,0), 30);
    ref_81 = dialogAlloc();
    ref_82 = msgShow(msg_6);
/***************************************
[color(yellow)][tatsuya][color(white)]
[tab]ろくでなしか…
[tab]確かにそうだな。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_82);
    dialogFree(ref_81);
    ref_86 = bustupFade(ref_7f, rgb(0,0,0), 10);
