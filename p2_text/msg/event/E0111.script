    b(label_fa);
  label_d0:
    bne(var_5, 1, label_fa);
    ref_d1 = dialogAlloc();
    ref_d2 = msgShow(msg_11);
/***************************************
[color(yellow)]シャカ[color(white)]
[tab]その通りです。
[tab]私という、ありもしない幻に囚われ執着する我執こそ、
[tab]貴女と世界に苦をもたらす最たるもの。
[wait][clear]
***************************************/
    wait(ref_d2);
    ref_d4 = msgShow(msg_12);
/***************************************
[color(yellow)]シャカ[color(white)]
[tab]諸法無我。
[wait][clear]
***************************************/
    wait(ref_d4);
    ref_d6 = msgShow(msg_13);
/***************************************
[color(yellow)]シャカ[color(white)]
[tab]この世の一切に主体なく、あるものと変化を
[tab]ありのまま縁起のもとに受け入れることを知りなさい。
[tab]それこそが、苦の終わりをもたらすのです。
[wait][clear]
***************************************/
    wait(ref_d6);
    ref_d8 = msgShow(msg_14);
/***************************************
[color(yellow)]シャカ[color(white)]
[tab]貴女方が探しておられる女性は、
[tab]未だ強き我執に囚われし者。
[wait][clear]
***************************************/
    wait(ref_d8);
    ref_da = msgShow(msg_15);
/***************************************
[color(yellow)]シャカ[color(white)]
[tab]彼の者の性格と気力の元となる、
[tab]機根を貴女に託しましょう。
[tab]仏の教えを悟る器を磨くよう、お伝えください。
[wait][clear]
***************************************/
    wait(ref_da);
    screenFlash(255, 255, 255);
    sndMusicPlay(sound_32ee, 127);
    unitDespawn(unit_43, none);
    unitSpawn(npc1, sprite_117, 800, 0, -800, east, none);
    unitWait(unit_43);
    ref_e1 = msgShow(msg_16);
/***************************************
[color(green)]大いなるものは消え去った。[color(white)]
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_e1);
    dialogFree(ref_d1);
    msgVar_Item(msgvar_0, hierophant_card);
    ref_e6 = dialogAlloc();
    ref_e7 = msgShow(msg_17);
/***************************************
[color(green)]舞耶達は、[var(msg_var_0)]のカードを２００枚
手に入れた。[color(white)]
[sync][wait][clear]
***************************************/
