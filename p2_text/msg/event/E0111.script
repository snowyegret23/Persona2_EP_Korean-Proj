    ref_91 = bustupLoad(bustup_21);
    bustupWait(ref_91);
    ref_93 = bustupAlloc(ref_91, left, rgb(0,0,0));
    bustupFade(ref_93, rgb(128,0,0), 30);
    ref_95 = dialogAlloc();
    ref_96 = msgShow(msg_7);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]己が自分にとってどんな存在かは、人それぞれだと
[tab]思うがな。たとえどんな自分であれ、
[tab]否定するだけでは先に進めん。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_96);
    dialogFree(ref_95);
    ref_9a = bustupFade(ref_93, rgb(0,0,0), 10);
    bustupWait(ref_9a);
    bustupFree(ref_93);
    unitAnimationPlay(katsuya, animation_a, 1);
