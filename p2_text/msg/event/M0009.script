    sync();
    wait(ref_4c1);
    ref_4c5 = msgShow(msg_78);
/***************************************
[color(yellow)]イゴール[color(white)]
[tab]もちろん、
[tab]必ず変異させねばならないわけでは
[tab]ありません。
[sync][wait][clear]
***************************************/
