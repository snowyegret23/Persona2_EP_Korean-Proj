function EIKITIBOX()
{
    controlDisable();
    unitFacePlayer(unit_62);
    ref_bd = bustupLoad(bustup_b2);
    bustupWait(ref_bd);
    ref_bf = bustupAlloc(ref_bd, left, rgb(0,0,0));
    bustupFade(ref_bf, rgb(128,0,0), 30);
    ref_c1 = dialogAlloc();
    ref_c2 = msgShow(msg_0);
/***************************************
[color(yellow)]栄吉[color(white)]
[tab]俺…ここ来たことあるかな…
[tab]無いよな…
[tab]だけどあの鼻…なんか知ってる気がすんだよ。
[wait][clear]
***************************************/
    wait(ref_c2);
    unitAnimationPlay(unit_62, animation_a, 1);
    dialogFree(ref_c1);
    ref_c6 = bustupFade(ref_bf, rgb(0,0,0), 10);
    bustupWait(ref_c6);
    bustupFree(ref_bf);
    unitRestoreFacing(unit_62);
    controlEnable();
}

