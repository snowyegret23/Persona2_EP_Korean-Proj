    wait(ref_667);
    shopOverlayInit();
    dialogFree(ref_666);
    ref_66c = bustupFade(ref_664, rgb(0,0,0), 10);
    bustupWait(ref_66c);
    bustupFree(ref_664);
    bitGet(var_0, MBIT_EXITBIT);
    bne(var_0, 0, label_676);
    unitRestoreFacing(shopkeeper);
    controlEnable();
    unitAnimationPlay(shopkeeper, animation_11, 1);
    cameraControlDisable();
    b(label_679);
  label_676:
    bne(var_0, 1, label_679);
    call(EXITBOX);
    b(label_679);
  label_679:
}

