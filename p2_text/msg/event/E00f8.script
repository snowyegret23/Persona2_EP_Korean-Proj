function ENEMY4MOVE()
{
  label_dd:
    ref_dd = unitMove(enemy4, 1000, -1500, face_north, medium);
    unitAnimationPlay(enemy4, animation_1b, 1);
    wait(ref_dd);
    delayClear();
    delayWait(30);
    ref_e2 = unitMove(enemy4, 1000, -1600, face_north, medium);
    unitAnimationPlay(enemy4, animation_7, 1);
    wait(ref_e2);
    delayClear();
    delayWait(30);
    ref_e7 = unitMove(enemy4, 1000, -1500, face_north, reverse);
    unitAnimationPlay(enemy4, animation_7, 1);
    wait(ref_e7);
    delayClear();
    delayWait(30);
    ref_ec = unitMove(enemy4, 1000, -1400, face_north, reverse);
    unitAnimationPlay(enemy4, animation_7, 1);
    wait(ref_ec);
    delayClear();
    delayWait(30);
    b(label_dd);
}

