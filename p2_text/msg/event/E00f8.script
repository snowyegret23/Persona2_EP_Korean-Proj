function START()
{
    sndMusicPlay(sound_406b, 90);
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    cameraSet(northwest, 410, 0, -1200);
    bitSet(bit_c78);
    ref_5 = spriteLoad(sprite_18);
    wait(ref_5);
    ref_7 = spriteLoad(sprite_11f);
    wait(ref_7);
    ref_9 = spriteLoad(sprite_27);
    wait(ref_9);
    ref_b = spriteLoad(sprite_e8);
    wait(ref_b);
    ref_d = spriteLoad(sprite_e5);
    wait(ref_d);
    ref_f = spriteLoad(sprite_e6);
    wait(ref_f);
    unitSpawn(tatsuya, sprite_18, 400, 0, -1390, south, none);
    unitSpawn(eikichi, sprite_27, 400, 0, -1200, north, none);
    unitSpawn(enemy1, sprite_e8, 700, -110, -920, north, none);
    unitFootstepSet(enemy1, sfx_ff);
    call(ENEMY1MOVE);
    unitSpawn(enemy2, sprite_e6, 400, 0, -1000, south, none);
    unitFootstepSet(enemy2, sfx_ff);
    call(ENEMY2MOVE);
    unitSpawn(enemy3, sprite_e6, 630, -110, -880, east, none);
    unitFootstepSet(enemy3, sfx_ff);
    call(ENEMY3MOVE);
    unitSpawn(enemy4, sprite_e6, 1000, 0, -1400, north, none);
    unitFootstepSet(enemy4, sfx_ff);
    call(ENEMY4MOVE);
    unitSpawn(enemy5, sprite_e5, 100, 0, -1110, east, none);
    unitFootstepSet(enemy5, sfx_ff);
    call(ENEMY5MOVE);
    unitSpawn(enemy6, sprite_e5, 750, 0, -1350, west, none);
    unitFootstepSet(enemy6, sfx_ff);
    call(ENEMY6MOVE);
    objAnimRotate(obj_72, 0, -120, 0, 1, 0);
    objAnimRotate(obj_73, 0, 120, 0, 1, 0);
    objAnimRotate(obj_82, 0, -90, 0, 1, 0);
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    unitAnimationPlay(tatsuya, animation_14, 1);
    unitWait(tatsuya);
    ref_2f = bustupLoad(bustup_b);
    bustupWait(ref_2f);
    ref_31 = bustupAlloc(ref_2f, left, rgb(0,0,0));
    bustupFade(ref_31, rgb(128,0,0), 30);
    ref_33 = dialogAlloc();
    ref_34 = msgShow(msg_0);
/***************************************
[color(yellow)][tatsuya][color(white)]
[tab]みんなで中に隠れてろ、栄吉。
[tab]ドアは全部閉めるなよ。
[tab]酸欠で死ぬぞ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_34);
    dialogFree(ref_33);
    ref_38 = bustupFade(ref_31, rgb(0,0,0), 10);
    bustupWait(ref_38);
    bustupFree(ref_31);
    unitAnimationPlay(tatsuya, animation_0, 1);
    unitWait(tatsuya);
    delayClear();
    delayWait(60);
    unitAnimationPlay(eikichi, animation_1f, 1);
    unitWait(eikichi);
    ref_41 = bustupLoad(bustup_116);
    bustupWait(ref_41);
    ref_43 = bustupAlloc(ref_41, right, rgb(0,0,0));
    bustupFade(ref_43, rgb(128,0,0), 30);
    ref_45 = dialogAlloc();
    ref_46 = msgShow(msg_1);
/***************************************
[color(yellow)]栄吉[color(white)]
[tab]ああ…[tab]なぁ、[suou]。
[tab]さっきから俺たちすげー自然に話してっけど、
[tab]なんで俺の名前知ってんだ？
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_46);
    dialogFree(ref_45);
    ref_4a = bustupFade(ref_43, rgb(0,0,0), 10);
    bustupWait(ref_4a);
    bustupFree(ref_43);
    unitAnimationPlay(eikichi, animation_a, 1);
    unitWait(eikichi);
    unitAnimationPlay(tatsuya, animation_a, 1);
    unitWait(tatsuya);
    ref_51 = bustupLoad(bustup_10);
    bustupWait(ref_51);
    ref_53 = bustupAlloc(ref_51, left, rgb(0,0,0));
    bustupFade(ref_53, rgb(128,0,0), 30);
    ref_55 = dialogAlloc();
    ref_56 = msgShow(msg_2);
/***************************************
[color(yellow)][tatsuya][color(white)]
[tab]…カス校のパンツ番長の名前を、知らない奴が
[tab]いるのか？
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_56);
    dialogFree(ref_55);
    ref_5a = bustupFade(ref_53, rgb(0,0,0), 10);
    bustupWait(ref_5a);
    bustupFree(ref_53);
    unitAnimationPlay(eikichi, animation_1d, 1);
    unitWait(eikichi);
    ref_5f = bustupLoad(bustup_116);
    bustupWait(ref_5f);
    ref_61 = bustupAlloc(ref_5f, right, rgb(0,0,0));
    bustupFade(ref_61, rgb(128,0,0), 30);
    ref_63 = dialogAlloc();
    ref_64 = msgShow(msg_3);
/***************************************
[color(yellow)]栄吉[color(white)]
[tab]パンツ番長？[tab]なんだそりゃ。
[tab]なんか、すげー懐かしいっつーか、腹立つっつーか…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_64);
    dialogFree(ref_63);
    ref_68 = bustupFade(ref_61, rgb(0,0,0), 10);
    bustupWait(ref_68);
    bustupFree(ref_61);
    ref_6b = dialogAlloc();
    ref_6c = msgShow(msg_4);
/***************************************
失敗した。
こいつは、こちら側ではそんな通り名じゃないらしい。
もうこれ以上は無理だ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_6c);
    dialogFree(ref_6b);
    unitAnimationPlay(eikichi, animation_a, 1);
    unitWait(eikichi);
    cameraMoveTo(410, 0, -1350, 60);
    delayClear();
    delayWait(20);
    unitFace(tatsuya, north);
    unitMove(tatsuya, 400, -1490, face_north, medium);
    unitWait(tatsuya);
    delayClear();
    delayWait(30);
    unitFace(tatsuya, west);
    delayClear();
    delayWait(3);
    unitAnimationPlay(tatsuya, animation_1, 1);
    unitWait(tatsuya);
    delayClear();
    delayWait(3);
    unitAnimationPlay(tatsuya, animation_2, 1);
    unitWait(tatsuya);
    ref_83 = bustupLoad(bustup_d);
    bustupWait(ref_83);
    ref_85 = bustupAlloc(ref_83, left, rgb(0,0,0));
    bustupFade(ref_85, rgb(128,0,0), 30);
    ref_87 = dialogAlloc();
    ref_88 = msgShow(msg_5);
/***************************************
[color(yellow)][tatsuya][color(white)]
[tab]いいから、そいつらを見張ってろ。
[tab]すぐ、舞…天野さんたちも戻ってくる。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_88);
    dialogFree(ref_87);
    ref_8c = bustupFade(ref_85, rgb(0,0,0), 10);
    bustupWait(ref_8c);
    bustupFree(ref_85);
    unitFace(eikichi, north);
    unitMove(eikichi, 400, -1250, face_north, medium);
    unitWait(eikichi);
    unitAnimationPlay(eikichi, animation_1f, 1);
    ref_93 = bustupLoad(bustup_116);
    bustupWait(ref_93);
    ref_95 = bustupAlloc(ref_93, right, rgb(0,0,0));
    bustupFade(ref_95, rgb(128,0,0), 30);
    ref_97 = dialogAlloc();
    ref_98 = msgShow(msg_6);
/***************************************
[color(yellow)]栄吉[color(white)]
[tab]おい、お前はどうすんだよ！
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_98);
    dialogFree(ref_97);
    ref_9c = bustupFade(ref_95, rgb(0,0,0), 10);
    bustupWait(ref_9c);
    bustupFree(ref_95);
    unitAnimationPlay(tatsuya, animation_1, 1);
    unitWait(tatsuya);
    delayClear();
    delayWait(3);
    unitAnimationPlay(tatsuya, animation_0, 1);
    unitWait(tatsuya);
    delayClear();
    delayWait(3);
    unitFace(tatsuya, north);
    unitAnimationPlay(tatsuya, animation_1, 1);
    unitWait(tatsuya);
    delayClear();
    delayWait(3);
    unitAnimationPlay(tatsuya, animation_0, 1);
    unitWait(tatsuya);
    unitMove(tatsuya, 400, -1600, face_north, medium);
    dngLoad(science_lab2, 2, 39, 14, 4);
    sndMusicPlay(sound_406b, 90);
}

function ENEMY1MOVE()
{
  label_b2:
    unitAnimationPlay(enemy1, animation_0, 1);
    delayClear();
    delayWait(15);
    unitAnimationPlay(enemy1, animation_1, 1);
    delayClear();
    delayWait(15);
    unitAnimationPlay(enemy1, animation_0, 1);
    delayClear();
    delayWait(15);
    unitAnimationPlay(enemy1, animation_1, 1);
    delayClear();
    delayWait(15);
    unitAnimationPlay(enemy1, animation_0, 1);
    b(label_b2);
}

function ENEMY2MOVE()
{
  label_c1:
    ref_c1 = unitMove(enemy2, 400, -800, face_south, slowestNoAnim);
    unitAnimationPlay(enemy2, animation_7, 1);
    wait(ref_c1);
    ref_c4 = unitMove(enemy2, 200, -800, face_east, slowestNoAnim);
    unitAnimationPlay(enemy2, animation_7, 1);
    wait(ref_c4);
    ref_c7 = unitMove(enemy2, 200, -1000, face_north, slowestNoAnim);
    unitAnimationPlay(enemy2, animation_7, 1);
    wait(ref_c7);
    ref_ca = unitMove(enemy2, 400, -1000, face_west, slowestNoAnim);
    unitAnimationPlay(enemy2, animation_7, 1);
    wait(ref_ca);
    b(label_c1);
}

