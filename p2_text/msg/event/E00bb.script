    ref_22 = spriteLoad(sprite_10);
    wait(ref_22);
    cameraSet(southeast, 1473, 0, -1919);
    ref_25 = sndLoad(sound_302c);
    wait(ref_25);
    sndMusicPlay(sound_302c, 127);
    bitGet(var_0, EBIT_KABAU);
