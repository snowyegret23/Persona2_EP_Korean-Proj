    levelFootstepSet(sfx_10);
    objVisible(obj_c, true);
    objVisible(obj_d, true);
    objVisible(obj_9, true);
    objVisible(obj_a, true);
    objVisible(obj_b, true);
    objVisible(obj_1, false);
    objVisible(obj_2, false);
    objVisible(obj_3, false);
    objAnimRotate(obj_0, 0, 360, 0, 2400, 1);
    ref_c = spriteLoad(sprite_6);
    wait(ref_c);
    unitSpawn(ulala, sprite_6, 1511, 0, -1853, south, none);
    ref_f = spriteLoad(sprite_d);
    wait(ref_f);
    unitSpawn(katsuya, sprite_d, 1279, 0, -1884, south, none);
