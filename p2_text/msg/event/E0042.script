    unitAnimationPlay(npc1, animation_4, 1);
    delayClear();
    delayWait(15);
    unitFace(npc1, east);
    unitAnimationPlay(npc1, animation_0, 1);
    delayClear();
    delayWait(60);
    unitAnimationPlay(npc1, animation_2f, 1);
    delayClear();
    delayWait(180);
    unitAnimationPlay(npc1, animation_3, 1);
    delayClear();
    delayWait(15);
    unitAnimationPlay(npc1, animation_4, 1);
    delayClear();
    delayWait(15);
    unitFace(npc1, south);
    unitAnimationPlay(npc1, animation_0, 1);
    delayClear();
    delayWait(60);
    unitAnimationPlay(npc1, animation_b, 1);
    unitWait(npc1);
    delayClear();
    delayWait(120);
    unitAnimationPlay(npc1, animation_a, 1);
    unitWait(npc1);
    unitFace(npc1, north);
    unitAnimationPlay(npc1, animation_0, 1);
    delayClear();
    delayWait(60);
    b(label_174);
}
