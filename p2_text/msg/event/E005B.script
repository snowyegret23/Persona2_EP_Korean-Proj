    ref_77 = bustupAlloc(ref_75, left, rgb(0,0,0));
    bustupFade(ref_77, rgb(128,0,0), 30);
    ref_79 = dialogAlloc();
    ref_7a = msgShow(msg_3);
/***************************************
[color(yellow)]パオフゥ[color(white)]
[tab]チッ…
[tab]イライラするぜ…
[tab]あのクソ猫探して吐かせた方が早ぇぜ。
[sync][wait][clear]
***************************************/
    unitAnimationPlay(baofu, animation_2d, 1);
    delayClear();
    delayWait(60);
    sync();
    wait(ref_7a);
    dialogFree(ref_79);
    ref_81 = bustupFade(ref_77, rgb(0,0,0), 10);
    bustupWait(ref_81);
    bustupFree(ref_77);
    unitAnimationPlay(baofu, animation_a, 1);
    unitRestoreFacing(katsuya);
    controlEnable();
}

function KATUYA()
{
    controlDisable();
    unitFacePlayer(katsuya);
    ref_8a = bustupLoad(bustup_21);
    bustupWait(ref_8a);
    ref_8c = bustupAlloc(ref_8a, left, rgb(0,0,0));
    bustupFade(ref_8c, rgb(128,0,0), 30);
    ref_8e = dialogAlloc();
    ref_8f = msgShow(msg_4);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]猫を虐待するのは反対だな。
[tab]あんな可愛い動物を、どうやったらいじめたり
[tab]できるんだ！？
[sync][wait][clear]
***************************************/
    unitAnimationPlay(katsuya, animation_2d, 1);
    delayClear();
    delayWait(60);
    sync();
    wait(ref_8f);
    ref_95 = msgShow(msg_5);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]そりゃ、あの黒猫は化け物かもしれんが…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_95);
    dialogFree(ref_8e);
    ref_99 = bustupFade(ref_8c, rgb(0,0,0), 10);
    bustupWait(ref_99);
    bustupFree(ref_8c);
    unitAnimationPlay(katsuya, animation_a, 1);
    unitRestoreFacing(katsuya);
    controlEnable();
}

function EXIT()
{
    controlDisable();
    objAnimRotate(obj_a, 0, -80, 0, 60, 0);
    sndMusicPlay(sound_3198, 127);
    objAnimWait(obj_a);
    bitSet(EBIT_E005F);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    cameraSetNorth(east);
    dngLoad2(sumaru_tv2-6);
}

function EXIT2()
{
    controlDisable();
    ref_af = dialogAlloc();
    ref_b0 = msgShow(msg_6);
/***************************************
[color(yellow)]モニター室のドア[color(green)]
[tab]ここには入れない。[color(white)]
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_b0);
    dialogFree(ref_af);
    controlEnable();
}
