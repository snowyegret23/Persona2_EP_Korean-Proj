function HA_SHOP_EXPLAIN_0()
{
    ref_19f = dialogAlloc();
    ref_1a0 = msgShow(msg_17);
/***************************************
[color(yellow)]オバサン？[color(white)]
うひょひょひょ。
”売買”についてねぇ～。
[wait][clear][color(yellow)]オバサン？[color(white)]
まずは、購入の説明なのねぇ～。
うちの店で”消費物を買う”を選ぶと
消費アイテムを買うことができるわよぉ～。
[wait][clear][color(yellow)]オバサン？[color(white)]
あっ、そうそう、アイテムは持てる数が
決まってるからねぇ～。
[wait][clear][color(yellow)]オバサン？[color(white)]
次に、売却の説明なのねぇ～。
”アイテムを売る”を選んで、まず種類を決めて、
次に売りたいものを選んでねぇ～。
[wait][clear][color(yellow)]オバサン？[color(white)]
買取価格は元値の約半額くらいよぉ～。
あと、装備中の物は売ることができないからねぇ～。
それと、物によっては買取できない物もあるわよぉ～。
[wait][clear][color(yellow)]オバサン？[color(white)]
こんなとこかしらぁ～。
うひょひょひょ。
[wait][clear]
***************************************/
    wait(ref_1a0);
    dialogFree(ref_19f);
}

function NOITEM()
{
    unitFacePlayer(shopkeeper);
    ref_1a5 = bustupLoad(bustup_fd);
    bustupWait(ref_1a5);
    ref_1a7 = bustupAlloc(ref_1a5, right, rgb(0,0,0));
    bustupFade(ref_1a7, rgb(128,0,0), 30);
    ref_1a9 = dialogAlloc();
    ref_1aa = msgShow(msg_18);
/***************************************
[color(yellow)]オバサン？[color(white)]
売れる物、持ってないじゃないの～。[wait][clear]
***************************************/
    wait(ref_1aa);
    dialogFree(ref_1a9);
    ref_1ad = bustupFade(ref_1a7, rgb(0,0,0), 10);
    bustupWait(ref_1ad);
    bustupFree(ref_1a7);
    li(var_5, 20);
}

function DECIDE_BUY()
{
    msgVar_Number(msgvar_0, var_6);
    unitFacePlayer(shopkeeper);
    ref_1b4 = bustupLoad(bustup_fd);
    bustupWait(ref_1b4);
    ref_1b6 = bustupAlloc(ref_1b4, left, rgb(0,0,0));
    bustupFade(ref_1b6, rgb(128,0,0), 30);
    ref_1b8 = dialogAlloc();
    choiceSetResult(1);
    ref_1ba = msgShow(msg_19);
/***************************************
[color(yellow)]オバサン？[color(white)]
全部で、[var(msg_var_0)]円になるけど
いいかしらぁ～？
[choice(2)]はい
いいえ
[end_choice][clear]
***************************************/
    wait(ref_1ba);
    choiceGetResult(var_7);
    bne(var_7, 0, label_1c0);
    li(var_7, 1);
    b(label_1c3);
  label_1c0:
    bne(var_7, 1, label_1c3);
    li(var_7, 0);
    b(label_1c3);
  label_1c3:
    wait(ref_1ba);
    dialogFree(ref_1b8);
    ref_1c5 = bustupFade(ref_1b6, rgb(0,0,0), 10);
    bustupWait(ref_1c5);
    bustupFree(ref_1b6);
    li(var_5, 20);
}

