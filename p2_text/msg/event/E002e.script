function ENEMY1MOVE()
{
    unitMove(enemy1, 700, -1430, face_east, medium);
    unitWait(enemy1);
    unitMove(enemy1, 700, -1550, face_north, medium);
    unitWait(enemy1);
    objAnimTranslate(obj_30, -100, 0, 0, 60);
    objAnimTranslate(obj_31, 100, 0, 0, 60);
    sndMusicPlay(sound_311d, 127);
    objAnimWait(obj_30);
    objAnimWait(obj_31);
    unitMove(enemy1, 700, -1650, fade, medium);
    unitWait(enemy1);
}

function ENEMY2MOVE()
{
    unitMove(enemy2, 700, -1350, face_east, medium);
    unitWait(enemy2);
    unitMove(enemy2, 700, -1470, face_north, medium);
    unitWait(enemy2);
    delayClear();
    delayWait(60);
    unitMove(enemy2, 700, -1650, fade, medium);
    unitWait(enemy2);
    objAnimTranslate(obj_30, 100, 0, 0, 60);
    objAnimTranslate(obj_31, -100, 0, 0, 60);
    sndMusicPlay(sound_311d, 127);
    objAnimWait(obj_30);
    objAnimWait(obj_31);
}
