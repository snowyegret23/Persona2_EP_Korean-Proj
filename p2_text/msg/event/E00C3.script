    ref_1e9 = msgShow(msg_18);
/***************************************
[color(yellow)]ギンコ[color(white)]
[tab]おまじない…
[tab]これできっと、[tatsuya]のこと忘れないよ…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_1e9);
    ref_1ec = bustupFade(ref_1e2, rgb(0,0,0), 10);
    bustupWait(ref_1ec);
    bustupFree(ref_1e2);
