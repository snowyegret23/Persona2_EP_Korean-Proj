}

function REI()
{
    delayClear();
    delayWait(60);
    unitAnimationPlay(tatsuya, animation_3, 1);
    delayClear();
    delayWait(8);
    unitAnimationPlay(tatsuya, animation_4, 1);
    delayClear();
    delayWait(60);
    unitAnimationPlay(philemon, animation_19, 1);
    ref_22a = bustupLoad(bustup_de);
    bustupWait(ref_22a);
    ref_22c = bustupAlloc(ref_22a, right, rgb(0,0,0));
    bustupFade(ref_22c, rgb(128,0,0), 30);
    ref_22e = dialogAlloc();
    ref_22f = msgShow(msg_21);
/***************************************
[color(yellow)]フィレモン[color(white)]
[tab]礼には及ばん。
[tab]諸君が運命の不文律を破り、
[tab]お互いを憶えていることを祈ろう…さらばだ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_22f);
    dialogFree(ref_22e);
    ref_233 = bustupFade(ref_22c, rgb(0,0,0), 10);
    bustupWait(ref_233);
    bustupFree(ref_22c);
    unitAnimationPlay(tatsuya, animation_a, 1);
    delayClear();
    delayWait(120);
    sndMusicPlay(sound_32f6, 127);
    efctPlay(effect_b, efct_6, 820, 0, -820, 820, 0, -820, false);
    unitDespawn(tatsuya, ghost);
    efctWait(efct_6);
    delayClear();
    delayWait(60);
    bitSet(EBIT_E00C3_MOVIE);
    sndVolumeFadeOff(sound_3042, 180);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), add);
    screenFadeInner(rgb(255,255,255), 2, false);
    screenFadeOuter(rgb(255,255,255), 2, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    cutscenePlay(cutscene_c, 0);
    cutsceneFollowupEvent(event_62);
    op_bd();
}

