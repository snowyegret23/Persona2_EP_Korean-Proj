function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    cameraSet(northeast, 730, 0, -1130);
    objCollisionLink(collision_2, coll_e, obj_4d);
    objVisible(obj_4d, false);
    ref_5 = spriteLoad(sprite_0);
    wait(ref_5);
    ref_7 = spriteLoad(sprite_35);
    wait(ref_7);
    ref_9 = spriteLoad(sprite_6b);
    wait(ref_9);
    ref_b = spriteLoad(sprite_c0);
    wait(ref_b);
    ref_d = spriteLoad(sprite_c2);
    wait(ref_d);
    ref_f = spriteLoad(sprite_46);
    wait(ref_f);
    unitSpawn(yukino, sprite_35, 700, 0, -1030, north, none);
    unitAnimationPlay(yukino, animation_b, 1);
    unitSpawn(fujii, sprite_6b, 600, 0, -1070, west, none);
    unitSpawn(enemy1, sprite_c0, 600, 0, -1190, west, none);
    unitPalette(enemy1, 1);
    unitSpawn(enemy2, sprite_c2, 700, 0, -1250, south, none);
    unitAnimationPlay(enemy2, animation_3, 1);
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 4, true);
    screenFadeOuter(rgb(0,0,0), 4, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    delayClear();
    delayWait(60);
    ref_1f = dialogAlloc();
    ref_20 = msgShow(msg_0);
/***************************************
[color(yellow)]ＴＶ画面のアナウンサー[color(white)]
[tab]…なるほど。
[tab]さすがはワンロン占い。よく当たりますねぇ～
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_20);
    dialogFree(ref_1f);
    delayClear();
    delayWait(60);
    ref_26 = cameraRotateTo(5, 1);
    ref_27 = cameraMoveTo(480, 0, -1530, 1);
    wait(ref_26);
    wait(ref_27);
    delayClear();
    delayWait(90);
    objAnimRotate(obj_15, 0, 80, 0, 60, 0);
    sndMusicPlay(sound_3110, 127);
    objAnimWait(obj_15);
    delayClear();
    delayWait(10);
    unitAnimationPlay(yukino, animation_a, 1);
    unitAnimationPlay(fujii, animation_1, 1);
    unitAnimationPlay(enemy1, animation_1, 1);
    unitAnimationPlay(enemy2, animation_0, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(fujii, animation_2, 1);
    unitAnimationPlay(enemy1, animation_2, 1);
    unitAnimationPlay(enemy2, animation_1, 1);
    delayClear();
    delayWait(7);
    unitFace(enemy2, east);
    unitAnimationPlay(enemy2, animation_0, 1);
    delayClear();
    delayWait(7);
    unitFace(enemy2, north);
    unitAnimationPlay(enemy2, animation_3, 1);
    objAnimWait(obj_15);
    unitSpawn(unit_15, sprite_46, 300, 0, -1850, south, fade);
    unitMove(unit_15, 300, -1650, face_south, medium);
    unitWait(unit_15);
    objAnimRotate(obj_15, 0, -80, 0, 60, 0);
    sndMusicPlay(sound_3111, 127);
    ref_48 = call(BORYUMOVE1);
    delayClear();
    delayWait(60);
    unitAnimationPlay(fujii, animation_1, 1);
    unitAnimationPlay(enemy1, animation_1, 1);
    unitAnimationPlay(enemy2, animation_0, 1);
    delayClear();
    delayWait(30);
    unitAnimationPlay(yukino, animation_b, 1);
    unitAnimationPlay(enemy2, animation_1, 1);
    wait(ref_48);
    ref_53 = call(BORYUMOVE2);
    delayClear();
    delayWait(30);
    unitAnimationPlay(enemy1, animation_0, 1);
    unitAnimationPlay(fujii, animation_0, 1);
    unitFace(enemy2, west);
    unitAnimationPlay(enemy2, animation_0, 1);
    unitFace(yukino, west);
    unitAnimationPlay(yukino, animation_b, 1);
    delayClear();
    delayWait(60);
    unitAnimationPlay(enemy1, animation_3, 1);
    unitAnimationPlay(enemy2, animation_3, 1);
    unitAnimationPlay(yukino, animation_a, 1);
    unitAnimationPlay(fujii, animation_0, 1);
    delayClear();
    delayWait(30);
    unitAnimationPlay(yukino, animation_d, 1);
    unitAnimationPlay(fujii, animation_3, 1);
    delayClear();
    delayWait(120);
    unitAnimationPlay(enemy1, animation_4, 1);
    unitAnimationPlay(enemy2, animation_4, 1);
    unitAnimationPlay(fujii, animation_4, 1);
    unitAnimationPlay(yukino, animation_e, 1);
    wait(ref_53);
    ref_6d = call(BORYUMOVE3);
    unitFace(enemy1, south);
    unitFace(enemy2, south);
    unitFace(fujii, south);
    unitFace(yukino, south);
    unitAnimationPlay(enemy1, animation_3, 1);
    unitAnimationPlay(enemy2, animation_3, 1);
    unitAnimationPlay(fujii, animation_3, 1);
    unitAnimationPlay(yukino, animation_d, 1);
    wait(ref_6d);
    ref_77 = call(BORYUMOVE4);
    wait(ref_77);
    delayClear();
    delayWait(60);
    ref_7b = cameraMoveTo(700, -250, -1100, 1);
    ref_7c = cameraRotateTo(5, 1);
    wait(ref_7b);
    wait(ref_7c);
    delayClear();
    delayWait(60);
    objAnimRotate(obj_15, 0, 80, 0, 60, 0);
    sndMusicPlay(sound_3110, 127);
    objAnimWait(obj_15);
    delayClear();
    delayWait(10);
    unitSpawn(maya, sprite_0, 300, 0, -1850, south, fade);
    unitMove(maya, 300, -1650, face_south, medium);
    unitWait(maya);
    objAnimRotate(obj_15, 0, -80, 0, 60, 0);
    sndMusicPlay(sound_3111, 127);
    delayClear();
    delayWait(10);
    cameraMoveTo(700, 0, -1100, 120);
    ref_8e = call(MAYAMOVE);
    unitAnimationPlay(yukino, animation_0, 1);
    unitAnimationPlay(fujii, animation_4, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(yukino, animation_1, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(yukino, animation_2, 1);
    delayClear();
    delayWait(30);
    unitFace(yukino, east);
    unitFace(fujii, west);
    unitAnimationPlay(yukino, animation_0, 1);
    unitAnimationPlay(fujii, animation_0, 1);
    delayClear();
    delayWait(7);
    unitFace(yukino, north);
    unitFace(fujii, north);
    delayClear();
    delayWait(20);
    unitAnimationPlay(enemy2, animation_0, 1);
    unitAnimationPlay(enemy1, animation_4, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(enemy2, animation_1, 1);
    unitFace(enemy1, west);
    unitAnimationPlay(enemy1, animation_1, 1);
    delayClear();
    delayWait(7);
    unitFace(enemy2, east);
    unitAnimationPlay(enemy2, animation_3, 1);
    unitAnimationPlay(enemy1, animation_2, 1);
    wait(ref_8e);
    ref_b0 = bustupLoad(bustup_11a);
    bustupWait(ref_b0);
    ref_b2 = bustupAlloc(ref_b0, right, rgb(0,0,0));
    bustupFade(ref_b2, rgb(128,0,0), 30);
    ref_b4 = dialogAlloc();
    ref_b5 = msgShow(msg_1);
/***************************************
[color(yellow)]ゆきの[color(white)]
[tab]舞耶さん…
[tab]ワンロン千鶴と、どんなこと話したんだい？
[sync][wait][clear]
***************************************/
    unitAnimationPlay(yukino, animation_2d, 1);
    unitAnimationPlay(maya, animation_3, 1);
    delayClear();
    delayWait(60);
    sync();
    wait(ref_b5);
    dialogFree(ref_b4);
    ref_bd = bustupFade(ref_b2, rgb(0,0,0), 10);
    bustupWait(ref_bd);
    bustupFree(ref_b2);
    unitAnimationPlay(yukino, animation_a, 1);
    ref_c1 = bustupLoad(bustup_d5);
    bustupWait(ref_c1);
    ref_c3 = bustupAlloc(ref_c1, right, rgb(0,0,0));
    bustupFade(ref_c3, rgb(128,0,0), 30);
    ref_c5 = dialogAlloc();
    ref_c6 = msgShow(msg_2);
/***************************************
[color(yellow)]藤井[color(white)]
[tab]丁度今、その御当人が出てる特番を見ててね。
[tab]何やら、ＪＯＫＥＲの正体を占うっていうんだが…
[sync][wait][clear]
***************************************/
    unitAnimationPlay(fujii, animation_24, 1);
    unitAnimationPlay(maya, animation_0, 1);
    delayClear();
    delayWait(60);
    sync();
    wait(ref_c6);
    dialogFree(ref_c5);
    ref_ce = bustupFade(ref_c3, rgb(0,0,0), 10);
    bustupWait(ref_ce);
    bustupFree(ref_c3);
    unitAnimationPlay(fujii, animation_0, 1);
    delayClear();
    delayWait(30);
    ref_d4 = cameraRotateTo(1, 1);
    wait(ref_d4);
    delayClear();
    delayWait(30);
    ref_d8 = dialogAlloc();
    ref_d9 = msgShow(msg_3);
/***************************************
[color(yellow)]ＴＶ画面のアナウンサー[color(white)]
[tab]…ということは、
[tab]ズバリ、ＪＯＫＥＲとは一体何者なんでしょう？
[sync][wait][clear]
***************************************/
    unitAnimationPlay(yukino, animation_b, 1);
    unitAnimationPlay(fujii, animation_1, 1);
    unitAnimationPlay(enemy1, animation_1, 1);
    unitAnimationPlay(enemy2, animation_0, 1);
    unitAnimationPlay(maya, animation_d, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(fujii, animation_2, 1);
    unitAnimationPlay(enemy1, animation_0, 1);
    unitAnimationPlay(enemy2, animation_1, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(enemy2, animation_2, 1);
    delayClear();
    delayWait(45);
    sync();
    wait(ref_d9);
    ref_eb = msgShow(msg_4);
/***************************************
[color(yellow)]ワンロン千鶴[color(white)]
[tab]ＪＯＫＥＲは…
[tab]「女媧（じょか）」という、ワンロン占いにおける
[tab]穢れ…罪や妬みなどの邪気に憑かれた人間です。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_eb);
    ref_ee = msgShow(msg_5);
/***************************************
[color(yellow)]ワンロン千鶴[color(white)]
[tab]女媧は、穢れに満ちた龍で、
[tab]守護龍がこの周期に入ると凶運に見舞われます…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_ee);
    ref_f1 = msgShow(msg_6);
/***************************************
[color(yellow)]ワンロン千鶴[color(white)]
[tab]皆さんも、天中殺や暗剣殺といった
[tab]スランプ概念はご存知でしょう？
[tab]それのより強いもの、と考えて頂いて結構です。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_f1);
    ref_f4 = msgShow(msg_7);
/***************************************
[color(yellow)]ワンロン千鶴[color(white)]
[tab]穢れは更なる穢れを呼び、女媧は罪を重ねさせる…
[tab]人が罪を重ねれば、穢れは更に力を増していきます。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_f4);
    ref_f7 = msgShow(msg_8);
/***************************************
[color(yellow)]ワンロン千鶴[color(white)]
[tab]因果応報…妬みや恨みに駆られて、
[tab]ＪＯＫＥＲ呪いなどしてはいけません！
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_f7);
    ref_fa = msgShow(msg_9);
/***************************************
[color(yellow)]ワンロン千鶴[color(white)]
[tab]そのような事をすれば女媧に憑りつかれ、
[tab]呪いを行った人自身がＪＯＫＥＲになってしまう
[tab]でしょう…
[sync][wait][clear]
***************************************/
    sndVolumeFadeOff(sound_3035, 300);
    sync();
    wait(ref_fa);
    dialogFree(ref_d8);
    unitAnimationHold(yukino, animation_21, 60);
    unitAnimationHold(fujii, animation_1b, 60);
    unitAnimationHold(maya, animation_21, 60);
    unitAnimationHold(enemy1, animation_1b, 60);
    unitAnimationHold(enemy2, animation_1b, 60);
    ref_104 = dialogAlloc();
    ref_105 = msgShow(msg_10);
/***************************************
[color(yellow)]ＴＶ画面のアナウンサー[color(white)]
[tab]なんと…！
[tab]ではＪＯＫＥＲとは、特定の個人を指すのではない
[tab]ということですか…！？
[sync][wait][clear]
***************************************/
    unitWait(yukino);
    unitWait(fujii);
    unitWait(maya);
    unitWait(enemy1);
    unitWait(enemy2);
    unitAnimationPlay(yukino, animation_b, 1);
    unitAnimationPlay(fujii, animation_2, 1);
    unitAnimationPlay(enemy1, animation_0, 1);
    unitAnimationPlay(enemy2, animation_2, 1);
    unitAnimationPlay(maya, animation_3, 1);
    sync();
    wait(ref_105);
    dialogFree(ref_104);
    delayClear();
    delayWait(90);
    unitAnimationPlay(yukino, animation_a, 1);
    unitAnimationPlay(fujii, animation_1, 1);
    unitAnimationPlay(maya, animation_a, 1);
    unitAnimationPlay(enemy1, animation_0, 1);
    unitAnimationPlay(enemy2, animation_1, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(yukino, animation_d, 1);
    delayClear();
    delayWait(90);
    ref_11f = screenHorizontalFadeOut();
    wait(ref_11f);
    eventLoad(event_a7);
}

function BORYUMOVE1()
{
    cameraMoveTo(1000, 0, -100, 600);
    unitMove(unit_15, 1200, -1650, face_west, medium);
    unitWait(unit_15);
}

function BORYUMOVE2()
{
    unitMove(unit_15, 1200, -100, face_south, medium);
    unitWait(unit_15);
    cameraRotateTo(7, 1);
}

function BORYUMOVE3()
{
    unitMove(unit_15, 1000, -100, face_east, medium);
    unitWait(unit_15);
    unitFace(unit_15, south);
}

function BORYUMOVE4()
{
    delayClear();
    delayWait(60);
    sndMusicPlay(sound_310f, 127);
    objAnimTranslate(obj_13, 100, 0, 0, 60);
    objAnimTranslate(obj_14, -200, 0, 0, 60);
    objAnimWait(obj_13);
    objAnimWait(obj_14);
    unitMove(unit_15, 1000, 50, fade, medium);
    unitWait(unit_15);
    sndMusicPlay(sound_310f, 127);
    objAnimTranslate(obj_13, -100, 0, 0, 60);
    objAnimTranslate(obj_14, 200, 0, 0, 60);
    objAnimWait(obj_13);
    objAnimWait(obj_14);
    delayClear();
    delayWait(60);
}

function MAYAMOVE()
{
    unitMove(maya, 600, -1650, face_west, medium);
    unitWait(maya);
    unitMove(maya, 600, -1280, face_south, medium);
    unitWait(maya);
}
