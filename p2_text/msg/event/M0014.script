    ref_80 = dialogAlloc();
    ref_81 = msgShow(msg_2);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]あのコが言ってるのって、[tatsuya]君の事よね？
[tab]やっぱ有名人なのね。
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2d, 1);
    wait(ref_81);
    unitAnimationPlay(ulala, animation_a, 1);
    dialogFree(ref_80);
    ref_86 = bustupFade(ref_7e, rgb(0,0,0), 10);
    bustupWait(ref_86);
