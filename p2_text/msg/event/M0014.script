    bustupWait(ref_8c);
    ref_8e = bustupAlloc(ref_8c, left, rgb(0,0,0));
    bustupFade(ref_8e, rgb(128,0,0), 30);
    ref_90 = dialogAlloc();
    bitGet(var_0, MBIT_HI_NANJOTOUJO);
    bne(var_0, 0, label_9a);
    ref_93 = msgShow(msg_3);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]南条君が言ってたコ、いないねぇ？
[tab]ＪＯＫＥＲに狙われていたらしいけど…
[tab]もしかして…逃げてる真っ最中？
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2d, 1);
    wait(ref_93);
    ref_96 = msgShow(msg_4);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]…ゴメン、不謹慎だね。
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_6, 1);
    wait(ref_96);
    b(label_9f);
  label_9a:
    bne(var_0, 1, label_9f);
    ref_9b = msgShow(msg_5);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]栄吉君、ちゃんとみんなの所に顔だしてたんだね。
[tab]よかったぁ～みんなを心配させたままじゃ
[tab]カワイそうだもんね。
[wait][clear]
***************************************/
