function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    sndMusicPlay(sound_3043, 127);
    levelFootstepSet(sfx_18);
    envTriggerSet(DOORBOX, 131, 1, line, coll_20);
    cameraSet(southwest, 240, -300, -1640);
    li(var_0, 0);
    li(var_1, 0);
    partyMemberCheck(var_0, ulala);
    add(var_1, var_1, var_0);
    partyMemberCheck(var_0, katsuya);
    add(var_1, var_1, var_0);
    partyMemberCheck(var_0, baofu);
    add(var_1, var_1, var_0);
    partyMemberCheck(var_0, nanjo);
    add(var_1, var_1, var_0);
    partyMemberCheck(var_0, elly);
    add(var_1, var_1, var_0);
    boutrange(var_1, 0, 4, label_15);
    li(var_0, 0);
    b(label_1a);
  label_15:
    ref_15 = dialogAlloc();
    ref_16 = msgShow(msg_0);
/***************************************
パーティの人数が四人を超えています。
このままじゃハングします。
金田・片岡に連絡してください。
[wait][clear]
***************************************/
    wait(ref_16);
    dialogFree(ref_15);
    b(label_1a);
  label_1a:
    bitGet(var_0, EBIT_E0046);
    bez(var_0, label_28);
    partyMemberCheck(var_0, nanjo);
    bez(var_0, label_22);
    ref_1e = spriteLoad(sprite_1f);
    wait(ref_1e);
    unitSpawn(nanjo, sprite_1f, 280, 0, -1230, south, none);
    unitTriggerSet(nanjo, B_NANJ, 255, 1);
  label_22:
    partyMemberCheck(var_0, elly);
    bez(var_0, label_28);
    ref_24 = spriteLoad(sprite_23);
    wait(ref_24);
    unitSpawn(elly, sprite_23, 470, 0, -1540, south, none);
    unitTriggerSet(elly, B_ERI, 255, 1);
  label_28:
    bitGet(var_0, EBIT_E003E);
    bnz(var_0, label_30);
    bitGet(var_0, EBIT_E0038);
    bez(var_0, label_30);
    ref_2c = spriteLoad(sprite_6a);
    wait(ref_2c);
    unitSpawn(makimura, sprite_6a, 1090, 0, -1400, west, none);
    unitTriggerSet(makimura, B_KATUYYY, 255, 1);
  label_30:
    partyMemberCheck(var_0, ulala);
    bez(var_0, label_36);
    ref_32 = spriteLoad(sprite_6);
    wait(ref_32);
    unitSpawn(ulala, sprite_6, 800, 0, -900, south, none);
    unitTriggerSet(ulala, B_URARATI, 255, 1);
  label_36:
    partyMemberCheck(var_0, katsuya);
    bez(var_0, label_3c);
    ref_38 = spriteLoad(sprite_d);
    wait(ref_38);
    unitSpawn(katsuya, sprite_d, 1160, 0, -1250, west, none);
    unitTriggerSet(katsuya, B_KATUYYY, 255, 1);
  label_3c:
    partyMemberCheck(var_0, baofu);
    bez(var_0, label_42);
    ref_3e = spriteLoad(sprite_13);
    wait(ref_3e);
    unitSpawn(baofu, sprite_13, 490, 0, -460, south, none);
    unitTriggerSet(baofu, B_PAO, 255, 1);
  label_42:
