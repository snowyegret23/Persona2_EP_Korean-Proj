    b(label_310);
  label_2fb:
    ref_2fb = bustupLoad(bustup_d0);
    bustupWait(ref_2fb);
    ref_2fd = bustupAlloc(ref_2fb, right, rgb(0,0,0));
    bustupFade(ref_2fd, rgb(128,0,0), 30);
    unitFacePlayer(miyabi);
    ref_300 = dialogAlloc();
    ref_301 = msgShow(msg_50);
/***************************************
[color(yellow)]雅[color(white)]
[tab]栄吉君、詳しいことは何も言わずに
[tab]出て行きました。
[wait][clear]
***************************************/
    unitAnimationPlay(miyabi, animation_24, 1);
    wait(ref_301);
    ref_304 = call(MIYABISHOKAI2);
    wait(ref_304);
    ref_306 = msgShow(msg_51);
/***************************************
[color(yellow)]雅[color(white)]
[tab]…何があったか分かりませんが、
[tab]何か大事な事を忘れている気がするって。
[wait][clear]
***************************************/
    unitAnimationPlay(miyabi, animation_24, 1);
    wait(ref_306);
    unitAnimationPlay(miyabi, animation_0, 1);
    dialogFree(ref_300);
    ref_30b = bustupFade(ref_2fd, rgb(0,0,0), 10);
    bustupWait(ref_30b);
    bustupFree(ref_2fd);
    unitRestoreFacing(miyabi);
    b(label_310);
  label_310:
    controlEnable();
}

