    bne(var_0, 1, label_1ee);
    bitGet(var_0, EBIT_MITUKETERU);
    bne(var_0, 0, label_1ea);
    b(label_1fc);
    b(label_1ed);
  label_1ea:
    bne(var_0, 1, label_1ed);
    b(label_1ee);
    b(label_1ed);
  label_1ed:
    b(label_1ee);
  label_1ee:
    ref_1ee = bustupLoad(bustup_12);
    bustupWait(ref_1ee);
    ref_1f0 = bustupAlloc(ref_1ee, left, rgb(0,0,0));
    bustupFade(ref_1f0, rgb(128,0,0), 30);
    ref_1f2 = dialogAlloc();
    ref_1f3 = msgShow(msg_18);
/***************************************
[color(yellow)][tatsuya][color(white)]
[tab]済まない、栄吉…
[tab]あんな辛い思い…思い出す必要はなかったのに…
[wait][clear]
***************************************/
    unitAnimationPlay(tatsuya, animation_6, 1);
    wait(ref_1f3);
    unitAnimationPlay(tatsuya, animation_a, 1);
    dialogFree(ref_1f2);
    ref_1f8 = bustupFade(ref_1f0, rgb(0,0,0), 10);
    bustupWait(ref_1f8);
    bustupFree(ref_1f0);
    b(label_209);
  label_1fc:
    ref_1fc = bustupLoad(bustup_10);
    bustupWait(ref_1fc);
    ref_1fe = bustupAlloc(ref_1fc, left, rgb(0,0,0));
    bustupFade(ref_1fe, rgb(128,0,0), 30);
    ref_200 = dialogAlloc();
    ref_201 = msgShow(msg_19);
/***************************************
[color(yellow)][tatsuya][color(white)]
[tab]守ってみせる…
[tab]「こちら側」も…みんなの記憶も…
[wait][clear]
***************************************/
    unitAnimationPlay(tatsuya, animation_2f, 1);
    wait(ref_201);
    unitAnimationPlay(tatsuya, animation_a, 1);
    dialogFree(ref_200);
    ref_206 = bustupFade(ref_1fe, rgb(0,0,0), 10);
    bustupWait(ref_206);
    bustupFree(ref_1fe);
  label_209:
    controlEnable();
}

function KATUYABOX()
{
    controlDisable();
    unitFacePlayer(katsuya);
    ref_20d = bustupLoad(bustup_23);
    bustupWait(ref_20d);
    ref_20f = bustupAlloc(ref_20d, left, rgb(0,0,0));
    bustupFade(ref_20f, rgb(128,0,0), 30);
    ref_211 = dialogAlloc();
    ref_212 = msgShow(msg_20);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]天野君…奴は、怒りが影の力の源だと言ったね…？
[tab]申し訳ないが…僕は自分を抑えられそうにない…
[wait][clear]
***************************************/
    unitAnimationPlay(katsuya, animation_1a, 1);
    wait(ref_212);
    ref_215 = msgShow(msg_21);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]僕をどれだけ蔑もうが構わない…
[tab]だが…[tatsuya]や皆に対するこの仕打ちだけは
[tab]がまんならん…
[wait][clear]
***************************************/
    unitAnimationPlay(katsuya, animation_2f, 1);
    wait(ref_215);
    unitAnimationPlay(katsuya, animation_a, 1);
    dialogFree(ref_211);
    ref_21a = bustupFade(ref_20f, rgb(0,0,0), 10);
    bustupWait(ref_21a);
    bustupFree(ref_20f);
    unitRestoreFacing(katsuya);
    controlEnable();
}

