function FREEBOX()
{
    sndIdGet(var_0);
    bne(var_0, -1, label_48);
    ref_44 = sndLoad(sound_1260);
    wait(ref_44);
    sndMusicPlay(sound_1260, 90);
    b(label_4a);
  label_48:
    sndVolumeFadeTo(var_0, 90, 60);
    b(label_4a);
  label_4a:
    sndUnkCF(90);
    unitSpawn(ulala, sprite_6, 1093, 0, -1512, west, none);
    unitTriggerSet(ulala, URARABOX, 255, 1);
    unitSpawn(baofu, sprite_13, 1386, 0, -1716, south, none);
    unitTriggerSet(baofu, PAOBOX, 255, 1);
    unitSpawn(tatsuya, sprite_18, 1339, 0, -1488, south, none);
    unitTriggerSet(tatsuya, TATUYABOX, 255, 1);
    unitSpawn(katsuya, sprite_d, 1610, 0, -1380, east, none);
    unitTriggerSet(katsuya, KATUYABOX, 255, 1);
    unitAnimationPlay(ulala, animation_a, 1);
    unitAnimationPlay(katsuya, animation_a, 1);
    unitAnimationPlay(baofu, animation_a, 1);
    unitAnimationPlay(tatsuya, animation_a, 1);
    cameraSetNorth(west);
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 5, true);
    screenFadeOuter(rgb(0,0,0), 5, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

