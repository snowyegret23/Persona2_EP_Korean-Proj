    ref_5d = spriteLoad(sprite_0);
    wait(ref_5d);
    ref_5f = spriteLoad(sprite_2);
    wait(ref_5f);
    playerInit(south);
    controlDisable();
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    unitIdleOnAll();
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

