function START()
{
    sndMusicPlay(sound_406b, 127);
    ref_1 = spriteLoad(sprite_18);
    wait(ref_1);
    ref_3 = spriteLoad(sprite_1a);
    wait(ref_3);
    ref_5 = spriteLoad(sprite_199);
    wait(ref_5);
    ref_7 = spriteLoad(sprite_f4);
    wait(ref_7);
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    cameraSet(northwest, 350, 0, -240);
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    delayClear();
    delayWait(30);
    objAnimRotate(obj_5, 0, -80, 0, 60, 0);
    sndMusicPlay(sound_30ca, 127);
    objAnimWait(obj_5);
    unitSpawn(tatsuya, sprite_18, 300, 0, 60, north, none);
    unitMove(tatsuya, 300, -60, face_north, medium);
    unitWait(tatsuya);
    objAnimRotate(obj_5, 0, 80, 0, 60, 0);
    sndMusicPlay(sound_30cb, 127);
    delayClear();
    delayWait(60);
    unitFace(tatsuya, south);
    unitMove(tatsuya, 420, -60, face_north, medium);
    unitWait(tatsuya);
    unitMove(tatsuya, 420, -300, face_north, medium);
    unitWait(tatsuya);
    unitAnimationPlay(tatsuya, animation_b, 1);
    delayClear();
    delayWait(60);
    unitAnimationPlay(tatsuya, animation_a, 1);
    delayClear();
    delayWait(5);
    unitAnimationPlay(tatsuya, animation_d, 1);
    delayClear();
    delayWait(60);
    unitAnimationPlay(tatsuya, animation_a, 1);
    delayClear();
    delayWait(5);
    unitAnimationPlay(tatsuya, animation_b, 1);
    delayClear();
    delayWait(30);
    ref_31 = dialogAlloc();
    ref_32 = msgShow(msg_0);
/***************************************
ここも密室には違いないが、宮代[tab]詩織の姿はなかった。
吉栄の話では、彼女はＪＯＫＥＲを逮捕するために
自分の殺害を依頼したらしい。
[wait][clear]
***************************************/
    wait(ref_32);
    ref_34 = msgShow(msg_1);
/***************************************
普通、刑事が一人でそこまでしないだろう。
兄さん以外の警官には、連絡するなと口止めしたことも
気になる。
[wait][clear]
***************************************/
    wait(ref_34);
    ref_36 = msgShow(msg_2);
/***************************************
何か事情があるのだろうが…
まさか、警察とＪＯＫＥＲの間に何か関係があるのか？
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_36);
    dialogFree(ref_31);
    sndMusicPlay(sound_3028, 127);
    screenFlash(255, 255, 255);
    screenColorAdjust(0.5, 0.5, 0.61328125);
    unitSpriteClear(tatsuya);
    unitSpriteSet(tatsuya, sprite_1a);
    unitJumpTo(tatsuya, 450, 0, -224, 10, 0);
    sndMusicPlay(sound_32e5, 127);
    unitFace_2(tatsuya, north);
    unitAnimationPlay(tatsuya, animation_a, 1);
    unitFace_2(tatsuya, north);
    unitWait(tatsuya);
    unitAnimationPlay(tatsuya, animation_d, 1);
    unitWait(tatsuya);
    delayClear();
    delayWait(60);
    screenFlash(0, 0, 0);
    unitSpawn(enemy1, sprite_199, 450, 0, -500, south, none);
    ref_4b = efctAuraLoad();
    wait(ref_4b);
    ref_4d = dialogAlloc();
    ref_4e = msgShow(msg_3);
/***************************************
テーブルの上に鍵を見つけ近寄ろうとすると、
吐き気を催す臭いと共に部屋の角がぐにゃりと歪み、
汚穢な触手が歪んだ空間から数本伸びて来た。
[wait][clear]
***************************************/
    wait(ref_4e);
    ref_50 = msgShow(msg_4);
/***************************************
寸でのところで飛び退いてかわすと、触手は部屋の四方に
粘液を飛び散らせ張り付いた。
壁から激しく煙が上がる。
そいつの腕が溶かしているのだ。
[wait][clear]
***************************************/
    wait(ref_50);
    ref_52 = msgShow(msg_5);
/***************************************
壁に伸ばした触手を足がかりに、次元を切り裂き何かが
無理矢理こちら側にやって来ようとしている。
壁と同じように、俺の全身も編立った。
こいつも今まで見たことがない奴だ。
[wait][clear]
***************************************/
    wait(ref_52);
    ref_54 = msgShow(msg_6);
/***************************************
どうも、こちら側の悪魔は向こう側で見た奴らより
悪趣味でグロテスクだ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_54);
    dialogFree(ref_4d);
    ref_58 = dialogAlloc();
    ref_59 = msgShow(msg_7);
/***************************************
[color(yellow)]汚穢な化け物[color(white)]
[tab]Ｉａ！[tab]ＳＨＵＢ－ＮＩＧＧＵＲＡＴＨ！
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_59);
    dialogFree(ref_58);
    unitAnimationPlay(tatsuya, animation_0, 1);
    sndMusicPlay(sound_32e9, 127);
    ref_5f = dialogAlloc();
    ref_60 = msgShow(msg_8);
/***************************************
爛れた雲のような、損のような、ねじくれた木のような
そいつの身体では、粘液を垂れ流す無数の口が牙を
鳴らしていた。黒い足は山羊の仙のように割れている。
普通の人間がこんな奴を見たら発狂するだろう。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_60);
    dialogFree(ref_5f);
    sndMusicPlay(sound_3309, 127);
    unitAura(tatsuya, true);
    delayClear();
    delayWait(30);
    ref_68 = unitEfctPersona(tatsuya, unit_62, sprite_f4);
    unitFace(unit_62, north);
    wait(ref_68);
    ref_6b = dialogAlloc();
    ref_6c = msgShow(msg_9);
/***************************************
ペルソナ能力に覚醒すると、神や悪魔のような力を持った
もうひとりの自分、ペルソナを召還できるようになる。
俺のアポロのように、火を司る神を呼び出せば、
自在に炎を操ることもできる。
[wait][clear]
***************************************/
    wait(ref_6c);
    ref_6e = msgShow(msg_10);
/***************************************
人の心の奥底には、全ての人間が共有する神話的元型が
棲む領域があり、個々人の人格形成に影響を与えている。
世界中の神話が似たような神性、エピソードを持つのも
そのためだろうと、舞耶姉は言っていた。
[wait][clear]
***************************************/
    wait(ref_6e);
    ref_70 = msgShow(msg_11);
/***************************************
神や悪魔は、天上や魔界ではなく人の心の中にいるのだ。
ペルソナは、身体能力や精神にも影響を及ぼす。
俺が達人のように刀を扱えるのも、恐怖に耐性があるのも
ペルソナのおかげだ。
[wait][clear]
***************************************/
    wait(ref_70);
    ref_72 = msgShow(msg_12);
/***************************************
神や悪魔だけが、人の心に眠る元型ではない。
普遍的無意識が、全ての人の心が生まれ帰る場所なら、
剣聖や銃の名手である俺もまた、無意識の世界の
どこかにはいるってことだろう。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_72);
    dialogFree(ref_6b);
    ref_76 = bustupLoad(bustup_b);
    bustupWait(ref_76);
    ref_78 = bustupAlloc(ref_76, left, rgb(0,0,0));
    bustupFade(ref_78, rgb(128,0,0), 30);
    ref_7a = dialogAlloc();
    ref_7b = msgShow(msg_13);
/***************************************
[color(yellow)][tatsuya][color(white)]
[tab]だが、お前も俺もこちら側には不要な生き物だ。
[tab]帰ってもらおうか。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_7b);
    dialogFree(ref_7a);
    ref_7f = bustupFade(ref_78, rgb(0,0,0), 10);
    bustupWait(ref_7f);
    bustupFree(ref_78);
    ref_82 = dialogAlloc();
    ref_83 = msgShow(msg_14);
/***************************************
早くケリをつけなければ、こいつの臭いと
壁が焼ける臭いで桃息しそうだ。
いくらペルソナ使いでも、息ができなきゃ死ぬだろう。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_83);
    dialogFree(ref_82);
    delayClear();
    delayWait(60);
    encounterLoad(encounter_41);
}
