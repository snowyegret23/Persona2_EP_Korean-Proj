function EXIT1()
{
    controlDisable();
    sndMusicPlay(sound_328b, 127);
    objAnimTranslate(obj_4, 100, 0, 0, 30);
    ref_180 = objAnimTranslate(obj_5, -100, 0, 0, 30);
    wait(ref_180);
    wait(ref_180);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 4, false);
    screenFadeOuter(rgb(255,255,255), 4, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    cameraSetNorth(south);
    dngLoad2(torifune2-6);
}

