function FREE()
{
    sndIdGet(var_a);
    bne(var_a, -1, label_d0);
    ref_cc = sndLoad(sound_1580);
    wait(ref_cc);
    sndMusicPlay(sound_1580, 90);
    b(label_d2);
  label_d0:
    sndVolumeFadeTo(var_a, 90, 60);
    b(label_d2);
  label_d2:
    sndUnkCF(90);
    levelFootstepSet(sfx_1a);
    ref_d4 = spriteLoad(sprite_0);
    wait(ref_d4);
    ref_d6 = spriteLoad(sprite_2);
    wait(ref_d6);
    ref_d8 = spriteLoad(sprite_6);
    wait(ref_d8);
    ref_da = spriteLoad(sprite_d);
    wait(ref_da);
    ref_dc = spriteLoad(sprite_13);
    wait(ref_dc);
    ref_de = spriteLoad(sprite_18);
    wait(ref_de);
    unitSpawn(ulala, sprite_6, 1000, 0, -920, west, none);
    unitSpawn(katsuya, sprite_d, 270, 0, -1070, east, none);
    unitSpawn(baofu, sprite_13, 750, 0, -450, south, none);
    unitSpawn(tatsuya, sprite_18, 640, 0, -930, south, none);
    unitTriggerSet(ulala, URARA, 255, 1);
    unitTriggerSet(katsuya, KATUYA, 255, 1);
    unitTriggerSet(baofu, PAOFU, 255, 1);
    unitTriggerSet(tatsuya, TATUYA, 255, 1);
    envTriggerSet(EXIT1, 131, 1, line, coll_2b);
    envTriggerSet(EXIT2, 56, 1, line, coll_2a);
    cameraSetNorth(south);
    unknownVar1(var_2);
    bne(var_2, 11270, label_f1);
    cameraSet(southwest, 600, 0, -1550);
    playerInit(south);
    controlDisable();
    b(label_f5);
  label_f1:
    cameraSet(northeast, 600, 0, -50);
    playerInit(north);
    controlDisable();
    b(label_f5);
  label_f5:
    unitIdleOnAll();
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 4, true);
    screenFadeOuter(rgb(0,0,0), 4, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

function PAOFU_SMOKE()
{
    sndMusicPlay(sound_328c, 127);
    unitAnimationPlay(baofu, animation_18, 1);
    unitWait(baofu);
    unitAnimationPlay(baofu, animation_19, 1);
    unitWait(baofu);
  label_102:
    bnz(var_1, label_112);
    delayClear();
    delayWait(30);
    bnz(var_1, label_112);
    delayClear();
    delayWait(30);
    bnz(var_1, label_112);
    delayClear();
    delayWait(30);
    bnz(var_1, label_112);
    delayClear();
    delayWait(30);
    bnz(var_1, label_112);
    unitAnimationPlay(baofu, animation_19, 1);
    unitWait(baofu);
    bez(var_1, label_102);
  label_112:
    unitAnimationPlay(baofu, animation_13, 1);
    delayClear();
    delayWait(60);
    unitSpriteClear(baofu);
    unitSpriteSet(baofu, sprite_13);
    unitSpawn(baofu, sprite_13, 610, 0, -700, south, none);
    unitAnimationPlay(baofu, animation_a, 1);
}

function KATUYA_IDO()
{
    unitMove(katsuya, 400, -940, face_east, slow);
    unitWait(katsuya);
    unitAnimationPlay(katsuya, animation_10, 1);
    delayClear();
    delayWait(30);
    unitAnimationHold(katsuya, animation_16, -1);
}

function URARA()
{
    controlDisable();
    unitFacePlayer(ulala);
    unitAnimationPlay(ulala, animation_1f, 1);
    ref_124 = bustupLoad(bustup_17);
    bustupWait(ref_124);
    ref_126 = bustupAlloc(ref_124, left, rgb(0,0,0));
    bustupFade(ref_126, rgb(128,0,0), 30);
    ref_128 = dialogAlloc();
    ref_129 = msgShow(msg_8);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]私は一人っ子だから経験ないけどさ、
[tab]兄弟っていいもんね…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_129);
    unitAnimationPlay(ulala, animation_6, 1);
    ref_12d = msgShow(msg_9);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]克哉さんがボソって話してくれたんだけど、
[tab][tatsuya]君、お父さんの事でグレてたらしいよ…
[tab]尊敬、してたんじゃないのかな…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_12d);
    unitAnimationPlay(ulala, animation_14, 1);
    ref_131 = msgShow(msg_10);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]克哉さんはそれをどうにかしたくて刑事になった。
[tab]弟の性格を知ってるから、本当の事は言えない、
[tab]自分がお父さんの汚名を晴らすってね…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_131);
    dialogFree(ref_128);
    ref_135 = bustupFade(ref_126, rgb(0,0,0), 10);
    bustupWait(ref_135);
    bustupFree(ref_126);
    unitAnimationPlay(ulala, animation_a, 1);
    unitRestoreFacing(ulala);
    controlEnable();
}

function KATUYA()
{
