function ENEMY4MOVE()
{
  label_9e:
    ref_9e = unitMove(enemy4, 850, -850, face_north, medium);
    unitAnimationPlay(enemy4, animation_1b, 1);
    wait(ref_9e);
    delayClear();
    delayWait(30);
    ref_a3 = unitMove(enemy4, 850, -900, face_north, medium);
    unitAnimationPlay(enemy4, animation_7, 1);
    wait(ref_a3);
    delayClear();
    delayWait(30);
    ref_a8 = unitMove(enemy4, 850, -850, face_north, reverse);
    unitAnimationPlay(enemy4, animation_7, 1);
    wait(ref_a8);
    delayClear();
    delayWait(30);
    ref_ad = unitMove(enemy4, 850, -800, face_north, reverse);
    unitAnimationPlay(enemy4, animation_7, 1);
    wait(ref_ad);
    delayClear();
    delayWait(30);
    b(label_9e);
}

