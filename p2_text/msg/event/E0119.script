    ref_194 = bustupFade(ref_18d, rgb(0,0,0), 10);
    bustupWait(ref_194);
    bustupFree(ref_18d);
    msgVar_Item(msgvar_0, death_card);
    ref_198 = dialogAlloc();
    ref_199 = msgShow(msg_31);
/***************************************
[color(green)]舞耶達は、[var(msg_var_0)]のカードを５０枚
手に入れた。[color(white)]
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_199);
    dialogFree(ref_198);
    partyItemAdd(death_card, 50);
    b(label_19f);
  label_19f:
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    ref_1a5 = dialogAlloc();
    ref_1a6 = msgShow(msg_32);
/***************************************
[color(green)]舞耶達は、記憶のトラペゾヘドロンを手に入れ、
記憶の塔を後にした。[color(white)]
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_1a6);
    dialogFree(ref_1a5);
    bitSet(bit_c83);
    dngLoad2(kadath_mandala2-8);
}
