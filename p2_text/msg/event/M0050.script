function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    sndIdGet(var_0);
    bne(var_0, -1, label_5);
    b(label_7);
  label_5:
    sndVolumeFadeTo(var_0, 90, 60);
    b(label_7);
  label_7:
    sndUnkCF(90);
    envTriggerSet(DOORBOX, 131, 1, line, coll_0);
    cameraSetNorth(north);
    cameraSet(southeast, 300, 0, -630);
    partyMemberCheck(var_0, ulala);
    bez(var_0, label_11);
    ref_d = spriteLoad(sprite_6);
    wait(ref_d);
    unitSpawn(ulala, sprite_6, 460, 0, -525, west, none);
    unitTriggerSet(ulala, B_URARATI, 255, 1);
  label_11:
    partyMemberCheck(var_0, katsuya);
    bez(var_0, label_17);
    ref_13 = spriteLoad(sprite_d);
    wait(ref_13);
    unitSpawn(katsuya, sprite_d, 370, 0, -100, west, none);
    unitTriggerSet(katsuya, B_KATUYYY, 255, 1);
  label_17:
    partyMemberCheck(var_0, baofu);
    bez(var_0, label_1d);
    ref_19 = spriteLoad(sprite_13);
    wait(ref_19);
    unitSpawn(baofu, sprite_13, 80, 0, -310, east, none);
    unitTriggerSet(baofu, B_PAO, 255, 1);
  label_1d:
    ref_1d = spriteLoad(sprite_e4);
    wait(ref_1d);
    unitSpawn(npc1, sprite_e4, 540, 0, -640, west, none);
    unitTriggerSet(npc1, NIGEOKURE, 255, 1);
    ref_21 = spriteLoad(sprite_0);
    wait(ref_21);
    ref_23 = spriteLoad(sprite_2);
    wait(ref_23);
    playerInit(south);
    controlDisable();
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    unitIdleOnAll();
    unitAnimationPlay(npc1, animation_20, 1);
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

function B_URARATI()
{
    controlDisable();
    unitFacePlayer(ulala);
    ref_32 = bustupLoad(bustup_17);
    bustupWait(ref_32);
    ref_34 = bustupAlloc(ref_32, left, rgb(0,0,0));
    bustupFade(ref_34, rgb(128,0,0), 30);
    ref_36 = dialogAlloc();
    ref_37 = msgShow(msg_0);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]この人さっき、
[tab]悪魔と戦う謎の武装グループを見た！
[tab]とか言ってたんだけど…
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2d, 1);
    wait(ref_37);
    ref_3a = msgShow(msg_1);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]それって、
[tab]あそこで死んでたマフィアのコトかな？
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2d, 1);
    wait(ref_3a);
    unitAnimationPlay(ulala, animation_a, 1);
    dialogFree(ref_36);
    ref_3f = bustupFade(ref_34, rgb(0,0,0), 10);
    bustupWait(ref_3f);
    bustupFree(ref_34);
    unitRestoreFacing(ulala);
    controlEnable();
}

function B_KATUYYY()
{
    controlDisable();
    unitFacePlayer(katsuya);
    ref_47 = bustupLoad(bustup_21);
    bustupWait(ref_47);
    ref_49 = bustupAlloc(ref_47, left, rgb(0,0,0));
    bustupFade(ref_49, rgb(128,0,0), 30);
    ref_4b = dialogAlloc();
    ref_4c = msgShow(msg_2);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]あの職員、かなり混乱しているようだが、
[tab]この惨状を見ると…全て事実と考えるべきか。
[wait][clear]
***************************************/
    unitAnimationPlay(katsuya, animation_1a, 1);
    wait(ref_4c);
    unitAnimationPlay(katsuya, animation_a, 1);
    dialogFree(ref_4b);
    ref_51 = bustupFade(ref_49, rgb(0,0,0), 10);
    bustupWait(ref_51);
    bustupFree(ref_49);
    unitRestoreFacing(katsuya);
    controlEnable();
}

function B_PAO()
{
    controlDisable();
    unitFacePlayer(baofu);
    ref_59 = bustupLoad(bustup_2d);
    bustupWait(ref_59);
    ref_5b = bustupAlloc(ref_59, left, rgb(0,0,0));
    bustupFade(ref_5b, rgb(128,0,0), 30);
    ref_5d = dialogAlloc();
    ref_5e = msgShow(msg_3);
/***************************************
[color(yellow)]パオフゥ[color(white)]
[tab]どうやら竜蔵は、
[tab]この病院に莫大な寄付をしているらしいな。
[wait][clear]
***************************************/
    unitAnimationPlay(baofu, animation_1a, 1);
    wait(ref_5e);
    ref_61 = msgShow(msg_4);
/***************************************
[color(yellow)]パオフゥ[color(white)]
[tab]慈善活動にかこつけた口封じだろうが…
[tab]あいつは簡単に口を割ったぜ。
[tab]まっ、この状況じゃ仕方ねぇか。
[wait][clear]
***************************************/
    unitAnimationPlay(baofu, animation_1d, 1);
    wait(ref_61);
    unitAnimationPlay(baofu, animation_a, 1);
    dialogFree(ref_5d);
    ref_66 = bustupFade(ref_5b, rgb(0,0,0), 10);
    bustupWait(ref_66);
    bustupFree(ref_5b);
    unitRestoreFacing(baofu);
    controlEnable();
}

function NIGEOKURE()
{
    controlDisable();
    unitFacePlayer(npc1);
    ref_6e = dialogAlloc();
    ref_6f = msgShow(msg_5);
/***************************************
[color(yellow)]隠れていた職員[color(white)]
[tab]あ…あなた達は…人…間……よね？
[tab]たたた…助けてちょうだい！
[tab]悪魔…悪魔が現れたのよ！！
[wait][clear]
***************************************/
    unitAnimationPlay(npc1, animation_24, 1);
    wait(ref_6f);
    ref_72 = msgShow(msg_6);
/***************************************
[color(yellow)]隠れていた職員[color(white)]
[tab]…あの人よ…あの人が悪魔を……
[tab]３０３号室の患者が…
[tab]須藤[tab]竜也が悪魔を呼び寄せたのよ！
[wait][clear]
***************************************/
    unitAnimationPlay(npc1, animation_26, 1);
    wait(ref_72);
    ref_75 = msgShow(msg_7);
/***************************************
[color(yellow)]隠れていた職員[color(white)]
[tab]悪魔が患者や同僚達に襲いかかって…
[tab]嘘じゃないわ！[tab]あなた達も見たでしょ！？
[tab]そこら中にある死体を！
[wait][clear]
***************************************/
    unitAnimationPlay(npc1, animation_24, 1);
    wait(ref_75);
    unitAnimationPlay(npc1, animation_0, 1);
    dialogFree(ref_6e);
    unitRestoreFacing(npc1);
    controlEnable();
}

function DOORBOX()
{
    controlDisable();
    sndMusicPlay(sound_3091, 127);
    objAnimRotate(obj_3, 0, -80, 0, 30, 0);
    objAnimWait(obj_3);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    dngLoad2(sanitarium-5);
}
