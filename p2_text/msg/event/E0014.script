function URARA_TOJO()
{
    unitSpawn(ulala, sprite_6, 400, 0, -870, south, fade);
    unitMove(ulala, 400, -770, face_south, medium);
    unitWait(ulala);
    unitAnimationPlay(ulala, animation_a, 1);
    sndMusicPlay(sound_30eb, 127);
    ref_15e = objAnimRotate(obj_3, 0, 70, 0, 30, 0);
    wait(ref_15e);
}

function KATUYA_TOJO()
{
    unitSpawn(katsuya, sprite_d, 400, 0, -870, south, fade);
    unitMove(katsuya, 260, -870, face_east, medium);
    unitWait(katsuya);
    unitMove(katsuya, 260, -700, face_south, medium);
    unitWait(katsuya);
    unitAnimationPlay(katsuya, animation_a, 1);
}

function PAOFU_TOJO()
{
    unitSpawn(baofu, sprite_13, 400, 0, -870, south, fade);
    unitMove(baofu, 500, -870, face_south, medium);
    unitWait(baofu);
    unitMove(baofu, 500, -670, face_south, medium);
    unitWait(baofu);
    unitAnimationPlay(baofu, animation_d, 1);
}
