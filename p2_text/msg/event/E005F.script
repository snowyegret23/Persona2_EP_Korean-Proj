function PAONARI()
{
    delayClear();
    delayWait(120);
    unitAnimationPlay(baofu, animation_1, 1);
}

function MAYANARI()
{
    unitAnimationPlay(maya, animation_1, 1);
    delayClear();
    delayWait(10);
    unitAnimationPlay(maya, animation_2, 1);
    delayClear();
    delayWait(60);
    unitFaceUnit(maya, elly);
    unitAnimationPlay(maya, animation_0, 1);
}

function KATUNARI()
{
    unitFaceUnit(katsuya, ulala);
}
