    ref_a4 = bustupFade(ref_9c, rgb(0,0,0), 10);
    bustupWait(ref_a4);
    bustupFree(ref_9c);
    unitRestoreFacing(ulala);
    b(label_c9);
  label_a9:
    unitFacePlayer(ulala);
    ref_aa = bustupLoad(bustup_17);
    bustupWait(ref_aa);
    ref_ac = bustupAlloc(ref_aa, left, rgb(0,0,0));
    bustupFade(ref_ac, rgb(128,0,0), 30);
    ref_ae = dialogAlloc();
    ref_af = msgShow(msg_2);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]な～んかムカツクなぁ～
[tab]私達とは育ちがチガウ！[tab]って言われてるみたい。
[tab]ねぇマーヤ、そう思わない？
[wait][clear]
***************************************/
