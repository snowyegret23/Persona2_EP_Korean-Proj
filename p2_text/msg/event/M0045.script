    bustupWait(ref_ca);
    ref_cc = bustupAlloc(ref_ca, left, rgb(0,0,0));
    bustupFade(ref_cc, rgb(128,0,0), 30);
    ref_ce = dialogAlloc();
    ref_cf = msgShow(msg_4);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]そっかぁ、雑誌を作ってるのは外部の人間かぁ。
[tab]確かにそうだね。アンタの元相棒も社員じゃないし
[tab]レイアウトもデザイン事務所の人だもんね。
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2d, 1);
    wait(ref_cf);
    ref_d2 = msgShow(msg_5);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]…あれ？
[tab]それじゃあマーヤの仕事って何？
[wait][clear]
***************************************/
