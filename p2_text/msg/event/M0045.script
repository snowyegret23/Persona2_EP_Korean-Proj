    bustupFree(ref_e4);
    dialogFree(ref_e1);
    ref_ee = bustupFade(ref_df, rgb(0,0,0), 10);
    bustupWait(ref_ee);
    bustupFree(ref_df);
    unitRestoreFacing(ulala);
    b(label_103);
  label_f3:
    unitFacePlayer(ulala);
