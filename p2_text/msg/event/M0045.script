    bustupWait(ref_ba);
    ref_bc = bustupAlloc(ref_ba, left, rgb(0,0,0));
    bustupFade(ref_bc, rgb(128,0,0), 30);
    ref_be = dialogAlloc();
    ref_bf = msgShow(msg_3);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]キスメット出版から懸賞雑誌は出さないの？
[tab]雑誌で豪華賞品が当たるって最近評判じゃん。
[tab]…企画、出してみたら？
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2d, 1);
    wait(ref_bf);
    unitAnimationPlay(ulala, animation_a, 1);
    dialogFree(ref_be);
    ref_c4 = bustupFade(ref_bc, rgb(0,0,0), 10);
    bustupWait(ref_c4);
    bustupFree(ref_bc);
    unitRestoreFacing(ulala);
    b(label_103);
  label_c9:
    unitFacePlayer(ulala);
