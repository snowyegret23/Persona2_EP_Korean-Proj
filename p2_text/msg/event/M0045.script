    ref_9c = bustupAlloc(ref_9a, left, rgb(0,0,0));
    bustupFade(ref_9c, rgb(128,0,0), 30);
    ref_9e = dialogAlloc();
    ref_9f = msgShow(msg_1);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]うぷぷ、あの刑事さんてば「色眼鏡」だって！
[tab]あれってギャグかね？[tab]本気かね？
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2d, 1);
    wait(ref_9f);
    unitAnimationPlay(ulala, animation_a, 1);
    dialogFree(ref_9e);
    ref_a4 = bustupFade(ref_9c, rgb(0,0,0), 10);
    bustupWait(ref_a4);
    bustupFree(ref_9c);
    unitRestoreFacing(ulala);
    b(label_103);
  label_a9:
    unitFacePlayer(ulala);
    ref_aa = bustupLoad(bustup_17);
    bustupWait(ref_aa);
    ref_ac = bustupAlloc(ref_aa, left, rgb(0,0,0));
    bustupFade(ref_ac, rgb(128,0,0), 30);
    ref_ae = dialogAlloc();
    ref_af = msgShow(msg_2);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]そりゃギョーカイ人は、
[tab]ちょっと世間とズレてるけどねぇ…
[tab]パオフゥのはかなりズレてるでしょ？
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2d, 1);
    wait(ref_af);
    unitAnimationPlay(ulala, animation_a, 1);
    dialogFree(ref_ae);
    ref_b4 = bustupFade(ref_ac, rgb(0,0,0), 10);
    bustupWait(ref_b4);
    bustupFree(ref_ac);
    unitRestoreFacing(ulala);
    b(label_103);
  label_b9:
    unitFacePlayer(ulala);
