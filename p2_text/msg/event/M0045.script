function ELE()
{
    controlDisable();
    sndMusicPlay(sound_30a9, 127);
    objAnimTranslate(obj_1, 0, 0, 100, 30);
    objAnimTranslate(obj_2, 0, 0, -100, 30);
    objAnimWait(obj_1);
    objAnimWait(obj_2);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    bitSet(MBIT_KISS_ELE);
    eventLoad(event_e6);
}

function EXIT()
{
    controlDisable();
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    bitClear(MBIT_EXITBIT);
    mapLoad(aoba, 22, 3);
}

function HIJOU()
{
    controlDisable();
    ref_316 = dialogAlloc();
    ref_317 = msgShow(msg_52);
/***************************************
[color(yellow)]非常口[color(green)]
[tab]ここには入れない。[color(white)]
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_317);
    dialogFree(ref_316);
    controlEnable();
}
