    wait(ref_d2);
    unitAnimationPlay(ulala, animation_a, 1);
    dialogFree(ref_ce);
    ref_d7 = bustupFade(ref_cc, rgb(0,0,0), 10);
    bustupWait(ref_d7);
    bustupFree(ref_cc);
    unitRestoreFacing(ulala);
    b(label_103);
  label_dc:
    unitFacePlayer(ulala);
    ref_dd = bustupLoad(bustup_17);
    bustupWait(ref_dd);
    ref_df = bustupAlloc(ref_dd, left, rgb(0,0,0));
    bustupFade(ref_df, rgb(128,0,0), 30);
    ref_e1 = dialogAlloc();
    ref_e2 = bustupLoad(bustup_76);
