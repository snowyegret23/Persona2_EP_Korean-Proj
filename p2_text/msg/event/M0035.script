function DOORBOX()
{
    controlDisable();
    objAnimRotate(obj_5, 0, -70, 0, 30, 0);
    objAnimRotate(obj_6, 0, 70, 0, 30, 0);
    sndMusicPlay(sound_307c, 127);
    objAnimWait(obj_5);
    objAnimWait(obj_6);
    call(EXITBOX);
}

function EXITBOX()
{
    bitClear(MBIT_EXITBIT);
    mapLoad(rengedai, 0, 0);
}

function ORUGORU()
{
    objAnimRotate(obj_0, 0, 360, 0, 500, 1);
    objAnimRotate(obj_3a, 0, 360, 0, 500, 1);
}

function HA_SHOP_EXPLAIN_0()
{
    ref_69b = dialogAlloc();
    ref_69c = msgShow(msg_101);
/***************************************
[color(yellow)]黎子さん[color(white)]
[tab]「回復」についてね。
[wait][clear][color(yellow)]黎子さん[color(white)]
[tab]当店で「回復してもらう」を選んでくれれば
[tab]貴方たちの心をケアすることで「ＨＰ」と「ＳＰ」そして
[tab]「猛毒」などのステータス異常も回復してあげるわ。
[wait][clear][color(yellow)]黎子さん[color(white)]
[tab]当然料金はいただくけど、全員まとめて診てあげるし
[tab]薬に頼るよりはお安いと思うわ。
[wait][clear]
***************************************/
    wait(ref_69c);
    dialogFree(ref_69b);
    call(HOKANI_SELECT);
}
