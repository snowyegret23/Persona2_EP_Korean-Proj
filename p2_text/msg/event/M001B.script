function DOORBOX()
{
    controlDisable();
    objAnimRotate(obj_6, 0, -70, 0, 30, 0);
    objAnimRotate(obj_5, 0, 70, 0, 30, 0);
    sndMusicPlay(sound_3072, 127);
    objAnimWait(obj_6);
    objAnimWait(obj_5);
    call(EXITBOX);
}

function EXITBOX()
{
    bitClear(MBIT_EXITBIT);
    mapLoad(rengedai, 0, 0);
}

function HA_SHOP_EXPLAIN_0()
{
    ref_59e = dialogAlloc();
    ref_59f = msgShow(msg_80);
/***************************************
[color(yellow)]あんちゃん[color(white)]
[tab]「回復」についてだね～。
[wait][clear][color(yellow)]あんちゃん[color(white)]
[tab]うちの店で「回復してもらう」を選べば、超ハイテク
[tab]日焼けマッシーンのイカした効果で「ＨＰ」と「ＳＰ」
[tab]さらに「猛毒」などのステータス異常を回復しちゃうよ。
[wait][clear][color(yellow)]あんちゃん[color(white)]
[tab]値段はそれなりにかかるけど、全員まとめてやるから
[tab]サトミタダシの薬をガブ飲みするよりは
[tab]安く済むんじゃないかなァ？
[wait][clear]
***************************************/
    wait(ref_59f);
    dialogFree(ref_59e);
    call(HOKANI_SELECT);
}
