}

function OKORU()
{
    controlDisable();
    ref_6c = cameraRotateTo(3, 30);
    wait(ref_6c);
    ref_6e = unitMove(npc6, 1257, -943, face_west, fast);
    wait(ref_6e);
    unitFace(npc6, north);
    delayClear();
    delayWait(30);
    ref_73 = dialogAlloc();
    ref_74 = msgShow(msg_1);
/***************************************
[color(yellow)]新米警察官[color(white)]
[tab]ピ～～～～～～～～～～～～～～～～～～～！！
[tab]そこから先は関係者以外、立ち入り禁止ッス！
[tab]入っちゃダメダメッス！！
[sync][wait][clear]
***************************************/
    sndMusicPlay(sound_3082, 127);
    unitAnimationPlay(npc6, animation_26, 1);
    delayClear();
    delayWait(60);
    sync();
    wait(ref_74);
    dialogFree(ref_73);
    unitAnimationPlay(npc6, animation_0, 1);
    ref_7d = unitMove(npc6, 1101, -943, face_east, medium);
    wait(ref_7d);
    unitFace(npc6, north);
    controlEnable();
}

function B_URARATI()
