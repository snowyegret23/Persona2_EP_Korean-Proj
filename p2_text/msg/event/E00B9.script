function KAISIJI()
{
    delayClear();
    delayWait(60);
    unitAnimationPlay(ulala, animation_1a, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(ulala, animation_19, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(ulala, animation_1b, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(ulala, animation_19, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(ulala, animation_1a, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(ulala, animation_19, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(ulala, animation_1b, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(ulala, animation_19, 1);
    delayClear();
    delayWait(30);
    unitAnimationPlay(ulala, animation_1d, 1);
}

function PEA()
{
    unitSpawn(unit_58, sprite_cb, 150, 0, -520, north, none);
    unitSpawn(npc1, sprite_ca, 200, 0, -510, north, none);
    unitPalette(npc1, 1);
    unitPalette(unit_58, 1);
    unitMove(unit_58, 150, -865, face_west, slow);
    unitMove(npc1, 200, -855, face_west, slow);
    unitWait(unit_58);
    unitMove(unit_58, 450, -965, face_west, slow);
    unitWait(npc1);
    unitMove(npc1, 450, -925, face_west, slow);
    delayClear();
    delayWait(30);
    unitAnimationPlay(ulala, animation_19, 1);
    delayClear();
    delayWait(12);
    unitAnimationPlay(ulala, animation_1b, 1);
    bitSet(LBIT_0001);
    unitWait(npc1);
    unitMove(npc1, 840, -880, face_west, slow);
    unitWait(unit_58);
    unitMove(unit_58, 840, -910, face_west, slow);
    unitWait(npc1);
    unitMove(npc1, 1295, -610, face_west, slow);
    unitWait(unit_58);
    unitMove(unit_58, 1240, -660, face_west, slow);
}

function WOMAN3()
{
    unitAnimationPlay(unit_5a, animation_a, 1);
    unitWait(unit_5a);
    unitFace(unit_5a, east);
    unitAnimationPlay(unit_5a, animation_0, 1);
    delayClear();
    delayWait(12);
    unitMove(unit_5a, 200, -350, face_south, medium);
    unitWait(unit_5a);
    unitMove(unit_5a, 200, 0, face_east, medium);
    unitWait(unit_5a);
}
