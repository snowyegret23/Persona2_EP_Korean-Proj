function KAOHANTEI()
{
    bitGet(var_0, MBIT_ROSAHENNISHU_2);
    bne(var_0, 0, label_681);
    ref_67c = bustupLoad(bustup_f8);
    bustupWait(ref_67c);
    ref_67e = bustupAlloc(ref_67c, right, rgb(0,0,0));
    bustupFade(ref_67e, rgb(128,0,0), 30);
    b(label_687);
  label_681:
    bne(var_0, 1, label_687);
    ref_682 = bustupLoad(bustup_11d);
    bustupWait(ref_682);
    ref_684 = bustupAlloc(ref_682, right, rgb(0,0,0));
    bustupFade(ref_684, rgb(128,0,0), 30);
    b(label_687);
  label_687:
}

function DELKAOHANTEI()
{
    bitGet(var_0, MBIT_ROSAHENNISHU_2);
    bne(var_0, 0, label_68e);
    ref_68a = bustupFade(ref_67e, rgb(0,0,0), 10);
    bustupWait(ref_68a);
    bustupFree(ref_67e);
    b(label_693);
  label_68e:
    bne(var_0, 1, label_693);
    ref_68f = bustupFade(ref_684, rgb(0,0,0), 10);
    bustupWait(ref_68f);
    bustupFree(ref_684);
    b(label_693);
  label_693:
}

function KOUISITU2()
{
    controlDisable();
    unitFacePlayer(shopkeeper);
    ref_696 = call(KAOHANTEI);
    wait(ref_696);
    ref_698 = dialogAlloc();
    ref_699 = msgShow(msg_106);
/***************************************
[color(yellow)]マヌカン[color(white)]
[tab]ちょっと。[delay(10)]
[tab]そこ更衣室なのよ。[delay(10)]
[tab]用もなく入らないでちょうだい。[wait][clear]
***************************************/
    wait(ref_699);
    unitAnimationPlay(shopkeeper, animation_0, 1);
    dialogFree(ref_698);
    ref_69d = call(DELKAOHANTEI);
    wait(ref_69d);
    unitRestoreFacing(shopkeeper);
    controlEnable();
}

function KOUISITU()
{
    controlDisable();
    ref_6a3 = cameraRotateTo(7, 40);
    wait(ref_6a3);
    unitFacePlayer(shopkeeper);
    ref_6a6 = call(KAOHANTEI);
    wait(ref_6a6);
    ref_6a8 = dialogAlloc();
    ref_6a9 = msgShow(msg_107);
/***************************************
[color(yellow)]マヌカン[color(white)]
[tab]ちょっと。[delay(10)]
[tab]そこ更衣室なのよ。[delay(10)]
[tab]用もなく入らないでちょうだい。[wait][clear]
***************************************/
    unitAnimationPlay(shopkeeper, animation_0, 1);
    unitWait(shopkeeper);
    delayClear();
    delayWait(3);
    unitAnimationPlay(shopkeeper, animation_1, 1);
    unitWait(shopkeeper);
    delayClear();
    delayWait(3);
    unitAnimationPlay(shopkeeper, animation_2, 1);
    unitWait(shopkeeper);
    delayClear();
    delayWait(6);
    unitAnimationPlay(shopkeeper, animation_1, 1);
    unitWait(shopkeeper);
    delayClear();
    delayWait(3);
    unitAnimationPlay(shopkeeper, animation_0, 1);
    unitWait(shopkeeper);
    delayClear();
    delayWait(3);
    unitAnimationPlay(shopkeeper, animation_3, 1);
    unitWait(shopkeeper);
    delayClear();
    delayWait(3);
    unitAnimationPlay(shopkeeper, animation_4, 1);
    unitWait(shopkeeper);
    delayClear();
    delayWait(6);
    unitAnimationPlay(shopkeeper, animation_3, 1);
    unitWait(shopkeeper);
    delayClear();
    delayWait(3);
    unitAnimationPlay(shopkeeper, animation_0, 1);
    unitWait(shopkeeper);
    delayClear();
    delayWait(10);
    unitAnimationPlay(shopkeeper, animation_19, 1);
    wait(ref_6a9);
    dialogFree(ref_6a8);
    unitWait(shopkeeper);
    unitAnimationPlay(shopkeeper, animation_0, 1);
    unitWait(shopkeeper);
    ref_6d4 = call(DELKAOHANTEI);
    wait(ref_6d4);
    unitRestoreFacing(shopkeeper);
    controlEnable();
}

function DOORBOX()
{
    controlDisable();
    sndMusicPlay(sound_3075, 127);
    objAnimRotate(obj_1e, 0, -70, 0, 30, 0);
    objAnimRotate(obj_2c, 0, 70, 0, 30, 0);
    objAnimWait(obj_1e);
    objAnimWait(obj_2c);
    call(GOOUT);
}

function GOOUT()
{
    bitClear(MBIT_EXITBIT);
    mapLoad(rengedai, 0, 0);
}

function warp1()
{
    call(DOORBOX);
}

function HA_SHOP_EXPLAIN_0()
{
    ref_6e6 = dialogAlloc();
    ref_6e7 = msgShow(msg_108);
/***************************************
[color(yellow)]マヌカン[color(white)]
[tab]「売買」についてですわね？
[wait][clear][color(yellow)]マヌカン[color(white)]
[tab]まずは、購入について説明しますわね。
[tab]当店で「防具を買う」を選びますと
[tab]素敵な防具を購入することができますわ。
[wait][clear][color(yellow)]マヌカン[color(white)]
[tab]防具は装備できる対象が決まっている物もあるわ。
[tab]よく確認して買っていってちょうだいね。
[wait][clear][color(yellow)]マヌカン[color(white)]
[tab]つぎは、売却の説明ね。
[tab]「アイテムを売る」を選択すると種類の選択になるわ。
[tab]売りたいものの種類を選び、物を決定してちょうだい。
[wait][clear][color(yellow)]マヌカン[color(white)]
[tab]買い取り価格は元値の約半額くらいで、
[tab]装備中の物と一部の物は売却することはできないわよ。
[tab]こんなところかしら。
[wait][clear]
***************************************/
    wait(ref_6e7);
    dialogFree(ref_6e6);
}

function BITSOUSADOWN()
{
    bitSet(TBIT_HE_RB);
    bitSet(MBIT_MI_ROSAHEN_B);
    bitClear(MBIT_MI_ROSAHENNI);
    ref_6ee = call(KYOYOBU);
    wait(ref_6ee);
    bitClear(TBIT_HE_RA);
}

function BITSOUSAUP()
{
    bitGet(var_0, MBIT_ROSKAN_HATUHENIGO);
    bne(var_0, 0, label_6fb);
    bitSet(TBIT_HE_RA);
    bitSet(MBIT_MI_ROSAHEN_A);
    bitClear(MBIT_MI_ROSAHENNI);
    ref_6f7 = call(KYOYOBU);
    wait(ref_6f7);
    bitClear(TBIT_HE_RB);
    b(label_6fd);
  label_6fb:
    bne(var_0, 1, label_6fd);
    b(label_6fd);
  label_6fd:
}

