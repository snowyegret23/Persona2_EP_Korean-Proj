    screenFadeOuter(rgb(255,255,255), 4, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    cutsceneFollowupEvent(event_5a);
    cutscenePlay(cutscene_a, 0);
}

function MAYA_TOJO()
{
    unitSpawn(maya, sprite_0, 1105, 0, -200, north, fade);
    unitMove(maya, 1100, -330, face_north, fast);
    unitWait(maya);
    unitAnimationHold(maya, animation_21, 60);
    unitWait(maya);
    unitMove(maya, 1100, -830, face_north, fast);
    unitWait(maya);
    ref_fd = spriteLoad(sprite_3);
    wait(ref_fd);
    unitSpriteClear(maya);
    unitSpriteSet(maya, sprite_3);
}

