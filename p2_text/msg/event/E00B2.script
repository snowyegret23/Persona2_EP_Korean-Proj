    ref_d = spriteLoad(sprite_3a);
    wait(ref_d);
    ref_f = spriteLoad(sprite_115);
    wait(ref_f);
    ref_11 = spriteLoad(sprite_0);
    wait(ref_11);
    ref_13 = spriteLoad(sprite_6);
    wait(ref_13);
    ref_15 = spriteLoad(sprite_d);
    wait(ref_15);
    ref_17 = spriteLoad(sprite_13);
    wait(ref_17);
    ref_19 = spriteLoad(sprite_18);
    wait(ref_19);
    unitSpawn(unit_12, sprite_3c, 1105, 0, -1220, south, none);
    unitSpawn(unit_11, sprite_3a, 1100, -50, -1750, south, none);
    unitSpawn(npc1, sprite_115, 1300, 0, -960, north, none);
    unitSpawn(unit_58, sprite_115, 1300, 0, -960, west, none);
    unitSpawn(npc2, sprite_115, 900, 0, -1050, east, none);
    unitSpawn(unit_59, sprite_115, 900, 0, -1050, north, none);
    unitSpawn(npc3, sprite_115, 1250, 0, -1400, north, none);
