function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    sndIdGet(var_a);
    bne(var_a, -1, label_5);
    b(label_7);
  label_5:
    sndVolumeFadeOff(var_a, 60);
    b(label_7);
  label_7:
    sndMusicPlay(sound_302c, 127);
    cameraSet(southwest, 1100, 0, -1200);
    levelFootstepSet(sfx_19);
    cameraZoom(-1500, 1);
    ref_b = spriteLoad(sprite_3c);
