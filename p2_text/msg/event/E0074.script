function PAOFU_MIRU()
{
    unitSpriteClear(baofu);
    unitSpriteSet(baofu, sprite_13);
    unitAnimationPlay(baofu, animation_c, 1);
}

function MAYA_BACK()
{
    unitMove(maya, 700, -600, face_north, reverse);
    unitWait(maya);
    delayClear();
    delayWait(30);
    unitAnimationPlay(maya, animation_1, 1);
}
