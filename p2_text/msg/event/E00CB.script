function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    levelHide();
    timerClear();
    bitSet(EBIT_GESUI_TIMEUP);
    sndIdGet(var_a);
    bne(var_a, -1, label_8);
    b(label_9);
  label_8:
    b(label_9);
  label_9:
    bitGet(var_0, EBIT_CHUKEITEN1);
    bnz(var_0, label_15);
    bitGet(var_1, EBIT_MAKI0);
    bne(var_1, 0, label_10);
    dngLoad2(sewer2-0);
    timerSet(600, event_90);
    b(label_14);
  label_10:
    bne(var_1, 1, label_14);
    dngLoad2(sewer1-0);
    timerSet(600, event_90);
    b(label_14);
  label_14:
    b(label_2b);
  label_15:
    bitGet(var_2, EBIT_CHUKEITEN2);
    bnz(var_2, label_21);
    bitGet(var_3, EBIT_MAKI1);
    bne(var_3, 0, label_1c);
    dngLoad2(sewer2-1);
    timerSet(600, event_90);
    b(label_20);
  label_1c:
    bne(var_3, 1, label_20);
    dngLoad2(sewer1-2);
    timerSet(600, event_90);
    b(label_20);
  label_20:
    b(label_2b);
  label_21:
    bitGet(var_4, EBIT_MAKI3);
    bne(var_4, 0, label_26);
    dngLoad2(sewer2-4);
    timerSet(600, event_90);
    b(label_2a);
  label_26:
    bne(var_4, 1, label_2a);
    dngLoad2(sewer1-4);
    timerSet(600, event_90);
    b(label_2a);
  label_2a:
    b(label_2b);
  label_2b:
}
