function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    dngRoomSet(31);
    dngRoomDraw();
    sndMusicPlay(sound_3044, 127);
    ref_5 = spriteLoad(sprite_0);
    wait(ref_5);
    ref_7 = spriteLoad(sprite_2);
    wait(ref_7);
    ref_9 = spriteLoad(sprite_d);
    wait(ref_9);
    ref_b = spriteLoad(sprite_e);
    wait(ref_b);
    ref_d = spriteLoad(sprite_13);
    wait(ref_d);
    ref_f = spriteLoad(sprite_6a);
    wait(ref_f);
    ref_11 = spriteLoad(sprite_d4);
    wait(ref_11);
    ref_13 = spriteLoad(sprite_d1);
    wait(ref_13);
    ref_15 = spriteLoad(sprite_c0);
    wait(ref_15);
    ref_17 = spriteLoad(sprite_c1);
    wait(ref_17);
    ref_19 = spriteLoad(sprite_c2);
    wait(ref_19);
    bitGet(var_0, EBIT_RESEERVE_0012);
    bnz(var_0, label_1e);
    disableMap();
  label_1e:
    bitGet(var_0, EBIT_E0039);
    bne(var_0, 0, label_23);
    ref_20 = call(KYOUSEI);
    wait(ref_20);
    b(label_27);
  label_23:
    bne(var_0, 1, label_27);
    ref_24 = call(FREE);
    wait(ref_24);
    b(label_27);
  label_27:
}

