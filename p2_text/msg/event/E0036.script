function EXIT()
{
    controlDisable();
    sndMusicPlay(sound_312b, 127);
    objAnimRotate(obj_6, 0, -80, 0, 60, 0);
    objAnimRotate(obj_7, 0, 80, 0, 60, 0);
    objAnimWait(obj_6);
    objAnimWait(obj_7);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    mapLoad(yumezaki, 1, 1);
}

function ELE()
{
    controlDisable();
    cameraSetNorth(west);
    sndMusicPlay(sound_312c, 127);
    objAnimTranslate(obj_8, 100, 0, 0, 60);
    objAnimTranslate(obj_9, -100, 0, 0, 60);
    objAnimWait(obj_8);
    objAnimWait(obj_9);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    bitSet(EBIT_E1200);
    bitSet(EBIT_RESEERVE_0012);
    dngLoad2(gold-0);
}

