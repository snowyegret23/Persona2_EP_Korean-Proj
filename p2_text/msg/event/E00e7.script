function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    cameraSet(north, 1000, 0, 1000);
    ref_3 = evtbgLoad(evtbg_11);
    wait(ref_3);
    evtbgInit(evtbg_handle_11, evtbg_11, 0, 0, rgb(0,0,0), true);
    ref_6 = spriteLoad(sprite_12a);
    wait(ref_6);
    unitSpawn(unit_73, sprite_12a, 1300, 0, 600, north, none);
    ref_9 = evtbgFade(evtbg_handle_11, rgb(128,128,128), 1, false);
    wait(ref_9);
    unitFace(unit_73, east);
    ref_c = unitMove(unit_73, 1000, 1000, face_north, medium);
    unitAnimationPlay(unit_73, animation_5, 1);
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    screenFadeInner(rgb(0,0,0), 4, true);
    screenFadeOuter(rgb(0,0,0), 4, true);
    screenEffectUnknown();
    screenFadeWait(inner);
    screenFadeWait(outer);
    wait(ref_c);
    delayClear();
    delayWait(30);
    unitAnimationPlay(unit_73, animation_3, 1);
    delayClear();
    delayWait(10);
    unitAnimationPlay(unit_73, animation_4, 1);
    delayClear();
    delayWait(60);
    unitAnimationPlay(unit_73, animation_3, 1);
    delayClear();
    delayWait(10);
    unitAnimationPlay(unit_73, animation_0, 1);
    delayClear();
    delayWait(10);
    unitAnimationPlay(unit_73, animation_1, 1);
    delayClear();
    delayWait(10);
    unitAnimationPlay(unit_73, animation_2, 1);
    delayClear();
    delayWait(60);
    unitAnimationPlay(unit_73, animation_1, 1);
    delayClear();
    delayWait(10);
    unitAnimationPlay(unit_73, animation_0, 1);
    delayClear();
    delayWait(30);
    ref_2f = dialogAlloc();
    ref_30 = msgShow(msg_0);
/***************************************
常連の口利きでしか入れないという、秘密の
ダンスフロアにつながる通路は、赤い中華風の内装に
変わっていた。
[wait][clear]
***************************************/
    wait(ref_30);
    ref_32 = msgShow(msg_1);
/***************************************
どうやら、この店が台湾系のマフィアに買収された
という噂は本当らしい。
[wait][clear]
***************************************/
    wait(ref_32);
    ref_34 = msgShow(msg_2);
/***************************************
以前、春日山高校の生徒たちの補導に来た時は、
ゾディアックという店の名前の通り
星座をあしらった安っぽいものだった。
[wait][clear]
***************************************/
    wait(ref_34);
    ref_36 = msgShow(msg_3);
/***************************************
私は成金趣味の下品な赤い廊下を歩きながら、
携帯を取り出し慣れ親しんだ番号をプッシュした。
５回呼び出し音が鳴った後、何者かが電話に出た。
やはり噂は本当だ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_36);
    dialogFree(ref_2f);
    ref_3a = bustupLoad(bustup_129);
    bustupWait(ref_3a);
    ref_3c = bustupAlloc(ref_3a, right, rgb(0,0,0));
    bustupFade(ref_3c, rgb(128,0,0), 30);
    ref_3e = dialogAlloc();
    ref_3f = msgShow(msg_4);
/***************************************
[color(yellow)]詩織[color(white)]
[tab]宮代[tab]詩織を殺してって、お願いしたの覚えてる？
[tab]彼女、夢崎区のクラブ[tab]ゾディアック、
[tab]ＶＩＰフロアにいるわ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_3f);
    dialogFree(ref_3e);
    ref_43 = bustupFade(ref_3c, rgb(0,0,0), 10);
    bustupWait(ref_43);
    bustupFree(ref_3c);
    ref_46 = dialogAlloc();
    ref_47 = msgShow(msg_5);
/***************************************
それだけ告げると、こちらから電話を切った。
もう後戻りはできない。
今夜中に、奴の正体が噂通りかどうかわかるだろう。
でなければ、死体が一人分増えるだけのことだ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_47);
    dialogFree(ref_46);
    unitFace(unit_73, north);
    unitMove(unit_73, 250, 0, face_north, medium);
    unitAnimationPlay(unit_73, animation_5, 1);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 2, false);
    screenFadeOuter(rgb(255,255,255), 2, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    evtbgFree(evtbg_handle_11);
    unitDespawn(unit_73, none);
    sndMusicPlay(sound_3015, 127);
    msgLocSet(30, 110);
    ref_58 = msgShow(msg_6);
/***************************************
[tab][tab][tab][tab][tab]○○月１３日[tab][tab]ＡＭ：１時３４分[tab][tab][tab][tab][tab]
[tab][tab][tab][tab][tab][tab][tab][tab][suou]家[tab][tab][tab]ガレージ[tab][tab][tab][tab][tab][tab][tab][tab]

***************************************/
    wait(ref_58);
    delayClear();
    delayWait(180);
    msgShow(msg_7);
/***************************************
[clear]
***************************************/
    msgLocDefault();
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 2, true);
    screenFadeOuter(rgb(0,0,0), 2, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    ref_63 = evtbgLoad(evtbg_5);
    wait(ref_63);
    evtbgInit(evtbg_handle_5, evtbg_5, 0, 0, rgb(0,0,0), true);
    ref_66 = evtbgFade(evtbg_handle_5, rgb(128,128,128), 1, false);
    wait(ref_66);
    delayClear();
    delayWait(180);
    ref_6a = dialogAlloc();
    ref_6b = msgShow(msg_8);
/***************************************
あの時俺は、自分が向こう側の人間であることも、
向こう側で何が起きたかも、全てを思い出した。
[wait][clear]
***************************************/
    wait(ref_6b);
    ref_6d = msgShow(msg_9);
/***************************************
舞耶姉、黛さん、栄吉、リサ、そして淳…
決して忘れないと誓い、離れ離れになった仲間たちが、
舞耶姉を…[tab]俺を見ていた。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_6d);
    dialogFree(ref_6a);
    ref_71 = evtbgLoad(evtbg_6);
    wait(ref_71);
    evtbgInit(evtbg_handle_6, evtbg_6, 0, 0, rgb(0,0,0), true);
    ref_74 = evtbgFade(evtbg_handle_6, rgb(128,128,128), 1, false);
    wait(ref_74);
    delayClear();
    delayWait(180);
    evtbgFree(evtbg_handle_5);
    ref_79 = dialogAlloc();
    ref_7a = msgShow(msg_10);
/***************************************
舞耶姉が…[tab]あの舞耶姉が目の前で微笑んでいる。
大丈夫？[tab]怪我はない？
ごめんなさい、私おっちょこちょいで。
あれ…[tab]キミ、どこかで会ったことある？
[wait][clear]
***************************************/
    wait(ref_7a);
    ref_7c = msgShow(msg_11);
/***************************************
ああ、ああ、あるともさ！
忘れろったって忘れられるものか…[tab]絶対に。
ガキの頃からずっと、
ずっとあんたの面影を追いかけていたんだ。
[wait][clear]
***************************************/
    wait(ref_7c);
    ref_7e = msgShow(msg_12);
/***************************************
そうだ、そうやってずっと笑っていてくれ。
その笑顔を守ると、淳と約束した。
[wait][clear]
***************************************/
    wait(ref_7e);
    ref_80 = msgShow(msg_13);
/***************************************
なのに俺はしくじった。
一度目は１０年前、二度目は【奴】の世界、三度目は…
[wait][clear]
***************************************/
    wait(ref_80);
    ref_82 = msgShow(msg_14);
/***************************************
なんてことだ…
俺は逃げるようにあの場を立ち去った。
どうしていいかわからなかった。
[wait][clear]
***************************************/
    wait(ref_82);
    ref_84 = msgShow(msg_15);
/***************************************
だから、こちら側の俺の中に閉じこもり眠ることにした。
何も見ず、何も聞かず、何も感じなければ、
皆が手にした平穏な日常を壊さずに済むかもしれない。
だが、【奴】がそれを見逃すはずがなかった。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_84);
    dialogFree(ref_79);
    ref_88 = evtbgLoad(evtbg_c);
    wait(ref_88);
    evtbgInit(evtbg_handle_c, evtbg_c, 0, 0, rgb(0,0,0), true);
    ref_8b = evtbgFade(evtbg_handle_c, rgb(128,128,128), 1, false);
    wait(ref_8b);
    delayClear();
    delayWait(180);
    evtbgFree(evtbg_handle_6);
    ref_90 = dialogAlloc();
    ref_91 = msgShow(msg_16);
/***************************************
[color(yellow)]何者かの声[color(white)]
[tab]罪から逃れ、隠れていたければそうするがいい。
[tab]だがこの世界がどうなるか、お前は知っているはずだ。
[wait][clear]
***************************************/
    wait(ref_91);
    ref_93 = msgShow(msg_17);
/***************************************
[color(yellow)]何者かの声[color(white)]
[tab]宿命の糸に操られし人形よ、
[tab]何人も昏き心の顎門からは逃れられん。
[tab]待っているぞ。待っているぞ…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_93);
    dialogFree(ref_90);
    ref_97 = evtbgFade(evtbg_handle_c, rgb(96,96,96), 1, false);
    wait(ref_97);
    ref_99 = bustupLoad(bustup_138);
    bustupWait(ref_99);
    ref_9b = bustupAlloc(ref_99, right, rgb(0,0,0));
    bustupFade(ref_9b, rgb(128,0,0), 30);
    ref_9d = dialogAlloc();
    ref_9e = msgShow(msg_18);
/***************************************
夢の中で、【奴】は俺の右手に翌印を残していった。
罪を犯し、影に魅入られた者の印だ。
[wait][clear]
***************************************/
    wait(ref_9e);
    ref_a0 = msgShow(msg_19);
/***************************************
俺は何が起きようとしているのかを悟った。
人は己自身から、逃げることも
隠れることもできはしない。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_a0);
    dialogFree(ref_9d);
    ref_a4 = bustupFade(ref_9b, rgb(0,0,0), 10);
    bustupWait(ref_a4);
    bustupFree(ref_9b);
    ref_a7 = evtbgLoad(evtbg_7);
    wait(ref_a7);
    evtbgInit(evtbg_handle_7, evtbg_7, 0, 0, rgb(0,0,0), true);
    ref_aa = evtbgFade(evtbg_handle_7, rgb(128,128,128), 1, false);
    wait(ref_aa);
    delayClear();
    delayWait(180);
    evtbgFree(evtbg_handle_c);
    ref_af = dialogAlloc();
    ref_b0 = msgShow(msg_20);
/***************************************
やるべきことは一つだ。
命をよこせと言うならくれてやる。
闇に墜ちろと言うならそうしよう。
[wait][clear]
***************************************/
    wait(ref_b0);
    ref_b2 = msgShow(msg_21);
/***************************************
だが、舞耶姉だけは…
仲間たちが生きるこの世界だけは、
誰の好きにもさせはしない。
[wait][clear]
***************************************/
    wait(ref_b2);
    ref_b4 = msgShow(msg_22);
/***************************************
【奴】が思い通りにできるのは、俺だけだ。
だが、容易くは無い。
俺の全てと引き換えに、あの嘲りに満ちた貌無き貌を、
【奴】の世界もろとも焼き尽くす。
[wait][clear]
***************************************/
    wait(ref_b4);
    ref_b6 = msgShow(msg_23);
/***************************************
それだけが、俺にできるたったひとつの償いだから。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_b6);
    dialogFree(ref_af);
    ref_ba = evtbgLoad(evtbg_8);
    wait(ref_ba);
    evtbgInit(evtbg_handle_8, evtbg_8, 0, 0, rgb(0,0,0), true);
    ref_bd = evtbgFade(evtbg_handle_8, rgb(128,128,128), 1, false);
    wait(ref_bd);
    delayClear();
    delayWait(180);
    evtbgFree(evtbg_handle_7);
    ref_c2 = sndStop(sound_3015);
    wait(ref_c2);
    sndMusicPlay(sound_30ec, 127);
    ref_c5 = dialogAlloc();
    ref_c6 = msgShow(msg_24);
/***************************************
突然、こちら側の俺の携帯が鳴った。
兄さんではない。
俺がやるまでもなく、既に着信拒否になっている。
こちら側でも、俺たち兄弟の仲は似たようなものだった。
[wait][clear]
***************************************/
    wait(ref_c6);
    ref_c8 = msgShow(msg_25);
/***************************************
着信表示は吉栄[tab]杏奈からだ。
こちら側の俺が、吉栄とツルんでいるのは知っていた。
だが、俺は向こう側の俺だ。
同じように、彼女に応えてやることはできない。
[wait][clear]
***************************************/
    wait(ref_c8);
    ref_ca = msgShow(msg_26);
/***************************************
１０回、２０回、３０回鳴ったところで仕方なく取った。
暫くこの身体を借りる以上、吉栄にも連絡できなくなる
ことだけは伝えておいた方が良さそうだ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_ca);
    dialogFree(ref_c5);
    ref_ce = sndStop(sound_30ec);
    wait(ref_ce);
    sndMusicPlay(sound_30c3, 127);
    delayClear();
    delayWait(60);
    sndMusicPlay(sound_4067, 127);
    ref_d4 = bustupLoad(bustup_fe);
    bustupWait(ref_d4);
    ref_d6 = bustupAlloc(ref_d4, right, rgb(0,0,0));
    bustupFade(ref_d6, rgb(128,0,0), 30);
    ref_d8 = dialogAlloc();
    ref_d9 = msgShow(msg_27);
/***************************************
[color(yellow)]杏奈の声[color(white)]
[tab][tatsuya]…？
[tab]怪我とか、してない？
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_d9);
    dialogFree(ref_d8);
    ref_dd = bustupFade(ref_d6, rgb(0,0,0), 10);
    bustupWait(ref_dd);
    bustupFree(ref_d6);
    ref_e0 = bustupLoad(bustup_10);
    bustupWait(ref_e0);
    ref_e2 = bustupAlloc(ref_e0, left, rgb(0,0,0));
    bustupFade(ref_e2, rgb(128,0,0), 30);
    ref_e4 = dialogAlloc();
    ref_e5 = msgShow(msg_28);
/***************************************
[color(yellow)][tatsuya][color(white)]
[tab]ああ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_e5);
    dialogFree(ref_e4);
    ref_e9 = bustupFade(ref_e2, rgb(0,0,0), 10);
    bustupWait(ref_e9);
    bustupFree(ref_e2);
    ref_ec = bustupLoad(bustup_fe);
    bustupWait(ref_ec);
    ref_ee = bustupAlloc(ref_ec, right, rgb(0,0,0));
    bustupFade(ref_ee, rgb(128,0,0), 30);
    ref_f0 = dialogAlloc();
    ref_f1 = msgShow(msg_29);
/***************************************
[color(yellow)]杏奈の声[color(white)]
[tab]良かった…
[tab]事故じゃなくて。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_f1);
    dialogFree(ref_f0);
    ref_f5 = bustupFade(ref_ee, rgb(0,0,0), 10);
    bustupWait(ref_f5);
    bustupFree(ref_ee);
    ref_f8 = dialogAlloc();
    ref_f9 = msgShow(msg_30);
/***************************************
吉栄は、今夜ずっとゾディアックで
こちら側の俺が来るのを待っていたはずだ。
俺はそれを知っていた。
[wait][clear]
***************************************/
    wait(ref_f9);
    ref_fb = msgShow(msg_31);
/***************************************
だが姿を見せないどころか電話にも出ないことを
責めもせず、吉栄は安苺の声を漏らした。
[wait][clear]
***************************************/
    wait(ref_fb);
    ref_fd = msgShow(msg_32);
/***************************************
彼女がこんな声を聞かせるのは、こちら側の俺だけだ。
俺に大切な仲間がいたように、こちら側の俺や吉栄にも
大切な仲間がいる。胸が痛んだ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_fd);
    dialogFree(ref_f8);
    ref_101 = bustupLoad(bustup_fe);
    bustupWait(ref_101);
    ref_103 = bustupAlloc(ref_101, right, rgb(0,0,0));
    bustupFade(ref_103, rgb(128,0,0), 30);
    ref_105 = dialogAlloc();
    ref_106 = msgShow(msg_33);
/***************************************
[color(yellow)]杏奈の声[color(white)]
[tab][tatsuya]、お兄さんが刑事って言ってたよね…
[tab]さっき、変な女刑事が来てＶＩＰフロアに立て篭もった。
[wait][clear]
***************************************/
    wait(ref_106);
    ref_108 = msgShow(msg_34);
/***************************************
[color(yellow)]杏奈の声[color(white)]
[tab]ＪＯＫＥＲに、自分を殺してくれって電話したみたい。
[tab]朝まで出てこなかったら、[tatsuya]の
[tab]お兄さんに連絡しろって中村さんに頼んでた。
[wait][clear]
***************************************/
    wait(ref_108);
    ref_10a = msgShow(msg_35);
/***************************************
[color(yellow)]杏奈の声[color(white)]
[tab]お兄さんに会いたくないんでしょ？
[tab]私ちょっと様子を見に行ってくるけど、[tatsuya]
[tab]今日はもう来ないほうがいいよ。
[wait][clear]
***************************************/
    wait(ref_10a);
    ref_10c = msgShow(msg_36);
/***************************************
[color(yellow)]杏奈の声[color(white)]
[tab]それだけ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_10c);
    dialogFree(ref_105);
    ref_110 = bustupFade(ref_103, rgb(0,0,0), 10);
    bustupWait(ref_110);
    bustupFree(ref_103);
    ref_113 = dialogAlloc();
    ref_114 = msgShow(msg_37);
/***************************************
こちら側の俺が、約束を破ったことがないからだろう。
吉栄はまだ俺が来るものと信じていた…
俺がこちら側の兄さんと鉢合わせなくて済むように、
わざわざ連絡してきてくれたのだ。
[wait][clear]
***************************************/
    wait(ref_114);
    ref_116 = msgShow(msg_38);
/***************************************
だがそれよりも、吉栄の口からＪＯＫＥＲの名が
出たことの方が衝撃だった。
向こう側で俺と舞耶姉たちは、ＪＯＫＥＲの手先と
なっていた吉栄と戦ったのだ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_116);
    dialogFree(ref_113);
    ref_11a = evtbgLoad(evtbg_7);
    wait(ref_11a);
    evtbgInit(evtbg_handle_7, evtbg_7, 0, 0, rgb(0,0,0), true);
    ref_11d = evtbgFade(evtbg_handle_7, rgb(128,128,128), 1, false);
    wait(ref_11d);
    delayClear();
    delayWait(180);
    evtbgFree(evtbg_handle_8);
    sndMusicPlay(sound_3020, 127);
    ref_123 = bustupLoad(bustup_d);
    bustupWait(ref_123);
    ref_125 = bustupAlloc(ref_123, left, rgb(0,0,0));
    bustupFade(ref_125, rgb(128,0,0), 30);
    ref_127 = dialogAlloc();
    ref_128 = msgShow(msg_39);
/***************************************
[color(yellow)][tatsuya][color(white)]
[tab]ダメだ、吉栄。
[tab]絶対奥に行くな、俺が行く。
[tab]今すぐ店を出ろ。ＪＯＫＥＲには近づくな。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_128);
    dialogFree(ref_127);
    ref_12c = bustupFade(ref_125, rgb(0,0,0), 10);
    bustupWait(ref_12c);
    bustupFree(ref_125);
    ref_12f = bustupLoad(bustup_fe);
    bustupWait(ref_12f);
    ref_131 = bustupAlloc(ref_12f, right, rgb(0,0,0));
    bustupFade(ref_131, rgb(128,0,0), 30);
    ref_133 = dialogAlloc();
    ref_134 = msgShow(msg_40);
/***************************************
[color(yellow)]杏奈の声[color(white)]
[tab]吉栄…？
[tab]わかった。
[tab][tatsuya]がそうしろって言うなら、そうする。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_134);
    dialogFree(ref_133);
    ref_138 = bustupFade(ref_131, rgb(0,0,0), 10);
    bustupWait(ref_138);
    bustupFree(ref_131);
    ref_13b = dialogAlloc();
    ref_13c = msgShow(msg_41);
/***************************************
こちら側の俺は、吉栄を下の名前で呼んでいた。
だが、言い直している暇はない。
吉栄のすぐ側に、ＪＯＫＥＲが来ているかもしれない。
兄さんの名を告げた女のことも気になった。
[wait][clear]
***************************************/
    wait(ref_13c);
    ref_13e = msgShow(msg_42);
/***************************************
向こう側では、俺の親友、黒須淳が【奴】に記憶を
歪められ、ＪＯＫＥＲの仮面を被っていた。
だが淳は最後の約束を守り、向こう側の記憶を忘れ、
こちら側の橿原淳として平和に暮らしているはずだ。
[wait][clear]
***************************************/
    wait(ref_13e);
    ref_140 = msgShow(msg_43);
/***************************************
淳ではない誰かがこちら側のＪＯＫＥＲとなり、
【奴】の手駒として殺人を繰り返しているのだ。
[wait][clear]
***************************************/
    wait(ref_140);
    ref_142 = msgShow(msg_44);
/***************************************
「そして刻は繰り返す」…
向こう側が滅ぶきっかけとなった
マイヤの託宣の最後の一節が、鮮明に思い返された。
[wait][clear]
***************************************/
    wait(ref_142);
    ref_144 = msgShow(msg_45);
/***************************************
向こう側と同じようなことをこちら側でも起こす。
それが、【奴】が１０年以上前から
二つの世界に跨り仕掛けた企みだったのだ。
[wait][clear]
***************************************/
    wait(ref_144);
    ref_146 = msgShow(msg_46);
/***************************************
舞耶姉を失った俺たちがどんな選択をするか、
その先どうなるか、【奴】は端から知っていたのだ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_146);
    dialogFree(ref_13b);
    delayClear();
    delayWait(30);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    delayClear();
    delayWait(60);
    sndMusicPlay(sound_3315, 127);
    ref_155 = dialogAlloc();
    ref_156 = msgShow(msg_47);
/***************************************
俺は歯噛みすると念のため吉栄の分のメットも
引っ掴み、バイクで深夜の街へ飛び出した。
[wait][clear]
***************************************/
    wait(ref_156);
    ref_158 = msgShow(msg_48);
/***************************************
いいだろう。
【奴】が因果律に織り込んだ下衆な企みは、
片端から食い破ってやる。
そして最後は、【奴】の喉笛もろとも…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_158);
    dialogFree(ref_155);
    delayClear();
    delayWait(60);
    ref_15e = sndVolumeFadeOff(sound_3020, 60);
    wait(ref_15e);
    eventFileLoad(E, 232);
}
