function NOITEM()
{
    unitFacePlayer(shopkeeper);
    ref_465 = bustupLoad(bustup_fd);
    bustupWait(ref_465);
    ref_467 = bustupAlloc(ref_465, right, rgb(0,0,0));
    bustupFade(ref_467, rgb(128,0,0), 30);
    ref_469 = dialogAlloc();
    ref_46a = msgShow(msg_67);
/***************************************
[color(yellow)]オバサン・六女[color(white)]
[tab]売れる物、持ってないじゃないの～。[wait][clear]
***************************************/
    wait(ref_46a);
    dialogFree(ref_469);
    ref_46d = bustupFade(ref_467, rgb(0,0,0), 10);
    bustupWait(ref_46d);
    bustupFree(ref_467);
    li(var_5, 20);
}

function DECIDE_BUY()
{
    msgVar_Number(msgvar_0, var_6);
    unitFacePlayer(shopkeeper);
    ref_474 = bustupLoad(bustup_fd);
    bustupWait(ref_474);
    ref_476 = bustupAlloc(ref_474, left, rgb(0,0,0));
    bustupFade(ref_476, rgb(128,0,0), 30);
    ref_478 = dialogAlloc();
    choiceSetResult(1);
    ref_47a = msgShow(msg_68);
/***************************************
[color(yellow)]オバサン・六女[color(white)]
[tab]全部で、[var(msg_var_0)]円になるけど
[tab]いいかしらぁ～？
[choice(2)]はい
いいえ
[end_choice][clear]
***************************************/
    wait(ref_47a);
    choiceGetResult(var_7);
    bne(var_7, 0, label_481);
    sndMusicPlay(sound_3037, 127);
    li(var_7, 1);
    b(label_484);
  label_481:
    bne(var_7, 1, label_484);
    li(var_7, 0);
    b(label_484);
  label_484:
    wait(ref_47a);
    dialogFree(ref_478);
    ref_486 = bustupFade(ref_476, rgb(0,0,0), 10);
    bustupWait(ref_486);
    bustupFree(ref_476);
    li(var_5, 20);
}

