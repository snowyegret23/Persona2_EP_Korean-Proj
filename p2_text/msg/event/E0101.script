function START()
{
    sndMusicPlay(sound_406b, 90);
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    cameraSet(north, 1000, 0, 1000);
    ref_4 = spriteLoad(sprite_18);
    wait(ref_4);
    ref_6 = spriteLoad(sprite_19);
    wait(ref_6);
    ref_8 = spriteLoad(sprite_1a);
    wait(ref_8);
    ref_a = spriteLoad(sprite_196);
    wait(ref_a);
    ref_c = spriteLoad(sprite_dc);
    wait(ref_c);
    ref_e = spriteLoad(sprite_dd);
    wait(ref_e);
    unitSpawn(tatsuya, sprite_1a, 830, 0, 800, south, none);
    unitAnimationPlay(tatsuya, animation_0, 1);
    unitSpawn(enemy1, sprite_196, 950, 0, 1100, north, none);
    unitAnimationPlay(enemy1, animation_10, 1);
    unitSpawn(enemy2, sprite_dc, 1000, 0, 950, east, none);
    unitAnimationPlay(enemy2, animation_17, 1);
    ref_16 = evtbgLoad(evtbg_19);
    wait(ref_16);
    evtbgInit(evtbg_handle_19, evtbg_19, 0, 0, rgb(0,0,0), true);
    ref_19 = evtbgFade(evtbg_handle_19, rgb(128,128,128), 1, false);
    wait(ref_19);
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    screenFadeInner(rgb(0,0,0), 4, true);
    screenFadeOuter(rgb(0,0,0), 4, true);
    screenEffectUnknown();
    screenFadeWait(inner);
    screenFadeWait(outer);
    sndMusicPlay(sound_320d, 127);
    ref_22 = efctDummy(effect_7);
    ref_23 = efctLoad(effect_7);
    delayClear();
    delayWait(60);
    unitAnimationPlay(enemy1, animation_c, 1);
    unitWait(enemy1);
    ref_28 = unitColor(enemy1, rgb(0,0,0), 5);
    wait(ref_28);
    ref_2a = unitColor(enemy1, rgb(112,112,112), 5);
    wait(ref_2a);
    ref_2c = unitColor(enemy1, rgb(0,0,0), 5);
    wait(ref_2c);
    ref_2e = unitColor(enemy1, rgb(112,112,112), 5);
    wait(ref_2e);
    ref_30 = unitColor(enemy1, rgb(0,0,0), 5);
    wait(ref_30);
    ref_32 = unitColor(enemy1, rgb(112,112,112), 5);
    wait(ref_32);
    ref_34 = unitColor(enemy1, rgb(0,0,0), 5);
    wait(ref_34);
    ref_36 = unitColor(enemy1, rgb(112,112,112), 5);
    wait(ref_36);
    ref_38 = unitColor(enemy1, rgb(0,0,0), 5);
    wait(ref_38);
    ref_3a = unitColor(enemy1, rgb(112,112,112), 5);
    wait(ref_3a);
    ref_3c = unitColor(enemy1, rgb(0,0,0), 5);
    wait(ref_3c);
    ref_3e = unitColor(enemy1, rgb(112,112,112), 5);
    wait(ref_3e);
    wait(ref_22);
    wait(ref_23);
    efctPlay(effect_7, efct_0, 950, 0, 1100, 950, 0, 1100, false);
    unitSpriteClear(enemy2);
    unitSpriteSet(enemy2, sprite_dd);
    unitAnimationPlay(enemy2, animation_d, 1);
    unitFace(enemy2, south);
    unitDespawn(enemy1, ghost);
    unitSpriteClear(enemy1);
    efctWait(efct_0);
    delayClear();
    delayWait(60);
    unitSpriteClear(enemy2);
    unitSpriteSet(enemy2, sprite_dc);
    unitAnimationPlay(enemy2, animation_17, 1);
    unitFace(enemy2, east);
    ref_50 = dialogAlloc();
    ref_51 = msgShow(msg_0);
/***************************************
[color(yellow)]Ｘ－０のパイロット[color(white)]
[tab]ええぃ、クソ！
[tab]歩くだけの能無しが！
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_51);
    dialogFree(ref_50);
    unitSpriteClear(tatsuya);
    unitSpriteSet(tatsuya, sprite_18);
    unitAnimationPlay(tatsuya, animation_0, 1);
    unitFace(tatsuya, south);
    unitMove(tatsuya, 900, 850, face_south, medium);
    unitWait(tatsuya);
    unitAnimationPlay(enemy2, animation_1, 1);
    unitWait(enemy2);
    delayClear();
    delayWait(5);
    unitAnimationPlay(enemy2, animation_0, 1);
    unitFace(enemy2, north);
    unitSpriteClear(tatsuya);
    unitSpriteSet(tatsuya, sprite_19);
    unitAnimationPlay(tatsuya, animation_1, 1);
    unitWait(tatsuya);
    sndMusicPlay(sound_32e9, 127);
    ref_66 = dialogAlloc();
    ref_67 = msgShow(msg_1);
/***************************************
駆動系がショートし、機体のいたるとこから煙を上げる
鉄屑のハッチが開き、操縦していた男が飛び出してきた。
そいつはまだ腰の銃を抜こうとしていたが、
額に刀を突きつけると大人しくなった。
[wait][clear]
***************************************/
    wait(ref_67);
    ref_69 = msgShow(msg_2);
/***************************************
フェンスの向こうの若い男は、もう消えていた。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_69);
    dialogFree(ref_66);
    ref_6d = bustupLoad(bustup_b);
    bustupWait(ref_6d);
    ref_6f = bustupAlloc(ref_6d, left, rgb(0,0,0));
    bustupFade(ref_6f, rgb(128,0,0), 30);
    ref_71 = dialogAlloc();
    ref_72 = msgShow(msg_3);
/***************************************
[color(yellow)][tatsuya][color(white)]
[tab]手を上げろ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_72);
    dialogFree(ref_71);
    ref_76 = bustupFade(ref_6f, rgb(0,0,0), 10);
    bustupWait(ref_76);
    bustupFree(ref_6f);
    delayClear();
    delayWait(60);
    unitAnimationPlay(enemy2, animation_2, 1);
    unitWait(enemy2);
    delayClear();
    delayWait(5);
    unitAnimationPlay(enemy2, animation_0, 1);
    unitWait(enemy2);
    delayClear();
    delayWait(5);
    unitAnimationPlay(enemy2, animation_4, 1);
    unitWait(enemy2);
    delayClear();
    delayWait(5);
    unitAnimationPlay(enemy2, animation_0, 1);
    unitWait(enemy2);
    delayClear();
    delayWait(5);
    unitAnimationPlay(enemy2, animation_2, 1);
    unitWait(enemy2);
    delayClear();
    delayWait(5);
    unitAnimationPlay(enemy2, animation_0, 1);
    unitWait(enemy2);
    delayClear();
    delayWait(5);
    unitWait(enemy2);
    ref_94 = dialogAlloc();
    ref_95 = msgShow(msg_4);
/***************************************
[color(yellow)]Ｘ－０のパイロット[color(white)]
[tab]な、何が目的だ。
[tab]生きてここを出られるとでも…
[wait][clear]
***************************************/
    wait(ref_95);
    ref_97 = msgShow(msg_5);
/***************************************
ほんの少し刃を押した。
男の額に切っ先がめり込み、血が鼻筋を伝う。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_97);
    dialogFree(ref_94);
    ref_9b = bustupLoad(bustup_b);
    bustupWait(ref_9b);
    ref_9d = bustupAlloc(ref_9b, left, rgb(0,0,0));
    bustupFade(ref_9d, rgb(128,0,0), 30);
    ref_9f = dialogAlloc();
    ref_a0 = msgShow(msg_6);
/***************************************
[color(yellow)][tatsuya][color(white)]
[tab]エレベーターに乗れ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_a0);
    dialogFree(ref_9f);
    ref_a4 = bustupFade(ref_9d, rgb(0,0,0), 10);
    bustupWait(ref_a4);
    bustupFree(ref_9d);
    delayClear();
    delayWait(60);
    unitAnimationPlay(enemy2, animation_6, 1);
    delayClear();
    delayWait(30);
    unitAnimationPlay(enemy2, animation_0, 1);
    unitWait(enemy2);
    ref_ae = dialogAlloc();
    ref_af = msgShow(msg_7);
/***************************************
[color(yellow)]Ｘ－０のパイロット[color(white)]
[tab]…わ、わかった。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_af);
    dialogFree(ref_ae);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    ref_b9 = dialogAlloc();
    ref_ba = msgShow(msg_8);
/***************************************
男は両手を挙げた。
切っ先を寄り目で見つめながら、そのままの姿勢で
俺の周りをそろりそろりと移動し、
エレベーター側へ回り込んだ。
[wait][clear]
***************************************/
    wait(ref_ba);
    sndMusicPlay(sound_3164, 127);
    delayClear();
    delayWait(30);
    ref_bf = msgShow(msg_9);
/***************************************
その間、刀はずっと奴の額にわずかに刺さったままだ。
男が片手で背後のエレベーターのボタンをまさぐると、
しばらくして扉が開いた。
[wait][clear]
***************************************/
    wait(ref_bf);
    ref_c1 = msgShow(msg_10);
/***************************************
俺が刀を突きつけたまま遠慮なく足を踏み出すと、
のけぞった男は尻から籠の中に転がり込んだ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_c1);
    dialogFree(ref_b9);
    sndMusicPlay(sound_3136, 127);
    delayClear();
    delayWait(30);
    ref_c8 = dialogAlloc();
    ref_c9 = msgShow(msg_11);
/***************************************
顎を蹴り上げ、脳を頭蓋骨の中でシェイクしてやってから
襟首を掴んで立たせると、ボタンが並んだパネルに顔を
押し付け腰の自動拳銃を奪った。
[wait][clear]
***************************************/
    wait(ref_c9);
    sndMusicPlay(sound_30c1, 127);
    ref_cc = msgShow(msg_12);
/***************************************
セイフティを解除してスライドを引くと、
既に装填済みの弾が一発排叱されて床に転がった。
[wait][clear]
***************************************/
    wait(ref_cc);
    ref_ce = msgShow(msg_13);
/***************************************
舞耶姉の見よう見真似だが、これで確実に撃てるはずだ。
銃口を男の耳の後ろに押し付ける。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_ce);
    dialogFree(ref_c8);
    ref_d2 = bustupLoad(bustup_b);
    bustupWait(ref_d2);
    ref_d4 = bustupAlloc(ref_d2, left, rgb(0,0,0));
    bustupFade(ref_d4, rgb(128,0,0), 30);
    ref_d6 = dialogAlloc();
    ref_d7 = msgShow(msg_14);
/***************************************
[color(yellow)][tatsuya][color(white)]
[tab]４階だ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_d7);
    dialogFree(ref_d6);
    ref_db = bustupFade(ref_d4, rgb(0,0,0), 10);
    bustupWait(ref_db);
    bustupFree(ref_d4);
    ref_de = dialogAlloc();
    ref_df = msgShow(msg_15);
/***************************************
男は額と鼻から血を垂らしたまま、３１１２３２１３Ｂ１
と続けてボタンを押した。
かすかに下方へ押し付けられるＧと共に、エレベーターが
動き出す。
[wait][clear]
***************************************/
    wait(ref_df);
    ref_e1 = msgShow(msg_16);
/***************************************
そのまま襟首を掴んで、男をドア正面に立たせた。
小細工をしていても、ドアが開いて最初に撃たれるのは
こいつだ。
[wait][clear]
***************************************/
    wait(ref_e1);
    ref_e3 = msgShow(msg_17);
/***************************************
３階を過ぎると、パネルの階数表示が３で点滅しだした。
数秒過ぎ、ドアが開く。４階についたようだ。
[wait][clear]
***************************************/
    wait(ref_e3);
    sndMusicPlay(sound_3164, 127);
    delayClear();
    delayWait(30);
    ref_e8 = msgShow(msg_18);
/***************************************
警備員が待ち構えてると思ったが誰もいない。
男の背を押してエレベーターを出た。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_e8);
    dialogFree(ref_de);
    eventFileLoad(E, 258);
}
