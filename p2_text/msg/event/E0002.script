function MAYAMOVE()
{
    unitSpawn(maya, sprite_0, 1000, 0, 50, north, fade);
    unitMove(maya, 1000, -100, face_north, medium);
    unitWait(maya);
    unitMove(maya, 1250, -100, face_north, medium);
    unitWait(maya);
    unitMove(maya, 1250, -260, face_north, medium);
    unitWait(maya);
}

function MAYAMOVE2()
{
    unitMove(maya, 610, -260, face_north, medium);
    unitWait(maya);
    unitMove(maya, 560, -415, face_north, medium);
    unitWait(maya);
}

function MAYAMOVE3()
{
    cameraFollow(maya);
    unitMove(maya, 670, -510, face_north, fast);
    unitWait(maya);
    unitMove(maya, 670, -1550, face_north, fast);
    unitWait(maya);
    unitMove(maya, 320, -1750, face_east, fast);
    unitWait(maya);
    unitFace(maya, north);
}
