function EXIT_RED()
{
    controlDisable();
    unitAnimationPlay(nanjo, animation_b, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(nanjo, animation_c, 1);
    cameraRotateTo(1, 60);
    ref_166 = cameraMoveTo(980, 0, -700, 60);
    wait(ref_166);
    ref_168 = bustupLoad(bustup_36);
    bustupWait(ref_168);
    ref_16a = bustupAlloc(ref_168, left, rgb(0,0,0));
    bustupFade(ref_16a, rgb(128,0,0), 30);
    ref_16c = dialogAlloc();
    ref_16d = msgShow(msg_14);
/***************************************
[color(yellow)]南条[color(white)]
[tab]天野さん、もう後戻りはできない。
[tab]前進あるのみだ！
