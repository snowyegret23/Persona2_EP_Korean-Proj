function START()
{
    timerClear();
    bitClear(EBIT_NOSAVE_B);
    bitSet(EBIT_CHUKEITEN1);
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    levelFootstepSet(sfx_1a);
    sndIdGet(var_0);
    bne(var_0, -1, label_9);
    b(label_b);
  label_9:
    sndVolumeFadeTo(var_0, 0, 5);
    b(label_b);
  label_b:
    sndUnkCF(0);
    sndMusicPlay(sound_3156, 60);
    ref_d = spriteLoad(sprite_0);
    wait(ref_d);
    ref_f = spriteLoad(sprite_2);
    wait(ref_f);
    ref_11 = spriteLoad(sprite_1);
    wait(ref_11);
    ref_13 = spriteLoad(sprite_6);
    wait(ref_13);
    ref_15 = spriteLoad(sprite_d);
    wait(ref_15);
    ref_17 = spriteLoad(sprite_13);
    wait(ref_17);
    ref_19 = spriteLoad(sprite_1f);
    wait(ref_19);
    unknownVar1(var_0);
    bne(var_0, 1793, label_22);
    cameraSetNorth(east);
    cameraSet(northeast, 930, 0, -80);
    playerInit(north);
    controlDisable();
    b(label_2d);
  label_22:
    bne(var_0, 6915, label_28);
    cameraSetNorth(east);
    cameraSet(northeast, 980, 0, -330);
    playerInit(east);
    controlDisable();
    b(label_2d);
  label_28:
    cameraSetNorth(east);
    cameraSet(northeast, 980, 0, -330);
    playerInit(east);
    controlDisable();
    b(label_2d);
  label_2d:
    unitSpawn(ulala, sprite_6, 280, -300, -700, east, none);
    unitAnimationPlay(ulala, animation_a, 1);
    unitSpawn(katsuya, sprite_d, 800, 0, -950, south, none);
    unitAnimationPlay(katsuya, animation_a, 1);
    unitSpawn(baofu, sprite_13, 80, -300, -500, north, none);
    unitAnimationPlay(baofu, animation_a, 1);
    unitSpawn(nanjo, sprite_1f, 980, 0, -700, east, none);
    unitAnimationPlay(nanjo, animation_a, 1);
    unitIdleOnAll();
    unitTriggerSet(ulala, URARA, 255, 1);
    unitTriggerSet(katsuya, KATUYA, 255, 1);
    unitTriggerSet(baofu, PAOFU, 255, 1);
    unitTriggerSet(nanjo, NANJO, 255, 1);
    envTriggerSet(RED_DOOR, 131, 1, line, coll_14);
    envTriggerSet(BLUE_DOOR, 14, 1, line, coll_13);
    envTriggerSet(EXIT_BLUE, 56, 1, line, coll_8);
    envTriggerSet(EXIT_RED, 224, 1, line, coll_5);
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

function NANJO()
{
    controlDisable();
    unitFacePlayer(nanjo);
    ref_47 = bustupLoad(bustup_36);
    bustupWait(ref_47);
    ref_49 = bustupAlloc(ref_47, left, rgb(0,0,0));
    bustupFade(ref_49, rgb(128,0,0), 30);
    ref_4b = dialogAlloc();
    ref_4c = msgShow(msg_0);
/***************************************
[color(yellow)]南条[color(white)]
[tab]しかし桐島の奴、いらぬ気を回したものだ…
[tab]あの二人は、神取と浅からぬ因縁があるからと
[tab]俺が連絡しなかったものを…
[sync][wait][clear]
***************************************/
    unitAnimationPlay(nanjo, animation_2d, 1);
    delayClear();
    delayWait(60);
    sync();
    wait(ref_4c);
    dialogFree(ref_4b);
    ref_53 = bustupFade(ref_49, rgb(0,0,0), 10);
    bustupWait(ref_53);
    bustupFree(ref_49);
    ref_56 = bustupLoad(bustup_37);
    bustupWait(ref_56);
    ref_58 = bustupAlloc(ref_56, left, rgb(0,0,0));
    bustupFade(ref_58, rgb(128,0,0), 30);
    ref_5a = dialogAlloc();
    ref_5b = msgShow(msg_1);
/***************************************
[color(yellow)]南条[color(white)]
[tab]まあ、それがわかっているから、
[tab]自分で行きたいのをこらえたのだろうがな…
[tab]流石、俺が認めた奴らだ…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_5b);
    dialogFree(ref_5a);
    ref_5f = bustupFade(ref_58, rgb(0,0,0), 10);
    bustupWait(ref_5f);
    bustupFree(ref_58);
    unitAnimationPlay(nanjo, animation_a, 1);
    unitRestoreFacing(nanjo);
    controlEnable();
}

