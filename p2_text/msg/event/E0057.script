    unitFace(ulala, south);
    unitFace(katsuya, south);
    unitFace(baofu, east);
    unitFace(elly, east);
    ref_23a = cameraMoveTo(250, 0, -700, 1);
    wait(ref_23a);
    ref_23c = cameraRotateTo(5, 1);
    wait(ref_23c);
