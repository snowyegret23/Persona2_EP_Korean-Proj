function FREE()
{
    sndIdGet(var_0);
    bne(var_0, -1, label_212);
    bitGet(var_2, EBIT_E0010);
    bne(var_2, 0, label_20c);
    ref_208 = sndLoad(sound_1000);
    wait(ref_208);
    sndMusicPlay(sound_1000, 90);
    b(label_211);
  label_20c:
    bne(var_2, 1, label_211);
    ref_20d = sndLoad(sound_15a0);
    wait(ref_20d);
    sndMusicPlay(sound_15a0, 90);
    b(label_211);
  label_211:
    b(label_214);
  label_212:
    sndVolumeFadeTo(var_0, 90, 60);
    b(label_214);
  label_214:
    sndUnkCF(90);
    unitSpawn(ulala, sprite_6, 1184, 0, -520, north, none);
    unitFace(ulala, north);
    unitSpawn(noriko, sprite_5d, 1250, 0, -1100, north, none);
    unitFace(noriko, south);
    unitSpawn(enemy1, sprite_ad, 950, 0, -780, north, none);
    unitFace(enemy1, west);
    unitSpawn(enemy2, sprite_af, 1450, 0, -1170, north, none);
    unitFace(enemy2, east);
