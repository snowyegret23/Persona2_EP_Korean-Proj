function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    levelFootstepSet(sfx_15);
    ref_3 = spriteLoad(sprite_0);
    wait(ref_3);
    ref_5 = spriteLoad(sprite_2);
    wait(ref_5);
    ref_7 = spriteLoad(sprite_6);
    wait(ref_7);
    ref_9 = spriteLoad(sprite_5c);
    wait(ref_9);
    ref_b = spriteLoad(sprite_5d);
    wait(ref_b);
    ref_d = spriteLoad(sprite_5a);
    wait(ref_d);
    ref_f = spriteLoad(sprite_59);
    wait(ref_f);
    ref_11 = spriteLoad(sprite_5b);
    wait(ref_11);
    ref_13 = spriteLoad(sprite_ad);
    wait(ref_13);
    ref_15 = spriteLoad(sprite_af);
    wait(ref_15);
    ref_17 = spriteLoad(sprite_c8);
    wait(ref_17);
    objVisible(obj_e, false);
    bitGet(var_1, EBIT_E000D);
    bne(var_1, 0, label_1f);
    ref_1c = call(KYOUSEI);
    wait(ref_1c);
    b(label_23);
  label_1f:
    bne(var_1, 1, label_23);
    ref_20 = call(FREE);
    wait(ref_20);
    b(label_23);
  label_23:
}

