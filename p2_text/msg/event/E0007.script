function URARA()
{
    controlDisable();
    unitFacePlayer(ulala);
    ref_255 = bustupLoad(bustup_19);
    bustupWait(ref_255);
    ref_257 = bustupAlloc(ref_255, left, rgb(0,0,0));
    bustupFade(ref_257, rgb(128,0,0), 30);
    ref_259 = dialogAlloc();
    ref_25a = msgShow(msg_14);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]あの親父、きっと校長室でふん反り返ってるって！
[tab]私、あーいうのが一番頭くんのよ。
[tab]絶対文句言っちゃる！
[sync][wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2f, 1);
    sync();
    wait(ref_25a);
    dialogFree(ref_259);
    ref_25f = bustupFade(ref_257, rgb(0,0,0), 10);
    bustupWait(ref_25f);
    bustupFree(ref_257);
    unitAnimationPlay(ulala, animation_0, 1);
    unitWait(ulala);
    unitRestoreFacing(ulala);
    controlEnable();
}

