    ref_b6 = bustupAlloc(ref_b4, left, rgb(0,0,0));
    bustupFade(ref_b6, rgb(128,0,0), 30);
    ref_b8 = dialogAlloc();
    ref_b9 = msgShow(msg_6);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]なんでだろう…私、あの[tatsuya]って子、
[tab]ＧＯＬＤで見た事あるような気がするんだ…
[tab]そんな訳無いのに…
[wait][clear]
***************************************/
