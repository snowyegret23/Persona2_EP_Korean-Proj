    bustupFade(ref_88, rgb(128,0,0), 30);
    ref_8a = dialogAlloc();
    ref_8b = msgShow(msg_1);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]うわぁ、みんな四字熟語使ってるよぉ！？
[tab]あぁどうしようかマーヤぁ。
[tab]私達も何か言わなきゃ。
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2f, 1);
    wait(ref_8b);
    ref_8e = msgShow(msg_2);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]えーと、…ええい、国士無双うららの拳！！
[tab]ホレ、マーヤも一発かましてやんな！
[tab][delay(30)]…え、立直一発！？[tab]…って…あぁ～
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_1d, 1);
    wait(ref_8e);
    unitAnimationPlay(ulala, animation_a, 1);
    dialogFree(ref_8a);
    ref_93 = bustupFade(ref_88, rgb(0,0,0), 10);
    bustupWait(ref_93);
    bustupFree(ref_88);
    unitRestoreFacing(ulala);
    b(label_e8);
  label_98:
    unitFacePlayer(ulala);
    ref_99 = bustupLoad(bustup_1d);
    bustupWait(ref_99);
    ref_9b = bustupAlloc(ref_99, left, rgb(0,0,0));
    bustupFade(ref_9b, rgb(128,0,0), 30);
    ref_9d = dialogAlloc();
    ref_9e = msgShow(msg_3);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]ねぇマーヤ…
[tab]この混乱って新世塾が悪いんだよね？
[tab]私達は…悪くないよね？
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2d, 1);
    wait(ref_9e);
    unitAnimationPlay(ulala, animation_a, 1);
    dialogFree(ref_9d);
    ref_a3 = bustupFade(ref_9b, rgb(0,0,0), 10);
    bustupWait(ref_a3);
    bustupFree(ref_9b);
    unitRestoreFacing(ulala);
    b(label_e8);
  label_a8:
    unitFacePlayer(ulala);
    ref_a9 = bustupLoad(bustup_17);
    bustupWait(ref_a9);
    ref_ab = bustupAlloc(ref_a9, left, rgb(0,0,0));
    bustupFade(ref_ab, rgb(128,0,0), 30);
    ref_ad = dialogAlloc();
    ref_ae = msgShow(msg_4);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]あの子が自分に酔ってるって？[tab]ふ～ん。
[tab]思春期でもないのに自分に酔ってるオジサンが
[tab]そんなこと言ってもねぇ～説得力無いわねぇ。
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_1d, 1);
    wait(ref_ae);
    unitAnimationPlay(ulala, animation_a, 1);
    dialogFree(ref_ad);
    ref_b3 = bustupFade(ref_ab, rgb(0,0,0), 10);
    bustupWait(ref_b3);
    bustupFree(ref_ab);
    unitRestoreFacing(ulala);
    b(label_e8);
  label_b8:
    unitFacePlayer(ulala);
    ref_b9 = bustupLoad(bustup_17);
    bustupWait(ref_b9);
    ref_bb = bustupAlloc(ref_b9, left, rgb(0,0,0));
    bustupFade(ref_bb, rgb(128,0,0), 30);
    ref_bd = dialogAlloc();
    ref_be = msgShow(msg_5);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]う～ん、「向こう側」の世界でも
[tab]サトミタダシは人気あったのかな？
[tab]聞いてみよ～よ。ねぇマーヤ。
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2d, 1);
    wait(ref_be);
    unitAnimationPlay(ulala, animation_a, 1);
    dialogFree(ref_bd);
    ref_c3 = bustupFade(ref_bb, rgb(0,0,0), 10);
    bustupWait(ref_c3);
    bustupFree(ref_bb);
    unitRestoreFacing(ulala);
    b(label_e8);
  label_c8:
    unitFacePlayer(ulala);
    ref_c9 = bustupLoad(bustup_17);
    bustupWait(ref_c9);
    ref_cb = bustupAlloc(ref_c9, left, rgb(0,0,0));
    bustupFade(ref_cb, rgb(128,0,0), 30);
    ref_cd = dialogAlloc();
    ref_ce = msgShow(msg_6);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]どうマーヤ、買物は終了？
[tab]準備は出来た？
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2d, 1);
    wait(ref_ce);
    unitAnimationPlay(ulala, animation_a, 1);
