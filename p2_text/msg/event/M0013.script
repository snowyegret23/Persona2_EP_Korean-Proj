    bustupWait(ref_d9);
    ref_db = bustupAlloc(ref_d9, left, rgb(0,0,0));
    bustupFade(ref_db, rgb(128,0,0), 30);
    ref_dd = dialogAlloc();
    ref_de = msgShow(msg_7);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]もしもよ、このアメノトリフネが
