function EXITBOX()
{
    controlDisable();
    bitClear(MBIT_EXITBIT);
    mapLoad(rengedai, 0, 0);
}

function warp1()
{
    call(EXITBOX);
}

function HA_SHOP_EXPLAIN_0()
{
    bitGet(var_0, MBIT_HI_TONYITEM);
    bne(var_0, 0, label_78d);
    ref_788 = dialogAlloc();
    ref_789 = msgShow(msg_115);
/***************************************
[color(yellow)]トニー[color(white)]
[tab]ウーン、「売買」についてダネ。
[wait][clear][color(yellow)]トニー[color(white)]
[tab]まずは、購入の説明をするよ。
[tab]ボクの店で「アクセサリーを買う」を選ぶと
[tab]いかしたアクセサリーを買うことができるんだよ。
[wait][clear][color(yellow)]トニー[color(white)]
[tab]アクセサリーはモノによって
[tab]装備できる人に制限があったりスルから、
[tab]よく確認して買っていってネ。
[wait][clear][color(yellow)]トニー[color(white)]
[tab]つぎに、売却の説明をするヨ。
[tab]「アイテムを売る」を選ぶと、種類の選択になるから
[tab]売りたいものの種類を選んで、売りたいものを選んでネ。
[wait][clear][color(yellow)]トニー[color(white)]
[tab]買い取り価格は元値の約半額くらいだよ。
[tab]あと、装備中のモノは売ることができないから～
[tab]それと、モノによっては買取できないものもあるヨ。
[wait][clear][color(yellow)]トニー[color(white)]
[tab]こんなとこダネ。
[wait][clear]
***************************************/
    wait(ref_789);
    dialogFree(ref_788);
    b(label_793);
  label_78d:
    bne(var_0, 1, label_793);
    ref_78e = dialogAlloc();
    ref_78f = msgShow(msg_116);
/***************************************
[color(yellow)]トニー[color(white)]
[tab]ウーン、「売買」についてダネ。
[wait][clear][color(yellow)]トニー[color(white)]
[tab]まずは、購入の説明をするよ。
[tab]ボクの店で「特殊アイテムを買う」を選ぶと
