function NOITEM()
{
    unitFacePlayer(shopkeeper);
    ref_795 = bustupLoad(bustup_f7);
    bustupWait(ref_795);
    ref_797 = bustupAlloc(ref_795, right, rgb(0,0,0));
    bustupFade(ref_797, rgb(128,0,0), 30);
    ref_799 = dialogAlloc();
    ref_79a = msgShow(msg_117);
/***************************************
[color(yellow)]トニー[color(white)]
[tab]ウーン？[tab]キミの持ち物で買い取れるものは
[tab]無さそうだヨ？[wait][clear]
***************************************/
    wait(ref_79a);
    dialogFree(ref_799);
    ref_79d = bustupFade(ref_797, rgb(0,0,0), 10);
    bustupWait(ref_79d);
    bustupFree(ref_797);
    li(var_5, 20);
}

function DECIDE_BUY()
{
    msgVar_Number(msgvar_0, var_6);
