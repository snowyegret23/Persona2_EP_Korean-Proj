function DOORBOX()
{
    controlDisable();
    sndMusicPlay(sound_306b, 127);
    objAnimTranslate(obj_6, 80, 0, 0, 30);
    objAnimTranslate(obj_7, -80, 0, 0, 30);
    objAnimWait(obj_6);
    objAnimWait(obj_7);
    call(GOOUT);
}

function GOOUT()
{
    bitClear(MBIT_EXITBIT);
    mapLoad(rengedai, 0, 0);
}

function warp1()
{
    call(DOORBOX);
}

function HA_SHOP_EXPLAIN_0()
{
    ref_48b = dialogAlloc();
    ref_48c = msgShow(msg_67);
/***************************************
[color(yellow)]オバサン・長女[color(white)]
[tab]うひょひょひょ。
[tab]「売買」についてねぇ～。
[wait][clear][color(yellow)]オバサン・長女[color(white)]
[tab]まずは、購入の説明なのねぇ～。
[tab]うちの店で「消費物を買う」を選ぶと
[tab]消費アイテムを買うことができるわよぉ～。
[wait][clear][color(yellow)]オバサン・長女[color(white)]
[tab]あっ、そうそう、アイテムは持てる数が
[tab]決まってるからねぇ～。
[wait][clear][color(yellow)]オバサン・長女[color(white)]
[tab]次に、売却の説明なのねぇ～。
[tab]「アイテムを売る」を選んで、まず種類を決めて、
[tab]次に売りたいものを選んでねぇ～。
[wait][clear][color(yellow)]オバサン・長女[color(white)]
[tab]買取価格は元値の約半額くらいよぉ～。
[tab]あと、装備中の物は売ることができないからねぇ～。
[tab]それと、物によっては買取できない物もあるわよぉ～。
[wait][clear][color(yellow)]オバサン・長女[color(white)]
[tab]こんなとこかしらぁ～。
[tab]うひょひょひょ。
[wait][clear]
***************************************/
    wait(ref_48c);
    dialogFree(ref_48b);
}

function NOITEM()
{
    unitFacePlayer(shopkeeper);
    ref_491 = bustupLoad(bustup_fd);
    bustupWait(ref_491);
    ref_493 = bustupAlloc(ref_491, right, rgb(0,0,0));
    bustupFade(ref_493, rgb(128,0,0), 30);
    ref_495 = dialogAlloc();
    ref_496 = msgShow(msg_68);
/***************************************
[color(yellow)]オバサン・長女[color(white)]
[tab]売れる物、持ってないじゃないの～。[wait][clear]
***************************************/
    wait(ref_496);
    dialogFree(ref_495);
    ref_499 = bustupFade(ref_493, rgb(0,0,0), 10);
    bustupWait(ref_499);
    bustupFree(ref_493);
    li(var_5, 20);
}

function DECIDE_BUY()
{
    msgVar_Number(msgvar_0, var_6);
    unitFacePlayer(shopkeeper);
    ref_4a0 = bustupLoad(bustup_fd);
    bustupWait(ref_4a0);
    ref_4a2 = bustupAlloc(ref_4a0, left, rgb(0,0,0));
    bustupFade(ref_4a2, rgb(128,0,0), 30);
    ref_4a4 = dialogAlloc();
    choiceSetResult(1);
    ref_4a6 = msgShow(msg_69);
/***************************************
[color(yellow)]オバサン・長女[color(white)]
[tab]全部で、[var(msg_var_0)]円になるけど
[tab]いいかしらぁ～？
[choice(2)]はい
いいえ
[end_choice][clear]
***************************************/
    wait(ref_4a6);
    choiceGetResult(var_7);
    bne(var_7, 0, label_4ad);
    sndMusicPlay(sound_3037, 127);
    li(var_7, 1);
    b(label_4b0);
  label_4ad:
    bne(var_7, 1, label_4b0);
    li(var_7, 0);
    b(label_4b0);
  label_4b0:
    wait(ref_4a6);
    dialogFree(ref_4a4);
    ref_4b2 = bustupFade(ref_4a2, rgb(0,0,0), 10);
    bustupWait(ref_4b2);
    bustupFree(ref_4a2);
    li(var_5, 20);
}

