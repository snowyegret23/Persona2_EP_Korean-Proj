function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    levelFootstepSet(sfx_f);
    ref_3 = spriteLoad(sprite_0);
    wait(ref_3);
    ref_5 = spriteLoad(sprite_2);
    wait(ref_5);
    ref_7 = spriteLoad(sprite_1);
    wait(ref_7);
    ref_9 = spriteLoad(sprite_6);
    wait(ref_9);
    ref_b = spriteLoad(sprite_d);
    wait(ref_b);
    ref_d = spriteLoad(sprite_13);
    wait(ref_d);
    ref_f = spriteLoad(sprite_1f);
    wait(ref_f);
    ref_11 = spriteLoad(sprite_23);
    wait(ref_11);
    partyHealthRestore(katsuya);
    partySPRestore(katsuya);
    partyStatusClear(katsuya);
    partyHealthRestore(baofu);
    partySPRestore(baofu);
    partyStatusClear(baofu);
    partyMemberRemove(katsuya);
    partyMemberRemove(baofu);
    objVisible(obj_b, false);
    bitGet(var_1, EBIT_E0075);
    bne(var_1, 0, label_21);
    ref_1e = call(KYOUSEI);
    wait(ref_1e);
    b(label_25);
  label_21:
    bne(var_1, 1, label_25);
    ref_22 = call(FREE);
    wait(ref_22);
    b(label_25);
  label_25:
}

