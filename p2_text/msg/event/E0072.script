function FREE()
{
    sndIdGet(var_0);
    bne(var_0, -1, label_711);
    b(label_713);
  label_711:
    sndVolumeFadeTo(var_0, 90, 60);
    b(label_713);
  label_713:
    sndUnkCF(90);
    call(JIRIRI);
    unitSpawn(ulala, sprite_6, 343, 0, -382, north, none);
    unitFace(ulala, west);
    bitGet(var_1, MBIT_HI_NANJOTOUJO);
    bne(var_1, 0, label_71c);
    unitSpawn(elly, sprite_23, 920, 0, -660, north, none);
    unitFace(elly, north);
    b(label_720);
  label_71c:
    bne(var_1, 1, label_720);
    unitSpawn(nanjo, sprite_1f, 920, 0, -660, north, none);
    unitFace(nanjo, north);
    b(label_720);
  label_720:
    unitIdleOnAll();
    unitTriggerSet(ulala, URARA, 255, 1);
    bne(var_1, 0, label_725);
    unitTriggerSet(elly, ERI, 255, 1);
    b(label_728);
  label_725:
    bne(var_1, 1, label_728);
    unitTriggerSet(nanjo, NANJO, 255, 1);
    b(label_728);
  label_728:
    envTriggerSet(EXIT, 131, 1, line, coll_7);
    envTriggerSet(TOIRE1, 131, 1, line, coll_8);
    envTriggerSet(TOIRE2, 131, 1, line, coll_9);
    envTriggerSet(TOIRE3, 131, 1, line, coll_a);
    envTriggerSet(TOIRE4, 131, 1, line, coll_b);
    envTriggerSet(TOIRE5, 56, 1, line, coll_c);
    envTriggerSet(TOIRE6, 56, 1, line, coll_d);
    envTriggerSet(TOIRE7, 56, 1, line, coll_e);
    envTriggerSet(TOIRE8, 56, 1, line, coll_f);
    envTriggerSet(TOIRE9, 56, 1, line, coll_10);
    envTriggerSet(YOUGU, 56, 1, line, coll_11);
    cameraSetNorth(west);
    cameraSet(southeast, 250, 0, -1430);
    playerInit(south);
    controlDisable();
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

