    bitGet(var_0, EBIT_E0033);
    bnz(var_0, label_fa);
    bitGet(var_0, EBIT_E0018);
    bnz(var_0, label_e1);
    unitFacePlayer(yukino);
    ref_cf = bustupLoad(bustup_11a);
    bustupWait(ref_cf);
    ref_d1 = bustupAlloc(ref_cf, right, rgb(0,0,0));
    bustupFade(ref_d1, rgb(128,0,0), 30);
    ref_d3 = dialogAlloc();
    ref_d4 = msgShow(msg_0);
/***************************************
[color(yellow)]ゆきの[color(white)]
[tab]あ、舞耶さん！
[tab]セブンスで事件に巻き込まれたんだろ！？
[tab]冴子先生は？[tab]冴子先生は大丈夫なのか！？
[wait][clear]
***************************************/
    unitAnimationPlay(yukino, animation_1f, 1);
    wait(ref_d4);
    ref_d7 = msgShow(msg_1);
/***************************************
[color(yellow)]ゆきの[color(white)]
[tab]…そうか、良かった。
[tab]本当に良かった。
[wait][clear]
***************************************/
    unitAnimationPlay(yukino, animation_2d, 1);
    wait(ref_d7);
    unitAnimationPlay(yukino, animation_a, 1);
    dialogFree(ref_d3);
    ref_dc = bustupFade(ref_d1, rgb(0,0,0), 10);
    bustupWait(ref_dc);
    bustupFree(ref_d1);
    unitRestoreFacing(yukino);
    b(label_138);
  label_e1:
    unitFacePlayer(yukino);
    ref_e2 = bustupLoad(bustup_11a);
    bustupWait(ref_e2);
    ref_e4 = bustupAlloc(ref_e2, right, rgb(0,0,0));
    bustupFade(ref_e4, rgb(128,0,0), 30);
    ref_e6 = dialogAlloc();
    bitGet(var_0, MBIT_KISS_YUKINO);
    bne(var_0, 0, label_ee);
    bitSet(LBIT_0000);
    ref_ea = msgShow(msg_2);
/***************************************
[color(yellow)]ゆきの[color(white)]
[tab]最近、編集部では本物の武器を売る店の噂で
[tab]大変なんだ。あとで取材に同行するんだけどさ、
[tab]みんな馬鹿な噂に踊らされてるよね？
[wait][clear]
***************************************/
    unitAnimationPlay(yukino, animation_2d, 1);
    wait(ref_ea);
    b(label_f3);
  label_ee:
    bne(var_0, 1, label_f3);
    ref_ef = msgShow(msg_3);
/***************************************
[color(yellow)]ゆきの[color(white)]
[tab]舞耶さん！[tab]スゴイよ！
[tab]本当に武器を売ってる店があったんだよ！
[tab]…あれ、…前にもあった…かな…？
