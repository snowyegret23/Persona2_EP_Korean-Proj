    partyItemAdd(king_in_yellow, 1);
    msgVarSet(msgvar_0, 8237);
    bitSet(MBIT_W_ITEMGET);
    dialogFree(ref_465);
    ref_46c = bustupFade(ref_463, rgb(0,0,0), 10);
    bustupWait(ref_46c);
    bustupFree(ref_463);
    delayClear();
    delayWait(30);
    ref_471 = dialogAlloc();
    ref_472 = msgShow(msg_90);
/***************************************
[tab][color(green)][item_with_type(item_ffff)]を手に入れた。[color(white)]
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_472);
    dialogFree(ref_471);
    b(label_47a);
  label_477:
    bne(var_0, 1, label_47a);
    b(label_47b);
    b(label_47a);
  label_47a:
    b(label_47b);
  label_47b:
    objVisible(obj_4d, false);
    controlEnable();
}

