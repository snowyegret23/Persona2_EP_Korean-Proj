function ELE()
{
    controlDisable();
    sndMusicPlay(sound_30a7, 127);
    objAnimTranslate(obj_13, 100, 0, 0, 30);
    objAnimTranslate(obj_14, -200, 0, 0, 30);
    objAnimWait(obj_13);
    objAnimWait(obj_14);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    call(GOOUT);
}

function GOOUT()
{
    bitGet(var_0, LBIT_0000);
    bne(var_0, 0, label_501);
    b(label_504);
  label_501:
    bne(var_0, 1, label_504);
    bitSet(MBIT_KISS_YUKINO);
    b(label_504);
  label_504:
    eventLoad(event_e3);
}

function MAN5()
{
    controlDisable();
    objAnimRotate(obj_32, 0, 45, 0, 5, 0);
    unitFace8(npc5, southeast);
    objAnimWait(obj_32);
    objAnimRotate(obj_32, 0, 45, 0, 5, 0);
    unitFace8(npc5, south);
    objAnimWait(obj_32);
    objAnimRotate(obj_32, 0, 45, 0, 5, 0);
    unitFace8(npc5, southwest);
    objAnimWait(obj_32);
    objAnimRotate(obj_32, 0, 45, 0, 5, 0);
    unitFace8(npc5, west);
    objAnimWait(obj_32);
    ref_513 = call(MAN555);
    wait(ref_513);
    unitRestoreFacing(npc5);
    objAnimRotate(obj_32, 0, 45, 0, 5, 0);
    unitFace8(npc5, northwest);
    objAnimWait(obj_32);
    objAnimRotate(obj_32, 0, 45, 0, 5, 0);
    unitFace8(npc5, north);
    objAnimWait(obj_32);
    objAnimRotate(obj_32, 0, 45, 0, 5, 0);
    unitFace8(npc5, northeast);
    objAnimWait(obj_32);
    objAnimRotate(obj_32, 0, 45, 0, 5, 0);
    unitFace8(npc5, east);
    objAnimWait(obj_32);
    controlEnable();
    unitIdleOff(npc5);
}

