    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    bitSet(TBIT_MD106);
    bitSet(EBIT_E008F);
    mapLoad(rengedai, 0, 2);
}

function TATUYAMOVE()
{
    unitMove(tatsuya, 970, -2200, face_north, fast);
    unitWait(tatsuya);
}

function U_M_BACK()
{
    unitMove(ulala, 1050, -1160, face_east, reverse);
    unitMove(maya, 900, -1250, face_west, reverse);
    unitWait(ulala);
    unitWait(maya);
    unitAnimationPlay(ulala, animation_3, 1);
    unitAnimationPlay(maya, animation_1, 1);
}

function PAOFUMOVE()
{
    unitMove(baofu, 860, -2200, face_north, fast);
    unitWait(baofu);
}

function KATUYAMOVE()
{
    unitMove(katsuya, 1170, -2200, face_north, fast);
    unitWait(katsuya);
}

function MAYAMOVE()
{
    unitMove(maya, 970, -2200, face_north, fast);
    unitWait(maya);
}

function URARAMOVE()
{
    unitMove(ulala, 970, -2200, face_north, fast);
    unitWait(ulala);
}

function ENEMY1MOVE()
{
    unitMove(enemy1, 820, -2200, face_north, fast);
    unitWait(enemy1);
}
