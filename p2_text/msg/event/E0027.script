    unitAnimationPlay(maya, animation_0, 1);
    unitWait(maya);
    delayClear();
    delayWait(120);
    unitAnimationPlay(enemy2, animation_10, 1);
    unitWait(enemy2);
    delayClear();
    delayWait(60);
    unitAnimationPlay(enemy2, animation_a, 1);
    unitWait(enemy2);
    delayClear();
    delayWait(60);
    unitAnimationPlay(enemy2, animation_10, 1);
    unitWait(enemy2);
    delayClear();
    delayWait(60);
    unitAnimationPlay(enemy2, animation_a, 1);
    unitWait(enemy2);
    delayClear();
    delayWait(120);
    unitAnimationPlay(enemy2, animation_2d, 1);
    ref_bb = bustupLoad(bustup_54);
