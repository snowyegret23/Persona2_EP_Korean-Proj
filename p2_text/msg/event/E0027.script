function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    disableMap();
    ref_3 = spriteLoad(sprite_0);
    wait(ref_3);
    ref_5 = spriteLoad(sprite_2);
    wait(ref_5);
    ref_7 = spriteLoad(sprite_46);
    wait(ref_7);
    ref_9 = spriteLoad(sprite_56);
    wait(ref_9);
    bitGet(var_1, EBIT_E002D);
    bne(var_1, 0, label_10);
    ref_d = call(KYOUSEI);
    wait(ref_d);
    b(label_14);
  label_10:
    bne(var_1, 1, label_14);
    ref_11 = call(FREE);
    wait(ref_11);
    b(label_14);
  label_14:
}

function KYOUSEI()
{
    cameraSet(northeast, 300, 0, -250);
    unitSpawn(enemy2, sprite_46, 300, 0, -250, north, none);
    unitFace(enemy2, west);
    unitSpawn(enemy1, sprite_56, 495, 0, -250, north, none);
    unitFace(enemy1, east);
    unitIdleOffAll();
    unitTriggerSet(enemy1, HENSHU, 255, 1);
    envTriggerSet(BOARD, 7, 1, line, coll_a);
    envTriggerSet(MAGAZINE, 14, 1, line, coll_1b);
    envTriggerSet(EXIT, 14, 1, line, coll_18);
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    screenEffectUnknown();
    screenFadeWait(inner);
    screenFadeWait(outer);
    delayClear();
    delayWait(60);
    ref_27 = bustupLoad(bustup_5b);
    bustupWait(ref_27);
    ref_29 = bustupAlloc(ref_27, right, rgb(0,0,0));
    bustupFade(ref_29, rgb(128,0,0), 30);
    ref_2b = dialogAlloc();
    ref_2c = msgShow(msg_0);
/***************************************
[color(yellow)]水野編集長[color(white)]
[tab]今日はどうも、
[tab]わざわざご足労頂いてありがとうございました。
[sync][wait][clear]
***************************************/
    unitAnimationPlay(enemy1, animation_1f, 1);
    delayClear();
    delayWait(30);
    unitAnimationPlay(enemy1, animation_6, 1);
    delayClear();
    delayWait(15);
    unitAnimationPlay(enemy1, animation_0, 1);
    delayClear();
    delayWait(20);
    sync();
    wait(ref_2c);
    dialogFree(ref_2b);
    ref_39 = bustupFade(ref_29, rgb(0,0,0), 10);
    bustupWait(ref_39);
    bustupFree(ref_29);
    objAnimRotate(obj_b, 0, -80, 0, 60, 0);
    sndMusicPlay(sound_310d, 127);
    objAnimWait(obj_b);
    unitAnimationPlay(enemy2, animation_1, 1);
    unitAnimationPlay(enemy1, animation_3, 1);
    delayClear();
    delayWait(60);
    unitSpawn(maya, sprite_0, -50, 0, -695, west, fade);
    unitMove(maya, 50, -690, face_west, medium);
    objAnimRotate(obj_b, 0, 80, 0, 60, 0);
    sndMusicPlay(sound_310e, 127);
    objAnimWait(obj_b);
    unitWait(maya);
    delayClear();
    delayWait(60);
    unitAnimationPlay(maya, animation_3, 1);
    delayClear();
    delayWait(60);
    ref_4e = cameraMoveTo(260, 0, -390, 1);
    ref_4f = cameraRotateTo(7, 1);
    unitAnimationPlay(maya, animation_1, 1);
    unitAnimationPlay(enemy1, animation_1, 1);
    unitAnimationPlay(enemy2, animation_4, 1);
    wait(ref_4f);
    wait(ref_4e);
    delayClear();
    delayWait(60);
    unitMove(enemy1, 495, -315, face_north, medium);
    unitWait(enemy1);
    unitMove(enemy1, 580, -315, face_west, medium);
    unitWait(enemy1);
    unitMove(enemy1, 580, -510, face_north, medium);
    unitWait(enemy1);
    unitMove(enemy1, 380, -510, face_east, medium);
    unitMove(maya, 220, -510, face_west, medium);
    unitWait(enemy1);
    unitWait(maya);
    unitFace(maya, west);
    unitFace(enemy2, north);
    unitWait(enemy2);
    unitAnimationPlay(enemy2, animation_0, 1);
    unitWait(enemy2);
    delayClear();
    delayWait(60);
    ref_68 = bustupLoad(bustup_5b);
    bustupWait(ref_68);
    ref_6a = bustupAlloc(ref_68, right, rgb(0,0,0));
    bustupFade(ref_6a, rgb(128,0,0), 30);
    ref_6c = dialogAlloc();
    ref_6d = msgShow(msg_1);
/***************************************
[color(yellow)]水野編集長[color(white)]
[tab]天野！[tab]あなた一体どこをフラフラしてたの！？
[tab]あなたがいつまでたっても連絡よこさないから、
[tab]私がこうして、千鶴さんにお願いして…
[sync][wait][clear]
***************************************/
    unitAnimationPlay(enemy1, animation_2f, 1);
    delayClear();
    delayWait(10);
    unitAnimationPlay(maya, animation_6, 1);
    delayClear();
    delayWait(60);
    sync();
    wait(ref_6d);
    dialogFree(ref_6c);
    ref_77 = bustupFade(ref_6a, rgb(0,0,0), 10);
    bustupWait(ref_77);
    bustupFree(ref_6a);
    delayClear();
    delayWait(30);
    ref_7c = bustupLoad(bustup_54);
    bustupWait(ref_7c);
    ref_7e = bustupAlloc(ref_7c, right, rgb(0,0,0));
    bustupFade(ref_7e, rgb(128,0,0), 30);
    ref_80 = dialogAlloc();
    ref_81 = msgShow(msg_2);
/***************************************
[color(yellow)]ワンロン千鶴[color(white)]
[tab]まぁ、いいじゃありませんか。
[sync][wait][clear]
***************************************/
    unitAnimationPlay(enemy2, animation_2d, 1);
    delayClear();
    delayWait(10);
    unitAnimationPlay(enemy1, animation_3, 1);
    unitAnimationPlay(maya, animation_1, 1);
    delayClear();
    delayWait(15);
    sync();
    wait(ref_81);
    unitAnimationPlay(enemy2, animation_a, 1);
    unitWait(enemy2);
    delayClear();
    delayWait(30);
    ref_8f = msgShow(msg_3);
/***************************************
[color(yellow)]石神[tab]千鶴（いしがみ[tab]ちづる）[color(white)]
[color(green)][tab]「ワンロン千鶴」の名で時の人となった、
[tab]ワンロン占いの美人占い師。[color(white)]
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_8f);
    dialogFree(ref_80);
    ref_93 = bustupFade(ref_7e, rgb(0,0,0), 10);
    bustupWait(ref_93);
