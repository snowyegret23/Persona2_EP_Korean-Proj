function FREE()
{
    sndIdGet(var_0);
    bne(var_0, -1, label_165);
    ref_161 = sndLoad(sound_3035);
    wait(ref_161);
    sndMusicPlay(sound_3035, 127);
    b(label_166);
  label_165:
    b(label_166);
  label_166:
    unitSpawn(enemy1, sprite_56, 380, 0, -810, north, none);
    unitFace(enemy1, south);
    unitAnimationStop(enemy1);
    unitAnimationPlay(enemy1, animation_a, 1);
    unitWait(enemy1);
    unitTriggerSet(enemy1, HENSHU, 255, 1);
    envTriggerSet(BOARD, 7, 1, line, coll_a);
    envTriggerSet(MAGAZINE, 14, 1, line, coll_1b);
    envTriggerSet(EXIT, 14, 1, line, coll_18);
    envTriggerSet(HENSHU, 224, 1, line, coll_8);
    envTriggerSet(HENSHU, 224, 1, line, coll_6);
    envTriggerSet(HENSHU, 193, 1, line, coll_5);
    envTriggerSet(HENSHU, 131, 1, line, coll_4);
    envTriggerSet(HENSHU, 131, 1, line, coll_3);
    cameraSet(southwest, 50, 0, -700);
    playerInit(west);
    controlDisable();
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    unitIdleOnAll();
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

function HENSHU()
{
    controlDisable();
    unitFacePlayer(enemy1);
    ref_181 = bustupLoad(bustup_5b);
    bustupWait(ref_181);
    ref_183 = bustupAlloc(ref_181, right, rgb(0,0,0));
    bustupFade(ref_183, rgb(128,0,0), 30);
    ref_185 = dialogAlloc();
    ref_186 = msgShow(msg_13);
/***************************************
[color(yellow)]水野編集長[color(white)]
[tab]報告書はどうしたの！？
[tab]早く仕事なさい！
[tab]本当に手のかかる子ね！！
[sync][wait][clear]
***************************************/
    unitAnimationPlay(enemy1, animation_2f, 1);
    delayClear();
    delayWait(45);
    sync();
    wait(ref_186);
    dialogFree(ref_185);
    ref_18d = bustupFade(ref_183, rgb(0,0,0), 10);
    bustupWait(ref_18d);
    bustupFree(ref_183);
    unitAnimationPlay(enemy1, animation_a, 1);
    unitWait(enemy1);
    unitRestoreFacing(enemy1);
    controlEnable();
}

function BOARD()
{
    controlDisable();
    ref_196 = dialogAlloc();
    ref_197 = msgShow(msg_14);
/***************************************
[color(yellow)]クーレストの売り上げ表[color(white)]
[tab][color(green)]販売部数が落ち込んでいる。
[tab]編集長のイライラの原因らしい。
[color(white)]
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_197);
    dialogFree(ref_196);
    controlEnable();
}

function MAGAZINE()
{
    controlDisable();
    ref_19e = dialogAlloc();
    ref_19f = msgShow(msg_15);
/***************************************
[color(yellow)]マガジンラック[color(white)]
[tab][color(green)]クーレストのバックナンバーがある。
[color(white)]
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_19f);
    dialogFree(ref_19e);
    controlEnable();
}

function EXIT()
{
    controlDisable();
    objAnimRotate(obj_b, 0, -80, 0, 60, 0);
    sndMusicPlay(sound_310d, 127);
    objAnimWait(obj_b);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    bitSet(EBIT_E1001);
    bitGet(var_2, EBIT_E0032);
    bne(var_2, 0, label_1b4);
    eventLoad(event_a5);
    b(label_1b7);
  label_1b4:
    bne(var_2, 1, label_1b7);
    eventLoad(event_a6);
    b(label_1b7);
  label_1b7:
}
