    ref_bd = bustupAlloc(ref_bb, right, rgb(0,0,0));
    bustupFade(ref_bd, rgb(128,0,0), 30);
    ref_bf = dialogAlloc();
    ref_c0 = msgShow(msg_4);
/***************************************
[color(yellow)]ワンロン千鶴[color(white)]
[tab]面白い相をしてるわね…
[tab]私が占ってあげるわ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_c0);
    unitAnimationPlay(enemy2, animation_a, 1);
    ref_c4 = msgShow(msg_5);
/***************************************
[color(yellow)]ワンロン千鶴[color(white)]
[tab]あなた…
[tab]自分が自分でないような、そんな気がしてるわね？
[tab]自分より年下の男の事で悩んでる…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_c4);
    unitAnimationPlay(enemy2, animation_14, 1);
    ref_c8 = msgShow(msg_6);
/***************************************
[color(yellow)]ワンロン千鶴[color(white)]
[tab]ねぇあなた、生きていて楽しい？
[tab]生まれてきてよかった？
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_c8);
    unitWait(enemy2);
    unitAnimationPlay(enemy2, animation_2d, 1);
    ref_cd = msgShow(msg_7);
/***************************************
[color(yellow)]ワンロン千鶴[color(white)]
[tab]この世はね、苦行のための世界なの。
[tab]輪廻転生の輪の中で、永遠に生きる苦しみを
[tab]背負わされた、罪人の世界…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_cd);
    unitAnimationPlay(enemy2, animation_a, 1);
    ref_d1 = msgShow(msg_8);
/***************************************
[color(yellow)]ワンロン千鶴[color(white)]
[tab]前世のあなたは、一体どこにいたのかしら。
[tab]過去？[tab]違う国？[tab]それとも…違う世界…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_d1);
    unitAnimationPlay(enemy2, animation_1f, 1);
    ref_d5 = msgShow(msg_9);
/***************************************
[color(yellow)]ワンロン千鶴[color(white)]
[tab]人は繋がってるの。
[tab]過去だけじゃなく、別の世界の自分ともね…
[tab]あなた…変わるわよ。この世界と一緒にね…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_d5);
    dialogFree(ref_bf);
    ref_d9 = bustupFade(ref_bd, rgb(0,0,0), 10);
    bustupWait(ref_d9);
    bustupFree(ref_bd);
    unitAnimationPlay(enemy2, animation_a, 1);
    delayClear();
    delayWait(30);
    ref_df = bustupLoad(bustup_5b);
    bustupWait(ref_df);
    ref_e1 = bustupAlloc(ref_df, right, rgb(0,0,0));
    bustupFade(ref_e1, rgb(128,0,0), 30);
    ref_e3 = dialogAlloc();
    ref_e4 = msgShow(msg_10);
/***************************************
[color(yellow)]水野編集長[color(white)]
[tab]感謝しなさい。
[tab]千鶴さん直々に占ってもらえるなんて、
[tab]そうはないんだから。
[sync][wait][clear]
***************************************/
    unitAnimationPlay(enemy1, animation_2d, 1);
    unitAnimationPlay(maya, animation_1, 1);
    unitWait(maya);
    delayClear();
    delayWait(7);
    unitAnimationPlay(maya, animation_2, 1);
    unitWait(maya);
    sync();
    wait(ref_e4);
    dialogFree(ref_e3);
    ref_ef = bustupFade(ref_e1, rgb(0,0,0), 10);
    bustupWait(ref_ef);
    bustupFree(ref_e1);
    unitAnimationPlay(enemy1, animation_0, 1);
    unitWait(enemy1);
    delayClear();
    delayWait(30);
    unitAnimationPlay(enemy2, animation_3, 1);
    unitWait(enemy2);
    ref_f8 = bustupLoad(bustup_54);
    bustupWait(ref_f8);
    ref_fa = bustupAlloc(ref_f8, right, rgb(0,0,0));
    bustupFade(ref_fa, rgb(128,0,0), 30);
    ref_fc = dialogAlloc();
    ref_fd = msgShow(msg_11);
/***************************************
[color(yellow)]ワンロン千鶴[color(white)]
[tab]じゃあ、私はこれで。
[sync][wait][clear]
***************************************/
    unitAnimationPlay(maya, animation_1, 1);
    unitWait(maya);
    delayClear();
    delayWait(7);
    unitAnimationPlay(maya, animation_0, 1);
    unitWait(maya);
    sync();
    wait(ref_fd);
    dialogFree(ref_fc);
    ref_107 = bustupFade(ref_fa, rgb(0,0,0), 10);
    bustupWait(ref_107);
    bustupFree(ref_fa);
    delayClear();
    delayWait(60);
    unitMove(enemy2, 104, -420, face_east, medium);
    unitAnimationPlay(maya, animation_3, 1);
    unitWait(maya);
    unitWait(enemy2);
    unitMove(enemy2, 45, -695, face_north, medium);
    unitFace(maya, east);
    unitWait(maya);
    unitAnimationPlay(maya, animation_0, 1);
    unitWait(maya);
    delayClear();
    delayWait(10);
    unitAnimationPlay(enemy1, animation_6, 1);
    unitWait(enemy1);
    delayClear();
    delayWait(15);
    unitAnimationPlay(enemy1, animation_0, 1);
    unitWait(enemy1);
    delayClear();
    delayWait(30);
    unitAnimationPlay(enemy1, animation_1, 1);
    unitWait(enemy1);
    unitWait(enemy2);
    unitFace(enemy2, east);
    unitWait(enemy2);
    delayClear();
    delayWait(30);
    objAnimRotate(obj_b, 0, -80, 0, 60, 0);
    sndMusicPlay(sound_310d, 127);
    objAnimWait(obj_b);
    delayClear();
    delayWait(15);
    unitMove(enemy2, -55, -695, fade, medium);
    unitWait(enemy2);
    delayClear();
    delayWait(15);
    objAnimRotate(obj_b, 0, 80, 0, 60, 0);
    sndMusicPlay(sound_310e, 127);
    objAnimWait(obj_b);
    delayClear();
    delayWait(15);
    unitAnimationPlay(enemy1, animation_0, 1);
    unitWait(enemy1);
    delayClear();
    delayWait(30);
    ref_138 = bustupLoad(bustup_5b);
    bustupWait(ref_138);
    ref_13a = bustupAlloc(ref_138, right, rgb(0,0,0));
    bustupFade(ref_13a, rgb(128,0,0), 30);
    ref_13c = dialogAlloc();
    ref_13d = msgShow(msg_12);
/***************************************
[color(yellow)]水野編集長[color(white)]
[tab]まったく、あなたって人は…
[tab]まぁいいわ。取材の結果をまとめて報告して頂戴。
[tab]さぁ早く！
[sync][wait][clear]
***************************************/
    unitAnimationPlay(enemy1, animation_2f, 1);
    unitAnimationPlay(maya, animation_3, 1);
    unitWait(maya);
    delayClear();
    delayWait(7);
    unitFace(maya, south);
