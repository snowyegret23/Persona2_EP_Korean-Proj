function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    ref_2 = spriteLoad(sprite_0);
    wait(ref_2);
    ref_4 = spriteLoad(sprite_2);
    wait(ref_4);
    ref_6 = spriteLoad(sprite_1);
    wait(ref_6);
    ref_8 = spriteLoad(sprite_6);
    wait(ref_8);
    ref_a = spriteLoad(sprite_d);
    wait(ref_a);
    ref_c = spriteLoad(sprite_13);
    wait(ref_c);
    ref_e = spriteLoad(sprite_1f);
    wait(ref_e);
    unknownVar1(var_0);
    bne(var_0, 1793, label_16);
    cameraSet(northeast, 980, 0, -330);
    playerInit(east);
    controlDisable();
    b(label_1f);
  label_16:
    bne(var_0, 6915, label_1b);
    cameraSet(northeast, 930, 0, -80);
    playerInit(north);
    controlDisable();
    b(label_1f);
  label_1b:
    cameraSet(northeast, 980, 0, -330);
    playerInit(east);
    controlDisable();
    b(label_1f);
  label_1f:
    unitSpawn(ulala, sprite_6, 280, -300, -700, east, none);
    unitAnimationPlay(ulala, animation_a, 1);
    unitSpawn(katsuya, sprite_d, 800, 0, -950, south, none);
    unitAnimationPlay(katsuya, animation_a, 1);
    unitSpawn(baofu, sprite_13, 80, -300, -500, north, none);
    unitAnimationPlay(baofu, animation_a, 1);
    unitSpawn(nanjo, sprite_1f, 980, 0, -700, east, none);
    unitAnimationPlay(nanjo, animation_a, 1);
    unitIdleOnAll();
    unitTriggerSet(ulala, URARA, 255, 1);
    unitTriggerSet(katsuya, KATUYA, 255, 1);
    unitTriggerSet(baofu, PAOFU, 255, 1);
    unitTriggerSet(nanjo, NANJO, 255, 1);
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

function NANJO()
{
    controlDisable();
    unitFacePlayer(nanjo);
    ref_35 = bustupLoad(bustup_36);
    bustupWait(ref_35);
    ref_37 = bustupAlloc(ref_35, left, rgb(0,0,0));
    bustupFade(ref_37, rgb(128,0,0), 30);
    ref_39 = dialogAlloc();
    ref_3a = msgShow(msg_0);
/***************************************
[color(yellow)]南条[color(white)]
[tab]赤い扉は第一制御室の園村、
[tab]青い扉は第二制御室の城戸が開けられるはずだ。
[tab]渡した最新トランシーバーで連絡してください。
[sync][wait][clear]
***************************************/
    unitAnimationPlay(nanjo, animation_2d, 1);
    delayClear();
    delayWait(60);
    sync();
    wait(ref_3a);
    dialogFree(ref_39);
    ref_41 = bustupFade(ref_37, rgb(0,0,0), 10);
    bustupWait(ref_41);
    bustupFree(ref_37);
    unitAnimationPlay(nanjo, animation_a, 1);
    unitRestoreFacing(nanjo);
    controlEnable();
}

