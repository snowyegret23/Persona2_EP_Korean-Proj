function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), add);
    levelFootstepSet(sfx_f);
    sndMusicPlay(sound_3010, 127);
    cameraSet(southwest, 390, 0, -615);
    ref_5 = spriteLoad(sprite_58);
    wait(ref_5);
    ref_7 = spriteLoad(sprite_12);
    wait(ref_7);
    ref_9 = spriteLoad(sprite_0);
    wait(ref_9);
    ref_b = spriteLoad(sprite_6);
    wait(ref_b);
    ref_d = spriteLoad(sprite_d);
    wait(ref_d);
    ref_f = spriteLoad(sprite_13);
    wait(ref_f);
    ref_11 = spriteLoad(sprite_18);
    wait(ref_11);
    unitSpawn(enemy1, sprite_12, 390, 0, -615, west, none);
    unitSpawn(enemy2, sprite_58, 500, 0, -615, east, none);
    unitAnimationPlay(enemy2, animation_24, 1);
    unitSpawn(katsuya, sprite_d, 150, 0, -615, west, none);
    unitSpawn(maya, sprite_0, 80, 0, -730, west, none);
    unitSpawn(ulala, sprite_6, 170, 0, -845, south, none);
    unitSpawn(tatsuya, sprite_18, 120, 0, -450, west, none);
    unitSpawn(baofu, sprite_13, 190, 0, -330, west, none);
    unitSpriteEffect(katsuya, 2);
    unitSpriteEffect(maya, 2);
    unitSpriteEffect(ulala, 2);
    unitSpriteEffect(tatsuya, 2);
    unitSpriteEffect(baofu, 2);
    unitShadowRadius(katsuya, 0);
    unitShadowRadius(maya, 0);
    unitShadowRadius(ulala, 0);
    unitShadowRadius(tatsuya, 0);
    unitShadowRadius(baofu, 0);
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), add);
    screenFadeInner(rgb(0,0,0), 4, true);
    screenFadeOuter(rgb(0,0,0), 4, true);
    screenEffectUnknown();
    screenFadeWait(inner);
    screenFadeWait(outer);
    delayClear();
    delayWait(60);
    unitAnimationPlay(ulala, animation_28, 1);
    unitAnimationPlay(tatsuya, animation_28, 1);
    unitAnimationPlay(maya, animation_28, 1);
    unitAnimationPlay(baofu, animation_28, 1);
    unitAnimationHold(katsuya, animation_21, 90);
    unitWait(katsuya);
    unitAnimationPlay(katsuya, animation_0, 1);
    unitAnimationPlay(ulala, animation_3, 1);
    unitAnimationPlay(baofu, animation_1, 1);
    unitAnimationPlay(maya, animation_3, 1);
    unitAnimationPlay(tatsuya, animation_1, 1);
    delayClear();
    delayWait(30);
    ref_3a = bustupLoad(bustup_c9);
    bustupWait(ref_3a);
    ref_3c = bustupAlloc(ref_3a, right, rgb(0,0,0));
    bustupFade(ref_3c, rgb(128,0,0), 30);
    ref_3e = dialogAlloc();
    ref_3f = msgShow(msg_0);
/***************************************
[color(yellow)]橿原先生[color(white)]
[tab][suou]君、本当にいいんだね…？
[tab]その…ケーキ職人さんになるという
[tab]夢を諦めてしまっても。
[sync][wait][clear]
***************************************/
    delayClear();
    delayWait(10);
    unitAnimationPlay(ulala, animation_3, 1);
    unitAnimationPlay(baofu, animation_1, 1);
    delayClear();
    delayWait(50);
    sync();
    wait(ref_3f);
    dialogFree(ref_3e);
    ref_49 = bustupFade(ref_3c, rgb(0,0,0), 10);
    bustupWait(ref_49);
    bustupFree(ref_3c);
    unitAnimationPlay(enemy2, animation_0, 1);
    delayClear();
    delayWait(30);
    unitAnimationHold(ulala, animation_22, 60);
    unitAnimationHold(maya, animation_22, 60);
    unitWait(maya);
    unitAnimationPlay(maya, animation_3, 1);
    unitAnimationPlay(ulala, animation_0, 1);
    unitAnimationPlay(tatsuya, animation_1, 1);
    unitAnimationPlay(baofu, animation_2, 1);
    delayClear();
    delayWait(90);
    ref_58 = bustupLoad(bustup_6d);
    bustupWait(ref_58);
    ref_5a = bustupAlloc(ref_58, left, rgb(0,0,0));
    bustupFade(ref_5a, rgb(128,0,0), 30);
    ref_5c = dialogAlloc();
    ref_5d = msgShow(msg_1);
/***************************************
[color(yellow)]高校時代の克哉[color(white)]
[tab]「パティシエ」です。
[sync][wait][clear]
***************************************/
    unitAnimationPlay(enemy1, animation_c, 1);
    delayClear();
    delayWait(10);
    unitAnimationPlay(baofu, animation_1, 1);
    unitAnimationPlay(tatsuya, animation_1, 1);
    unitAnimationPlay(maya, animation_3, 1);
    unitAnimationPlay(ulala, animation_3, 1);
    delayClear();
    delayWait(50);
    sync();
    wait(ref_5d);
    dialogFree(ref_5c);
    ref_6a = bustupFade(ref_5a, rgb(0,0,0), 10);
    bustupWait(ref_6a);
    bustupFree(ref_5a);
    unitAnimationPlay(enemy1, animation_0, 1);
    delayClear();
    delayWait(30);
    ref_70 = bustupLoad(bustup_c9);
    bustupWait(ref_70);
    ref_72 = bustupAlloc(ref_70, right, rgb(0,0,0));
    bustupFade(ref_72, rgb(128,0,0), 30);
    ref_74 = dialogAlloc();
    ref_75 = msgShow(msg_2);
/***************************************
[color(yellow)]橿原先生[color(white)]
[tab]ああ、そうだったね。
[tab]で…本当にいいのかい？
[sync][wait][clear]
***************************************/
    unitAnimationPlay(enemy2, animation_24, 1);
    delayClear();
    delayWait(60);
    sync();
    wait(ref_75);
    dialogFree(ref_74);
    ref_7c = bustupFade(ref_72, rgb(0,0,0), 10);
    bustupWait(ref_7c);
    bustupFree(ref_72);
    unitAnimationPlay(enemy2, animation_0, 1);
    delayClear();
    delayWait(30);
    unitAnimationPlay(enemy1, animation_6, 1);
    delayClear();
    delayWait(10);
    unitAnimationPlay(enemy1, animation_0, 1);
    delayClear();
    delayWait(30);
    ref_88 = bustupLoad(bustup_6d);
    bustupWait(ref_88);
    ref_8a = bustupAlloc(ref_88, left, rgb(0,0,0));
    bustupFade(ref_8a, rgb(128,0,0), 30);
    ref_8c = dialogAlloc();
    ref_8d = msgShow(msg_3);
/***************************************
[color(yellow)]高校時代の克哉[color(white)]
[tab]自分で決めたことです…
[tab]国立大学の法学部から、刑事を目指します。
[sync][wait][clear]
***************************************/
    unitAnimationPlay(enemy1, animation_24, 1);
    delayClear();
    delayWait(60);
    sync();
    wait(ref_8d);
    dialogFree(ref_8c);
    ref_94 = bustupFade(ref_8a, rgb(0,0,0), 10);
    bustupWait(ref_94);
    bustupFree(ref_8a);
    unitAnimationPlay(enemy1, animation_0, 1);
    delayClear();
    delayWait(30);
    ref_9a = bustupLoad(bustup_c9);
    bustupWait(ref_9a);
    ref_9c = bustupAlloc(ref_9a, right, rgb(0,0,0));
    bustupFade(ref_9c, rgb(128,0,0), 30);
    ref_9e = dialogAlloc();
    ref_9f = msgShow(msg_4);
/***************************************
[color(yellow)]橿原先生[color(white)]
[tab]君の成績なら、どこだって大丈夫なんだが…
[sync][wait][clear]
***************************************/
    unitAnimationPlay(enemy2, animation_24, 1);
    delayClear();
    delayWait(30);
    sync();
    wait(ref_9f);
    ref_a5 = msgShow(msg_5);
/***************************************
[color(yellow)]橿原先生[color(white)]
[tab]お父さんの事が…原因なんだね？
[sync][wait][clear]
***************************************/
    unitAnimationPlay(enemy2, animation_c, 1);
    delayClear();
    delayWait(45);
    sync();
    wait(ref_a5);
    dialogFree(ref_9e);
    ref_ac = bustupFade(ref_9c, rgb(0,0,0), 10);
    bustupWait(ref_ac);
    bustupFree(ref_9c);
    unitAnimationPlay(enemy2, animation_0, 1);
    delayClear();
    delayWait(30);
    unitFace(enemy1, south);
    delayClear();
    delayWait(30);
    unitAnimationPlay(enemy1, animation_1, 1);
    delayClear();
    delayWait(60);
    ref_b8 = bustupLoad(bustup_6d);
    bustupWait(ref_b8);
    ref_ba = bustupAlloc(ref_b8, left, rgb(0,0,0));
    bustupFade(ref_ba, rgb(128,0,0), 30);
    ref_bc = dialogAlloc();
    ref_bd = msgShow(msg_6);
/***************************************
[color(yellow)]高校時代の克哉[color(white)]
[tab]…先生には、関係ないことです。
[tab]失礼します。
[sync][wait][clear]
***************************************/
    delayClear();
    delayWait(90);
    unitAnimationPlay(enemy1, animation_0, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(enemy1, animation_3, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(enemy1, animation_4, 1);
    sync();
    wait(ref_bd);
    dialogFree(ref_bc);
    ref_ca = bustupFade(ref_ba, rgb(0,0,0), 10);
    bustupWait(ref_ca);
    bustupFree(ref_ba);
    delayClear();
    delayWait(30);
    unitAnimationPlay(enemy1, animation_3, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(enemy1, animation_0, 1);
    delayClear();
    delayWait(7);
    unitFace(enemy1, east);
    delayClear();
    delayWait(30);
    ref_d8 = call(KATUYAMOVE1);
    wait(ref_d8);
    ref_da = call(KATUYAMOVE2);
    delayClear();
    delayWait(10);
    unitAnimationPlay(baofu, animation_2, 1);
    unitAnimationPlay(ulala, animation_4, 1);
    unitAnimationPlay(maya, animation_1, 1);
    unitAnimationPlay(tatsuya, animation_1, 1);
    delayClear();
    delayWait(30);
    unitFace(ulala, west);
    unitAnimationPlay(ulala, animation_2, 1);
    unitAnimationPlay(maya, animation_2, 1);
    unitAnimationPlay(tatsuya, animation_2, 1);
    wait(ref_da);
    delayClear();
    delayWait(30);
    unitAnimationPlay(ulala, animation_1, 1);
    unitAnimationPlay(maya, animation_1, 1);
    unitAnimationPlay(tatsuya, animation_1, 1);
    unitAnimationPlay(baofu, animation_1, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(ulala, animation_0, 1);
    unitAnimationPlay(maya, animation_0, 1);
    unitAnimationPlay(tatsuya, animation_0, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(ulala, animation_3, 1);
    delayClear();
    delayWait(30);
    unitAnimationPlay(enemy2, animation_1, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(enemy2, animation_2, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(enemy2, animation_1, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(enemy2, animation_0, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(enemy2, animation_3, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(enemy2, animation_4, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(enemy2, animation_3, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(enemy2, animation_0, 1);
    delayClear();
    delayWait(30);
    unitAnimationPlay(enemy2, animation_6, 1);
    delayClear();
    delayWait(60);
    delayClear();
    delayWait(30);
    sndVolumeFadeOff(sound_3010, 120);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), add);
    screenFadeInner(rgb(255,255,255), 4, false);
    screenFadeOuter(rgb(255,255,255), 4, false);
    op_bd();
    eventLoad(event_d6);
}

function KATUYAMOVE1()
{
    unitMove(enemy1, 250, -615, face_east, medium);
    unitWait(enemy1);
}

function KATUYAMOVE2()
{
    unitMove(enemy1, 230, -1060, face_north, medium);
    unitWait(enemy1);
    unitFace(enemy1, north);
    unitAnimationPlay(enemy1, animation_c, 1);
    objAnimTranslate(obj_2a, 100, 0, 0, 60);
    delayClear();
    delayWait(20);
    sndMusicPlay(sound_32bf, 127);
    objAnimWait(obj_2a);
    unitMove(enemy1, 230, -1150, fade, medium);
    unitWait(enemy1);
    objAnimTranslate(obj_2a, -100, 0, 0, 60);
    delayClear();
    delayWait(20);
    sndMusicPlay(sound_32bf, 127);
    objAnimWait(obj_2a);
}
