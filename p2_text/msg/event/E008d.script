    ref_e8 = dialogAlloc();
    ref_e9 = msgShow(msg_3);
/***************************************
[color(yellow)]パオフゥ[color(white)]
[tab]人の過去を映すだと…
[tab]冗談じゃねぇぞ…
[sync][wait][clear]
***************************************/
    unitAnimationPlay(baofu, animation_1f, 1);
    delayClear();
    delayWait(45);
    unitAnimationPlay(baofu, animation_2b, 1);
    unitWait(baofu);
    delayClear();
    delayWait(5);
    sync();
    wait(ref_e9);
