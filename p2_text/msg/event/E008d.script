function TATUYAMOVE()
{
    unitMove(tatsuya, 495, -440, face_south, medium);
    unitWait(tatsuya);
}

function MAYAMOVE()
{
    unitMove(maya, 385, -675, face_south, medium);
    unitWait(maya);
    unitAnimationPlay(maya, animation_3, 1);
}

function KATUYAMOVE()
{
    unitMove(katsuya, 600, -725, face_south, medium);
    unitWait(katsuya);
    unitAnimationPlay(katsuya, animation_1, 1);
}

function PAOFUMOVE()
{
    unitMove(baofu, 430, -830, face_south, medium);
    unitWait(baofu);
    unitAnimationPlay(baofu, animation_a, 1);
}

function URARAMOVE()
{
    unitMove(ulala, 580, -915, face_south, medium);
    unitWait(ulala);
    unitAnimationPlay(ulala, animation_0, 1);
}

function ERIMOVE()
{
    unitMove(elly, 430, -990, face_south, medium);
    unitWait(elly);
    unitAnimationPlay(elly, animation_a, 1);
}

function NANJOMOVE()
{
    unitMove(nanjo, 430, -990, face_south, medium);
    unitWait(nanjo);
    unitAnimationPlay(nanjo, animation_a, 1);
}

function EXIT()
{
    controlDisable();
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    dngLoad2(mt_iwato-1);
}

function DUNGEON()
{
    controlDisable();
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    bitSet(TBIT_008d);
    dngLoad2(mt_iwato-2);
}
