function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    disableMap();
    levelFootstepSet(sfx_15);
    sndIdGet(var_0);
    bne(var_0, -1, label_a);
    ref_6 = sndLoad(sound_3035);
    wait(ref_6);
    sndMusicPlay(sound_3035, 127);
    b(label_b);
  label_a:
    b(label_b);
  label_b:
    ref_b = spriteLoad(sprite_0);
    wait(ref_b);
    ref_d = spriteLoad(sprite_2);
    wait(ref_d);
    ref_f = spriteLoad(sprite_13);
    wait(ref_f);
    ref_11 = spriteLoad(sprite_d4);
    wait(ref_11);
    bitGet(var_1, EBIT_E0033);
    bne(var_1, 0, label_18);
    ref_15 = call(KYOUSEI);
    wait(ref_15);
    b(label_1c);
  label_18:
    bne(var_1, 1, label_1c);
    ref_19 = call(FREE);
    wait(ref_19);
    b(label_1c);
  label_1c:
}

function KYOUSEI()
{
    cameraSet(northwest, 368, 0, -598);
    unitIdleOffAll();
