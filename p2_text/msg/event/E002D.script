    ref_6a = msgShow(msg_1);
/***************************************
[color(yellow)]パオフゥ[color(white)]
[tab]チッ…流石に手が早ぇ…
[tab]そんなニュースはデタラメだ。
[sync][wait][clear]
***************************************/
    unitAnimationPlay(baofu, animation_1e, 1);
    unitWait(baofu);
    delayClear();
    delayWait(30);
    unitAnimationPlay(baofu, animation_28, 1);
    unitWait(baofu);
    delayClear();
    delayWait(15);
