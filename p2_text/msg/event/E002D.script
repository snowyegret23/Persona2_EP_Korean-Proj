    ref_80 = bustupAlloc(ref_7e, left, rgb(0,0,0));
    bustupFade(ref_80, rgb(128,0,0), 30);
    ref_82 = msgShow(msg_3);
/***************************************
[color(yellow)]パオフゥ[color(white)]
[tab]飛行船の事も、どこかで息子を監視してるヤツが
[tab]いたに違いねぇ…
[tab]野郎、相当広く手を回してやがる。
[sync][wait][clear]
***************************************/
