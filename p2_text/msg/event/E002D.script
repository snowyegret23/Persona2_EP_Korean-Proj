function FREE()
{
    bitGet(var_3, EBIT_E1100);
    bne(var_3, 0, label_107);
    cameraSet(southwest, 600, 0, -1400);
    playerInit(south);
    controlDisable();
    b(label_10c);
  label_107:
    bne(var_3, 1, label_10c);
    cameraSet(northwest, 80, 0, -500);
    playerInit(west);
    controlDisable();
    b(label_10c);
  label_10c:
    unitSpawn(baofu, sprite_13, 472, 0, -598, north, none);
    unitFace(baofu, east);
    unitSpawn(enemy1, sprite_d4, 600, 0, -152, north, none);
    unitFace(enemy1, north);
    unitTriggerSet(baofu, PAOFU, 255, 1);
    envTriggerSet(BLOCK_UKETUKE, 14, 1, line, coll_1c);
    envTriggerSet(BLOCK_UKETUKE, 14, 1, line, coll_1d);
    envTriggerSet(BLOCK_UKETUKE, 28, 1, line, coll_1e);
    envTriggerSet(BLOCK_UKETUKE, 28, 1, line, coll_1f);
    envTriggerSet(BLOCK_UKETUKE, 56, 1, line, coll_20);
    envTriggerSet(BLOCK_UKETUKE, 56, 1, line, coll_21);
    envTriggerSet(BLOCK_UKETUKE, 112, 1, line, coll_22);
    envTriggerSet(BLOCK_UKETUKE, 112, 1, line, coll_23);
    envTriggerSet(BLOCK_UKETUKE, 224, 1, line, coll_24);
    envTriggerSet(BLOCK_UKETUKE, 224, 1, line, coll_25);
    envTriggerSet(ELE, 14, 1, line, coll_0);
    envTriggerSet(EXIT, 131, 2, line, coll_1);
    envTriggerSet(EXIT, 7, 2, line, coll_1);
    envTriggerSet(EXIT, 131, 2, line, coll_2);
    envTriggerSet(EXIT, 193, 2, line, coll_2);
    envTriggerSet(HIJOU, 14, 1, line, coll_38);
    unitIdleOnAll();
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

function PAOFU()
{
    controlDisable();
    unitFacePlayer(baofu);
    ref_12b = bustupLoad(bustup_31);
    bustupWait(ref_12b);
    ref_12d = bustupAlloc(ref_12b, left, rgb(0,0,0));
    bustupFade(ref_12d, rgb(128,0,0), 30);
    ref_12f = dialogAlloc();
    ref_130 = msgShow(msg_11);
/***************************************
[color(yellow)]パオフゥ[color(white)]
[tab]なぜ、[suou]の奴に突っかかるのか…だと？
[tab]別に突っかかっちゃいねぇよ。
[sync][wait][clear]
***************************************/
    delayClear();
    delayWait(120);
    unitAnimationPlay(baofu, animation_1d, 1);
    unitWait(baofu);
    sync();
    wait(ref_130);
    unitAnimationPlay(baofu, animation_10, 1);
    ref_138 = msgShow(msg_12);
/***************************************
[color(yellow)]パオフゥ[color(white)]
[tab]ただ…あの甘ちゃん見てると、
[tab]どうにもイライラするだけだ…
[tab]そんだけだよ…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_138);
    dialogFree(ref_12f);
    ref_13c = bustupFade(ref_12d, rgb(0,0,0), 10);
    bustupWait(ref_13c);
    bustupFree(ref_12d);
    unitAnimationPlay(baofu, animation_a, 1);
    unitRestoreFacing(baofu);
    controlEnable();
}

function BLOCK_UKETUKE()
{
    controlDisable();
    unitFacePlayer(enemy1);
    unitAnimationPlay(enemy1, animation_19, 1);
    ref_146 = dialogAlloc();
    ref_147 = msgShow(msg_13);
/***************************************
[color(yellow)]受付嬢[color(white)]
[tab]聞いた、舞耶？
[tab]お呪いした人もＪＯＫＥＲになっちゃうって、噂！
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_147);
    unitAnimationPlay(enemy1, animation_c, 1);
    ref_14b = msgShow(msg_14);
/***************************************
[color(yellow)]受付嬢[color(white)]
[tab]私、やめといてよかったわぁ～
[tab]そういうのって、ちょっと興味あるじゃない？
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_14b);
    dialogFree(ref_146);
    unitAnimationPlay(enemy1, animation_0, 1);
    unitRestoreFacing(enemy1);
    controlEnable();
}

function EXIT()
{
    controlDisable();
    bitClear(EBIT_E1100);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    mapLoad(aoba, 22, 3);
}

function ELE()
{
    controlDisable();
    sndMusicPlay(sound_311b, 127);
    objAnimTranslate(obj_1, 0, 0, 100, 60);
    objAnimTranslate(obj_2, 0, 0, -100, 60);
    objAnimWait(obj_1);
    objAnimWait(obj_2);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    bitSet(EBIT_E1000);
    bitClear(EBIT_E1100);
    eventLoad(event_a6);
}

function HIJOU()
{
    controlDisable();
    ref_16e = dialogAlloc();
    ref_16f = msgShow(msg_15);
/***************************************
[color(yellow)]非常口[color(green)]
[tab]ここには入れない。[color(white)]
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_16f);
    dialogFree(ref_16e);
    controlEnable();
}
