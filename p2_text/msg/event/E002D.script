    delayWait(30);
    unitAnimationPlay(baofu, animation_1f, 1);
    unitWait(baofu);
    delayClear();
    delayWait(10);
    sync();
    wait(ref_82);
    ref_91 = msgShow(msg_4);
/***************************************
[color(yellow)]パオフゥ[color(white)]
[tab]自宅の電話を盗聴したんだが、
[tab]後始末だの計画がどうしたのと言ってたからな。
[tab]相手が誰かまではわからねぇ。
[sync][wait][clear]
***************************************/
    unitAnimationPlay(baofu, animation_2d, 1);
    delayClear();
    delayWait(60);
    sync();
    wait(ref_91);
    dialogFree(ref_69);
    ref_98 = bustupFade(ref_80, rgb(0,0,0), 10);
    bustupWait(ref_98);
    bustupFree(ref_80);
    unitAnimationPlay(baofu, animation_0, 1);
