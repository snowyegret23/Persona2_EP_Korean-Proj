    wait(ref_6a);
    ref_75 = msgShow(msg_2);
/***************************************
[color(yellow)]パオフゥ[color(white)]
[tab]竜蔵だよ…
[tab]野郎、病院に火付けて証拠を消しやがったんだ。
[sync][wait][clear]
***************************************/
