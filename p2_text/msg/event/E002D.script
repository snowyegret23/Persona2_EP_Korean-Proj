    ref_dd = dialogAlloc();
    ref_de = msgShow(msg_9);
/***************************************
[color(yellow)]パオフゥ[color(white)]
[tab]気はすすまねぇが、
[tab][suou]から情報引き出すしかねぇな…
[sync][wait][clear]
***************************************/
