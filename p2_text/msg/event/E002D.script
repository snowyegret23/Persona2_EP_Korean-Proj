/***************************************
[color(yellow)]パオフゥ[color(white)]
[tab]どうした、青い顔してよ？
[sync][wait][clear]
***************************************/
    unitAnimationPlay(baofu, animation_14, 1);
    unitWait(baofu);
    delayClear();
    delayWait(30);
    sync();
    wait(ref_4f);
    dialogFree(ref_4e);
    ref_57 = bustupFade(ref_4c, rgb(0,0,0), 10);
    bustupWait(ref_57);
    bustupFree(ref_4c);
    unitAnimationPlay(baofu, animation_0, 1);
    unitWait(baofu);
    delayClear();
    delayWait(30);
    unitAnimationPlay(maya, animation_2d, 1);
    delayClear();
    delayWait(180);
    unitAnimationPlay(maya, animation_0, 1);
    unitWait(maya);
    delayClear();
    delayWait(30);
    ref_65 = bustupLoad(bustup_2e);
