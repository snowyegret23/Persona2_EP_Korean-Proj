    bustupFade(ref_bf, rgb(128,0,0), 30);
    ref_c1 = dialogAlloc();
    ref_c2 = msgShow(msg_7);
/***************************************
[color(yellow)]パオフゥ[color(white)]
[tab]気はすすまねぇが、それしかねぇか…
[tab]警察の情報を聞き出すにゃ、
[tab]奴さんしかいねぇしな。
[sync][wait][clear]
***************************************/
    unitAnimationPlay(baofu, animation_1d, 1);
    unitWait(baofu);
    delayClear();
    delayWait(15);
    unitAnimationPlay(baofu, animation_14, 1);
    unitWait(baofu);
    delayClear();
    delayWait(20);
    sync();
    wait(ref_c2);
