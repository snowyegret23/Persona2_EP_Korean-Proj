    ref_ac = bustupFade(ref_a1, rgb(0,0,0), 10);
    bustupWait(ref_ac);
    bustupFree(ref_a1);
    ref_af = bustupLoad(bustup_3);
    bustupWait(ref_af);
    ref_b1 = bustupAlloc(ref_af, center, rgb(0,0,0));
    bustupFade(ref_b1, rgb(128,0,0), 30);
    ref_b3 = dialogChoiceAlloc();
    ref_b4 = msgShow(msg_6);
/***************************************
[tab]で、これからどうするよ？
[choice(2)]克哉さんと合流しましょ。
ど、どうしよう…
[end_choice][clear]
***************************************/
    sync();
    wait(ref_b4);
    dialogFree(ref_b3);
    ref_b8 = bustupFade(ref_b1, rgb(0,0,0), 10);
    bustupWait(ref_b8);
    bustupFree(ref_b1);
    choiceGetResult(var_2);
    bne(var_2, 0, label_d8);
    ref_bd = bustupLoad(bustup_2c);
