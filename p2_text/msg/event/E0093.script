    screenFadeOuter(rgb(0,0,0), 4, true);
    screenEffectUnknown();
    screenFadeWait(inner);
    screenFadeWait(outer);
    unitAnimationPlay(katsuya, animation_1f, 1);
    ref_40 = bustupLoad(bustup_25);
