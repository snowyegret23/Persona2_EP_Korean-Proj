    ref_eb = bustupAlloc(ref_e9, left, rgb(0,0,0));
    bustupFade(ref_eb, rgb(128,0,0), 30);
    ref_ed = dialogAlloc();
    ref_ee = msgShow(msg_6);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]バカな…ナンセンスだ…！
[tab]ＳＦじゃあないんだぞ！？
