    sync();
    wait(ref_48);
    dialogFree(ref_44);
    ref_4d = bustupFade(ref_42, rgb(0,0,0), 10);
    bustupWait(ref_4d);
    bustupFree(ref_42);
    unitAnimationPlay(katsuya, animation_a, 1);
    unitAnimationPlay(ulala, animation_27, 1);
    ref_52 = bustupLoad(bustup_b);
    bustupWait(ref_52);
    ref_54 = bustupAlloc(ref_52, right, rgb(0,0,0));
    bustupFade(ref_54, rgb(128,0,0), 30);
    bustupFlip(ref_54, true);
    ref_57 = dialogAlloc();
    ref_58 = msgShow(msg_2);
/***************************************
[color(yellow)][tatsuya][color(white)]
[tab]まだ分からないのか…？
[tab]今見ていたのは「向こう側」…
[tab]この世界とは違う世界の記憶なんだ…！
[sync][wait][clear]
***************************************/
    unitAnimationPlay(tatsuya, animation_13, 1);
    unitWait(tatsuya);
    unitAnimationPlay(tatsuya, animation_1e, 1);
    unitWait(tatsuya);
    unitAnimationPlay(tatsuya, animation_1f, 1);
    sync();
    wait(ref_58);
    dialogFree(ref_57);
    ref_61 = bustupFade(ref_54, rgb(0,0,0), 10);
    bustupWait(ref_61);
    bustupFree(ref_54);
    delayClear();
    delayWait(30);
    unitAnimationPlay(tatsuya, animation_0, 1);
    unitAnimationHold(ulala, animation_21, 60);
    unitAnimationHold(maya, animation_21, 60);
    unitAnimationHold(baofu, animation_21, 60);
    unitAnimationHold(katsuya, animation_21, 60);
    bitGet(var_1, MBIT_HI_NANJOTOUJO);
    bez(var_1, label_6f);
    unitAnimationHold(nanjo, animation_21, 60);
    b(label_70);
  label_6f:
