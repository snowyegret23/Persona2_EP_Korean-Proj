function FREE()
{
    unitSpawn(ulala, sprite_6, 550, 0, -600, west, none);
    unitTriggerSet(ulala, URARA, 255, 1);
    unitSpawn(katsuya, sprite_d, 1000, 0, -900, east, none);
    unitTriggerSet(katsuya, KATUYA, 255, 1);
    unitSpawn(baofu, sprite_13, 1150, 0, -450, north, none);
    unitTriggerSet(baofu, PAOFU, 255, 1);
    bitGet(var_0, MBIT_HI_NANJOTOUJO);
    bez(var_0, label_c5);
    unitSpawn(nanjo, sprite_1f, 600, 0, -850, west, none);
    unitTriggerSet(nanjo, NANJO, 255, 1);
    b(label_c7);
  label_c5:
    unitSpawn(elly, sprite_23, 600, 0, -850, west, none);
    unitTriggerSet(elly, ERI, 255, 1);
  label_c7:
    sndIdGet(var_0);
    bne(var_0, -1, label_cd);
    ref_c9 = sndLoad(sound_11e0);
    wait(ref_c9);
    sndMusicPlay(sound_11e0, 90);
    b(label_cf);
  label_cd:
    sndVolumeFadeTo(var_0, 90, 60);
    b(label_cf);
  label_cf:
    bitGet(var_0, TBIT_0093);
    bne(var_0, 0, label_d6);
    cameraSetNorth(east);
    cameraSet(north, 600, 0, -1350);
    playerInit(south);
    controlDisable();
    b(label_dd);
  label_d6:
    bne(var_0, 1, label_dd);
    cameraSetNorth(east);
    bitClear(TBIT_0093);
    cameraSet(east, 1350, 0, -600);
    playerInit(east);
    controlDisable();
    b(label_dd);
  label_dd:
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    envTriggerSet(DUNGEON, 131, 2, line, coll_2b);
    envTriggerSet(DUNGEON2, 224, 2, line, coll_2d);
    unitIdleOnAll();
    controlEnable();
}

function KATUYA()
{
