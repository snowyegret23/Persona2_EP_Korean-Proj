function EIKITI()
{
    controlDisable();
    unitFacePlayer(eikichi);
    playerConvertToUnit(maya, sprite_0, east);
    playerHide();
    unitFaceUnit(maya, eikichi);
    bitGet(var_4, MBIT_MEETAKITI);
    bne(var_4, 0, label_222);
    ref_1bf = bustupLoad(bustup_116);
    bustupWait(ref_1bf);
    ref_1c1 = bustupAlloc(ref_1bf, right, rgb(0,0,0));
    bustupFade(ref_1c1, rgb(128,0,0), 30);
    ref_1c3 = dialogAlloc();
    ref_1c4 = msgShow(msg_16);
/***************************************
[color(yellow)]栄吉[color(white)]
[tab]姐さん…前にどっかで会ったことねぇすか？
[tab]なーんか知ってる気がするんだよなぁ。
[sync][wait][clear]
***************************************/
    unitAnimationPlay(eikichi, animation_1f, 1);
    delayClear();
    delayWait(60);
    sync();
    wait(ref_1c4);
    dialogFree(ref_1c3);
    ref_1cb = bustupFade(ref_1c1, rgb(0,0,0), 10);
