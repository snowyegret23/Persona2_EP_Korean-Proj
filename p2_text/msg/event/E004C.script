    delayClear();
    delayWait(60);
    ref_1e1 = bustupLoad(bustup_116);
    bustupWait(ref_1e1);
    ref_1e3 = bustupAlloc(ref_1e1, right, rgb(0,0,0));
    bustupFade(ref_1e3, rgb(128,0,0), 30);
    ref_1e5 = dialogAlloc();
    ref_1e6 = msgShow(msg_18);
/***************************************
[color(yellow)]栄吉[color(white)]
[tab]姐さんも…？
[tab]どこだっけかなぁ…
[tab]ひょっとして、カニ缶好き？
[sync][wait][clear]
***************************************/
    unitAnimationPlay(eikichi, animation_2d, 1);
    delayClear();
