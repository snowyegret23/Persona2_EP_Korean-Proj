function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    dngRoomSet(44);
    dngRoomDraw();
    sndMusicPlay(sound_3009, 127);
    levelFootstepSet(sfx_19);
    disableMap();
    ref_7 = spriteLoad(sprite_0);
    wait(ref_7);
    ref_9 = spriteLoad(sprite_2);
    wait(ref_9);
    ref_b = spriteLoad(sprite_1f);
    wait(ref_b);
    ref_d = spriteLoad(sprite_6);
    wait(ref_d);
    ref_f = spriteLoad(sprite_13);
    wait(ref_f);
    ref_11 = spriteLoad(sprite_d);
    wait(ref_11);
    ref_13 = spriteLoad(sprite_27);
    wait(ref_13);
    envTriggerSet(INDOOR0, 255, 1, line, coll_24);
    envTriggerSet(INDOOR0, 255, 1, line, coll_17);
    envTriggerSet(INDOOR1, 255, 1, line, coll_26);
    envTriggerSet(INDOOR1, 255, 1, line, coll_1a);
    envTriggerSet(EXIT1, 14, 1, line, coll_5);
    envTriggerSet(EXIT2, 131, 1, line, coll_2);
    bitGet(var_1, EBIT_E0050);
    bne(var_1, 0, label_20);
    ref_1d = call(KYOUSEI);
    wait(ref_1d);
    b(label_24);
  label_20:
    bne(var_1, 1, label_24);
    ref_21 = call(FREE);
    wait(ref_21);
    b(label_24);
  label_24:
}

function KYOUSEI()
{
    cameraSet(northeast, 1060, 0, -150);
    unitSpawn(nanjo, sprite_1f, 1160, 0, -250, west, none);
    li(var_2, 0);
    call(NANJOSOUSA);
    unitSpawn(eikichi, sprite_27, 980, 0, -360, north, none);
    unitAnimationPlay(eikichi, animation_2d, 1);
    delayClear();
    delayWait(37);
    unitSpawn(ulala, sprite_6, 980, 0, -500, south, none);
    unitAnimationPlay(ulala, animation_2d, 1);
    unitSpawn(katsuya, sprite_d, 890, 0, -200, north, none);
    unitAnimationPlay(katsuya, animation_b, 1);
    unitSpawn(baofu, sprite_13, 820, 0, -350, west, none);
    unitAnimationPlay(baofu, animation_a, 1);
    unitSpawn(maya, sprite_0, 1000, 0, -150, north, none);
    unitAnimationPlay(maya, animation_a, 1);
    unitTriggerSet(nanjo, NANJO, 255, 1);
    unitTriggerSet(eikichi, EIKITI, 255, 1);
    unitTriggerSet(ulala, URARA, 255, 1);
    unitTriggerSet(katsuya, KATUYA, 255, 1);
    unitTriggerSet(baofu, PAOFU, 255, 1);
    delayClear();
    delayWait(15);
    unitIdleOffAll();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    screenEffectUnknown();
    screenFadeWait(inner);
    screenFadeWait(outer);
    delayClear();
    delayWait(120);
    li(var_2, 1);
    unitMove(nanjo, 1160, -330, face_west, fast);
    unitWait(nanjo);
    unitFace(nanjo, west);
    li(var_2, 0);
    call(NANJOSOUSA);
    unitAnimationPlay(eikichi, animation_0, 1);
    delayClear();
    delayWait(30);
    ref_4e = bustupLoad(bustup_17);
    bustupWait(ref_4e);
    ref_50 = bustupAlloc(ref_4e, left, rgb(0,0,0));
    bustupFade(ref_50, rgb(128,0,0), 30);
    ref_52 = dialogAlloc();
    ref_53 = msgShow(msg_0);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]…それで塀乗り越えて、ＪＯＫＥＲ使いになって
[tab]さらわれた友達を追っかけてきたってわけ？
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_53);
    ref_56 = msgShow(msg_1);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]しっかしアンタ、無茶するわ…
[tab]大体、そいつがＪＯＫＥＲ呪いした相手って、
[tab]アンタなんでしょ？
[sync][wait][clear]
***************************************/
    delayClear();
    delayWait(60);
    sync();
    wait(ref_56);
    dialogFree(ref_52);
    ref_5c = bustupFade(ref_50, rgb(0,0,0), 10);
    bustupWait(ref_5c);
    bustupFree(ref_50);
    unitAnimationPlay(ulala, animation_0, 1);
    delayClear();
    delayWait(30);
    li(var_2, 1);
    unitMove(nanjo, 1160, -170, face_west, fast);
    ref_64 = bustupLoad(bustup_116);
    bustupWait(ref_64);
    ref_66 = bustupAlloc(ref_64, right, rgb(0,0,0));
    bustupFade(ref_66, rgb(128,0,0), 30);
    ref_68 = dialogAlloc();
    ref_69 = msgShow(msg_2);
/***************************************
[color(yellow)]栄吉[color(white)]
[tab]そりゃアイツのせいで、どエライ目に会ったけど、
[tab]ほっとけないっしょ。
[tab]俺は番長すからね。
[sync][wait][clear]
***************************************/
    unitAnimationPlay(eikichi, animation_2d, 1);
    unitWait(nanjo);
    unitFace(nanjo, west);
    li(var_2, 0);
    call(NANJOSOUSA);
    delayClear();
    delayWait(40);
    sync();
    wait(ref_69);
    dialogFree(ref_68);
    ref_74 = bustupFade(ref_66, rgb(0,0,0), 10);
    bustupWait(ref_74);
    bustupFree(ref_66);
    unitAnimationPlay(eikichi, animation_0, 1);
    delayClear();
    delayWait(30);
    li(var_2, 1);
    unitMove(nanjo, 1160, -250, face_west, fast);
    unitWait(nanjo);
    unitFace(nanjo, west);
    unitAnimationPlay(nanjo, animation_1a, 1);
    unitWait(nanjo);
    delayClear();
    delayWait(60);
    unitAnimationPlay(nanjo, animation_1, 1);
    delayClear();
    delayWait(7);
    unitFace(nanjo, north);
    unitAnimationPlay(nanjo, animation_0, 1);
    delayClear();
    delayWait(7);
    unitFace(nanjo, east);
    delayClear();
    delayWait(30);
    ref_8c = bustupLoad(bustup_36);
    bustupWait(ref_8c);
    ref_8e = bustupAlloc(ref_8c, left, rgb(0,0,0));
    bustupFade(ref_8e, rgb(128,0,0), 30);
    ref_90 = dialogAlloc();
    ref_91 = msgShow(msg_3);
/***************************************
[color(yellow)]南条[color(white)]
[tab]セキュリティはカットしました。
[tab]これで警報装置の類はしばらくごまかせるはずだ。
[sync][wait][clear]
***************************************/
    unitAnimationPlay(nanjo, animation_2d, 1);
    delayClear();
    delayWait(10);
    unitAnimationPlay(maya, animation_b, 1);
    unitAnimationPlay(katsuya, animation_c, 1);
    unitAnimationPlay(ulala, animation_3, 1);
    unitAnimationPlay(eikichi, animation_1, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(eikichi, animation_2, 1);
    delayClear();
    delayWait(40);
    sync();
    wait(ref_91);
    dialogFree(ref_90);
    ref_a1 = bustupFade(ref_8e, rgb(0,0,0), 10);
    bustupWait(ref_a1);
    bustupFree(ref_8e);
    unitAnimationPlay(nanjo, animation_a, 1);
    delayClear();
    delayWait(30);
    ref_a7 = bustupLoad(bustup_21);
    bustupWait(ref_a7);
    ref_a9 = bustupAlloc(ref_a7, left, rgb(0,0,0));
    bustupFade(ref_a9, rgb(128,0,0), 30);
    ref_ab = dialogAlloc();
    ref_ac = msgShow(msg_4);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]栄吉君、友達のことは我々にまかせて帰りたまえ。
[tab]ここは子供の来るところじゃない。
[sync][wait][clear]
***************************************/
    unitAnimationPlay(katsuya, animation_2d, 1);
    delayClear();
    delayWait(10);
    unitAnimationPlay(maya, animation_a, 1);
    unitAnimationPlay(baofu, animation_d, 1);
    unitAnimationPlay(ulala, animation_0, 1);
    unitAnimationPlay(eikichi, animation_1, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(maya, animation_d, 1);
    unitAnimationPlay(baofu, animation_e, 1);
    unitAnimationPlay(ulala, animation_1, 1);
    unitAnimationPlay(eikichi, animation_0, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(eikichi, animation_3, 1);
    delayClear();
    delayWait(7);
    unitFace(eikichi, east);
    unitAnimationPlay(eikichi, animation_1, 1);
    delayClear();
    delayWait(30);
    sync();
    wait(ref_ac);
    dialogFree(ref_ab);
    ref_c6 = bustupFade(ref_a9, rgb(0,0,0), 10);
    bustupWait(ref_c6);
    bustupFree(ref_a9);
    unitAnimationPlay(katsuya, animation_b, 1);
    delayClear();
    delayWait(30);
    unitFace(eikichi, south);
    unitAnimationPlay(eikichi, animation_0, 1);
    delayClear();
    delayWait(30);
    ref_d0 = bustupLoad(bustup_117);
    bustupWait(ref_d0);
    ref_d2 = bustupAlloc(ref_d0, right, rgb(0,0,0));
    bustupFade(ref_d2, rgb(128,0,0), 30);
    ref_d4 = dialogAlloc();
    ref_d5 = msgShow(msg_5);
/***************************************
[color(yellow)]栄吉[color(white)]
[tab]冗談じゃねぇ！
[tab]このまますっこんでられっか！
[tab]俺も連れて行ってくれよ！
[sync][wait][clear]
***************************************/
    unitAnimationPlay(eikichi, animation_2f, 1);
    delayClear();
    delayWait(10);
    unitAnimationPlay(baofu, animation_d, 1);
    unitAnimationPlay(ulala, animation_0, 1);
    unitAnimationPlay(maya, animation_a, 1);
    unitAnimationPlay(nanjo, animation_d, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(baofu, animation_a, 1);
    delayClear();
    delayWait(50);
    sync();
    wait(ref_d5);
    ref_e4 = msgShow(msg_6);
/***************************************
[color(yellow)]栄吉[color(white)]
[tab]じゃねぇと、騒ぐぜ！？
[tab]「だーれーかぁー！！」
[sync][wait][clear]
***************************************/
    unitAnimationPlay(eikichi, animation_1f, 1);
    delayClear();
    delayWait(30);
    unitAnimationHold(eikichi, animation_18, -1);
    delayClear();
    delayWait(30);
    sync();
    wait(ref_e4);
    dialogFree(ref_d4);
    ref_ee = bustupFade(ref_d2, rgb(0,0,0), 10);
    bustupWait(ref_ee);
    bustupFree(ref_d2);
    call(AWA);
    unitAnimationPlay(nanjo, animation_1d, 1);
    unitAnimationPlay(baofu, animation_1d, 1);
    unitWait(nanjo);
    unitWait(baofu);
    delayClear();
    delayWait(30);
    unitAnimationPlay(baofu, animation_a, 1);
    li(var_3, 1);
    ref_fa = bustupLoad(bustup_36);
    bustupWait(ref_fa);
    ref_fc = bustupAlloc(ref_fa, left, rgb(0,0,0));
    bustupFade(ref_fc, rgb(128,0,0), 30);
    ref_fe = dialogAlloc();
    ref_ff = msgShow(msg_7);
/***************************************
[color(yellow)]南条[color(white)]
[tab]仕方ない…連れて行きましょう。
[tab]気持ちは理解できる。
[sync][wait][clear]
***************************************/
    unitAnimationPlay(nanjo, animation_2d, 1);
    unitAnimationPlay(maya, animation_b, 1);
    unitAnimationStop(eikichi);
    unitFace(eikichi, west);
    unitAnimationPlay(eikichi, animation_3, 1);
    delayClear();
    delayWait(60);
    sync();
    wait(ref_ff);
    ref_109 = msgShow(msg_8);
/***************************************
[color(yellow)]南条[color(white)]
[tab]その代わり…
[tab]少年、我々の邪魔はするなよ。
[tab]途中で戻れと言ったら戻るんだ。
[sync][wait][clear]
***************************************/
    unitAnimationPlay(nanjo, animation_d, 1);
    delayClear();
    delayWait(60);
    sync();
    wait(ref_109);
    dialogFree(ref_fe);
    ref_110 = bustupFade(ref_fc, rgb(0,0,0), 10);
    bustupWait(ref_110);
    bustupFree(ref_fc);
    delayClear();
    delayWait(30);
    ref_115 = bustupLoad(bustup_116);
    bustupWait(ref_115);
    ref_117 = bustupAlloc(ref_115, right, rgb(0,0,0));
    bustupFade(ref_117, rgb(128,0,0), 30);
    ref_119 = dialogAlloc();
    ref_11a = msgShow(msg_9);
/***************************************
[color(yellow)]栄吉[color(white)]
[tab]がってん承知でぃ！
[sync][wait][clear]
***************************************/
    unitAnimationPlay(eikichi, animation_1e, 1);
    delayClear();
    delayWait(10);
    unitAnimationPlay(maya, animation_a, 1);
    unitAnimationPlay(katsuya, animation_b, 1);
    unitAnimationPlay(ulala, animation_a, 1);
    delayClear();
    delayWait(20);
    unitWait(eikichi);
    sync();
    wait(ref_11a);
    dialogFree(ref_119);
    ref_127 = bustupFade(ref_117, rgb(0,0,0), 10);
    bustupWait(ref_127);
    bustupFree(ref_117);
    unitAnimationPlay(eikichi, animation_0, 1);
    unitAnimationPlay(katsuya, animation_a, 1);
    unitAnimationPlay(ulala, animation_a, 1);
    unitAnimationPlay(baofu, animation_a, 1);
    unitAnimationPlay(nanjo, animation_a, 1);
    delayClear();
    delayWait(60);
    ref_131 = cameraLookAtUnit(maya, 0, 30);
    wait(ref_131);
    unitDespawn(maya, none);
    playerInit(north);
    controlDisable();
    bitSet(EBIT_E0050);
    unitIdleOnAll();
    controlEnable();
}

function FREE()
{
    unitSpawn(nanjo, sprite_1f, 1160, 0, -250, east, none);
    unitSpawn(eikichi, sprite_27, 980, 0, -360, north, none);
    unitSpawn(ulala, sprite_6, 1050, 0, -700, south, none);
    unitSpawn(katsuya, sprite_d, 650, 0, -160, west, none);
    unitSpawn(baofu, sprite_13, 770, 0, -520, west, none);
    unitTriggerSet(nanjo, NANJO, 255, 1);
    unitTriggerSet(eikichi, EIKITI, 255, 1);
    unitTriggerSet(ulala, URARA, 255, 1);
    unitTriggerSet(katsuya, KATUYA, 255, 1);
    unitTriggerSet(baofu, PAOFU, 255, 1);
    unitIdleOnAll();
    cameraSet(southwest, 50, 0, -350);
    playerInit(west);
    controlDisable();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    screenEffectUnknown();
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

function NANJO()
{
    controlDisable();
    unitFacePlayer(nanjo);
    ref_152 = bustupLoad(bustup_36);
