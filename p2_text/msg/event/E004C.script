    delayClear();
    delayWait(60);
    sync();
    wait(ref_157);
    dialogFree(ref_156);
    ref_15e = bustupFade(ref_154, rgb(0,0,0), 10);
    bustupWait(ref_15e);
    bustupFree(ref_154);
    unitAnimationPlay(nanjo, animation_0, 1);
    unitRestoreFacing(nanjo);
    controlEnable();
}

