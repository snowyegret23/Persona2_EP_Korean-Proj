    ref_1d2 = dialogChoiceAlloc();
    ref_1d3 = msgShow(msg_17);
/***************************************
[tab]なーんか知ってる気がするんだよなぁ。
[choice(2)]私も…
前に駅前で見たかな？
[end_choice][clear]
***************************************/
    sync();
    wait(ref_1d3);
    dialogFree(ref_1d2);
    ref_1d7 = bustupFade(ref_1d0, rgb(0,0,0), 10);
    bustupWait(ref_1d7);
    bustupFree(ref_1d0);
    choiceGetResult(var_5);
    bne(var_5, 0, label_208);
    unitAnimationPlay(maya, animation_14, 1);
    unitWait(maya);
