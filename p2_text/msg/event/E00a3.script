function URARABOX()
{
    controlDisable();
    unitFacePlayer(ulala);
    ref_187 = bustupLoad(bustup_1a);
    bustupWait(ref_187);
    ref_189 = bustupAlloc(ref_187, left, rgb(0,0,0));
    bustupFade(ref_189, rgb(128,0,0), 30);
    ref_18b = dialogAlloc();
    ref_18c = msgShow(msg_4);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]正義の味方を気取るわけじゃないけどさ…
[tab]今まで、大勢人が死んだよね…
[tab]こんな私でもさ、もうたくさんだって思うわよ！
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2f, 1);
    wait(ref_18c);
    ref_18f = bustupFade(ref_189, rgb(0,0,0), 10);
    bustupWait(ref_18f);
    bustupFree(ref_189);
    ref_192 = bustupLoad(bustup_19);
    bustupWait(ref_192);
    ref_194 = bustupAlloc(ref_192, left, rgb(0,0,0));
    bustupFade(ref_194, rgb(128,0,0), 30);
    ref_196 = msgShow(msg_5);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]人のために何かをしたいって思ったら、
[tab]損得考えずにやりなさいっておばあちゃんが
[tab]言ってたけど、ようやくわかったわ！
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2d, 1);
    wait(ref_196);
    unitAnimationPlay(ulala, animation_a, 1);
    dialogFree(ref_18b);
    ref_19b = bustupFade(ref_194, rgb(0,0,0), 10);
    bustupWait(ref_19b);
    bustupFree(ref_194);
    unitRestoreFacing(ulala);
    controlEnable();
}

function KATUYABOX()
{
    controlDisable();
    unitFacePlayer(katsuya);
    ref_1a3 = bustupLoad(bustup_21);
    bustupWait(ref_1a3);
    ref_1a5 = bustupAlloc(ref_1a3, left, rgb(0,0,0));
    bustupFade(ref_1a5, rgb(128,0,0), 30);
    ref_1a7 = dialogAlloc();
    ref_1a8 = msgShow(msg_6);
/***************************************
[color(yellow)]克哉[color(white)]
[tab][tatsuya]の奴、ここは無意識の世界の一部だ
[tab]というような事を言ったな…
[wait][clear]
***************************************/
    unitAnimationPlay(katsuya, animation_1a, 1);
    wait(ref_1a8);
    unitAnimationPlay(katsuya, animation_2d, 1);
    ref_1ac = msgShow(msg_7);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]我々の心は、幾つもの層から成り立っているんだ…
[tab]普段、僕達が「自分」と意識する自我があり、
[tab]その下には抑圧された個人的無意識がある。
[wait][clear][color(yellow)]克哉[color(white)]
[tab]そしてその下には、属する社会によって異なる
[tab]家族的無意識や文化的無意識…普遍的無意識と
[tab]呼ばれる深淵がどこまでも広がっている…
[wait][clear][color(yellow)]克哉[color(white)]
[tab]普遍的無意識は、人類全体が共有する無意識の海
[tab]のようなものだと思えばいいだろう…
[tab]その海に浮かぶちっぽけな島…それが自我なんだ
[wait][clear][color(yellow)]克哉[color(white)]
[tab]街の人々の噂がこの船を生んだのならば、
[tab]ここは珠閒瑠市に住む人々の、社会的無意識
[tab]そのものと言えるのかもしれないな…
[wait][clear]
***************************************/
    wait(ref_1ac);
    unitAnimationPlay(katsuya, animation_a, 1);
    dialogFree(ref_1a7);
    ref_1b0 = bustupFade(ref_1a5, rgb(0,0,0), 10);
    bustupWait(ref_1b0);
    bustupFree(ref_1a5);
    unitRestoreFacing(katsuya);
    controlEnable();
}

