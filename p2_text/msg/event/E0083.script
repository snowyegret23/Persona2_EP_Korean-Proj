function KAUIDO()
{
    delayClear();
    delayWait(30);
    unitAnimationPlay(katsuya, animation_28, 1);
    cameraMoveTo(535, -300, -2400, 120);
    unitWait(katsuya);
    delayClear();
    delayWait(45);
    unitMove(katsuya, 490, -1940, face_north, fastest);
}

function TATUKAITEN()
{
    unitWait(tatsuya);
    sndStop(sound_322b);
    unitAnimationPlay(tatsuya, animation_0, 1);
    delayClear();
    delayWait(40);
    unitFace(tatsuya, west);
    sndMusicPlay(sound_322c, 127);
}

function TATUKAITEN2()
{
    delayClear();
    delayWait(120);
    sndMusicPlay(sound_322c, 127);
    unitFace(tatsuya, east);
    delayClear();
    delayWait(20);
    unitFace(tatsuya, north);
}
