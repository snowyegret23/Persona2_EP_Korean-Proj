function MAYAMOVE()
{
    unitMove(maya, 100, -1950, face_west, fast);
    unitWait(maya);
    unitMove(maya, 300, -1950, face_south, fast);
    unitWait(maya);
    unitMove(maya, 300, -1530, face_west, fast);
    unitWait(maya);
    unitMove(maya, 820, -1530, face_north, fast);
    unitWait(maya);
    unitMove(maya, 850, -1575, face_north, fast);
}

function URARAMOVE()
{
    unitMove(ulala, 100, -1950, face_west, fast);
    unitWait(ulala);
    unitMove(ulala, 300, -1950, face_south, fast);
    unitWait(ulala);
    unitMove(ulala, 300, -1530, face_west, fast);
    unitWait(ulala);
    unitMove(ulala, 700, -1530, face_north, fast);
    unitWait(ulala);
    unitMove(ulala, 700, -1670, face_north, fast);
}

function KATUYAMOVE()
{
    unitMove(katsuya, 100, -1950, face_west, fast);
    unitWait(katsuya);
    unitMove(katsuya, 300, -1950, face_south, fast);
    unitWait(katsuya);
    unitMove(katsuya, 300, -1530, face_west, fast);
    unitWait(katsuya);
    unitMove(katsuya, 590, -1530, face_north, fast);
    unitWait(katsuya);
    unitMove(katsuya, 590, -1650, face_west, fast);
    unitWait(katsuya);
    unitAnimationPlay(katsuya, animation_3, 1);
    delayClear();
    delayWait(7);
    unitFace(katsuya, south);
    unitAnimationPlay(katsuya, animation_0, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(katsuya, animation_28, 1);
    unitWait(katsuya);
    delayClear();
    delayWait(12);
    unitAnimationPlay(katsuya, animation_28, 1);
    unitWait(katsuya);
    delayClear();
    delayWait(30);
    unitAnimationPlay(katsuya, animation_3, 1);
    delayClear();
    delayWait(7);
    unitFace(katsuya, west);
    unitAnimationPlay(katsuya, animation_0, 1);
    delayClear();
    delayWait(30);
    unitAnimationPlay(katsuya, animation_1, 1);
}

