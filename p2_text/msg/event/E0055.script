    ref_65 = dialogAlloc();
    ref_66 = msgShow(msg_3);
/***************************************
[color(yellow)]パオフゥ[color(white)]
[tab]黒須…純子か…
[tab]大人の女ってないいねぇ～
[tab]芹沢なんかにゃねぇ、色気ってのがある。
[sync][wait][clear]
***************************************/
    unitAnimationPlay(baofu, animation_2d, 1);
    delayClear();
    delayWait(60);
    sync();
    wait(ref_66);
    dialogFree(ref_65);
    ref_6d = bustupFade(ref_63, rgb(0,0,0), 10);
    bustupWait(ref_6d);
    bustupFree(ref_63);
    unitAnimationPlay(baofu, animation_a, 1);
    unitRestoreFacing(baofu);
    controlEnable();
}

