function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    sndIdGet(var_0);
    bne(var_0, -1, label_5);
    b(label_7);
  label_5:
    sndVolumeFadeTo(var_0, 90, 60);
    b(label_7);
  label_7:
    sndUnkCF(90);
    cameraSetNorth(east);
    cameraSet(southwest, 350, 0, -750);
    ref_a = spriteLoad(sprite_0);
    wait(ref_a);
    ref_c = spriteLoad(sprite_2);
    wait(ref_c);
    ref_e = spriteLoad(sprite_6);
    wait(ref_e);
    ref_10 = spriteLoad(sprite_13);
    wait(ref_10);
    ref_12 = spriteLoad(sprite_d);
    wait(ref_12);
    ref_14 = spriteLoad(sprite_23);
    wait(ref_14);
    ref_16 = spriteLoad(sprite_6c);
    wait(ref_16);
    unitSpawn(ulala, sprite_6, 110, 0, -180, west, none);
    unitSpawn(baofu, sprite_13, 660, 0, -300, east, none);
    unitSpawn(katsuya, sprite_d, 120, 0, -600, south, none);
    unitSpawn(elly, sprite_23, 600, 0, -570, south, none);
    unitSpawn(junko, sprite_6c, 400, 0, -180, north, none);
    unitAnimationPlay(ulala, animation_a, 1);
    unitAnimationPlay(baofu, animation_a, 1);
    unitAnimationPlay(katsuya, animation_a, 1);
    unitAnimationPlay(elly, animation_a, 1);
    unitIdleOnAll();
    unitTriggerSet(ulala, URARA, 255, 1);
    unitTriggerSet(katsuya, KATUYA, 255, 1);
    unitTriggerSet(baofu, PAOFU, 255, 1);
    unitTriggerSet(elly, ERI, 255, 1);
    unitTriggerSet(junko, JUNKO, 255, 1);
    envTriggerSet(EXIT, 131, 1, line, coll_0);
    playerInit(south);
    controlDisable();
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

function JUNKO()
{
    controlDisable();
    unitFacePlayer(junko);
    bitGet(var_0, EBIT_JUNKOMES);
    bne(var_0, 0, label_49);
    ref_35 = bustupLoad(bustup_ca);
    bustupWait(ref_35);
    ref_37 = bustupAlloc(ref_35, right, rgb(0,0,0));
    bustupFade(ref_37, rgb(128,0,0), 30);
    ref_39 = dialogAlloc();
    ref_3a = msgShow(msg_0);
/***************************************
[color(yellow)]黒須[tab]純子[color(white)]
[tab]あら、ここは私の楽屋よ、お嬢さん。
[tab]道に迷ったのなら、人を呼んであげましょうか？
[sync][wait][clear]
***************************************/
    unitAnimationPlay(junko, animation_24, 1);
    delayClear();
    delayWait(60);
    sync();
    wait(ref_3a);
    unitAnimationPlay(junko, animation_0, 1);
    ref_41 = msgShow(msg_1);
/***************************************
[color(yellow)]黒須[tab]純子（くろす[tab]じゅんこ）[color(white)]
[color(green)][tab]本名は橿原[tab]純子。
[tab]大女優であり橿原[tab]淳の母。
[tab]なんとなく知っている気がする…[color(white)]
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_41);
    dialogFree(ref_39);
    ref_45 = bustupFade(ref_37, rgb(0,0,0), 10);
    bustupWait(ref_45);
    bustupFree(ref_37);
    b(label_5b);
  label_49:
    bne(var_0, 1, label_5b);
    ref_4a = bustupLoad(bustup_ca);
    bustupWait(ref_4a);
    ref_4c = bustupAlloc(ref_4a, right, rgb(0,0,0));
    bustupFade(ref_4c, rgb(128,0,0), 30);
    ref_4e = dialogAlloc();
    ref_4f = msgShow(msg_2);
/***************************************
[color(yellow)]黒須[tab]純子[color(white)]
[tab]あら、ここは私の楽屋よ、お嬢さん。
[tab]道に迷ったのなら、人を呼んであげましょうか？
[sync][wait][clear]
***************************************/
    unitAnimationPlay(junko, animation_24, 1);
    delayClear();
    delayWait(60);
    sync();
    wait(ref_4f);
    dialogFree(ref_4e);
    ref_56 = bustupFade(ref_4c, rgb(0,0,0), 10);
    bustupWait(ref_56);
    bustupFree(ref_4c);
    unitAnimationPlay(junko, animation_0, 1);
    b(label_5b);
  label_5b:
    bitSet(EBIT_JUNKOMES);
    unitRestoreFacing(junko);
    controlEnable();
}

function PAOFU()
{
    controlDisable();
