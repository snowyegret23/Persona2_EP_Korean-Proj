function URARA()
{
    controlDisable();
    unitFacePlayer(ulala);
    ref_8d = bustupLoad(bustup_18);
    bustupWait(ref_8d);
    ref_8f = bustupAlloc(ref_8d, left, rgb(0,0,0));
    bustupFade(ref_8f, rgb(128,0,0), 30);
    ref_91 = dialogAlloc();
    ref_92 = msgShow(msg_5);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]ぎゃ～黒須[tab]純子よ！
[tab]マーヤ、サインサイン！
[tab]おじさん連中に高く売れるわよぅ！！
[sync][wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2c, 1);
    delayClear();
    delayWait(45);
    unitAnimationHold(ulala, animation_18, -1);
    delayClear();
    delayWait(10);
    sync();
    wait(ref_92);
    dialogFree(ref_91);
    ref_9c = bustupFade(ref_8f, rgb(0,0,0), 10);
    bustupWait(ref_9c);
    bustupFree(ref_8f);
    unitAnimationStop(ulala);
    unitAnimationPlay(ulala, animation_a, 1);
    unitRestoreFacing(ulala);
    controlEnable();
}

function ERI()
{
    controlDisable();
    unitFacePlayer(elly);
    ref_a6 = bustupLoad(bustup_3e);
    bustupWait(ref_a6);
    ref_a8 = bustupAlloc(ref_a6, left, rgb(0,0,0));
    bustupFade(ref_a8, rgb(128,0,0), 30);
    ref_aa = dialogAlloc();
    ref_ab = msgShow(msg_6);
/***************************************
[color(yellow)]エリー[color(white)]
[tab]さすが大女優の貫禄ですわね。
[tab]ご迷惑をおかけしないうちに、おいとましましょう。
[sync][wait][clear]
***************************************/
    unitAnimationPlay(elly, animation_2d, 1);
    delayClear();
    delayWait(60);
    sync();
    wait(ref_ab);
    dialogFree(ref_aa);
    ref_b2 = bustupFade(ref_a8, rgb(0,0,0), 10);
    bustupWait(ref_b2);
    bustupFree(ref_a8);
    unitAnimationPlay(elly, animation_a, 1);
    unitRestoreFacing(elly);
    controlEnable();
}

function EXIT()
{
    controlDisable();
    objAnimRotate(obj_d, 0, -80, 0, 60, 0);
    sndMusicPlay(sound_3189, 127);
    objAnimWait(obj_d);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    dngLoad2(sumaru_tv1-5);
}
