function BOSS()
{
    delayClear();
    delayWait(240);
    sndMusicPlay(sound_30be, 127);
    unitMove(enemy1, 270, -2160, face_south, medium);
    unitAnimationPlay(enemy1, animation_6, 1);
    unitWait(enemy1);
    sndMusicPlay(sound_30ae, 127);
    unitAnimationHold(enemy1, animation_7, 120);
    unitWait(enemy1);
    unitAnimationPlay(enemy1, animation_6, 1);
    unitFace(enemy1, north);
}

