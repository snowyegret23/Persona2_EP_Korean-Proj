function DOORBOX()
{
    controlDisable();
    sndMusicPlay(sound_3078, 127);
    objAnimRotate(obj_4, 0, 70, 0, 30, 0);
    objAnimRotate(obj_3, 0, -70, 0, 30, 0);
    objAnimWait(obj_4);
    objAnimWait(obj_3);
    call(GOOUT);
}

function GOOUT()
{
    bitClear(MBIT_EXITBIT);
    mapLoad(rengedai, 0, 0);
}

function warp1()
{
    call(DOORBOX);
}

function HA_SHOP_EXPLAIN_0()
{
    ref_618 = dialogAlloc();
    ref_619 = msgShow(msg_121);
/***************************************
[color(yellow)]やる気のないボーイ[color(white)]
[tab]ああ、「食事」の説明ね…
[tab]うちで、「食事をする」を選ぶと食事ができるよ。
[tab]…全部レトルトとインスタントだけど。
[wait][clear][color(yellow)]やる気のないボーイ[color(white)]
[tab]でも一応、なんか食べたり飲んだりすると
[tab]しばらく能力をあげることができるそうだぜ。
[tab]で、物によって効果が違うらしいよ、よく知らんけど。
[wait][clear][color(yellow)]やる気のないボーイ[color(white)]
[tab]ああそれから、一度飲み食いしたら、
[tab]その効果が切れるまで次の食事はできないからな。
[wait][clear]
***************************************/
    wait(ref_619);
    dialogFree(ref_618);
}

function DECIDE_EAT()
{
    choiceSetResult(1);
    msgVar_Number(msgvar_0, var_6);
    unitFacePlayer(shopkeeper);
    ref_620 = bustupLoad(bustup_fa);
    bustupWait(ref_620);
    ref_622 = bustupAlloc(ref_620, left, rgb(0,0,0));
    bustupFade(ref_622, rgb(128,0,0), 30);
    ref_624 = dialogAlloc();
    ref_625 = msgShow(msg_122);
/***************************************
[color(yellow)]やる気のないボーイ[color(white)]
[tab][var(msg_var_0)]円だけど、いいかぁ？
[choice(2)]はい
いいえ
[end_choice][clear]
***************************************/
    wait(ref_625);
    choiceGetResult(var_7);
    bne(var_7, 0, label_62b);
    li(var_7, 1);
    b(label_62e);
  label_62b:
    bne(var_7, 1, label_62e);
    li(var_7, 0);
    b(label_62e);
  label_62e:
    wait(ref_625);
    dialogFree(ref_624);
    ref_630 = bustupFade(ref_622, rgb(0,0,0), 10);
    bustupWait(ref_630);
    bustupFree(ref_622);
    li(var_5, 20);
}
