    cameraSet(southwest, 395, 0, -1145);
    b(label_a);
  label_9:
    cameraSet(northeast, 660, 0, -235);
  label_a:
    li(var_0, 0);
    li(var_1, 0);
    partyMemberCheck(var_0, ulala);
