    ref_41 = spriteLoad(sprite_18);
    wait(ref_41);
    unitSpawn(tatsuya, sprite_18, 1276, 0, -969, west, none);
    unitTriggerSet(tatsuya, B_TATU, 255, 1);
    b(label_4f);
  label_46:
    bitGet(var_0, EBIT_E008C);
