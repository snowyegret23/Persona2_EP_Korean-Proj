function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    levelFootstepSet(sfx_f);
    sndIdGet(var_0);
    bne(var_0, -1, label_6);
    b(label_8);
  label_6:
    sndVolumeFadeTo(var_0, 90, 60);
    b(label_8);
  label_8:
    sndUnkCF(90);
    envTriggerSet(warp1, 131, 1, line, coll_1e);
    cameraSetNorth(south);
    cameraSet(southeast, 315, 0, -803);
    ref_c = spriteLoad(sprite_6);
    wait(ref_c);
    unitSpawn(ulala, sprite_6, 312, -50, -56, south, none);
    unitTriggerSet(ulala, B_URARATI, 255, 1);
    bitGet(var_0, EBIT_E0010);
    bne(var_0, 0, label_13);
    b(label_19);
  label_13:
    bne(var_0, 1, label_19);
    ref_14 = spriteLoad(sprite_d);
    wait(ref_14);
    unitSpawn(katsuya, sprite_d, 134, -50, -612, south, none);
    unitTriggerSet(katsuya, KATUYA, 255, 1);
    b(label_19);
  label_19:
    ref_19 = spriteLoad(sprite_65);
    wait(ref_19);
    unitSpawn(npc1, sprite_65, 497, -60, -304, east, none);
    unitRevolveAnimationPlay(npc1, animrevolve_10);
    unitTriggerSet(npc1, KOUMU, 255, 1);
    ref_1e = spriteLoad(sprite_66);
    wait(ref_1e);
    unitSpawn(npc2, sprite_66, 327, -60, -491, south, none);
    unitRevolveAnimationPlay(npc2, animrevolve_c);
    unitTriggerSet(npc2, HOKEN, 255, 1);
    ref_23 = spriteLoad(sprite_0);
    wait(ref_23);
    ref_25 = spriteLoad(sprite_2);
    wait(ref_25);
    playerInit(south);
    controlDisable();
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    unitIdleOnAll();
    unitIdleOff(npc1);
    unitIdleOff(npc2);
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
    unitRevolveAnimationPlay(npc1, animrevolve_10);
    unitRevolveAnimationPlay(npc2, animrevolve_c);
}

function B_URARATI()
{
    controlDisable();
    ref_36 = bustupLoad(bustup_17);
    bustupWait(ref_36);
    ref_38 = bustupAlloc(ref_36, left, rgb(0,0,0));
    bustupFade(ref_38, rgb(128,0,0), 30);
    ref_3a = dialogAlloc();
    ref_3b = msgShow(msg_0);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]ありゃ…
[tab]このポスター、口の所がふやけてる…

***************************************/
    unitAnimationPlay(ulala, animation_1f, 1);
    wait(ref_3b);
    ref_3e = msgShow(msg_1);
/***************************************
[tab]……まぁ…いっか。
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_6, 1);
    wait(ref_3e);
    dialogFree(ref_3a);
    unitAnimationPlay(ulala, animation_a, 1);
    ref_43 = bustupFade(ref_38, rgb(0,0,0), 10);
    bustupWait(ref_43);
    bustupFree(ref_38);
    controlEnable();
}

function KATUYA()
{
    controlDisable();
    bitGet(var_0, EBIT_GETKEY1);
    bnz(var_0, label_5b);
    unitFacePlayer(katsuya);
    ref_4c = bustupLoad(bustup_21);
    bustupWait(ref_4c);
    ref_4e = bustupAlloc(ref_4c, left, rgb(0,0,0));
    bustupFade(ref_4e, rgb(128,0,0), 30);
    ref_50 = dialogAlloc();
    ref_51 = msgShow(msg_2);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]ここにあった時計台の鍵が消えたそうだ。
[tab]窃盗の可能性が高いな…
[tab]取り敢えず鑑識に連絡しておくか…
[wait][clear]
***************************************/
    unitAnimationPlay(katsuya, animation_1a, 1);
    wait(ref_51);
    unitAnimationPlay(katsuya, animation_a, 1);
    dialogFree(ref_50);
    ref_56 = bustupFade(ref_4e, rgb(0,0,0), 10);
    bustupWait(ref_56);
    bustupFree(ref_4e);
    unitRestoreFacing(katsuya);
    b(label_6a);
  label_5b:
    unitFacePlayer(katsuya);
    ref_5c = bustupLoad(bustup_21);
    bustupWait(ref_5c);
    ref_5e = bustupAlloc(ref_5c, left, rgb(0,0,0));
    bustupFade(ref_5e, rgb(128,0,0), 30);
    ref_60 = dialogAlloc();
    ref_61 = msgShow(msg_3);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]ここに時計台の鍵がある事を知っているのは、
[tab]校務員さんと教員…そして生徒…か。
[tab]まさかあの娘が鍵を…
[wait][clear]
***************************************/
    unitAnimationPlay(katsuya, animation_2d, 1);
    wait(ref_61);
    dialogFree(ref_60);
    unitAnimationPlay(katsuya, animation_a, 1);
    ref_66 = bustupFade(ref_5e, rgb(0,0,0), 10);
    bustupWait(ref_66);
    bustupFree(ref_5e);
    unitRestoreFacing(katsuya);
  label_6a:
    controlEnable();
}

function KOUMU()
{
    controlDisable();
    bitGet(var_0, EBIT_E0010);
    bnz(var_0, label_7c);
    ref_6f = cameraRotateTo(3, 60);
    wait(ref_6f);
    unitAnimationPlay(npc1, animation_29, 1);
    ref_72 = dialogAlloc();
    ref_73 = msgShow(msg_4);
/***************************************
[color(yellow)]校務員さん[color(white)]
[tab]はぁ…
[tab]この歳で、大時計の手入れは大変じゃわい…
[tab]…ところで…飯はまだかの？
[wait][clear]
***************************************/
    wait(ref_73);
    dialogFree(ref_72);
    unitAnimationPlay(npc2, animation_2a, 1);
