/***************************************
[color(yellow)]保健のオバチャン[color(white)]
[tab]まったくお爺ちゃんったら、
[tab]さっき食べたばかりじゃない。
[tab]しょうがないわねぇ。
[wait][clear]
***************************************/
    wait(ref_78);
    dialogFree(ref_77);
    b(label_9d);
  label_7c:
    bitGet(var_0, MBIT_KOM_TALK);
    bnz(var_0, label_91);
