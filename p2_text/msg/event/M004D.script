    wait(ref_9a);
    dialogFree(ref_99);
  label_9d:
    controlEnable();
    unitIdleOff(npc1);
    unitIdleOff(npc2);
    unitRevolveAnimationPlay(npc1, animrevolve_10);
    unitRevolveAnimationPlay(npc2, animrevolve_c);
}

function HOKEN()
{
    controlDisable();
    bitClear(LBIT_0000);
    ref_a5 = call(KAIFUKUSURUBEKI);
    wait(ref_a5);
    bitGet(var_1, LBIT_0000);
    bne(var_1, 0, label_ac);
    call(KOUMU);
    b(label_f5);
    b(label_b3);
  label_ac:
    bne(var_1, 1, label_b3);
    unitFacePlayer(npc2);
    ref_ae = dialogAlloc();
    ref_af = msgShow(msg_11);
/***************************************
[color(yellow)]保健のオバチャン[color(white)]
[tab]あらあら？
[tab]怪我してるようね？
[tab]ちょっと見せてごらんなさい。
[wait][clear]
***************************************/
    wait(ref_af);
    dialogFree(ref_ae);
    b(label_b3);
  label_b3:
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), add);
    screenFadeInner(rgb(255,255,255), 8, false);
    screenFadeOuter(rgb(255,255,255), 8, false);
    sndMusicPlay(sound_3, 127);
    partyHealthRestore(maya);
    partySPRestore(maya);
    partyStatusClear(maya);
    partyMemberCheck(var_3, ulala);
    bez(var_3, label_c0);
    partyHealthRestore(ulala);
    partySPRestore(ulala);
    partyStatusClear(ulala);
  label_c0:
    partyMemberCheck(var_3, katsuya);
    bez(var_3, label_c5);
    partyHealthRestore(katsuya);
    partySPRestore(katsuya);
    partyStatusClear(katsuya);
  label_c5:
    partyMemberCheck(var_3, baofu);
    bez(var_3, label_ca);
    partyHealthRestore(baofu);
    partySPRestore(baofu);
    partyStatusClear(baofu);
  label_ca:
    partyMemberCheck(var_3, nanjo);
    bez(var_3, label_cf);
    partyHealthRestore(nanjo);
    partySPRestore(nanjo);
    partyStatusClear(nanjo);
  label_cf:
    partyMemberCheck(var_3, elly);
    bez(var_3, label_d4);
    partyHealthRestore(elly);
    partySPRestore(elly);
    partyStatusClear(elly);
  label_d4:
    partyMemberCheck(var_3, tatsuya);
    bez(var_3, label_d9);
    partyHealthRestore(tatsuya);
    partySPRestore(tatsuya);
    partyStatusClear(tatsuya);
  label_d9:
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), add);
    screenFadeInner(rgb(0,0,0), 8, true);
    screenFadeOuter(rgb(0,0,0), 8, true);
    screenEffectUnknown();
    delayClear();
    delayWait(40);
    ref_df = bustupLoad(bustup_1);
    bustupWait(ref_df);
    ref_e1 = bustupAlloc(ref_df, center, rgb(0,0,0));
    bustupFade(ref_e1, rgb(128,0,0), 30);
    ref_e3 = dialogAlloc();
    ref_e4 = msgShow(msg_12);
/***************************************
[color(green)][tab]舞耶達は回復した。[color(white)][wait][clear]
***************************************/
    wait(ref_e4);
    dialogFree(ref_e3);
    ref_e7 = bustupFade(ref_e1, rgb(0,0,0), 10);
    bustupWait(ref_e7);
    bustupFree(ref_e1);
    b(label_eb);
  label_eb:
    ref_eb = dialogAlloc();
    ref_ec = msgShow(msg_13);
/***************************************
[color(yellow)]保健のオバチャン[color(white)]
[tab]さぁこれで大丈夫。
[tab]性分かしらねぇ、怪我人は放っておけないの。
[tab]何かあったら、またいつでもいらっしゃいね。
[wait][clear]
***************************************/
    wait(ref_ec);
    dialogFree(ref_eb);
    unitRestoreFacing(npc2);
    controlEnable();
    unitIdleOff(npc1);
    unitIdleOff(npc2);
    unitRevolveAnimationPlay(npc1, animrevolve_10);
    unitRevolveAnimationPlay(npc2, animrevolve_c);
  label_f5:
    unitIdleOff(npc1);
    unitIdleOff(npc2);
    unitRevolveAnimationPlay(npc1, animrevolve_10);
    unitRevolveAnimationPlay(npc2, animrevolve_c);
}

