/***************************************
[color(yellow)]校務員さん[color(white)]
[tab]時計台の鍵が見当たらんのじゃ。
[tab]どこにしまったかのぉ…
[wait][clear]
***************************************/
    wait(ref_82);
    dialogFree(ref_81);
    unitAnimationPlay(npc2, animation_2a, 1);
    ref_86 = dialogAlloc();
    ref_87 = msgShow(msg_7);
/***************************************
[color(yellow)]保健のオバチャン[color(white)]
[tab]いつも机の上に
[tab]置いておいたじゃありませんか。
[wait][clear]
***************************************/
    wait(ref_87);
    dialogFree(ref_86);
    unitAnimationPlay(npc1, animation_28, 1);
    ref_8b = dialogAlloc();
    ref_8c = msgShow(msg_8);
/***************************************
[color(yellow)]校務員さん[color(white)]
[tab]それが無いんじゃよ。
[tab]誰かが持って行ったんじゃろうか…
[wait][clear]
***************************************/
    wait(ref_8c);
    dialogFree(ref_8b);
    bitSet(MBIT_KOM_TALK);
    b(label_9d);
  label_91:
    ref_91 = cameraRotateTo(3, 60);
    wait(ref_91);
    unitAnimationPlay(npc1, animation_29, 1);
    ref_94 = dialogAlloc();
    ref_95 = msgShow(msg_9);
/***************************************
[color(yellow)]校務員さん[color(white)]
[tab]あの鍵が無くては、時計台に入れん…
[tab]困ったのぉ…
[wait][clear]
***************************************/
    wait(ref_95);
    dialogFree(ref_94);
    unitAnimationPlay(npc2, animation_2a, 1);
    ref_99 = dialogAlloc();
    ref_9a = msgShow(msg_10);
/***************************************
[color(yellow)]保健のオバチャン[color(white)]
[tab]たしか…職員室に予備がなかったかしら？
[tab]先生に聞いてみたらどうです？
[wait][clear]
