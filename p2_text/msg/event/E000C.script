    wait(ref_e2);
    ref_e4 = spriteLoad(sprite_8);
    wait(ref_e4);
    ref_e6 = spriteLoad(sprite_f);
    wait(ref_e6);
    waitFunc(APEPU1_TOJO);
    waitFunc(APEPU2_TOJO);
    waitFunc(ENPU_TOJO);
