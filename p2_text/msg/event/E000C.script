    unitSpriteSet(katsuya, sprite_f);
    unitFace_2(katsuya, south);
    delayClear();
    delayWait(30);
    op_ac();
    encounterLoad(encounter_1);
    sndMusicPlay(sound_30c9, 127);
}

function KATUYA_KYORO()
{
    unitSpriteClear(katsuya);
    unitSpriteSet(katsuya, sprite_d);
    unitMove(katsuya, 500, -1200, face_east, medium);
    unitWait(katsuya);
    delayClear();
    delayWait(30);
    unitLook(katsuya, lookDir_4);
    delayClear();
    delayWait(30);
    unitFace_2(katsuya, south);
    unitLook(katsuya, lookDir_2);
    delayClear();
    delayWait(30);
    unitMove(katsuya, 420, -1060, face_south, medium);
    unitWait(katsuya);
    delayClear();
    delayWait(30);
    unitAnimationPlay(katsuya, animation_28, 1);
    unitWait(katsuya);
    delayClear();
    delayWait(30);
    unitLook(katsuya, lookDir_0);
    delayClear();
    delayWait(30);
    unitFace_2(katsuya, east);
    unitAnimationPlay(katsuya, animation_a, 1);
    delayClear();
    delayWait(30);
    unitAnimationPlay(katsuya, animation_2a, 1);
    unitWait(katsuya);
}

function URARA_KYORO()
{
    unitSpawn(ulala, sprite_6, 950, 0, -1220, east, none);
    unitMove(ulala, 600, -1220, face_east, medium);
    unitWait(ulala);
    delayClear();
    delayWait(30);
    unitLook(ulala, lookDir_0);
    delayClear();
    delayWait(30);
    unitFace_2(ulala, north);
    unitAnimationPlay(ulala, animation_a, 1);
    delayClear();
    delayWait(30);
    unitAnimationPlay(ulala, animation_f, 1);
    delayClear();
    delayWait(60);
    unitMove(ulala, 600, -1130, face_north, reverse);
    unitWait(ulala);
    unitAnimationPlay(ulala, animation_5, 1);
    delayClear();
    delayWait(60);
    unitAnimationPlay(ulala, animation_12, 1);
    unitWait(ulala);
    delayClear();
    delayWait(30);
    unitFace_2(ulala, south);
    unitAnimationPlay(ulala, animation_5, 1);
}

function MAYA_KYORO()
{
    unitSpawn(maya, sprite_0, 950, 0, -1220, east, none);
    unitMove(maya, 760, -1220, face_east, medium);
    unitWait(maya);
    sndMusicPlay(sound_30cb, 127);
    ref_13b = objAnimRotate(obj_0, 0, -70, 0, 30, 0);
    wait(ref_13b);
    delayClear();
    delayWait(30);
    unitAnimationPlay(maya, animation_28, 1);
    unitWait(maya);
    delayClear();
    delayWait(30);
    unitLook(maya, lookDir_4);
    delayClear();
    delayWait(30);
    unitFace_2(maya, south);
    unitLook(maya, lookDir_2);
    delayClear();
    delayWait(30);
    unitMove(maya, 720, -1100, face_south, medium);
    unitWait(maya);
    unitAnimationPlay(maya, animation_0, 1);
}

function PATY()
{
    unitAnimationPlay(ulala, animation_f, 1);
    unitAnimationPlay(maya, animation_1b, 1);
}

function APEPU1_TOJO()
{
    unitSpawn(enemy1, sprite_7c, 480, 0, -800, north, ghost);
    unitColor(enemy1, rgb(0,0,0), 1);
    ref_153 = unitColor(enemy1, rgb(128,128,128), 60);
    wait(ref_153);
    unitSpriteEffect(enemy1, 0);
}

