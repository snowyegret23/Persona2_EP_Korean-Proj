    ref_245 = dialogAlloc();
    ref_246 = msgShow(msg_22);
/***************************************
[color(yellow)]淳[color(white)]
[tab][suou][tab][tatsuya]…
[tab]君は一体…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_246);
    dialogFree(ref_245);
    ref_24a = bustupFade(ref_243, rgb(0,0,0), 10);
    bustupWait(ref_24a);
    bustupFree(ref_243);
