    ref_204 = bustupFade(ref_1f7, rgb(0,0,0), 10);
    bustupWait(ref_204);
    bustupFree(ref_1f7);
    unitFace(maya, east);
    unitAnimationPlay(maya, animation_0, 1);
    unitWait(baofu);
    delayClear();
    delayWait(60);
    delayClear();
    delayWait(15);
    unitAnimationPlay(maya, animation_29, 1);
    unitWait(maya);
    delayClear();
    delayWait(30);
    unitAnimationPlay(baofu, animation_23, 1);
    delayClear();
    delayWait(30);
    ref_215 = bustupLoad(bustup_2d);
    bustupWait(ref_215);
    ref_217 = bustupAlloc(ref_215, left, rgb(0,0,0));
    bustupFade(ref_217, rgb(128,0,0), 30);
    ref_219 = dialogAlloc();
    ref_21a = msgShow(msg_20);
/***************************************
[color(yellow)]パオフゥ[color(white)]
[tab]へへ…そうこなくちゃな…
[tab]じゃあ、俺は一度ヤサに戻って、
[tab]竜蔵の動きを追ってみる。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_21a);
    unitAnimationPlay(baofu, animation_0, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(baofu, animation_3, 1);
    ref_221 = msgShow(msg_21);
/***************************************
[color(yellow)]パオフゥ[color(white)]
[tab]お前さんも、一度会社に戻ってみちゃどうだ？
[tab]ずっと空けっぱなしじゃまずかろう。
[tab]後で迎えに行ってやるからよ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_221);
    dialogFree(ref_219);
    ref_225 = bustupFade(ref_217, rgb(0,0,0), 10);
    bustupWait(ref_225);
    bustupFree(ref_217);
    delayClear();
    delayWait(30);
    unitFace(baofu, north);
    unitAnimationPlay(baofu, animation_0, 1);
    unitWait(baofu);
    delayClear();
    delayWait(7);
    unitMove(baofu, 2090, -2900, fade, medium);
    delayClear();
    delayWait(60);
    unitAnimationPlay(maya, animation_1, 1);
    delayClear();
    delayWait(12);
    unitFace(maya, north);
    unitAnimationPlay(maya, animation_0, 1);
    delayClear();
    delayWait(120);
    ref_239 = cameraLookAtUnit(jun, 0, 90);
    delayClear();
    delayWait(45);
    unitAnimationPlay(jun, animation_0, 1);
    wait(ref_239);
    delayClear();
    delayWait(30);
    ref_240 = call(MAYA01);
    ref_241 = bustupLoad(bustup_10e);
    bustupWait(ref_241);
