    bustupFade(ref_1f7, rgb(128,0,0), 30);
    ref_1f9 = dialogAlloc();
    ref_1fa = msgShow(msg_18);
/***************************************
[color(yellow)]パオフゥ[color(white)]
[tab]甘ちゃんどもが…
