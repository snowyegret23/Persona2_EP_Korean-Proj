    mapLoad(kounan, 27, 5);
}

function JUN00()
{
    delayClear();
    delayWait(300);
    unitAnimationPlay(jun, animation_0, 1);
    delayClear();
    delayWait(60);
    unitAnimationPlay(jun, animation_3, 1);
    delayClear();
    delayWait(12);
    unitFace(jun, south);
    unitAnimationPlay(jun, animation_0, 1);
    delayClear();
    delayWait(120);
    unitAnimationPlay(jun, animation_6, 1);
}

function KATUYA00()
{
    unitWait(katsuya);
    unitAnimationPlay(katsuya, animation_1f, 1);
}

function MAYA00()
{
    delayClear();
    delayWait(45);
    unitFace(maya, west);
}

function MAYA01()
{
    delayClear();
    delayWait(210);
    unitAnimationPlay(maya, animation_3, 1);
    delayClear();
    delayWait(12);
    unitFace(maya, west);
    unitAnimationPlay(maya, animation_0, 1);
    delayClear();
    delayWait(12);
    unitAnimationPlay(maya, animation_1, 1);
}

function MAYA02()
{
    delayClear();
    delayWait(45);
    unitAnimationPlay(maya, animation_1, 1);
    delayClear();
    delayWait(12);
    unitFace(maya, east);
    unitAnimationPlay(maya, animation_0, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(maya, animation_3, 1);
}

function SANNIN()
{
    delayClear();
    delayWait(90);
    unitAnimationPlay(katsuya, animation_1, 1);
    delayClear();
    delayWait(12);
    unitFace(katsuya, east);
    unitAnimationPlay(katsuya, animation_0, 1);
    unitAnimationPlay(maya, animation_1, 1);
    delayClear();
    delayWait(12);
    unitFace(maya, south);
    unitAnimationPlay(maya, animation_0, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(maya, animation_3, 1);
}
