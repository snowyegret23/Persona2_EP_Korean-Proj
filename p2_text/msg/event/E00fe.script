function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    cameraSet(north, 1000, 0, 1000);
    ref_3 = spriteLoad(sprite_18);
    wait(ref_3);
    ref_5 = spriteLoad(sprite_1a);
    wait(ref_5);
    ref_7 = spriteLoad(sprite_19);
    wait(ref_7);
    ref_9 = spriteLoad(sprite_11f);
    wait(ref_9);
    ref_b = spriteLoad(sprite_dc);
    wait(ref_b);
    ref_d = spriteLoad(sprite_dd);
    wait(ref_d);
    unitSpawn(tatsuya, sprite_18, 850, 0, 825, north, none);
    unitAnimationPlay(tatsuya, animation_4, 1);
    unitSpawn(enemy1, sprite_dc, 1250, 0, 1000, west, none);
    unitSpawn(enemy2, sprite_dc, 1300, 0, 925, east, none);
    unitAnimationPlay(enemy2, animation_24, 1);
    ref_14 = evtbgLoad(evtbg_18);
    wait(ref_14);
    evtbgInit(evtbg_handle_18, evtbg_18, 0, 0, rgb(0,0,0), true);
    ref_17 = evtbgFade(evtbg_handle_18, rgb(128,128,128), 1, false);
    wait(ref_17);
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    screenFadeInner(rgb(0,0,0), 4, true);
    screenFadeOuter(rgb(0,0,0), 4, true);
    screenEffectUnknown();
    screenFadeWait(inner);
    screenFadeWait(outer);
    sndMusicPlay(sound_406b, 90);
    ref_20 = dialogAlloc();
    ref_21 = msgShow(msg_0);
/***************************************
フェンスの前で、警備員たちが
こちらに背中を向け煙草をふかしていた。
勤務態度の悪い奴らだ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_21);
    dialogFree(ref_20);
    unitAnimationPlay(enemy2, animation_c, 1);
    unitWait(enemy2);
    ref_27 = dialogAlloc();
    ref_28 = msgShow(msg_1);
/***************************************
[color(yellow)]若い警備員[color(white)]
[tab]侵入者ってな、本当なんですか？
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_28);
    dialogFree(ref_27);
    ref_2c = dialogAlloc();
    ref_2d = msgShow(msg_2);
/***************************************
[color(yellow)]中年の警備員[color(white)]
[tab]ああ、若い女二人に男が三人って話だ。
[tab]放っとけとよ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_2d);
    dialogFree(ref_2c);
    unitAnimationPlay(enemy2, animation_0, 1);
    unitWait(enemy2);
    ref_33 = dialogAlloc();
    ref_34 = msgShow(msg_3);
/***************************************
舞耶姉たちのことだろう。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_34);
    dialogFree(ref_33);
    unitAnimationPlay(enemy2, animation_19, 1);
    unitWait(enemy2);
    ref_3a = dialogAlloc();
    ref_3b = msgShow(msg_4);
/***************************************
[color(yellow)]若い警備員[color(white)]
[tab]なんでまた。
[tab]ここでやってることが外に知れたら、まずいでしょ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_3b);
    dialogFree(ref_3a);
    unitAnimationPlay(enemy1, animation_1, 1);
    unitWait(enemy1);
    ref_41 = dialogAlloc();
    ref_42 = msgShow(msg_5);
/***************************************
[color(yellow)]中年の警備員[color(white)]
[tab]知るかよ。
[tab]神条様のご命令、ってな。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_42);
    dialogFree(ref_41);
    unitAnimationPlay(enemy2, animation_0, 1);
    unitWait(enemy2);
    ref_48 = dialogAlloc();
    ref_49 = msgShow(msg_6);
/***************************************
神条…[tab]初めて聞く名だが、
こいつらよりは厄介な奴に違いない。
[wait][clear]
***************************************/
    wait(ref_49);
    ref_4b = msgShow(msg_7);
/***************************************
承知の上で放置しておくのは、罠に嵌める自信があるか、
放っておいても支障がないということだ。
そういう手合は性質が悪い。
[wait][clear]
***************************************/
    wait(ref_4b);
    ref_4d = msgShow(msg_8);
/***************************************
何にせよ急いだ方がよさそうだ。
年上の方が、腰にぶら下げている鍵束を頂いていこう。
そいつはまた煙草を取り出し火を付けようとしていた。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_4d);
    dialogFree(ref_48);
    unitAnimationPlay(enemy1, animation_c, 1);
    unitWait(enemy1);
    ref_53 = dialogAlloc();
    ref_54 = msgShow(msg_9);
/***************************************
[color(yellow)]中年の警備員[color(white)]
[tab]チッ、ガスが切れやがった。
[tab]おい、火貸してくれ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_54);
    dialogFree(ref_53);
    unitAnimationPlay(enemy1, animation_0, 1);
    unitWait(enemy1);
    unitAnimationPlay(enemy2, animation_20, 1);
    ref_5b = dialogAlloc();
    ref_5c = msgShow(msg_10);
/***************************************
若い方が、頷いてあちこちポケットをまさぐり始めた。
グズな奴だ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_5c);
    dialogFree(ref_5b);
    unitAnimationPlay(enemy1, animation_19, 1);
    unitWait(enemy1);
    ref_62 = dialogAlloc();
    ref_63 = msgShow(msg_11);
/***************************************
[color(yellow)]中年の警備員[color(white)]
[tab]おい、まだかよ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_63);
    dialogFree(ref_62);
    unitAnimationPlay(enemy2, animation_3, 1);
    unitWait(enemy2);
    delayClear();
    delayWait(5);
    unitFace(enemy2, south);
    unitAnimationPlay(enemy2, animation_0, 1);
    unitWait(enemy2);
    delayClear();
    delayWait(5);
    unitAnimationPlay(enemy2, animation_20, 1);
    ref_71 = dialogAlloc();
    ref_72 = msgShow(msg_12);
/***************************************
[color(yellow)]若い警備員[color(white)]
[tab]おかしいな…
[tab]さっき火つけましたよね？
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_72);
    dialogFree(ref_71);
    unitAnimationPlay(enemy1, animation_0, 1);
    unitWait(enemy1);
    unitAnimationPlay(tatsuya, animation_0, 1);
    unitFace(tatsuya, west);
    unitMove(tatsuya, 950, 770, face_north, medium);
    unitWait(tatsuya);
    unitMove(tatsuya, 1150, 1000, face_west, medium);
    unitWait(tatsuya);
    unitSpriteClear(tatsuya);
    unitSpriteSet(tatsuya, sprite_19);
    unitAnimationPlay(tatsuya, animation_15, 1);
    unitWait(tatsuya);
    ref_82 = sndMusicPlay(sound_330f, 90);
    wait(ref_82);
    unitAnimationHold(tatsuya, animation_16, -1);
    sndMusicPlay(sound_3311, 90);
    ref_86 = dialogAlloc();
    ref_87 = msgShow(msg_13);
/***************************************
俺が後ろから左手を伸ばしてジッポの火を差し出すと、
年上は礼を言って火をつけ、美味そうに煙を吐き出した。
手元が寂しくて自分で買ったものだが、
思わぬ役に立った。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_87);
    dialogFree(ref_86);
    unitFace(enemy1, north);
    ref_8c = dialogAlloc();
    ref_8d = msgShow(msg_14);
/***************************************
[color(yellow)]中年の警備員[color(white)]
[tab]おお、悪いな。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_8d);
    dialogFree(ref_8c);
    unitAnimationHold(enemy1, animation_1b, -1);
    unitAnimationPlay(enemy2, animation_3, 1);
    unitWait(enemy2);
    ref_94 = dialogAlloc();
    ref_95 = msgShow(msg_15);
/***************************************
[color(yellow)]若い警備員[color(white)]
[tab]あ、あった。
[tab]はい、どう…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_95);
    dialogFree(ref_94);
    unitAnimationPlay(enemy2, animation_4, 1);
    unitWait(enemy2);
    delayClear();
    delayWait(60);
    unitAnimationPlay(enemy2, animation_0, 1);
    unitFace(enemy2, east);
    unitAnimationHold(enemy2, animation_1c, -1);
    delayClear();
    delayWait(30);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 8, false);
    screenFadeOuter(rgb(255,255,255), 8, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    sndMusicPlay(sound_312e, 127);
    unitSpriteClear(tatsuya);
    unitSpriteSet(tatsuya, sprite_1a);
    unitSpawn(tatsuya, sprite_1a, 1250, 0, 921, south, none);
    unitAnimationPlay(tatsuya, animation_0, 1);
    unitSpriteClear(enemy1);
    unitSpriteSet(enemy1, sprite_dd);
    unitSpawn(enemy1, sprite_dc, 1225, 0, 1025, south, none);
    unitAnimationPlay(enemy1, animation_c, 1);
    unitSpriteClear(enemy2);
    unitSpriteSet(enemy2, sprite_dd);
    unitSpawn(enemy2, sprite_dc, 1320, 0, 925, east, none);
    unitAnimationPlay(enemy2, animation_d, 1);
    unitFace(enemy2, north);
    delayClear();
    delayWait(45);
    ref_b8 = dialogAlloc();
    ref_b9 = msgShow(msg_16);
/***************************************
ようやくライターを見つけた若い方は、
横を向き俺に気づいて目を丸くした。
手早く年上の顔面に左肘を食らわせ壁とサンドイッチにし
若い方の鳩尾にも刀の柄を叩き込んだ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_b9);
    dialogFree(ref_b8);
    sndMusicPlay(sound_31f2, 127);
    ref_be = dialogAlloc();
    ref_bf = msgShow(msg_17);
/***************************************
[color(yellow)]若い警備員[color(white)]
[tab]ぐお…
[tab]お…[tab]おっ…！
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_bf);
    dialogFree(ref_be);
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 8, true);
    screenFadeOuter(rgb(0,0,0), 8, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    ref_c8 = dialogAlloc();
    ref_c9 = msgShow(msg_18);
/***************************************
目の端で、年上が白目を剥いて崩れ落ちていく。
手加減した若い方は、身を屈めて空気を求め喘いでいた。
そいつの襟首を掴んでフェンスに叩きつけると、
鞘からわずかに抜いた刀の刃を首筋に押し付けた。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_c9);
    dialogFree(ref_c8);
    ref_cd = bustupLoad(bustup_b);
    bustupWait(ref_cd);
    ref_cf = bustupAlloc(ref_cd, left, rgb(0,0,0));
    bustupFade(ref_cf, rgb(128,0,0), 30);
    ref_d1 = dialogAlloc();
    ref_d2 = msgShow(msg_19);
/***************************************
[color(yellow)][tatsuya][color(white)]
[tab]宮代[tab]詩織、髪の長い女の警官を拉致したはずだ。
[tab]どこにいる。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_d2);
    dialogFree(ref_d1);
    ref_d6 = bustupFade(ref_cf, rgb(0,0,0), 10);
    bustupWait(ref_d6);
    bustupFree(ref_cf);
    ref_d9 = dialogAlloc();
    ref_da = msgShow(msg_20);
/***************************************
[color(yellow)]若い警備員[color(white)]
[tab]よ…[tab]４階だ…
[tab]研究…[tab]室…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_da);
    dialogFree(ref_d9);
    ref_de = bustupLoad(bustup_b);
    bustupWait(ref_de);
    ref_e0 = bustupAlloc(ref_de, left, rgb(0,0,0));
    bustupFade(ref_e0, rgb(128,0,0), 30);
    ref_e2 = dialogAlloc();
    ref_e3 = msgShow(msg_21);
/***************************************
[color(yellow)][tatsuya][color(white)]
[tab]エレベーターには、３階までしか表示がなかった。
[tab]どうやって４階に行く。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_e3);
    dialogFree(ref_e2);
    ref_e7 = bustupFade(ref_e0, rgb(0,0,0), 10);
    bustupWait(ref_e7);
    bustupFree(ref_e0);
    ref_ea = dialogAlloc();
    ref_eb = msgShow(msg_22);
/***************************************
[color(yellow)]若い警備員[color(white)]
[tab]エレベーターのボタンを押す順番が…
[tab]セキュリティコードになってるって話だ…
[tab]俺は…[tab]知らん…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_eb);
    dialogFree(ref_ea);
    ref_ef = bustupLoad(bustup_b);
    bustupWait(ref_ef);
    ref_f1 = bustupAlloc(ref_ef, left, rgb(0,0,0));
    bustupFade(ref_f1, rgb(128,0,0), 30);
    ref_f3 = dialogAlloc();
    ref_f4 = msgShow(msg_23);
/***************************************
[color(yellow)][tatsuya][color(white)]
[tab]誰が知ってる。
[tab]そいつか？
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_f4);
    dialogFree(ref_f3);
    ref_f8 = bustupFade(ref_f1, rgb(0,0,0), 10);
    bustupWait(ref_f8);
    bustupFree(ref_f1);
    ref_fb = dialogAlloc();
    ref_fc = msgShow(msg_24);
/***************************************
[color(yellow)]若い警備員[color(white)]
[tab]このフェンスの…
[tab]向こうの部屋に…
[tab]警備担当の管理者が…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_fc);
    dialogFree(ref_fb);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 4, false);
    screenFadeOuter(rgb(255,255,255), 4, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    sndMusicPlay(sound_3136, 127);
    delayClear();
    delayWait(60);
    sndMusicPlay(sound_31f2, 127);
    delayClear();
    delayWait(90);
    ref_10c = dialogAlloc();
    ref_10d = msgShow(msg_25);
/***************************************
フェンスの向こうには、エレベーターで行くしか
なさそうだ。
[wait][clear]
***************************************/
    wait(ref_10d);
    ref_10f = msgShow(msg_26);
/***************************************
俺は、年上がぶら下げていた鍵束に
エレベーターの配電盤の鍵があることを聞き出すと、
今度は鳩尾に膝をプレゼントして寝かせてやった。
[wait][clear]
***************************************/
    wait(ref_10f);
    ref_111 = msgShow(msg_27);
/***************************************
こいつらには、舞耶姉たちのことを聞くだけ無駄だろう。
伸びている年上から火の礼に鍵束を頂戴し、
その場を離れた。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_111);
    dialogFree(ref_10c);
    bitClear(bit_c79);
    bitSet(bit_c7a);
    evtbgFree(evtbg_handle_18);
    unitDespawn(tatsuya, none);
    unitDespawn(enemy1, none);
    unitDespawn(enemy2, none);
    dngLoad(science_lab2, 1, 49, 15, 0);
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 4, true);
    screenFadeOuter(rgb(0,0,0), 4, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
    sndMusicPlay(sound_406b, 90);
}
