    delayWait(60);
    unitAnimationStop(enemy1);
    unitAnimationStop(enemy2);
    unitAnimationPlay(enemy1, animation_17, 1);
    unitAnimationPlay(enemy2, animation_17, 1);
    delayClear();
    delayWait(60);
    sndMusicPlay(sound_3162, 127);
    encounterLoad(encounter_6);
}

function NANJOMOVE()
{
    unitSpawn(nanjo, sprite_1f, 480, 0, -1350, west, fade);
    unitMove(nanjo, 500, -1050, face_south, fast);
    unitWait(nanjo);
    unitAnimationPlay(nanjo, animation_28, 254);
}

function MAYAMOVE()
{
    unitSpawn(maya, sprite_0, 480, 0, -1350, west, fade);
    unitMove(maya, 400, -1120, face_south, fast);
    unitWait(maya);
    unitFace(maya, east);
    unitAnimationPlay(maya, animation_28, 254);
}

function URARAMOVE()
{
    unitSpawn(ulala, sprite_6, 480, 0, -1350, west, fade);
    unitMove(ulala, 440, -1250, face_south, fast);
    unitWait(ulala);
    unitMove(ulala, 220, -1250, face_east, fast);
    unitWait(ulala);
    unitMove(ulala, 220, -1050, face_south, fast);
    unitWait(ulala);
    unitAnimationPlay(ulala, animation_28, 254);
}

function PAOFUMOVE()
{
    unitSpawn(baofu, sprite_13, 480, 0, -1350, west, fade);
    unitMove(baofu, 440, -1250, face_south, fast);
    unitWait(baofu);
    unitMove(baofu, 100, -1250, face_east, fast);
    unitWait(baofu);
    unitMove(baofu, 100, -1130, face_south, fast);
    unitWait(baofu);
    unitFace(baofu, east);
    unitAnimationPlay(baofu, animation_28, 254);
}

function KATUYAMOVE()
{
    unitSpawn(katsuya, sprite_d, 480, 0, -1350, west, fade);
    unitMove(katsuya, 440, -1250, face_south, fast);
    unitWait(katsuya);
    unitMove(katsuya, 220, -1250, face_east, fast);
    unitWait(katsuya);
    unitAnimationPlay(katsuya, animation_28, 254);
}
