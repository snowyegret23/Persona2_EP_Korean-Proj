    ref_60 = msgShow(msg_5);
/***************************************
[color(yellow)]栄吉[color(white)]
[tab]なんだ？
[tab]なんでも言ってくれよ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_60);
    dialogFree(ref_5f);
    ref_64 = bustupFade(ref_5d, rgb(0,0,0), 10);
