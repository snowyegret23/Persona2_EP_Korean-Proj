function START()
{
    sndMusicPlay(sound_4064, 127);
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    cameraSet(northeast, 700, 0, -1150);
    ref_4 = spriteLoad(sprite_18);
    wait(ref_4);
    ref_6 = spriteLoad(sprite_27);
    wait(ref_6);
    ref_8 = spriteLoad(sprite_12e);
    wait(ref_8);
    ref_a = spriteLoad(sprite_120);
    wait(ref_a);
    unitSpawn(tatsuya, sprite_18, 700, 0, -1150, south, none);
