    ref_88 = bustupAlloc(ref_86, right, rgb(0,0,0));
    bustupFade(ref_88, rgb(128,0,0), 30);
    ref_8a = dialogAlloc();
    ref_8b = msgShow(msg_7);
/***************************************
[color(yellow)]栄吉[color(white)]
[tab]…訳ありみてぇだな。
[tab]わかった、何も言わねぇよ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_8b);
