    sndMusicPlay(sound_316a, 127);
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    screenEffectUnknown();
    screenFadeWait(inner);
    screenFadeWait(outer);
    delayClear();
    delayWait(60);
    cameraMoveTo(550, 0, -800, 60);
    unitFace(tatsuya, south);
    unitMove(tatsuya, 700, -950, face_north, medium);
    unitAnimationPlay(enemy1, animation_1, 1);
    unitAnimationPlay(eikichi, animation_0, 1);
    unitWait(eikichi);
    delayClear();
    delayWait(5);
    unitAnimationPlay(eikichi, animation_1, 1);
    unitWait(eikichi);
    delayClear();
    delayWait(5);
    unitFace(eikichi, north);
    unitAnimationPlay(eikichi, animation_0, 1);
    unitWait(eikichi);
    unitWait(tatsuya);
    unitMove(tatsuya, 600, -950, face_south, medium);
    unitWait(tatsuya);
    ref_2d = dialogAlloc();
    ref_2e = msgShow(msg_0);
/***************************************
詩織さんを置いてきた研究室に戻ると、
栄吉と小月がいた。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_2e);
    dialogFree(ref_2d);
    unitAnimationPlay(eikichi, animation_6, 1);
    unitWait(eikichi);
    ref_34 = bustupLoad(bustup_118);
