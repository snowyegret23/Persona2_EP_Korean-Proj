    bustupFade(ref_36, rgb(128,0,0), 30);
    ref_38 = dialogAlloc();
    ref_39 = msgShow(msg_1);
/***************************************
[color(yellow)]栄吉[color(white)]
[tab]すまねぇ、[suou]。
[tab]また借りができちまったな。
[wait][clear]
***************************************/
    wait(ref_39);
    ref_3b = msgShow(msg_2);
/***************************************
[color(yellow)]栄吉[color(white)]
[tab]駐車場で、さっきのグラサン野郎に捕まっちまって…
[tab]俺はダメな奴だ。
[sync][wait][clear]
***************************************/
