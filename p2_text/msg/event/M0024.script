function KAOHANTEI()
{
    bitGet(var_0, MBIT_ROSAHENNISHU_2);
    bne(var_0, 0, label_637);
    ref_632 = bustupLoad(bustup_f8);
    bustupWait(ref_632);
    ref_634 = bustupAlloc(ref_632, right, rgb(0,0,0));
    bustupFade(ref_634, rgb(128,0,0), 30);
    b(label_63d);
  label_637:
    bne(var_0, 1, label_63d);
    ref_638 = bustupLoad(bustup_11d);
    bustupWait(ref_638);
    ref_63a = bustupAlloc(ref_638, right, rgb(0,0,0));
    bustupFade(ref_63a, rgb(128,0,0), 30);
    b(label_63d);
  label_63d:
}

function DELKAOHANTEI()
{
    bitGet(var_0, MBIT_ROSAHENNISHU_2);
    bne(var_0, 0, label_644);
    ref_640 = bustupFade(ref_634, rgb(0,0,0), 10);
    bustupWait(ref_640);
    bustupFree(ref_634);
    b(label_649);
  label_644:
    bne(var_0, 1, label_649);
    ref_645 = bustupFade(ref_63a, rgb(0,0,0), 10);
    bustupWait(ref_645);
    bustupFree(ref_63a);
    b(label_649);
  label_649:
}

function KOUISITU2()
{
    controlDisable();
    unitFacePlayer(shopkeeper);
    ref_64c = call(KAOHANTEI);
    wait(ref_64c);
    ref_64e = dialogAlloc();
    ref_64f = msgShow(msg_99);
/***************************************
[color(yellow)]マヌカン[color(white)]
[tab]ちょっと。[delay(10)]
[tab]そこ更衣室なのよ。[delay(10)]
[tab]用もなく入らないでちょうだい。[wait][clear]
***************************************/
    wait(ref_64f);
    unitAnimationPlay(shopkeeper, animation_0, 1);
    dialogFree(ref_64e);
    ref_653 = call(DELKAOHANTEI);
    wait(ref_653);
    unitRestoreFacing(shopkeeper);
    controlEnable();
}

function KOUISITU()
{
    controlDisable();
    ref_659 = cameraRotateTo(7, 40);
    wait(ref_659);
    unitFacePlayer(shopkeeper);
    ref_65c = call(KAOHANTEI);
    wait(ref_65c);
    ref_65e = dialogAlloc();
    ref_65f = msgShow(msg_100);
/***************************************
[color(yellow)]マヌカン[color(white)]
[tab]ちょっと。[delay(10)]
[tab]そこ更衣室なのよ。[delay(10)]
[tab]用もなく入らないでちょうだい。[wait][clear]
***************************************/
    unitAnimationPlay(shopkeeper, animation_0, 1);
    unitWait(shopkeeper);
    delayClear();
    delayWait(3);
    unitAnimationPlay(shopkeeper, animation_1, 1);
    unitWait(shopkeeper);
    delayClear();
    delayWait(3);
    unitAnimationPlay(shopkeeper, animation_2, 1);
    unitWait(shopkeeper);
    delayClear();
    delayWait(6);
    unitAnimationPlay(shopkeeper, animation_1, 1);
    unitWait(shopkeeper);
    delayClear();
    delayWait(3);
    unitAnimationPlay(shopkeeper, animation_0, 1);
    unitWait(shopkeeper);
    delayClear();
    delayWait(3);
    unitAnimationPlay(shopkeeper, animation_3, 1);
    unitWait(shopkeeper);
    delayClear();
    delayWait(3);
    unitAnimationPlay(shopkeeper, animation_4, 1);
    unitWait(shopkeeper);
    delayClear();
    delayWait(6);
    unitAnimationPlay(shopkeeper, animation_3, 1);
    unitWait(shopkeeper);
    delayClear();
    delayWait(3);
    unitAnimationPlay(shopkeeper, animation_0, 1);
    unitWait(shopkeeper);
    delayClear();
    delayWait(10);
    unitAnimationPlay(shopkeeper, animation_19, 1);
    wait(ref_65f);
    dialogFree(ref_65e);
    unitWait(shopkeeper);
    unitAnimationPlay(shopkeeper, animation_0, 1);
    unitWait(shopkeeper);
    ref_68a = call(DELKAOHANTEI);
    wait(ref_68a);
    unitRestoreFacing(shopkeeper);
    controlEnable();
}

function DOORBOX()
{
    controlDisable();
    sndMusicPlay(sound_3075, 127);
    objAnimRotate(obj_1e, 0, -70, 0, 30, 0);
    objAnimRotate(obj_2c, 0, 70, 0, 30, 0);
    objAnimWait(obj_1e);
    objAnimWait(obj_2c);
    call(GOOUT);
}

function GOOUT()
{
    bitClear(MBIT_EXITBIT);
    mapLoad(rengedai, 0, 0);
}

function warp1()
{
    call(DOORBOX);
}

function HA_SHOP_EXPLAIN_0()
{
    ref_69c = dialogAlloc();
    ref_69d = msgShow(msg_101);
/***************************************
[color(yellow)]マヌカン[color(white)]
[tab]「売買」についてですわね？
[wait][clear][color(yellow)]マヌカン[color(white)]
[tab]まずは、購入について説明しますわね。
[tab]当店で「防具を買う」を選びますと
[tab]素敵な防具を購入することができますわ。
[wait][clear][color(yellow)]マヌカン[color(white)]
[tab]防具は装備できる対象が決まっている物もあるわ。
[tab]よく確認して買っていってちょうだいね。
[wait][clear][color(yellow)]マヌカン[color(white)]
[tab]つぎは、売却の説明ね。
[tab]「アイテムを売る」を選択すると種類の選択になるわ。
[tab]売りたいものの種類を選び、物を決定してちょうだい。
[wait][clear][color(yellow)]マヌカン[color(white)]
[tab]買い取り価格は元値の約半額くらいで、
[tab]装備中の物と一部の物は売却することはできないわよ。
[tab]こんなところかしら。
[wait][clear]
***************************************/
    wait(ref_69d);
    dialogFree(ref_69c);
}

