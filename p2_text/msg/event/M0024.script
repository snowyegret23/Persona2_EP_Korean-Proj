    bne(var_0, 0, label_b);
    b(label_1a);
  label_b:
    bne(var_0, 1, label_1a);
    bitGet(var_0, MBIT_ROSAHENNISHU);
    bitGet(var_1, MBIT_ROSAHENNISHU_2);
