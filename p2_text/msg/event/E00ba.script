function START()
{
    levelFootstepSet(sfx_10);
    bitGet(var_0, EBIT_E00BC);
    bne(var_0, 0, label_7);
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), add);
    call(KYOSEI);
    b(label_c);
  label_7:
    bne(var_0, 1, label_c);
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    call(FREE00);
    b(label_c);
  label_c:
}

