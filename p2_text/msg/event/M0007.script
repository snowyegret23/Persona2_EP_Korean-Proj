function NOITEM()
{
    unitFacePlayer(shopkeeper);
    ref_4b1 = bustupLoad(bustup_fd);
    bustupWait(ref_4b1);
    ref_4b3 = bustupAlloc(ref_4b1, right, rgb(0,0,0));
    bustupFade(ref_4b3, rgb(128,0,0), 30);
    ref_4b5 = dialogAlloc();
    ref_4b6 = msgShow(msg_67);
/***************************************
[color(yellow)]オバサン・六女[color(white)]
[tab]売れる物、持ってないじゃないの～。[wait][clear]
***************************************/
    wait(ref_4b6);
    dialogFree(ref_4b5);
    ref_4b9 = bustupFade(ref_4b3, rgb(0,0,0), 10);
    bustupWait(ref_4b9);
    bustupFree(ref_4b3);
    li(var_5, 20);
}

function DECIDE_BUY()
{
    msgVar_Number(msgvar_0, var_6);
    unitFacePlayer(shopkeeper);
    ref_4c0 = bustupLoad(bustup_fd);
    bustupWait(ref_4c0);
    ref_4c2 = bustupAlloc(ref_4c0, left, rgb(0,0,0));
    bustupFade(ref_4c2, rgb(128,0,0), 30);
    ref_4c4 = dialogAlloc();
    choiceSetResult(1);
    ref_4c6 = msgShow(msg_68);
/***************************************
[color(yellow)]オバサン・六女[color(white)]
[tab]全部で、[var(msg_var_0)]円になるけど
[tab]いいかしらぁ～？
[choice(2)]はい
いいえ
[end_choice][clear]
***************************************/
    wait(ref_4c6);
    choiceGetResult(var_7);
    bne(var_7, 0, label_4cd);
    sndMusicPlay(sound_3037, 127);
    li(var_7, 1);
    b(label_4d0);
  label_4cd:
    bne(var_7, 1, label_4d0);
    li(var_7, 0);
    b(label_4d0);
  label_4d0:
    wait(ref_4c6);
    dialogFree(ref_4c4);
    ref_4d2 = bustupFade(ref_4c2, rgb(0,0,0), 10);
    bustupWait(ref_4d2);
    bustupFree(ref_4c2);
    li(var_5, 20);
}

