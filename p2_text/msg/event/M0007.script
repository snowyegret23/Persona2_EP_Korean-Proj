[color(yellow)]若い男[color(white)]
[tab]ＴＶ見たかい？
[tab]地下にアメノトリフネって遺跡があるらしいぜ！
[tab]なんでも、空まで飛ぶんだってさ！
[wait][clear]
***************************************/
    unitAnimationPlay(npc2, animation_24, 1);
    wait(ref_48d);
    unitAnimationPlay(npc2, animation_0, 1);
    dialogFree(ref_48c);
    unitRestoreFacing(npc2);
    b(label_4ae);
  label_494:
    unitFacePlayer(npc2);
    ref_495 = dialogAlloc();
    ref_496 = msgShow(msg_64);
/***************************************
[color(yellow)]若い男[color(white)]
[tab]アンタ知ってる？
[tab]トリフネさえ飛んじまえば、
[tab]俺達は世界滅亡に巻き込まれずに済むんだぜ！
[wait][clear]
***************************************/
    unitAnimationPlay(npc2, animation_24, 1);
    wait(ref_496);
    unitAnimationPlay(npc2, animation_0, 1);
    dialogFree(ref_495);
    unitRestoreFacing(npc2);
