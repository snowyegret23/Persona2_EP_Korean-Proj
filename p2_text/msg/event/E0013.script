function URARA()
{
    controlDisable();
    unitFacePlayer(ulala);
    ref_1cd = bustupLoad(bustup_1b);
    bustupWait(ref_1cd);
    ref_1cf = bustupAlloc(ref_1cd, left, rgb(0,0,0));
    bustupFade(ref_1cf, rgb(128,0,0), 30);
    ref_1d1 = dialogAlloc();
    ref_1d2 = msgShow(msg_16);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]ちょ…何このでっかい眼…気色ワル！
[tab]ニャル…なんとかって書いてあるけど…
[tab]読めんわこんな字…
[sync][wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2d, 1);
    delayClear();
    delayWait(45);
    unitAnimationPlay(ulala, animation_1d, 1);
    unitWait(ulala);
    delayClear();
    delayWait(15);
    sync();
    wait(ref_1d2);
    dialogFree(ref_1d1);
    ref_1dd = bustupFade(ref_1cf, rgb(0,0,0), 10);
    bustupWait(ref_1dd);
    bustupFree(ref_1cf);
    unitAnimationPlay(ulala, animation_a, 1);
    unitRestoreFacing(ulala);
    controlEnable();
}

