}

function ERI_IDO()
{
    unitMove(elly, 1400, -1600, face_north, slow);
    unitWait(elly);
    unitAnimationPlay(elly, animation_a, 1);
}

function MAKI_IDO()
{
    unitMove(maki, 1200, -1450, face_north, slow);
    unitWait(maki);
}

function MATUOKA_TOJO()
