function NANJO_IDO()
{
    unitFace_2(nanjo, north);
    unitMove(nanjo, 1230, -1780, face_north, slow);
    unitWait(nanjo);
    unitAnimationPlay(nanjo, animation_a, 1);
}

function HERO_IDO()
{
    unitMove(naoya, 1370, -1680, face_north, slow);
    unitWait(naoya);
