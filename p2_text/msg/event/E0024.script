}

function PAOFU_ODOROKU()
{
    unitFace_2(baofu, west);
    unitAnimationPlay(baofu, animation_1d, 1);
}

function NPC_ODOROKU()
{
    unitAnimationHold(npc1, animation_10, -1);
    unitAnimationHold(npc2, animation_10, -1);
    unitFace_2(unit_58, west);
    unitAnimationHold(unit_58, animation_10, -1);
}

