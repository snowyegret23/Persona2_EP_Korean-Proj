function TOBIRA()
{
    objAnimTranslate(obj_1b, 5, 0, 0, 10);
    objAnimTranslate(obj_1c, -5, 0, 0, 10);
    objAnimWait(obj_1b);
    objAnimWait(obj_1c);
    delayClear();
    delayWait(10);
    objAnimTranslate(obj_1b, -5, 0, 0, 10);
    objAnimTranslate(obj_1c, 5, 0, 0, 10);
    objAnimWait(obj_1b);
    objAnimWait(obj_1c);
    delayClear();
    delayWait(10);
    objAnimTranslate(obj_1b, 5, 0, 0, 10);
    objAnimTranslate(obj_1c, -5, 0, 0, 10);
    objAnimWait(obj_1b);
    objAnimWait(obj_1c);
    delayClear();
    delayWait(10);
    objAnimTranslate(obj_1b, -5, 0, 0, 10);
    objAnimTranslate(obj_1c, 5, 0, 0, 10);
    objAnimWait(obj_1b);
    objAnimWait(obj_1c);
    delayClear();
    delayWait(10);
    objAnimTranslate(obj_1b, 200, 0, 0, 30);
    objAnimTranslate(obj_1c, -200, 0, 0, 30);
    objAnimWait(obj_1b);
    objAnimWait(obj_1c);
}

