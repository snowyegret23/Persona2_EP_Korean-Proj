function ENEMY1MOVE()
{
  label_171:
    unitAnimationPlay(enemy1, animation_0, 1);
    delayClear();
    delayWait(15);
    unitAnimationPlay(enemy1, animation_1, 1);
    delayClear();
    delayWait(15);
    unitAnimationPlay(enemy1, animation_0, 1);
    delayClear();
    delayWait(15);
    unitAnimationPlay(enemy1, animation_1, 1);
    delayClear();
    delayWait(15);
    unitAnimationPlay(enemy1, animation_0, 1);
    b(label_171);
}

