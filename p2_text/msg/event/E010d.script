function START()
{
    sndMusicPlay(sound_301e, 127);
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    cameraSet(south, 800, 0, -800);
    objAnimRotate(obj_a, 0, 360, 0, 1660, 1);
    objAnimRotate(obj_c, 0, 360, 0, 3200, 1);
    objAnimRotate(obj_b, 0, -360, 0, 2000, 1);
    objAnimRotate(obj_d, 0, -360, 0, 4000, 1);
    ref_8 = spriteLoad(sprite_18);
    wait(ref_8);
    ref_a = spriteLoad(sprite_0);
    wait(ref_a);
    ref_c = spriteLoad(sprite_6);
    wait(ref_c);
    ref_e = spriteLoad(sprite_d);
    wait(ref_e);
    ref_10 = spriteLoad(sprite_13);
    wait(ref_10);
    ref_12 = spriteLoad(sprite_12c);
    wait(ref_12);
    ref_14 = spriteLoad(sprite_1a);
    wait(ref_14);
    ref_16 = spriteLoad(sprite_3);
    wait(ref_16);
    ref_18 = spriteLoad(sprite_8);
    wait(ref_18);
    ref_1a = spriteLoad(sprite_f);
    wait(ref_1a);
    ref_1c = spriteLoad(sprite_15);
    wait(ref_1c);
    unitSpawn(tatsuya, sprite_18, 570, 0, -600, west, none);
    unitSpawn(maya, sprite_0, 640, 0, -540, west, none);
    unitAnimationPlay(maya, animation_a, 1);
    unitSpawn(ulala, sprite_6, 950, 0, -1050, east, none);
    unitAnimationPlay(ulala, animation_a, 1);
    unitSpawn(katsuya, sprite_d, 650, 0, -1050, south, none);
    unitSpawn(baofu, sprite_13, 950, 0, -550, north, none);
    unitAnimationPlay(baofu, animation_a, 1);
    unitSpawn(unit_58, sprite_12c, 800, 0, -800, east, none);
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    screenEffectUnknown();
    screenFadeWait(inner);
    screenFadeWait(outer);
    delayClear();
    delayWait(60);
    ref_2f = bustupLoad(bustup_139);
    bustupWait(ref_2f);
    ref_31 = bustupAlloc(ref_2f, right, rgb(0,0,0));
    bustupFade(ref_31, rgb(128,0,0), 30);
    ref_33 = dialogAlloc();
    ref_34 = msgShow(msg_0);
/***************************************
[color(yellow)]猫中将ズーラ[color(white)]
[tab]よし。
[tab]ではさっそく、最初の難関に立ち向かうがいい。
[tab]私の尻尾を見ろ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_34);
    dialogFree(ref_33);
    ref_38 = bustupFade(ref_31, rgb(0,0,0), 10);
    bustupWait(ref_38);
    bustupFree(ref_31);
    ref_3b = dialogAlloc();
    ref_3c = msgShow(msg_1);
/***************************************
[color(green)]ズーラの尻尾の毛が逆立ち、
たわしのように膨らんでいる。[color(white)]
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_3c);
    dialogFree(ref_3b);
    screenShake(3);
    sndMusicPlay(sound_30fb, 90);
    unitAnimationHold(maya, animation_22, -1);
    unitAnimationHold(ulala, animation_22, -1);
    unitAnimationHold(katsuya, animation_21, -1);
    unitAnimationHold(baofu, animation_21, -1);
    unitAnimationHold(tatsuya, animation_21, -1);
    delayClear();
    delayWait(90);
    unitAnimationPlay(maya, animation_f, 1);
    unitAnimationPlay(tatsuya, animation_5, 1);
    delayClear();
    delayWait(10);
    unitAnimationPlay(katsuya, animation_5, 1);
    unitAnimationPlay(baofu, animation_f, 1);
    delayClear();
    delayWait(10);
    unitAnimationPlay(ulala, animation_f, 1);
    ref_52 = bustupLoad(bustup_3);
    bustupWait(ref_52);
    ref_54 = bustupAlloc(ref_52, left, rgb(0,0,0));
    bustupFade(ref_54, rgb(128,0,0), 30);
    ref_56 = dialogAlloc();
    ref_57 = msgShow(msg_2);
/***************************************
[color(yellow)]舞耶[color(white)]
[tab]…！
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_57);
    dialogFree(ref_56);
    ref_5b = bustupFade(ref_54, rgb(0,0,0), 10);
    bustupWait(ref_5b);
    bustupFree(ref_54);
    unitAnimationPlay(tatsuya, animation_1, 1);
    unitWait(tatsuya);
    delayClear();
    delayWait(5);
    unitAnimationPlay(tatsuya, animation_2, 1);
    ref_63 = bustupLoad(bustup_d);
    bustupWait(ref_63);
    ref_65 = bustupAlloc(ref_63, left, rgb(0,0,0));
    bustupFade(ref_65, rgb(128,0,0), 30);
    ref_67 = dialogAlloc();
    ref_68 = msgShow(msg_3);
/***************************************
[color(yellow)][tatsuya][color(white)]
[tab]舞耶姉、下がれ…！
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_68);
    dialogFree(ref_67);
    ref_6c = bustupFade(ref_65, rgb(0,0,0), 10);
    bustupWait(ref_6c);
    bustupFree(ref_65);
    unitAnimationPlay(maya, animation_3, 1);
    unitWait(maya);
    delayClear();
    delayWait(5);
    unitAnimationPlay(maya, animation_4, 1);
    delayClear();
    delayWait(30);
    unitAnimationPlay(tatsuya, animation_5, 1);
    unitWait(tatsuya);
    delayClear();
    delayWait(30);
    unitAnimationPlay(maya, animation_5, 1);
    ref_7b = bustupLoad(bustup_2e);
    bustupWait(ref_7b);
    ref_7d = bustupAlloc(ref_7b, left, rgb(0,0,0));
    bustupFade(ref_7d, rgb(128,0,0), 30);
    ref_7f = dialogAlloc();
    ref_80 = msgShow(msg_4);
/***************************************
[color(yellow)]パオフゥ[color(white)]
[tab]でけぇ…
[tab]何か来やがるぞ！
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_80);
    dialogFree(ref_7f);
    ref_84 = bustupFade(ref_7d, rgb(0,0,0), 10);
    bustupWait(ref_84);
    bustupFree(ref_7d);
    ref_87 = dialogAlloc();
    ref_88 = msgShow(msg_5);
/***************************************
[color(green)]上の方から、空間そのものが
のしかかってくるような気配を感じる。[color(white)]
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_88);
    dialogFree(ref_87);
    ref_8c = bustupLoad(bustup_25);
    bustupWait(ref_8c);
    ref_8e = bustupAlloc(ref_8c, left, rgb(0,0,0));
    bustupFade(ref_8e, rgb(128,0,0), 30);
    ref_90 = dialogAlloc();
    ref_91 = msgShow(msg_6);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]これは…！
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_91);
    dialogFree(ref_90);
    ref_95 = bustupFade(ref_8e, rgb(0,0,0), 10);
    bustupWait(ref_95);
    bustupFree(ref_8e);
    ref_98 = bustupLoad(bustup_139);
    bustupWait(ref_98);
    ref_9a = bustupAlloc(ref_98, right, rgb(0,0,0));
    bustupFade(ref_9a, rgb(128,0,0), 30);
    ref_9c = dialogAlloc();
    ref_9d = msgShow(msg_7);
/***************************************
[color(yellow)]猫中将ズーラ[color(white)]
[tab]窮極の門の守護者、
[tab]全にして一、一にして全なる者の化身、
[tab]ウムル・アト・タウィルに見つかったのだ。
[wait][clear]
***************************************/
    wait(ref_9d);
    unitAnimationPlay(katsuya, animation_0, 1);
    delayClear();
    delayWait(10);
    unitAnimationPlay(maya, animation_0, 1);
    unitAnimationPlay(ulala, animation_a, 1);
    ref_a4 = msgShow(msg_8);
/***************************************
[color(yellow)]猫中将ズーラ[color(white)]
[tab]カーターが通ることは許したが、
[tab]貴様たちを見逃すつもりはないらしい。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_a4);
    dialogFree(ref_9c);
    ref_a8 = bustupFade(ref_9a, rgb(0,0,0), 10);
    bustupWait(ref_a8);
    bustupFree(ref_9a);
    unitAnimationPlay(katsuya, animation_5, 1);
    delayClear();
    delayWait(10);
    unitAnimationPlay(maya, animation_5, 1);
    unitAnimationPlay(ulala, animation_f, 1);
    screenShake(5);
    screenFlash(255, 255, 255);
    delayClear();
    delayWait(30);
    screenFlash(255, 255, 255);
    delayClear();
    delayWait(30);
    screenFlash(255, 255, 255);
    delayClear();
    delayWait(60);
    screenShake(3);
    unitAnimationPlay(ulala, animation_2c, 1);
    ref_bc = bustupLoad(bustup_123);
    bustupWait(ref_bc);
    ref_be = bustupAlloc(ref_bc, left, rgb(0,0,0));
    bustupFade(ref_be, rgb(128,0,0), 30);
    ref_c0 = dialogAlloc();
    ref_c1 = msgShow(msg_9);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]あわわわ…！
[tab]なんか、初っ端から超ヤバそうじゃないよぅ！
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_c1);
    dialogFree(ref_c0);
    ref_c5 = bustupFade(ref_be, rgb(0,0,0), 10);
    bustupWait(ref_c5);
    bustupFree(ref_be);
    unitAnimationPlay(unit_58, animation_1, 1);
    unitWait(unit_58);
    delayClear();
    delayWait(5);
    unitAnimationPlay(unit_58, animation_2, 1);
    unitWait(unit_58);
    delayClear();
    delayWait(5);
    unitFace(unit_58, north);
    unitAnimationPlay(unit_58, animation_3, 1);
    unitWait(unit_58);
    delayClear();
    delayWait(5);
    unitAnimationPlay(unit_58, animation_4, 1);
    unitAnimationPlay(maya, animation_0, 1);
    unitAnimationPlay(katsuya, animation_0, 1);
    ref_d8 = bustupLoad(bustup_139);
    bustupWait(ref_d8);
    ref_da = bustupAlloc(ref_d8, right, rgb(0,0,0));
    bustupFade(ref_da, rgb(128,0,0), 30);
    ref_dc = dialogAlloc();
    ref_dd = msgShow(msg_10);
/***************************************
[color(yellow)]猫中将ズーラ[color(white)]
[tab]当然だ。奴は、世界の境界そのもの。
[tab]目を盗もうとするものはあれど、
[tab]挑もうとするものなどいない。
[wait][clear]
***************************************/
    wait(ref_dd);
    unitAnimationPlay(ulala, animation_0, 1);
    unitAnimationPlay(baofu, animation_a, 1);
    ref_e1 = msgShow(msg_11);
/***************************************
[color(yellow)]猫中将ズーラ[color(white)]
[tab]窮極の門を越えて無意識の世界に至ろうとする者は、
[tab]たいてい奴に何処ともしれない次元に送られ、
[tab]二度と帰ってこない。
[wait][clear]
***************************************/
    wait(ref_e1);
    unitAnimationHold(ulala, animation_21, -1);
    delayClear();
    delayWait(10);
    unitAnimationPlay(tatsuya, animation_0, 1);
    ref_e7 = msgShow(msg_12);
/***************************************
[color(yellow)]猫中将ズーラ[color(white)]
[tab]恐らく、お前たちの何人かはここで死ぬだろう。
[tab]全員かもしれん。
[tab]では、健闘を祈る。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_e7);
    dialogFree(ref_dc);
    ref_eb = bustupFade(ref_da, rgb(0,0,0), 10);
    bustupWait(ref_eb);
    bustupFree(ref_da);
    screenFlash(255, 255, 255);
    sndMusicPlay(sound_32ee, 127);
    unitDespawn(unit_58, none);
    ref_f1 = dialogAlloc();
    ref_f2 = msgShow(msg_13);
/***************************************
[color(green)]ズーラは、跳躍すると消え失せた。[color(white)]
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_f2);
    dialogFree(ref_f1);
    unitAnimationPlay(ulala, animation_29, 1);
    unitWait(ulala);
    delayClear();
    delayWait(60);
    unitSpriteClear(tatsuya);
    unitSpriteSet(tatsuya, sprite_1a);
    sndMusicPlay(sound_32e9, 127);
    delayClear();
    delayWait(15);
    unitSpriteClear(katsuya);
    unitSpriteSet(katsuya, sprite_f);
    sndMusicPlay(sound_32c1, 127);
    unitSpriteClear(baofu);
    unitSpriteSet(baofu, sprite_15);
    unitAnimationHold(baofu, animation_4, -1);
    sndMusicPlay(sound_32e8, 127);
    delayClear();
    delayWait(30);
    unitSpriteClear(maya);
    unitSpriteSet(maya, sprite_3);
    sndMusicPlay(sound_32e7, 127);
    unitSpriteClear(ulala);
    unitSpriteSet(ulala, sprite_8);
    sndMusicPlay(sound_32cc, 127);
    delayClear();
    delayWait(60);
    encounterLoad(encounter_48);
}
