function START()
{
    timerClear();
    bitClear(EBIT_NOSAVE_B);
    bitSet(EBIT_CHUKEITEN2);
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    levelFootstepSet(sfx_1a);
    sndIdGet(var_0);
    bne(var_0, -1, label_9);
    b(label_b);
  label_9:
    sndVolumeFadeTo(var_0, 0, 5);
    b(label_b);
  label_b:
    sndUnkCF(0);
    sndMusicPlay(sound_3159, 60);
    ref_d = spriteLoad(sprite_0);
    wait(ref_d);
    ref_f = spriteLoad(sprite_2);
    wait(ref_f);
    ref_11 = spriteLoad(sprite_1);
    wait(ref_11);
    ref_13 = spriteLoad(sprite_6);
    wait(ref_13);
    ref_15 = spriteLoad(sprite_d);
    wait(ref_15);
    ref_17 = spriteLoad(sprite_13);
    wait(ref_17);
    ref_19 = spriteLoad(sprite_1f);
    wait(ref_19);
    unknownVar1(var_0);
    bne(var_0, 1795, label_22);
    cameraSetNorth(east);
    cameraSet(northeast, 930, 0, -80);
    playerInit(north);
    controlDisable();
    b(label_2d);
  label_22:
    bne(var_0, 6914, label_28);
    cameraSetNorth(east);
    cameraSet(northeast, 980, 0, -330);
    playerInit(east);
    controlDisable();
    b(label_2d);
  label_28:
    cameraSetNorth(east);
    cameraSet(northeast, 980, 0, -330);
    playerInit(east);
    controlDisable();
    b(label_2d);
  label_2d:
    unitSpawn(ulala, sprite_6, 800, 0, -400, west, none);
    unitAnimationPlay(ulala, animation_a, 1);
    unitSpawn(katsuya, sprite_d, 200, -300, -500, north, none);
    unitAnimationPlay(katsuya, animation_a, 1);
    unitSpawn(baofu, sprite_13, 280, -300, -800, east, none);
    unitAnimationPlay(baofu, animation_a, 1);
    unitSpawn(nanjo, sprite_1f, 980, 0, -700, east, none);
    unitAnimationPlay(nanjo, animation_a, 1);
    unitIdleOnAll();
    unitTriggerSet(ulala, URARA, 255, 1);
    unitTriggerSet(katsuya, KATUYA, 255, 1);
    unitTriggerSet(baofu, PAOFU, 255, 1);
    unitTriggerSet(nanjo, NANJO, 255, 1);
    envTriggerSet(RED_DOOR, 131, 1, line, coll_14);
    envTriggerSet(BLUE_DOOR, 14, 1, line, coll_13);
    envTriggerSet(EXIT_BLUE, 56, 1, line, coll_8);
    envTriggerSet(EXIT_RED, 224, 1, line, coll_5);
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

function NANJO()
{
    controlDisable();
    unitFacePlayer(nanjo);
    ref_47 = bustupLoad(bustup_36);
    bustupWait(ref_47);
    ref_49 = bustupAlloc(ref_47, left, rgb(0,0,0));
    bustupFade(ref_49, rgb(128,0,0), 30);
    ref_4b = dialogAlloc();
    ref_4c = msgShow(msg_0);
/***************************************
[color(yellow)]南条[color(white)]
[tab]俺も最近知ったのだが、うちはセベク事件から流出
[tab]したセベクの技術者やノウハウを囲い込み、
[tab]政府と組んで研究を続けていたらしい…
[sync][wait][clear]
***************************************/
    unitAnimationPlay(nanjo, animation_2d, 1);
    delayClear();
    delayWait(60);
    sync();
    wait(ref_4c);
    ref_52 = msgShow(msg_1);
/***************************************
[color(yellow)]南条[color(white)]
[tab]神取の開発した空間歪曲装置…ＤＶＡシステムや
[tab]その他の研究は、実用化できれば莫大な利益を
[tab]もたらすからな…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_52);
    ref_55 = msgShow(msg_2);
/***************************************
[color(yellow)]南条[color(white)]
[tab]そこで竜蔵とパイプができたのだろう。
[tab]新世塾の存在を知らぬ間に、
[tab]荷担する形になってしまった…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_55);
    ref_58 = bustupFade(ref_49, rgb(0,0,0), 10);
    bustupWait(ref_58);
    bustupFree(ref_49);
    ref_5b = bustupLoad(bustup_3b);
    bustupWait(ref_5b);
    ref_5d = bustupAlloc(ref_5b, left, rgb(0,0,0));
    bustupFade(ref_5d, rgb(128,0,0), 30);
    ref_5f = msgShow(msg_3);
/***************************************
[color(yellow)]南条[color(white)]
[tab]愚かな話だ…
[tab]あの事件に関わった者の心情を思うと、
[tab]詫びのしようもない…
[sync][wait][clear]
***************************************/
    unitAnimationPlay(nanjo, animation_29, 1);
    unitWait(nanjo);
    unitAnimationPlay(nanjo, animation_14, 1);
    delayClear();
    delayWait(30);
    sync();
    wait(ref_5f);
    dialogFree(ref_4b);
    ref_68 = bustupFade(ref_5d, rgb(0,0,0), 10);
    bustupWait(ref_68);
    bustupFree(ref_5d);
    unitAnimationPlay(nanjo, animation_a, 1);
    unitRestoreFacing(nanjo);
    controlEnable();
}

