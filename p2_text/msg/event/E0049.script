function EXIT_RED()
{
    controlDisable();
    unitAnimationPlay(nanjo, animation_b, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(nanjo, animation_c, 1);
    cameraRotateTo(1, 60);
    ref_173 = cameraMoveTo(980, 0, -700, 60);
    wait(ref_173);
    ref_175 = bustupLoad(bustup_36);
    bustupWait(ref_175);
    ref_177 = bustupAlloc(ref_175, left, rgb(0,0,0));
    bustupFade(ref_177, rgb(128,0,0), 30);
    ref_179 = dialogAlloc();
    ref_17a = msgShow(msg_18);
/***************************************
[color(yellow)]南条[color(white)]
[tab]天野さん、もう後戻りはできない。
[tab]前進あるのみだ！
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_17a);
    dialogFree(ref_179);
    ref_17e = bustupFade(ref_177, rgb(0,0,0), 10);
    bustupWait(ref_17e);
    bustupFree(ref_177);
    playerConvertToUnit(maya, sprite_0, west);
    playerHide();
    ref_183 = cameraLookAtUnit(maya, 0, 60);
    wait(ref_183);
    unitDespawn(maya, none);
    playerInit(west);
    controlDisable();
    unitAnimationPlay(nanjo, animation_a, 1);
    controlEnable();
}

