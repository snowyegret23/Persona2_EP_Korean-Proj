    wait(ref_31);
    unitSpawn(nanjo, sprite_1f, 1840, 0, -1150, west, none);
    unitTriggerSet(nanjo, B_NANJ, 255, 1);
  label_35:
    partyMemberCheck(var_0, elly);
    bez(var_0, label_3b);
    ref_37 = spriteLoad(sprite_23);
    wait(ref_37);
    unitSpawn(elly, sprite_23, 1790, 0, -1040, north, none);
    unitTriggerSet(elly, B_ERI, 255, 1);
  label_3b:
    bitGet(var_0, EBIT_E003E);
    bnz(var_0, label_43);
    bitGet(var_0, EBIT_E0038);
    bez(var_0, label_43);
    ref_3f = spriteLoad(sprite_6a);
    wait(ref_3f);
    unitSpawn(makimura, sprite_6a, 950, 0, -1150, south, none);
    unitTriggerSet(makimura, SAGIBOX, 255, 1);
  label_43:
    partyMemberCheck(var_0, ulala);
    bez(var_0, label_49);
    ref_45 = spriteLoad(sprite_6);
    wait(ref_45);
    unitSpawn(ulala, sprite_6, 1360, 0, -1740, north, none);
    unitTriggerSet(ulala, B_URARATI, 255, 1);
  label_49:
