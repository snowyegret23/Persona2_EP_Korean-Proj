function START()
{
    sndMusicPlay(sound_406b, 90);
    cameraSet(north, 1000, 0, 1000);
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    cameraSet(north, 1000, 0, 1000);
    ref_5 = spriteLoad(sprite_18);
    wait(ref_5);
    ref_7 = spriteLoad(sprite_1a);
    wait(ref_7);
    ref_9 = spriteLoad(sprite_dc);
    wait(ref_9);
    ref_b = spriteLoad(sprite_dd);
    wait(ref_b);
    unitSpawn(tatsuya, sprite_18, 700, 0, 1350, west, none);
    unitSpawn(enemy1, sprite_dc, 1200, 0, 800, north, none);
    unitSpawn(enemy2, sprite_dc, 1100, 0, 700, south, none);
    ref_10 = evtbgLoad(evtbg_17);
    wait(ref_10);
    evtbgInit(evtbg_handle_17, evtbg_17, 0, 0, rgb(0,0,0), true);
    ref_13 = evtbgFade(evtbg_handle_17, rgb(128,128,128), 1, false);
    wait(ref_13);
    unitAnimationPlay(enemy2, animation_24, 1);
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    screenEffectUnknown();
    unitFace(tatsuya, west);
    unitMove(tatsuya, 900, 1150, face_west, medium);
    unitWait(tatsuya);
    unitAnimationPlay(tatsuya, animation_a, 1);
    delayClear();
    delayWait(30);
    unitAnimationPlay(enemy1, animation_2, 1);
    delayClear();
    delayWait(15);
    unitFace(enemy1, south);
    unitSpriteClear(enemy1);
    unitSpriteSet(enemy1, sprite_dd);
    unitAnimationPlay(enemy1, animation_0, 1);
    sndMusicPlay(sound_315c, 127);
    unitAnimationPlay(enemy2, animation_4, 1);
    unitWait(enemy2);
    delayClear();
    delayWait(30);
    unitAnimationPlay(enemy2, animation_0, 1);
    unitWait(enemy2);
    unitFace(enemy2, east);
    ref_2f = unitMove(enemy2, 1060, 750, face_east, medium);
    wait(ref_2f);
    unitAnimationPlay(enemy2, animation_19, 1);
    unitWait(enemy2);
    ref_33 = dialogAlloc();
    ref_34 = msgShow(msg_0);
/***************************************
[color(yellow)]エリート警備員[color(white)]
[tab]おい、お前！
[tab]ここで何してる！
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_34);
    dialogFree(ref_33);
    unitFace(enemy2, south);
    unitSpriteClear(enemy2);
    unitSpriteSet(enemy2, sprite_dd);
    unitAnimationPlay(enemy2, animation_0, 1);
    sndMusicPlay(sound_315c, 127);
    ref_3d = dialogAlloc();
    ref_3e = msgShow(msg_1);
/***************************************
栄吉の件で、むしゃくしゃしていた。
悪いが八つ当たりさせてもらう。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_3e);
    dialogFree(ref_3d);
    unitSpriteClear(tatsuya);
    unitSpriteSet(tatsuya, sprite_1a);
    unitAnimationPlay(tatsuya, animation_0, 1);
    sndMusicPlay(sound_32e9, 127);
    delayClear();
    delayWait(60);
    encounterLoad(encounter_44);
}
