横のでかいタンクを目で指した。
そうか、こいつは麻酔の管理がどうとか言っていた。
[wait][clear]
***************************************/
    wait(ref_194);
    ref_196 = msgShow(msg_33);
/***************************************
このタンクの中身で、詩織さんを
眠らせることができるかもしれない。
俺が考えを巡らせていると、詩織さんが首を一回転させて
こちらを振り向いた。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_196);
    dialogFree(ref_164);
    unitFace(unit_58, south);
    delayClear();
    delayWait(30);
    unitAnimationPlay(tatsuya, animation_1, 1);
    unitWait(tatsuya);
    delayClear();
    delayWait(3);
    unitAnimationPlay(tatsuya, animation_0, 1);
    unitWait(tatsuya);
    delayClear();
    delayWait(3);
    unitAnimationPlay(tatsuya, animation_3, 1);
    unitWait(tatsuya);
    delayClear();
    delayWait(3);
    unitFace(tatsuya, north);
    unitAnimationPlay(tatsuya, animation_0, 1);
    unitWait(tatsuya);
    delayClear();
    delayWait(60);
    unitSpriteClear(tatsuya);
    unitSpriteSet(tatsuya, sprite_1a);
    unitAnimationPlay(tatsuya, animation_0, 1);
    unitWait(tatsuya);
    delayClear();
    delayWait(60);
    encounterLoad(encounter_46);
}

function TATUYATOUJYOU()
{
    unitSpawn(tatsuya, sprite_18, 650, 0, 40, east, none);
    unitMove(tatsuya, 650, -100, face_north, medium);
    unitWait(tatsuya);
    objAnimTranslate(obj_a, 100, 0, 0, 50);
    objAnimTranslate(obj_9, -100, 0, 0, 50);
}
