function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 2, true);
    screenFadeOuter(rgb(0,0,0), 2, true);
    cameraSet(north, 432, 0, -497);
    ref_6 = dialogAlloc();
    ref_7 = msgShow(msg_0);
/***************************************
[tab]テレビ局のイベントに、
[tab]入れるようにしました。
[tab]女の子に話しかけてミソ。[wait][clear]
***************************************/
    ref_8 = spriteLoad(sprite_0);
    wait(ref_8);
    ref_a = spriteLoad(sprite_2);
    wait(ref_a);
    sync();
    wait(ref_7);
    ref_e = msgShow(msg_1);
/***************************************
[tab]…全ショップ機能をオンにするよ。
[tab]そういう制御をつくったよ。
[tab]オレが…そう、片岡がね…
[wait][clear]
***************************************/
    playerInit(northwest);
    controlDisable();
    ref_11 = spriteLoad(sprite_94);
    wait(ref_11);
    unitSpawn(npc1, sprite_94, 32, 0, -72, north, none);
    unitTriggerSet(npc1, EVENTSINKOU, 255, 1);
    unitSpawn(npc2, sprite_94, 208, 0, -72, north, none);
    unitTriggerSet(npc2, UWASA, 255, 1);
    unitSpawn(npc4, sprite_94, 352, 0, -72, north, none);
    unitPalette(npc4, 3);
    unitTriggerSet(npc4, battle, 255, 1);
    ref_1a = spriteLoad(sprite_9c);
    wait(ref_1a);
    unitSpawn(npc3, sprite_9c, 488, 0, -72, north, none);
    unitTriggerSet(npc3, SAGASE, 255, 1);
    ref_1e = spriteLoad(sprite_9c);
    wait(ref_1e);
    unitSpawn(npc5, sprite_9c, 608, 0, -72, north, none);
    unitTriggerSet(npc5, PSP_DEBUG, 255, 1);
    ref_22 = spriteLoad(sprite_9c);
    wait(ref_22);
    unitSpawn(npc6, sprite_9c, 728, 0, -72, north, none);
    unitTriggerSet(npc6, PSP_DEBUG_2, 255, 1);
    ref_26 = spriteLoad(sprite_9c);
    wait(ref_26);
    unitSpawn(npc7, sprite_9c, 850, 0, -72, north, none);
    unitTriggerSet(npc7, PSP_DEBUG_3, 255, 1);
    wait(ref_e);
    dialogFree(ref_6);
    partyPersonaGive(maia, VBIT_PR_MAIA, party_stock);
    partyPersonaEquip(maya, maia);
    partyMoneyAdd(100000);
    bitSet(EBIT_E0010);
    bitSet(EBIT_E0037_B);
    bitSet(EBIT_E0038);
    bitSet(EBIT_E001F);
    bitSet(EBIT_E0046);
    bitSet(EBIT_E0018);
    bitSet(EBIT_E0010);
    bitSet(EBIT_E0018);
    bitSet(EBIT_E0016);
    bitSet(EBIT_E0015);
    bitSet(EBIT_E1000);
    bitSet(EBIT_E1001);
    bitSet(EBIT_E0003_B);
    bitSet(EBIT_E0004_B);
    bitSet(EBIT_FUJII);
    bitSet(EBIT_JOHO1);
    bitSet(EBIT_JOHO2);
    bitSet(EBIT_JOHO3);
    bitSet(EBIT_JOHO4);
    bitSet(EBIT_JOHO5);
    bitSet(EBIT_JOHO6);
    bitSet(EBIT_JOHO7);
    bitSet(EBIT_0005);
    bitSet(EBIT_E0006);
    bitSet(EBIT_KASIHARA);
    bitSet(EBIT_OKAMURA);
    bitSet(EBIT_E000D);
    bitSet(EBIT_E0010);
    bitSet(EBIT_GETKEY1);
    bitSet(EBIT_SEVENS_KYOMEI);
    bitSet(MBIT_KUZU_KENSHOU);
    bitSet(MBIT_HBATOLUBUKI);
    partyMemberAdd(ulala);
    partyPersonaGive(callisto, VBIT_PR_KARIS, party_stock);
    partyPersonaEquip(ulala, callisto);
    delayClear();
    delayWait(1);
    partyMemberAdd(katsuya);
    partyPersonaGive(helios, VBIT_PR_HERIO, party_stock);
    partyPersonaEquip(katsuya, helios);
    delayClear();
    delayWait(1);
    partyMemberAdd(baofu);
    partyPersonaGive(odysseus, VBIT_PR_ODUSE, party_stock);
    partyPersonaEquip(baofu, odysseus);
    delayClear();
    delayWait(1);
    partyMemberAdd(tatsuya);
    partyPersonaGive(apollo, VBIT_PR_APORO, party_stock);
    partyPersonaEquip(tatsuya, apollo);
    delayClear();
    delayWait(1);
    controlEnable();
}

