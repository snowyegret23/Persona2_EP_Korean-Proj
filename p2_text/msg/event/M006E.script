function UWASA()
{
    controlDisable();
  label_524:
    choiceSetResult(4);
    ref_525 = dialogAlloc();
    ref_526 = msgShow(msg_21);
/***************************************
[color(green)][tab]噂操作イベント[color(white)]
[choice(5)][color(pink)]噂全て聞いた[color(white)]
[color(blue)]噂指定[color(white)]
[color(yellow)]お金いっぱい[color(white)]
[color(green)]説明[color(white)]
[color(gray)]終了[color(white)]
[end_choice][clear]
