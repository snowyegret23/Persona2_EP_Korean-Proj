function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    disableMap();
    sndIdGet(var_0);
    bne(var_0, -1, label_9);
    ref_5 = sndLoad(sound_3035);
    wait(ref_5);
    sndMusicPlay(sound_3035, 127);
    b(label_a);
  label_9:
    b(label_a);
  label_a:
    ref_a = spriteLoad(sprite_0);
    wait(ref_a);
    ref_c = spriteLoad(sprite_2);
    wait(ref_c);
    ref_e = spriteLoad(sprite_56);
    wait(ref_e);
    bitGet(var_1, EBIT_E0003_B);
    bne(var_1, 0, label_15);
    ref_12 = call(KYOUSEI);
    wait(ref_12);
    b(label_19);
  label_15:
    bne(var_1, 1, label_19);
    ref_16 = call(FREE);
    wait(ref_16);
    b(label_19);
  label_19:
}

function KYOUSEI()
{
    cameraSet(southeast, 450, 0, -730);
