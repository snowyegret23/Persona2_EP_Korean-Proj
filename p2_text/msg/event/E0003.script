function FREE()
{
    unitSpawn(enemy1, sprite_56, 380, 0, -810, north, none);
    unitFace(enemy1, south);
    unitAnimationPlay(enemy1, animation_a, 1);
    unitWait(enemy1);
    unitTriggerSet(enemy1, HENSHU, 255, 1);
    envTriggerSet(BOARD, 131, 1, line, coll_a);
    envTriggerSet(BOARD, 7, 1, line, coll_a);
    envTriggerSet(BOARD, 14, 1, line, coll_a);
    envTriggerSet(MAGAZINE, 14, 1, line, coll_1b);
    envTriggerSet(EXIT, 14, 1, line, coll_18);
    envTriggerSet(HENSHU, 224, 1, line, coll_8);
    envTriggerSet(HENSHU, 224, 1, line, coll_6);
    envTriggerSet(HENSHU, 193, 1, line, coll_5);
    envTriggerSet(HENSHU, 131, 1, line, coll_4);
    envTriggerSet(HENSHU, 131, 1, line, coll_3);
    cameraSet(southwest, 50, 0, -700);
    playerInit(west);
    controlDisable();
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    unitIdleOnAll();
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

function HENSHU()
{
    controlDisable();
    unitFacePlayer(enemy1);
    unitAnimationPlay(enemy1, animation_a, 1);
    ref_125 = bustupLoad(bustup_5b);
    bustupWait(ref_125);
    ref_127 = bustupAlloc(ref_125, right, rgb(0,0,0));
    bustupFade(ref_127, rgb(128,0,0), 30);
    ref_129 = dialogAlloc();
    ref_12a = msgShow(msg_15);
/***************************************
[color(yellow)]水野編集長[color(white)]
[tab]まったく最近の若いのは…仕事も出来ないくせに、
[tab]権利の主張だけは一人前で困るのよね。
[sync][wait][clear]
***************************************/
    unitAnimationPlay(enemy1, animation_2d, 1);
    sync();
    wait(ref_12a);
    dialogFree(ref_129);
    ref_12f = bustupFade(ref_127, rgb(0,0,0), 10);
    bustupWait(ref_12f);
    bustupFree(ref_127);
    unitAnimationPlay(enemy1, animation_0, 1);
    unitRestoreFacing(enemy1);
    unitIdleOn(enemy1);
    controlEnable();
}

function EXIT()
{
    controlDisable();
    objAnimRotate(obj_b, 0, -80, 0, 60, 0);
    sndMusicPlay(sound_30a6, 127);
    objAnimWait(obj_b);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    bitSet(EBIT_E1001);
    eventLoad(event_99);
}

function BOARD()
{
    controlDisable();
    ref_145 = dialogAlloc();
    ref_146 = msgShow(msg_16);
/***************************************
[color(yellow)]クーレストの売り上げ表[color(white)]
[tab][color(green)]販売部数が落ち込んでいる。
[tab]編集長のイライラの原因らしい。
[color(white)]
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_146);
    dialogFree(ref_145);
    controlEnable();
}

function MAGAZINE()
{
