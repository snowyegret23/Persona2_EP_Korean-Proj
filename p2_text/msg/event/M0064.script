function START()
{
    controlDisable();
    shopInventory(3, shopInventory_2a8);
    ref_2 = dialogAlloc();
    ref_3 = msgShow(msg_0);
/***************************************
[tab][color(green)]タイトルメニューに
[tab]「ＥＸＴＲＡ[tab]ＤＵＮＧＥＯＮ」が追加されました。[color(white)]
[wait][clear]
***************************************/
    wait(ref_3);
    dialogFree(ref_2);
    shopInventory(3, shopInventory_136);
    titleScreen();
}
