function DOORBOX()
{
    controlDisable();
    sndMusicPlay(sound_3094, 127);
    objAnimRotate(obj_2, 0, -70, 0, 30, 0);
    objAnimWait(obj_2);
    dngLoad2(kasu_high-12);
}

function DOORBOX2()
{
