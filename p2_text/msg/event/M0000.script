function DECIDE_BUY()
{
    msgVar_Number(msgvar_0, var_6);
    unitFacePlayer(shopkeeper);
    ref_5b9 = bustupLoad(bustup_f0);
    bustupWait(ref_5b9);
    ref_5bb = bustupAlloc(ref_5b9, left, rgb(0,0,0));
    bustupFade(ref_5bb, rgb(128,0,0), 30);
    ref_5bd = dialogAlloc();
    choiceSetResult(1);
    ref_5bf = msgShow(msg_90);
/***************************************
[color(yellow)]伯爵[color(white)]
[tab][var(msg_var_0)]円いただくことになるが、
[tab]よろしいかな？
[choice(2)]はい
いいえ
[end_choice][clear]
***************************************/
    wait(ref_5bf);
    choiceGetResult(var_7);
    bne(var_7, 0, label_5c6);
    sndMusicPlay(sound_3037, 127);
    li(var_7, 1);
    b(label_5c9);
  label_5c6:
    bne(var_7, 1, label_5c9);
    li(var_7, 0);
    b(label_5c9);
  label_5c9:
    wait(ref_5bf);
    dialogFree(ref_5bd);
    ref_5cb = bustupFade(ref_5bb, rgb(0,0,0), 10);
    bustupWait(ref_5cb);
    bustupFree(ref_5bb);
    li(var_5, 20);
}

