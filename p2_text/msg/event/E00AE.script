function EXIT()
{
    controlDisable();
    objAnimRotate(obj_9, 0, -80, 0, 60, 0);
    sndMusicPlay(sound_329f, 127);
    objAnimRotate(obj_a, 0, 80, 0, 60, 0);
    objAnimWait(obj_9);
    objAnimWait(obj_a);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    bitSet(EBIT_E1700);
    mapLoad(rengedai, 10, 5);
}

