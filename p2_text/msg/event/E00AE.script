function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    levelFootstepSet(sfx_1a);
    disableMap();
    ref_4 = spriteLoad(sprite_0);
    wait(ref_4);
    ref_6 = spriteLoad(sprite_2);
    wait(ref_6);
    ref_8 = spriteLoad(sprite_6);
    wait(ref_8);
    ref_a = spriteLoad(sprite_d);
    wait(ref_a);
    ref_c = spriteLoad(sprite_13);
    wait(ref_c);
    ref_e = spriteLoad(sprite_18);
    wait(ref_e);
    bitGet(var_1, EBIT_E00B0);
    bne(var_1, 0, label_15);
    ref_12 = call(KYOUSEI);
    wait(ref_12);
    b(label_19);
  label_15:
    bne(var_1, 1, label_19);
    ref_16 = call(FREE);
    wait(ref_16);
    b(label_19);
  label_19:
}

function KYOUSEI()
{
    cameraSet(northwest, 750, 0, -1000);
    ref_1b = sndLoad(sound_1240);
    wait(ref_1b);
    sndMusicPlay(sound_1240, 90);
    unitSpawn(maya, sprite_0, 750, 0, -700, south, none);
    unitSpawn(ulala, sprite_6, 550, 0, -800, south, none);
    unitSpawn(katsuya, sprite_d, 850, 0, -950, south, none);
    unitSpawn(baofu, sprite_13, 650, 0, -1050, south, none);
    unitSpawn(tatsuya, sprite_18, 1050, 0, -850, south, none);
    unitAnimationPlay(ulala, animation_a, 1);
    unitAnimationPlay(katsuya, animation_a, 1);
    unitAnimationPlay(baofu, animation_a, 1);
    unitAnimationPlay(tatsuya, animation_0, 1);
    unitIdleOffAll();
    unitTriggerSet(katsuya, KATUYA, 255, 1);
    unitTriggerSet(baofu, PAOFU, 255, 1);
    unitTriggerSet(ulala, URARA, 255, 1);
    unitTriggerSet(tatsuya, TATUYA, 255, 1);
    envTriggerSet(EXIT, 131, 1, line, coll_5);
    envTriggerSet(ATATA1, 255, 2, circle, coll_1);
    envTriggerSet(ATATA2, 255, 2, circle, coll_0);
    envTriggerSet(ATATA3, 255, 2, circle, coll_3);
    envTriggerSet(ATATA4, 255, 2, circle, coll_2);
    envTriggerSet(ATATA5, 255, 2, circle, coll_4);
    envTriggerSet(ATATA6, 255, 2, circle, coll_5);
    envTriggerSet(ATATA7, 255, 2, circle, coll_6);
    envTriggerSet(ATATA8, 255, 2, circle, coll_7);
    envTriggerSet(IDOL1, 255, 1, collision_2, coll_d);
    envTriggerSet(IDOL2, 255, 1, collision_2, coll_f);
    ref_37 = cameraMoveTo(750, 0, -150, 180);
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 4, true);
    screenFadeOuter(rgb(0,0,0), 4, true);
    wait(ref_37);
    delayClear();
    delayWait(60);
    cameraRotateTo(7, 30);
    ref_3f = cameraMoveTo(500, 0, -150, 60);
    wait(ref_3f);
    delayClear();
    delayWait(30);
    ref_43 = dialogAlloc();
    ref_44 = msgShow(msg_0);
/***************************************
[color(yellow)]女媧の像[color(white)]
[tab]わらわは女媧（じょか）…
[tab]ウテナの扉開かんとする者…
[tab]粛々と古の祝詞捧ぐべし…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_44);
    dialogFree(ref_43);
    delayClear();
    delayWait(60);
    cameraRotateTo(1, 30);
    ref_4b = cameraMoveTo(1000, 0, -150, 120);
    wait(ref_4b);
    ref_4d = dialogAlloc();
    ref_4e = msgShow(msg_1);
/***************************************
[color(yellow)]伏羲の像[color(white)]
[tab]我は伏羲（ふくぎ）…
[tab]祝詞は言霊…
[tab]分かたれし七霊集め、古の祝詞捧ぐべし…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_4e);
    dialogFree(ref_4d);
    delayClear();
    delayWait(30);
    ref_54 = cameraLookAtUnit(maya, 0, 90);
    wait(ref_54);
    unitDespawn(maya, none);
    playerInit(south);
    controlDisable();
    bitSet(EBIT_E00B0);
    unitIdleOnAll();
    controlEnable();
}

function FREE()
