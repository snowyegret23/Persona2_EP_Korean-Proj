function IDOL1()
{
    controlDisable();
    ref_32e = dialogAlloc();
    ref_32f = msgShow(msg_8);
/***************************************
[color(yellow)]女媧の像[color(white)]
[tab]わらわは女媧（じょか）…
[tab]ウテナの扉開かんとする者…
[tab]粛々と古の祝詞捧ぐべし…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_32f);
    dialogFree(ref_32e);
    controlEnable();
}

function IDOL2()
{
    controlDisable();
    ref_336 = dialogAlloc();
    ref_337 = msgShow(msg_9);
/***************************************
[color(yellow)]伏羲の像[color(white)]
[tab]我は伏羲（ふくぎ）…
[tab]祝詞は言霊…
[tab]分かたれし七霊集め、古の祝詞捧ぐべし…
[sync][wait][clear]
***************************************/
