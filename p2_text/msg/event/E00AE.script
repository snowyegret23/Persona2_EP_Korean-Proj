    unitTriggerSet(tatsuya, TATUYA, 255, 1);
    envTriggerSet(EXIT, 131, 1, line, coll_5);
    envTriggerSet(ATATA1, 255, 2, circle, coll_1);
    envTriggerSet(ATATA2, 255, 2, circle, coll_0);
    envTriggerSet(ATATA3, 255, 2, circle, coll_3);
    envTriggerSet(ATATA4, 255, 2, circle, coll_2);
    envTriggerSet(ATATA5, 255, 2, circle, coll_4);
    envTriggerSet(ATATA6, 255, 2, circle, coll_5);
    envTriggerSet(ATATA7, 255, 2, circle, coll_6);
    envTriggerSet(ATATA8, 255, 2, circle, coll_7);
    envTriggerSet(IDOL1, 255, 1, collision_2, coll_d);
    envTriggerSet(IDOL2, 255, 1, collision_2, coll_f);
    bitGet(var_7, EBIT_E1700);
    bne(var_7, 0, label_8c);
    cameraSet(northeast, 740, 0, -380);
    playerInit(north);
    controlDisable();
    b(label_92);
  label_8c:
    bne(var_7, 1, label_92);
    bitClear(EBIT_E1700);
    cameraSet(southeast, 750, 0, -1230);
    playerInit(south);
    controlDisable();
    b(label_92);
  label_92:
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

function KATUYA()
{
    controlDisable();
    unitFacePlayer(katsuya);
    ref_9b = bustupLoad(bustup_21);
    bustupWait(ref_9b);
    ref_9d = bustupAlloc(ref_9b, left, rgb(0,0,0));
    bustupFade(ref_9d, rgb(128,0,0), 30);
    ref_9f = dialogAlloc();
    ref_a0 = msgShow(msg_2);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]祝詞…？[tab]七つの言霊…？
[tab]それがわからないと、ウテナの間とやらは
[tab]開かないと言いたいのか…
[sync][wait][clear]
***************************************/
    unitAnimationPlay(katsuya, animation_2d, 1);
    delayClear();
    delayWait(60);
    sync();
    wait(ref_a0);
    dialogFree(ref_9f);
    ref_a7 = bustupFade(ref_9d, rgb(0,0,0), 10);
    bustupWait(ref_a7);
    bustupFree(ref_9d);
    unitAnimationPlay(katsuya, animation_a, 1);
    unitRestoreFacing(katsuya);
    controlEnable();
}

