function NANJOMOVE()
{
    unitMove(nanjo, 1180, -1300, face_east, medium);
    unitWait(nanjo);
}

function MATUOKAMOVE()
{
    unitMove(matsuoka, 1180, -1680, face_east, fastest);
    unitWait(matsuoka);
    unitMove(matsuoka, 1080, -1300, face_south, fastest);
    unitWait(matsuoka);
    unitFace(matsuoka, west);
}

function MATUOKABACK()
{
    unitMove(matsuoka, 1080, -1400, face_south, reverse);
    unitWait(matsuoka);
}

function NANJOMOVE2()
{
    unitMove(nanjo, 850, -1300, face_east, medium);
    unitWait(nanjo);
    unitMove(nanjo, 850, -2100, face_north, medium);
    unitWait(nanjo);
}

function MAYAMOVE()
{
    unitMove(maya, 1200, -1580, face_east, medium);
    unitWait(maya);
}

function URARAMOVE()
{
    unitMove(ulala, 1100, -1440, face_east, fastest);
    unitWait(ulala);
    unitMove(ulala, 1100, -1580, face_north, fastest);
    unitWait(ulala);
    unitFace(ulala, west);
}

function PAOFUMOVEX()
{
    unitMove(baofu, 700, -1580, face_east, medium);
    unitWait(baofu);
    unitMove(baofu, 700, -2100, face_east, medium);
    unitWait(baofu);
}

