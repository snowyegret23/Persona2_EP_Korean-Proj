    delayWait(90);
    unitAnimationPlay(maya, animation_1e, 1);
    unitWait(maya);
    delayClear();
    delayWait(30);
    unitFace(ulala, north);
    unitAnimationHold(ulala, animation_21, -1);
    delayClear();
    delayWait(30);
    ref_1bd = bustupLoad(bustup_1b);
    bustupWait(ref_1bd);
