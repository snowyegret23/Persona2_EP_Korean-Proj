    delayClear();
    delayWait(60);
    ref_154 = sndVolumeFadeOff(sound_320f, 120);
    ref_155 = screenHorizontalFadeOut();
    wait(ref_154);
    wait(ref_155);
    eventLoad(event_be);
}

function ERI_ROOT()
{
    cameraSet(northwest, 1470, 0, -1660);
