function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    sndIdGet(var_0);
    bne(var_0, -1, label_5);
    b(label_7);
  label_5:
    sndVolumeFadeTo(var_0, 0, 5);
    b(label_7);
  label_7:
    levelFootstepSet(sfx_1a);
    sndMusicPlay(sound_320f, 50);
    ref_9 = todLoad(tod_3);
    wait(ref_9);
    cameraSet(northeast, 680, 0, -550);
    ref_c = spriteLoad(sprite_0);
    wait(ref_c);
    ref_e = spriteLoad(sprite_6);
    wait(ref_e);
    ref_10 = spriteLoad(sprite_13);
    wait(ref_10);
    ref_12 = spriteLoad(sprite_d);
    wait(ref_12);
    ref_14 = spriteLoad(sprite_1f);
    wait(ref_14);
    ref_16 = spriteLoad(sprite_23);
    wait(ref_16);
    ref_18 = spriteLoad(sprite_76);
    wait(ref_18);
    bitGet(var_1, MBIT_HI_NANJOTOUJO);
    bne(var_1, 0, label_1f);
    ref_1c = call(ERI_ROOT);
    wait(ref_1c);
    b(label_23);
  label_1f:
    bne(var_1, 1, label_23);
    ref_20 = call(NANJO_ROOT);
    wait(ref_20);
    b(label_23);
  label_23:
}

function NANJO_ROOT()
{
    cameraSet(northwest, 1470, 0, -1660);
    cameraZoom(-4608, 1);
    delayClear();
    delayWait(10);
    unitSpawn(maya, sprite_0, 1350, 0, -1580, west, none);
    unitAnimationPlay(maya, animation_d, 1);
    unitSpawn(ulala, sprite_6, 1350, 0, -1440, west, none);
    unitAnimationPlay(ulala, animation_d, 1);
    unitSpawn(nanjo, sprite_1f, 1520, 0, -1300, north, none);
    unitAnimationPlay(nanjo, animation_a, 1);
    unitSpawn(matsuoka, sprite_76, 1500, 0, -1680, south, none);
    unitFace(matsuoka, south);
    unitAnimationPlay(matsuoka, animation_0, 1);
    unitSpawn(katsuya, sprite_d, 1640, 0, -1550, east, none);
    unitAnimationPlay(katsuya, animation_b, 1);
    unitSpawn(baofu, sprite_13, 1690, 0, -1350, east, none);
    unitAnimationPlay(baofu, animation_c, 1);
    unitIdleOffAll();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    screenEffectUnknown();
    screenFadeWait(inner);
    screenFadeWait(outer);
    delayClear();
    delayWait(60);
    ref_3e = bustupLoad(bustup_5f);
    bustupWait(ref_3e);
    ref_40 = bustupAlloc(ref_3e, right, rgb(0,0,0));
    bustupFade(ref_40, rgb(128,0,0), 30);
    ref_42 = dialogAlloc();
    ref_43 = msgShow(msg_0);
/***************************************
[color(yellow)]松岡[color(white)]
[tab]情報によれば、日輪丸は珠閒瑠湾の沖合い
[tab]洋上１０キロに停泊中…
[sync][wait][clear]
***************************************/
    unitAnimationHold(matsuoka, animation_13, -1);
    sync();
    wait(ref_43);
    ref_47 = msgShow(msg_1);
/***************************************
[color(yellow)]松岡[color(white)]
[tab]外装は客船だが、内部には大幅な改造が施されて
[tab]いる模様…とのことです。
[sync][wait][clear]
***************************************/
    delayClear();
    delayWait(30);
    unitAnimationStop(matsuoka);
    unitAnimationPlay(matsuoka, animation_14, 1);
    delayClear();
    delayWait(20);
    sync();
    wait(ref_47);
    dialogFree(ref_42);
    ref_51 = bustupFade(ref_40, rgb(0,0,0), 10);
    bustupWait(ref_51);
    bustupFree(ref_40);
    delayClear();
    delayWait(30);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 8, false);
    screenFadeOuter(rgb(255,255,255), 8, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    cameraZoom(0, 10);
    delayClear();
    delayWait(10);
    delayClear();
    delayWait(30);
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    screenFadeInner(rgb(0,0,0), 8, true);
    screenFadeOuter(rgb(0,0,0), 8, true);
    screenEffectUnknown();
    screenFadeWait(inner);
    screenFadeWait(outer);
    delayClear();
    delayWait(60);
    ref_69 = bustupLoad(bustup_5f);
    bustupWait(ref_69);
    ref_6b = bustupAlloc(ref_69, right, rgb(0,0,0));
    bustupFade(ref_6b, rgb(128,0,0), 30);
    ref_6d = dialogAlloc();
    ref_6e = msgShow(msg_2);
/***************************************
[color(yellow)]松岡[color(white)]
[tab]自衛隊は、陸自の第１５師団と海自の一部が
[tab]丸まる掌握されているようです…
[sync][wait][clear]
***************************************/
    unitAnimationPlay(matsuoka, animation_2d, 1);
    delayClear();
    delayWait(60);
    sync();
    wait(ref_6e);
    ref_74 = msgShow(msg_3);
/***************************************
[color(yellow)]松岡[color(white)]
[tab]永田町のお偉方もようやく気づき、
[tab]公安や防衛庁が事態の把握に躍起になっています…
[sync][wait][clear]
***************************************/
    delayClear();
    delayWait(60);
    sync();
    wait(ref_74);
    dialogFree(ref_6d);
    ref_7a = bustupFade(ref_6b, rgb(0,0,0), 10);
    bustupWait(ref_7a);
    bustupFree(ref_6b);
    unitAnimationPlay(matsuoka, animation_0, 1);
    delayClear();
    delayWait(60);
    unitAnimationHold(nanjo, animation_11, -1);
    delayClear();
    delayWait(60);
    ref_83 = bustupLoad(bustup_36);
    bustupWait(ref_83);
    ref_85 = bustupAlloc(ref_83, left, rgb(0,0,0));
    bustupFade(ref_85, rgb(128,0,0), 30);
    ref_87 = dialogAlloc();
    ref_88 = msgShow(msg_4);
/***************************************
[color(yellow)]南条[color(white)]
[tab]遅いな…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_88);
    dialogFree(ref_87);
    ref_8c = bustupFade(ref_85, rgb(0,0,0), 10);
    bustupWait(ref_8c);
    bustupFree(ref_85);
    call(NANJOMOVE);
    delayClear();
    delayWait(10);
    ref_92 = call(MATUOKAMOVE);
    cameraMoveTo(1180, 0, -1300, 60);
    unitAnimationPlay(maya, animation_a, 1);
    unitAnimationPlay(ulala, animation_a, 1);
    unitAnimationPlay(baofu, animation_a, 1);
    unitAnimationPlay(katsuya, animation_a, 1);
    delayClear();
    delayWait(7);
    unitAnimationPlay(maya, animation_b, 1);
    unitAnimationPlay(ulala, animation_b, 1);
    unitAnimationPlay(katsuya, animation_d, 1);
    delayClear();
    delayWait(7);
    unitFace(maya, south);
    unitFace(ulala, south);
    unitAnimationPlay(maya, animation_a, 1);
    unitAnimationPlay(ulala, animation_a, 1);
    delayClear();
    delayWait(7);
    unitFace(maya, east);
    unitFace(ulala, east);
    unitAnimationPlay(maya, animation_d, 1);
    wait(ref_92);
    delayClear();
    delayWait(30);
    ref_ab = bustupLoad(bustup_5f);
    bustupWait(ref_ab);
    ref_ad = bustupAlloc(ref_ab, right, rgb(0,0,0));
    bustupFade(ref_ad, rgb(128,0,0), 30);
    ref_af = dialogAlloc();
    ref_b0 = msgShow(msg_5);
/***************************************
[color(yellow)]松岡[color(white)]
[tab]しかし、貴方がやろうとしている事も、
[tab]将来南条のトップに立つ者の行動ではない。
[sync][wait][clear]
***************************************/
    unitAnimationPlay(matsuoka, animation_2d, 1);
    delayClear();
    delayWait(60);
    sync();
    wait(ref_b0);
    ref_b6 = msgShow(msg_6);
/***************************************
[color(yellow)]松岡[color(white)]
[tab]南条には力がある。
[tab]いくらでも沈める方法はあります。
[tab]ご自重なさい。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_b6);
    dialogFree(ref_af);
    ref_ba = bustupFade(ref_ad, rgb(0,0,0), 10);
    bustupWait(ref_ba);
    bustupFree(ref_ad);
    unitAnimationPlay(matsuoka, animation_0, 1);
    delayClear();
    delayWait(60);
    unitAnimationPlay(nanjo, animation_6, 1);
    ref_c1 = bustupLoad(bustup_3b);
    bustupWait(ref_c1);
    ref_c3 = bustupAlloc(ref_c1, left, rgb(0,0,0));
    bustupFade(ref_c3, rgb(128,0,0), 30);
    ref_c5 = dialogAlloc();
    ref_c6 = msgShow(msg_7);
/***************************************
[color(yellow)]南条[color(white)]
[tab]だからこそ俺は行く。
[tab]今の俺には、その力の何たるかを見極める事が
[tab]必要なのだ…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_c6);
    unitAnimationPlay(nanjo, animation_0, 1);
    ref_ca = msgShow(msg_8);
/***************************************
[color(yellow)]南条[color(white)]
[tab]単なる相続を、良しとはできん。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_ca);
    dialogFree(ref_c5);
    ref_ce = bustupFade(ref_c3, rgb(0,0,0), 10);
    bustupWait(ref_ce);
    bustupFree(ref_c3);
    delayClear();
    delayWait(60);
    unitAnimationPlay(matsuoka, animation_14, 1);
    ref_d4 = bustupLoad(bustup_5f);
    bustupWait(ref_d4);
    ref_d6 = bustupAlloc(ref_d4, right, rgb(0,0,0));
    bustupFade(ref_d6, rgb(128,0,0), 30);
    ref_d8 = dialogAlloc();
    ref_d9 = msgShow(msg_9);
/***************************************
[color(yellow)]松岡[color(white)]
[tab]…わかりました。
[tab]お好きになさい。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_d9);
    dialogFree(ref_d8);
    ref_dd = bustupFade(ref_d6, rgb(0,0,0), 10);
    bustupWait(ref_dd);
    bustupFree(ref_d6);
    unitAnimationPlay(matsuoka, animation_0, 1);
    call(MATUOKABACK);
    delayClear();
    delayWait(20);
    call(NANJOMOVE2);
    delayClear();
    delayWait(60);
    unitAnimationPlay(matsuoka, animation_1, 1);
    delayClear();
    delayWait(60);
    unitFace(matsuoka, west);
    unitAnimationPlay(matsuoka, animation_3, 1);
    delayClear();
    delayWait(30);
    ref_ee = bustupLoad(bustup_5f);
    bustupWait(ref_ee);
    ref_f0 = bustupAlloc(ref_ee, right, rgb(0,0,0));
    bustupFade(ref_f0, rgb(128,0,0), 30);
    ref_f2 = dialogAlloc();
    ref_f3 = msgShow(msg_10);
/***************************************
[color(yellow)]松岡[color(white)]
[tab]天野様…
[tab]圭様をお頼みします。
[sync][wait][clear]
***************************************/
    delayClear();
    delayWait(60);
    sync();
    wait(ref_f3);
    dialogFree(ref_f2);
    ref_f9 = bustupFade(ref_f0, rgb(0,0,0), 10);
    bustupWait(ref_f9);
    bustupFree(ref_f0);
    delayClear();
    delayWait(60);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    delayClear();
    delayWait(120);
    unitDespawn(maya, none);
    unitDespawn(ulala, none);
    unitDespawn(katsuya, none);
    unitDespawn(baofu, none);
    unitDespawn(nanjo, none);
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    screenEffectUnknown();
    sndMusicPlay(sound_3211, 127);
    todRun(tod_3, 0);
    delayClear();
    delayWait(800);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 4, false);
    screenFadeOuter(rgb(255,255,255), 4, false);
    sndVolumeFadeOff(sound_3211, 120);
    screenFadeWait(inner);
    screenFadeWait(outer);
    ref_11a = cameraRotateTo(1, 10);
    wait(ref_11a);
    ref_11c = cameraMoveTo(800, 0, -2200, 10);
    wait(ref_11c);
    unitSpawn(matsuoka, sprite_76, 800, 0, -3500, north, none);
