    ref_1c1 = dialogAlloc();
    ref_1c2 = msgShow(msg_17);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]え～！？[tab]アンタが運転するってぇ～！？
[sync][wait][clear]
***************************************/
