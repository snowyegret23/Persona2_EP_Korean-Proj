    ref_1e5 = bustupAlloc(ref_1e3, left, rgb(0,0,0));
    bustupFade(ref_1e5, rgb(128,0,0), 30);
    ref_1e7 = dialogAlloc();
    ref_1e8 = msgShow(msg_18);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]アンタのは車で懲りてんのよぅ！！
[tab]絶対ダメだかんね！！
[tab]どきなさいって、ホラ！！
[sync][wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2f, 1);
    delayClear();
    delayWait(60);
