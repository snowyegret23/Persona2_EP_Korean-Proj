    unitAnimationPlay(matsuoka, animation_0, 1);
    delayClear();
    delayWait(120);
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    screenFadeInner(rgb(0,0,0), 4, true);
    screenFadeOuter(rgb(0,0,0), 4, true);
    screenEffectUnknown();
    ref_127 = cameraMoveTo(800, 0, -3550, 360);
    wait(ref_127);
    delayClear();
    delayWait(60);
    unitAnimationPlay(matsuoka, animation_5, 1);
    delayClear();
    delayWait(60);
    ref_12e = bustupLoad(bustup_60);
    bustupWait(ref_12e);
    ref_130 = bustupAlloc(ref_12e, right, rgb(0,0,0));
    bustupFade(ref_130, rgb(128,0,0), 30);
    ref_132 = dialogAlloc();
    ref_133 = msgShow(msg_11);
/***************************************
[color(yellow)]松岡[color(white)]
[tab]山岡さん…
[tab]坊ちゃんは正しく成長された。
[tab]貴方と…御友人のおかげだな…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_133);
    dialogFree(ref_132);
    ref_137 = bustupFade(ref_130, rgb(0,0,0), 10);
    bustupWait(ref_137);
    bustupFree(ref_130);
