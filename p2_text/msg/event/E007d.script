    delayClear();
    delayWait(10);
    unitAnimationPlay(maya, animation_1, 1);
    delayClear();
    delayWait(7);
    unitFace(maya, south);
    unitAnimationPlay(maya, animation_0, 1);
    delayClear();
    delayWait(30);
    sync();
    wait(ref_1c2);
    dialogFree(ref_1c1);
    ref_1d0 = bustupFade(ref_1bf, rgb(0,0,0), 10);
