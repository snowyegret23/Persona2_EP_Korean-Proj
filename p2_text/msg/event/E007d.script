    bustupFade(ref_19b, rgb(128,0,0), 30);
    ref_19d = dialogAlloc();
    ref_19e = msgShow(msg_16);
/***************************************
[color(yellow)]エリー[color(white)]
[tab]さすが南条の情報網ですわね。
