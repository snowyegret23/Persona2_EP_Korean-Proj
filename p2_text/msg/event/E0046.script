    delayWait(10);
    unitAnimationPlay(ulala, animation_a, 1);
    delayClear();
    delayWait(10);
    unitAnimationPlay(katsuya, animation_0, 1);
    delayClear();
    delayWait(30);
    unitDespawn(maya, none);
    playerInit(west);
    controlDisable();
    bitSet(EBIT_E004A);
    bitSet(IBIT_RESERVE_0);
    unitIdleOnAll();
    controlEnable();
}

function FREE()
{
    unitSpawn(ulala, sprite_6, 360, 0, -560, south, none);
    unitAnimationPlay(ulala, animation_a, 1);
