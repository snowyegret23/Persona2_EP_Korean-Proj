function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    dngRoomSet(39);
    dngRoomDraw();
    levelFootstepSet(sfx_10);
    ref_5 = sndLoad(sound_3011);
    wait(ref_5);
    sndMusicPlay(sound_3011, 127);
    ref_8 = spriteLoad(sprite_0);
    wait(ref_8);
    ref_a = spriteLoad(sprite_2);
    wait(ref_a);
    ref_c = spriteLoad(sprite_1);
    wait(ref_c);
    ref_e = spriteLoad(sprite_6);
    wait(ref_e);
    ref_10 = spriteLoad(sprite_13);
    wait(ref_10);
    ref_12 = spriteLoad(sprite_d);
    wait(ref_12);
    ref_14 = spriteLoad(sprite_1f);
    wait(ref_14);
    ref_16 = spriteLoad(sprite_31);
    wait(ref_16);
    ref_18 = spriteLoad(sprite_33);
    wait(ref_18);
    bitGet(var_1, EBIT_E004A);
    bne(var_1, 0, label_1f);
    ref_1c = call(KYOUSEI);
    wait(ref_1c);
    b(label_23);
  label_1f:
    bne(var_1, 1, label_23);
    ref_20 = call(FREE);
    wait(ref_20);
    b(label_23);
  label_23:
}

function KYOUSEI()
{
    cameraSet(northwest, -50, 0, -320);
    unitSpawn(maya, sprite_0, 170, 0, -440, west, none);
    unitAnimationPlay(maya, animation_a, 1);
    unitSpawn(ulala, sprite_6, 240, 0, -260, north, none);
    unitAnimationPlay(ulala, animation_d, 1);
    unitSpawn(katsuya, sprite_d, 330, 0, -560, south, none);
    unitAnimationPlay(katsuya, animation_1, 1);
    unitSpawn(baofu, sprite_13, 370, 0, -280, north, none);
    unitAnimationPlay(baofu, animation_d, 1);
    unitSpawn(nanjo, sprite_1f, 460, 0, -440, east, none);
    unitAnimationPlay(nanjo, animation_a, 1);
    unitIdleOffAll();
    unitTriggerSet(ulala, URARA, 255, 1);
    unitTriggerSet(katsuya, KATUYA, 255, 1);
    unitTriggerSet(baofu, PAOFU, 255, 1);
    unitTriggerSet(nanjo, NANJO, 255, 1);
    envTriggerSet(EXIT, 224, 1, line, coll_12);
    envTriggerSet(RED_DOOR, 131, 1, line, coll_5);
    envTriggerSet(BLUE_DOOR, 14, 1, line, coll_8);
    envTriggerSet(BLACK_BOX, 56, 1, line, coll_18);
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 4, true);
    screenFadeOuter(rgb(0,0,0), 4, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    delayClear();
    delayWait(60);
    unitAnimationPlay(nanjo, animation_14, 1);
    ref_40 = bustupLoad(bustup_36);
    bustupWait(ref_40);
    ref_42 = bustupAlloc(ref_40, left, rgb(0,0,0));
    bustupFade(ref_42, rgb(128,0,0), 30);
    ref_44 = dialogAlloc();
    ref_45 = msgShow(msg_0);
/***************************************
[color(yellow)]南条[color(white)]
[tab]この下水処理施設は研究所専用だが、
[tab]セキュリティは比較的軽微です。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_45);
    unitWait(nanjo);
    unitAnimationPlay(nanjo, animation_1f, 1);
    ref_4a = msgShow(msg_1);
/***************************************
[color(yellow)]南条[color(white)]
[tab]特徴は数ブロックからなる迷路構造。
[tab]しかも、各ブロック毎に一定時間で多量の排水が
[tab]流れ込み、侵入者を押し流す仕組みになっている。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_4a);
    unitAnimationPlay(nanjo, animation_1a, 1);
    ref_4e = msgShow(msg_2);
/***************************************
[color(yellow)]南条[color(white)]
[tab]各ブロックを結ぶルートは二つ…
[tab]最短ルートを行かなければ、それだけ押し流される
[tab]危険が増す。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_4e);
    unitWait(nanjo);
    unitAnimationPlay(nanjo, animation_a, 1);
    ref_53 = msgShow(msg_3);
/***************************************
[color(yellow)]南条[color(white)]
[tab]各ルートの電子ロックは、それぞれ第一制御室と
[tab]第ニ制御室で制御するしかない。
[tab]よって、誰かが二人残る必要がある…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_53);
    dialogFree(ref_44);
    ref_57 = bustupFade(ref_42, rgb(0,0,0), 10);
    bustupWait(ref_57);
    bustupFree(ref_42);
    unitAnimationPlay(nanjo, animation_0, 1);
    delayClear();
    delayWait(60);
    unitAnimationPlay(katsuya, animation_b, 1);
    ref_5e = bustupLoad(bustup_21);
    bustupWait(ref_5e);
    ref_60 = bustupAlloc(ref_5e, left, rgb(0,0,0));
    bustupFade(ref_60, rgb(128,0,0), 30);
    ref_62 = dialogAlloc();
    ref_63 = msgShow(msg_4);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]よく調べたものだな。
[sync][wait][clear]
***************************************/
    delayClear();
    delayWait(10);
    unitAnimationPlay(nanjo, animation_1, 1);
    sync();
    wait(ref_63);
    dialogFree(ref_62);
    ref_6a = bustupFade(ref_60, rgb(0,0,0), 10);
    bustupWait(ref_6a);
    bustupFree(ref_60);
    delayClear();
    delayWait(60);
    unitAnimationPlay(nanjo, animation_6, 1);
    ref_70 = bustupLoad(bustup_3b);
    bustupWait(ref_70);
    ref_72 = bustupAlloc(ref_70, left, rgb(0,0,0));
    bustupFade(ref_72, rgb(128,0,0), 30);
    ref_74 = dialogAlloc();
    ref_75 = msgShow(msg_5);
/***************************************
[color(yellow)]南条[color(white)]
[tab]うちの技術だからですよ…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_75);
    ref_78 = bustupFade(ref_72, rgb(0,0,0), 10);
    bustupWait(ref_78);
    bustupFree(ref_72);
    unitAnimationPlay(nanjo, animation_2d, 1);
    ref_7c = bustupLoad(bustup_38);
    bustupWait(ref_7c);
    ref_7e = bustupAlloc(ref_7c, left, rgb(0,0,0));
    bustupFade(ref_7e, rgb(128,0,0), 30);
    ref_80 = msgShow(msg_6);
/***************************************
[color(yellow)]南条[color(white)]
[tab]父は、竜蔵に政治献金をしているんです。
[tab]この処理施設や研究所も、使用目的も問わずに
[tab]うちのグループが提供したものだ…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_80);
    dialogFree(ref_74);
    ref_84 = bustupFade(ref_7e, rgb(0,0,0), 10);
    bustupWait(ref_84);
    bustupFree(ref_7e);
    unitAnimationPlay(nanjo, animation_0, 1);
    delayClear();
    delayWait(60);
    unitAnimationPlay(baofu, animation_1d, 1);
    ref_8b = bustupLoad(bustup_2c);
    bustupWait(ref_8b);
    ref_8d = bustupAlloc(ref_8b, left, rgb(0,0,0));
    bustupFade(ref_8d, rgb(128,0,0), 30);
    ref_8f = dialogAlloc();
    ref_90 = msgShow(msg_7);
/***************************************
[color(yellow)]パオフゥ[color(white)]
[tab]大人の事情ってヤツか…
[tab]いいのか？
[sync][wait][clear]
***************************************/
    delayClear();
    delayWait(10);
    unitAnimationPlay(nanjo, animation_d, 1);
    unitWait(baofu);
    delayClear();
    delayWait(30);
    unitAnimationPlay(baofu, animation_d, 1);
    sync();
    wait(ref_90);
    dialogFree(ref_8f);
    ref_9b = bustupFade(ref_8d, rgb(0,0,0), 10);
    bustupWait(ref_9b);
    bustupFree(ref_8d);
    delayClear();
    delayWait(60);
    unitAnimationPlay(nanjo, animation_6, 1);
    ref_a1 = bustupLoad(bustup_3b);
    bustupWait(ref_a1);
    ref_a3 = bustupAlloc(ref_a1, left, rgb(0,0,0));
    bustupFade(ref_a3, rgb(128,0,0), 30);
    ref_a5 = dialogAlloc();
    ref_a6 = msgShow(msg_8);
/***************************************
[color(yellow)]南条[color(white)]
[tab]建前と利権だけの世界は寒いものだ…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_a6);
    ref_a9 = bustupFade(ref_a3, rgb(0,0,0), 10);
    bustupWait(ref_a9);
    bustupFree(ref_a3);
    unitAnimationPlay(nanjo, animation_a, 1);
    ref_ad = bustupLoad(bustup_36);
    bustupWait(ref_ad);
    ref_af = bustupAlloc(ref_ad, left, rgb(0,0,0));
    bustupFade(ref_af, rgb(128,0,0), 30);
    ref_b1 = msgShow(msg_9);
/***************************************
[color(yellow)]南条[color(white)]
[tab]俺は自分の信じた道を行く。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_b1);
    dialogFree(ref_a5);
    ref_b5 = bustupFade(ref_af, rgb(0,0,0), 10);
    bustupWait(ref_b5);
    bustupFree(ref_af);
    delayClear();
    delayWait(60);
    unitAnimationHold(baofu, animation_11, -1);
    ref_bb = bustupLoad(bustup_2d);
    bustupWait(ref_bb);
    ref_bd = bustupAlloc(ref_bb, left, rgb(0,0,0));
    bustupFade(ref_bd, rgb(128,0,0), 30);
    ref_bf = dialogAlloc();
    ref_c0 = msgShow(msg_10);
/***************************************
[color(yellow)]パオフゥ[color(white)]
[tab]上等だ…
[tab]で、誰が残る？
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_c0);
    dialogFree(ref_bf);
    ref_c4 = bustupFade(ref_bd, rgb(0,0,0), 10);
    bustupWait(ref_c4);
    bustupFree(ref_bd);
    unitAnimationStop(baofu);
    unitAnimationPlay(baofu, animation_a, 1);
    delayClear();
    delayWait(60);
    unitSpawn(reiji, sprite_33, 870, 0, -440, east, none);
    unitSpawn(maki, sprite_31, 950, 0, -420, east, none);
    ref_cd = bustupLoad(bustup_c4);
    bustupWait(ref_cd);
    ref_cf = bustupAlloc(ref_cd, right, rgb(0,0,0));
    bustupFade(ref_cf, rgb(128,0,0), 30);
    ref_d1 = dialogAlloc();
    ref_d2 = msgShow(msg_11);
/***************************************
[color(yellow)]玲司[color(white)]
[tab]まかせな…
[sync][wait][clear]
***************************************/
    ref_d3 = cameraMoveTo(950, 0, -420, 120);
    delayClear();
    delayWait(60);
    cameraRotateTo(1, 60);
    unitAnimationPlay(katsuya, animation_4, 1);
    unitAnimationPlay(ulala, animation_c, 1);
    unitAnimationPlay(baofu, animation_c, 1);
    unitAnimationPlay(nanjo, animation_3, 1);
    delayClear();
    delayWait(7);
    unitFace(nanjo, north);
    unitAnimationPlay(nanjo, animation_1, 1);
    delayClear();
    delayWait(7);
    unitFace(nanjo, west);
    unitAnimationPlay(nanjo, animation_0, 1);
    delayClear();
    delayWait(7);
    unitAnimationHold(nanjo, animation_21, -1);
    wait(ref_d3);
    sync();
    wait(ref_d2);
    unitAnimationPlay(reiji, animation_11, 1);
    ref_ea = msgShow(msg_12);
/***************************************
[color(yellow)]城戸[tab]玲司（きど[tab]れいじ）[color(white)]
[tab][color(green)]かつて南条やエリーと共に戦ったペルソナ使い。
[tab]「伝説の裸番長」の異名を持つ。
[tab]南条が追う神取の異母兄弟でもある。[color(white)]
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_ea);
    dialogFree(ref_d1);
    ref_ee = bustupFade(ref_cf, rgb(0,0,0), 10);
    bustupWait(ref_ee);
    bustupFree(ref_cf);
    unitWait(reiji);
    bitSet(EBIT_E1E01);
    unitAnimationPlay(reiji, animation_a, 1);
    delayClear();
    delayWait(30);
    unitAnimationHold(maki, animation_18, -1);
    delayClear();
    delayWait(30);
    ref_f9 = bustupLoad(bustup_c2);
    bustupWait(ref_f9);
    ref_fb = bustupAlloc(ref_f9, right, rgb(0,0,0));
    bustupFade(ref_fb, rgb(128,0,0), 30);
    ref_fd = dialogAlloc();
    ref_fe = msgShow(msg_13);
/***************************************
[color(yellow)]麻希[color(white)]
[tab]やっほー♥
[tab]私もいるよ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_fe);
    bitGet(var_2, MBIT_HIRA_MAKI);
    bne(var_2, 0, label_107);
    ref_103 = msgShow(msg_14);
/***************************************
[color(yellow)]園村[tab]麻希（そのむら[tab]まき）[color(white)]
[tab][color(green)]セベク事件の中心人物であったペルソナ使い。
[tab]やはり、神取と浅からぬ因縁を持つ。[color(white)]
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_103);
    b(label_109);
  label_107:
    bne(var_2, 1, label_109);
    b(label_109);
  label_109:
    bitSet(MBIT_HIRA_MAKI);
    dialogFree(ref_fd);
    ref_10b = bustupFade(ref_fb, rgb(0,0,0), 10);
    bustupWait(ref_10b);
    bustupFree(ref_fb);
    unitAnimationStop(maki);
    unitAnimationPlay(maki, animation_a, 1);
    unitAnimationStop(nanjo);
    unitAnimationPlay(nanjo, animation_0, 1);
    delayClear();
    delayWait(30);
    ref_114 = cameraMoveTo(500, 0, -400, 120);
    unitMove(reiji, 600, -500, face_east, medium);
    unitMove(maki, 700, -390, face_east, medium);
    wait(ref_114);
    unitWait(maki);
    unitWait(reiji);
    delayClear();
    delayWait(30);
    unitAnimationPlay(nanjo, animation_1f, 1);
    ref_11d = bustupLoad(bustup_3a);
    bustupWait(ref_11d);
    ref_11f = bustupAlloc(ref_11d, left, rgb(0,0,0));
    bustupFade(ref_11f, rgb(128,0,0), 30);
    ref_121 = dialogAlloc();
    ref_122 = msgShow(msg_15);
/***************************************
[color(yellow)]南条[color(white)]
[tab]お前達、どうして…！？
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_122);
    dialogFree(ref_121);
    ref_126 = bustupFade(ref_11f, rgb(0,0,0), 10);
    bustupWait(ref_126);
    bustupFree(ref_11f);
    unitAnimationPlay(nanjo, animation_0, 1);
    delayClear();
    delayWait(60);
    unitAnimationPlay(maki, animation_2d, 1);
    ref_12d = bustupLoad(bustup_c2);
    bustupWait(ref_12d);
    ref_12f = bustupAlloc(ref_12d, right, rgb(0,0,0));
    bustupFade(ref_12f, rgb(128,0,0), 30);
    ref_131 = dialogAlloc();
    ref_132 = msgShow(msg_16);
/***************************************
[color(yellow)]麻希[color(white)]
[tab]英理子から頼まれたの。
[tab]南条君が悩んでるみたいだから、
[tab]力になってやってって。も～水臭いよ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_132);
    dialogFree(ref_131);
    ref_136 = bustupFade(ref_12f, rgb(0,0,0), 10);
    bustupWait(ref_136);
    bustupFree(ref_12f);
    unitAnimationPlay(maki, animation_a, 1);
    delayClear();
    delayWait(60);
    unitAnimationPlay(reiji, animation_b, 1);
    ref_13d = bustupLoad(bustup_c4);
    bustupWait(ref_13d);
    ref_13f = bustupAlloc(ref_13d, right, rgb(0,0,0));
    bustupFade(ref_13f, rgb(128,0,0), 30);
    ref_141 = dialogAlloc();
    ref_142 = msgShow(msg_17);
/***************************************
[color(yellow)]玲司[color(white)]
[tab]話は後だ…早く行け。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_142);
    dialogFree(ref_141);
    ref_146 = bustupFade(ref_13f, rgb(0,0,0), 10);
    bustupWait(ref_146);
    bustupFree(ref_13f);
    unitAnimationPlay(reiji, animation_a, 1);
    delayClear();
    delayWait(60);
    unitAnimationPlay(maki, animation_6, 1);
    ref_14d = bustupLoad(bustup_c2);
    bustupWait(ref_14d);
    ref_14f = bustupAlloc(ref_14d, right, rgb(0,0,0));
    bustupFade(ref_14f, rgb(128,0,0), 30);
    ref_151 = dialogAlloc();
    ref_152 = msgShow(msg_18);
/***************************************
[color(yellow)]麻希[color(white)]
[tab]もしあの人が本当に生きてるなら…
[tab]南条君、助けてあげて…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_152);
    unitAnimationPlay(maki, animation_1f, 1);
    ref_156 = msgShow(msg_19);
/***************************************
[color(yellow)]麻希[color(white)]
[tab]あの人の苦しみをわかってあげられるのは、
[tab]私たちしかいないから…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_156);
    dialogFree(ref_151);
    ref_15a = bustupFade(ref_14f, rgb(0,0,0), 10);
    bustupWait(ref_15a);
    bustupFree(ref_14f);
    unitAnimationPlay(maki, animation_a, 1);
