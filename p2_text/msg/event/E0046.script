    unitAnimationPlay(katsuya, animation_1, 1);
    unitAnimationPlay(nanjo, animation_a, 1);
    unitDespawn(reiji, none);
    unitDespawn(maki, none);
    ref_181 = cameraLookAtUnit(maya, 0, 30);
