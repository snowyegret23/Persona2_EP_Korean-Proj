    ref_192 = dialogAlloc();
    ref_193 = msgShow(msg_21);
/***************************************
[color(yellow)]南条[color(white)]
[tab]ロックの解除は、あの二人にまかせましょう。
[tab]渡したトランシーバーで連絡が取れます。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_193);
    unitWait(nanjo);
    unitAnimationPlay(nanjo, animation_1f, 1);
    ref_198 = msgShow(msg_22);
/***************************************
[color(yellow)]南条[color(white)]
