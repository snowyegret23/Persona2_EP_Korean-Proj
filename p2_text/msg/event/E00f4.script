function START()
{
    sndMusicPlay(sound_3011, 127);
    cameraSet(northeast, 1200, 0, -200);
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    bitSet(DBIT_KEN_SHATA);
    bitSet(DBIT_KEN_SHATA2);
    bitSet(DBIT_KEN_SHATA3);
    envTriggerSet(INDOOR0, 255, 1, line, coll_24);
    envTriggerSet(INDOOR0, 255, 1, line, coll_17);
    envTriggerSet(INDOOR1, 255, 1, line, coll_26);
    envTriggerSet(INDOOR1, 255, 1, line, coll_1a);
    envTriggerSet(EXIT1, 14, 1, line, coll_5);
    envTriggerSet(EXIT2, 131, 1, line, coll_2);
    ref_d = spriteLoad(sprite_18);
    wait(ref_d);
    ref_f = spriteLoad(sprite_11f);
    wait(ref_f);
    ref_11 = spriteLoad(sprite_dd);
    wait(ref_11);
    unitSpawn(tatsuya, sprite_18, 950, 0, -1050, south, none);
    unitSpawn(npc1, sprite_dd, 1100, 0, -150, east, none);
    unitAnimationPlay(npc1, animation_c, 1);
    unitSpawn(npc2, sprite_dd, 850, 0, -450, west, none);
    unitAnimationPlay(npc2, animation_c, 1);
    bitGet(var_0, bit_c76);
    bnz(var_0, label_72);
    msgLocSet(35, 110);
    ref_1b = msgShow(msg_0);
/***************************************
[tab][tab][tab][tab][tab]○○月０４日[tab]ＰＭ：２２時２４分[tab][tab][tab][tab][tab]
[tab][tab][tab][tab][tab][tab][tab]理学研究所[tab][tab]警備管理室[tab][tab][tab][tab][tab][tab][tab]

***************************************/
    wait(ref_1b);
    delayClear();
    delayWait(180);
    ref_1f = msgShow(msg_1);
/***************************************
[clear]
***************************************/
    wait(ref_1f);
    msgLocDefault();
    sndMusicPlay(sound_3165, 127);
    delayClear();
    delayWait(60);
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    screenFadeInner(rgb(0,0,0), 4, true);
    screenFadeOuter(rgb(0,0,0), 4, true);
    screenEffectUnknown();
    screenFadeWait(inner);
    screenFadeWait(outer);
    unitFace(tatsuya, south);
    unitMove(tatsuya, 950, -230, face_north, medium);
    unitWait(tatsuya);
    unitMove(tatsuya, 1120, -230, face_west, medium);
    unitWait(tatsuya);
    unitAnimationPlay(tatsuya, animation_5, 1);
    unitWait(tatsuya);
    delayClear();
    delayWait(60);
    ref_34 = bustupLoad(bustup_d);
    bustupWait(ref_34);
    ref_36 = bustupAlloc(ref_34, left, rgb(0,0,0));
    bustupFade(ref_36, rgb(128,0,0), 30);
    ref_38 = dialogAlloc();
    ref_39 = msgShow(msg_2);
/***************************************
[color(yellow)][tatsuya][color(white)]
[tab]舞耶姉、まだ諦めてないのか…
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_39);
    dialogFree(ref_38);
    ref_3d = bustupFade(ref_36, rgb(0,0,0), 10);
    bustupWait(ref_3d);
    bustupFree(ref_36);
    ref_40 = dialogAlloc();
    ref_41 = msgShow(msg_3);
/***************************************
塀を飛び越え理学研究所の警備室らしい部屋に
辿り着くと、既に警備員たちが倒され
警報装置や監視装置が切られていた。
どうりで簡単に忍び込めたはずだ。
[wait][clear]
***************************************/
    wait(ref_41);
    ref_43 = msgShow(msg_4);
/***************************************
ドアの前に倒れていた警備員のそばには、
曲がったコインが３枚落ちていた。
[wait][clear]
***************************************/
    wait(ref_43);
    ref_45 = msgShow(msg_5);
/***************************************
あんなもので銃を持った相手を倒せる人間は
一人しか知らない。
パオフゥとかいう胡散臭いおっさんだ。
[wait][clear]
***************************************/
    wait(ref_45);
    ref_47 = msgShow(msg_6);
/***************************************
ということは、舞耶姉や兄さんも一緒にいる。
俺より一足先に、拉致されたＪＯＫＥＲ使いたちが
ここに連行されていることを嗅ぎ付けたのだろう。
面倒なことになった。
[wait][clear]
***************************************/
    wait(ref_47);
    unitAnimationPlay(tatsuya, animation_4, 1);
    unitWait(tatsuya);
    ref_4b = msgShow(msg_7);
/***************************************
詩織さんの家を出てから
噂を辿りここへ着くまで、まる二日経っている。
詩織さんは、その間家にも警察署にも戻っていない。
【奴】の手先に拉致されたと見て間違いない。
[wait][clear]
***************************************/
    wait(ref_4b);
    ref_4d = msgShow(msg_8);
/***************************************
街ではＪＯＫＥＲ呪いをした連中がＪＯＫＥＲ使いに
なるのと同時に、なぜか何者かに拉致される
という事件も起きていたのだ。
[wait][clear]
***************************************/
    wait(ref_4d);
    ref_4f = msgShow(msg_9);
/***************************************
詩織さんと舞耶姉たちを同時に助け、ＪＯＫＥＲ使いを
狩っている連中の正体を探る必要があった。
そいつらが、仮面党に代わるこちら側の【奴】の手駒だ。
[wait][clear]
***************************************/
    wait(ref_4f);
    ref_51 = msgShow(msg_10);
/***************************************
三つのことを同時にこなし、できれば舞耶姉たちが
これ以上深入りしないように、先に情報を手に入れ
痕跡を破壊したい…[tab]できるか？
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_51);
    dialogFree(ref_40);
    unitAnimationPlay(tatsuya, animation_0, 1);
    delayClear();
    delayWait(60);
    unitAnimationPlay(tatsuya, animation_12, 1);
    unitWait(tatsuya);
    delayClear();
    delayWait(30);
    cameraMoveTo(1030, 0, -230, 60);
    unitFace(tatsuya, east);
    unitMove(tatsuya, 1030, -230, face_east, medium);
    unitWait(tatsuya);
    unitAnimationPlay(tatsuya, animation_6, 1);
    delayClear();
    delayWait(60);
    unitAnimationPlay(tatsuya, animation_0, 1);
    unitWait(tatsuya);
    ref_65 = bustupLoad(bustup_b);
    bustupWait(ref_65);
    ref_67 = bustupAlloc(ref_65, left, rgb(0,0,0));
    bustupFade(ref_67, rgb(128,0,0), 30);
    ref_69 = dialogAlloc();
    ref_6a = msgShow(msg_11);
/***************************************
[color(yellow)][tatsuya][color(white)]
[tab]やってやるさ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_6a);
    dialogFree(ref_69);
    ref_6e = bustupFade(ref_67, rgb(0,0,0), 10);
    bustupWait(ref_6e);
    bustupFree(ref_67);
    bitSet(bit_c76);
  label_72:
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    unitDespawn(tatsuya, none);
    unitDespawn(npc1, none);
    ref_7a = unitDespawn(npc2, none);
    wait(ref_7a);
    cameraSet(northeast, 1030, 0, -230);
    playerInit(east);
    controlDisable();
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
    sndMusicPlay(sound_406b, 127);
}

function INDOOR0()
{
    controlDisable();
    objCollisionLink(line, coll_24, obj_c);
    objCollisionLink(line, coll_17, obj_d);
    objAnimTranslate(obj_c, 0, 0, 100, 60);
    objAnimTranslate(obj_d, 0, 0, 10, 60);
    sndMusicPlay(sound_3165, 127);
    objAnimWait(obj_c);
    objAnimWait(obj_d);
    objVisible(obj_c, false);
    objVisible(obj_d, false);
    controlEnable();
}

function INDOOR1()
{
    controlDisable();
    objCollisionLink(line, coll_26, obj_a);
    objCollisionLink(line, coll_1a, obj_b);
    objAnimTranslate(obj_a, 0, 0, -100, 60);
    objAnimTranslate(obj_b, 0, 0, -10, 60);
    sndMusicPlay(sound_3165, 127);
    objAnimWait(obj_a);
    objAnimWait(obj_b);
    objVisible(obj_a, false);
    objVisible(obj_b, false);
    controlEnable();
}

function EXIT1()
{
    controlDisable();
    objAnimTranslate(obj_e, 0, 0, -100, 60);
    objAnimTranslate(obj_f, 0, 0, 100, 60);
    sndMusicPlay(sound_3164, 127);
    objAnimWait(obj_e);
    objAnimWait(obj_f);
    delayClear();
    delayWait(30);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    dngLoad(science_lab2, 2, 39, 14, 4);
}

function EXIT2()
{
    controlDisable();
    ref_b0 = dialogAlloc();
    ref_b1 = msgShow(msg_12);
/***************************************
[color(green)][tab]戻っている暇はない。[color(white)]
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_b1);
    dialogFree(ref_b0);
    controlEnable();
}
