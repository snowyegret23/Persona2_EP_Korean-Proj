function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    sndMusicPlay(sound_3063, 127);
    levelFootstepSet(sfx_18);
    envTriggerSet(DOORBOX, 56, 1, line, coll_0);
    cameraSet(northeast, 915, -200, -90);
    li(var_0, 0);
    li(var_1, 0);
    partyMemberCheck(var_0, ulala);
    add(var_1, var_1, var_0);
    partyMemberCheck(var_0, katsuya);
    add(var_1, var_1, var_0);
    partyMemberCheck(var_0, baofu);
    add(var_1, var_1, var_0);
    partyMemberCheck(var_0, nanjo);
    add(var_1, var_1, var_0);
    partyMemberCheck(var_0, elly);
    add(var_1, var_1, var_0);
    partyMemberCheck(var_0, tatsuya);
    add(var_1, var_1, var_0);
    boutrange(var_1, 0, 4, label_17);
    li(var_0, 0);
    b(label_1c);
  label_17:
    ref_17 = dialogAlloc();
    ref_18 = msgShow(msg_0);
/***************************************
パーティの人数が四人を超えています。
このままじゃハングします。
金田・片岡に連絡してください。
[wait][clear]
***************************************/
    wait(ref_18);
    dialogFree(ref_17);
    b(label_1c);
  label_1c:
    bitGet(var_0, EBIT_E009F);
    bnz(var_0, label_21);
    bitGet(var_0, EBIT_E008C);
    bez(var_0, label_27);
    bnz(var_0, label_23);
  label_21:
    partyMemberCheck(var_0, tatsuya);
    bez(var_0, label_27);
  label_23:
    ref_23 = spriteLoad(sprite_18);
    wait(ref_23);
    unitSpawn(tatsuya, sprite_18, 930, -100, -400, east, none);
    unitTriggerSet(tatsuya, B_TATU, 255, 1);
  label_27:
    bitGet(var_0, EBIT_E009F);
    bnz(var_0, label_31);
    ref_29 = spriteLoad(sprite_1f);
    wait(ref_29);
    unitSpawn(nanjo, sprite_1f, 500, -100, -900, south, none);
    unitTriggerSet(nanjo, B_NANJ, 255, 1);
    ref_2d = spriteLoad(sprite_23);
    wait(ref_2d);
    unitSpawn(elly, sprite_23, 140, -50, -740, east, none);
    unitTriggerSet(elly, B_ERI, 255, 1);
  label_31:
    partyMemberCheck(var_0, ulala);
    bez(var_0, label_37);
    ref_33 = spriteLoad(sprite_6);
    wait(ref_33);
    unitSpawn(ulala, sprite_6, 340, -50, -160, west, none);
    unitTriggerSet(ulala, B_URARATI, 255, 1);
  label_37:
    partyMemberCheck(var_0, katsuya);
    bez(var_0, label_3d);
    ref_39 = spriteLoad(sprite_d);
    wait(ref_39);
    unitSpawn(katsuya, sprite_d, 940, -100, -710, west, none);
    unitTriggerSet(katsuya, B_KATUYYY, 255, 1);
  label_3d:
    partyMemberCheck(var_0, baofu);
    bez(var_0, label_43);
    ref_3f = spriteLoad(sprite_13);
    wait(ref_3f);
    unitSpawn(baofu, sprite_13, 185, -50, -445, east, none);
    unitTriggerSet(baofu, B_PAO, 255, 1);
  label_43:
    ref_43 = spriteLoad(sprite_0);
    wait(ref_43);
    ref_45 = spriteLoad(sprite_2);
    wait(ref_45);
    playerInit(north);
    controlDisable();
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    unitIdleOnAll();
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

