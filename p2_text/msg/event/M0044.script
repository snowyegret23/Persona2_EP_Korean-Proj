function DOORBOX()
{
    controlDisable();
    sndMusicPlay(sound_3088, 127);
    objAnimRotate(obj_11, 0, 80, 0, 30, 0);
    objAnimWait(obj_11);
    call(GOOUT);
}

function GOOUT()
{
    bitClear(MBIT_EXITBIT);
    mapLoad(narumi, 24, 1);
}
