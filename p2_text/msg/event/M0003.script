function EXITBOX()
{
    controlDisable();
    bitGet(var_0, MBIT_KAOYASUMI01);
    bne(var_0, 0, label_830);
    bitGet(var_0, MBIT_KAOYASUMI02);
    bne(var_0, 0, label_82c);
    bitSet(MBIT_KAOYASUMI01);
    bitSet(MBIT_KAOYASUMI02);
    b(label_82f);
  label_82c:
    bne(var_0, 1, label_82f);
    bitClear(MBIT_KAOYASUMI);
    b(label_82f);
  label_82f:
    b(label_83b);
  label_830:
    bne(var_0, 1, label_83b);
    bitGet(var_0, MBIT_KAOYASUMI02);
    bne(var_0, 0, label_836);
    bitClear(MBIT_KAOYASUMI01);
    bitSet(MBIT_KAOYASUMI02);
    b(label_83a);
  label_836:
    bne(var_0, 1, label_83a);
    bitSet(MBIT_KAOYASUMI01);
    bitClear(MBIT_KAOYASUMI02);
    b(label_83a);
  label_83a:
    b(label_83b);
  label_83b:
    objAnimRotate(obj_16, 0, -70, 0, 30, 0);
    objAnimRotate(obj_15, 0, 70, 0, 30, 0);
    sndMusicPlay(sound_3068, 127);
    objAnimWait(obj_15);
    objAnimWait(obj_16);
    call(GOOUT);
}

function warp1()
{
    call(EXITBOX);
}

function GOOUT()
{
    bitClear(MBIT_EXITBIT);
    mapLoad(rengedai, 0, 0);
}

function HA_SHOP_EXPLAIN_0()
{
    choiceSetResult(2);
    ref_848 = dialogChoiceAlloc();
    ref_849 = msgShow(msg_103);
/***************************************
[color(yellow)]香さん[color(white)]
[tab]何をお聞きになりますか？
[choice(3)]回復
[if_all(MBIT_HI_KAORIAROMA)]アロマテラピー
やめる
[end_choice][clear]
***************************************/
    wait(ref_849);
    dialogFree(ref_848);
    choiceGetResult(var_0);
    bne(var_0, 0, label_853);
    ref_84e = dialogAlloc();
    ref_84f = msgShow(msg_104);
/***************************************
[color(yellow)]香さん[color(white)]
[tab]「回復」についてですね。
[wait][clear][color(yellow)]香さん[color(white)]
[tab]当店で「回復してもらう」を選んでいただくと
[tab]香りの力で、皆さんの「ＨＰ」と「ＳＰ」を、そして
[tab]「猛毒」などのステータス異常も回復いたしますよ。
[wait][clear]
***************************************/
    wait(ref_84f);
    dialogFree(ref_84e);
    b(label_85b);
  label_853:
    bne(var_0, 1, label_859);
    ref_854 = dialogAlloc();
    ref_855 = msgShow(msg_105);
/***************************************
[color(yellow)]香さん[color(white)]
[tab]「アロマテラピー」についてですね。
[tab]当店で「アロマテラピー」を選んでいただきますと、
[tab]皆様に新開発の芳香療法を施させていただきます。
[wait][clear][color(yellow)]香さん[color(white)]
[tab]これにより、皆様は特殊な「香」をまとう事になります。
[tab]結果、皆様は香を好む方を引き寄せ嫌う方を遠ざけます。
[wait][clear][color(yellow)]香さん[color(white)]
[tab]ちなみに、この香は人ならざるものへの影響が大きいと
[tab]聞きましたが、本当なのでしょうかね。
[wait][clear][color(yellow)]香さん[color(white)]
[tab]注意点がひとつだけ。
[tab]香が完全に消えるまで、新しい香は施せません。
[tab]香りが混ざって、効果が出なくなってしまいますからね。
[wait][clear]
***************************************/
    wait(ref_855);
    dialogFree(ref_854);
    b(label_85b);
  label_859:
    bne(var_0, 2, label_85b);
    b(label_85b);
  label_85b:
}

