function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    sndMusicPlay(sound_3013, 127);
    envTriggerSet(DOORBOX, 56, 1, line, coll_4);
    cameraSet(northwest, 800, -50, -75);
    li(var_0, 0);
    li(var_1, 0);
    partyMemberCheck(var_0, ulala);
    add(var_1, var_1, var_0);
    partyMemberCheck(var_0, katsuya);
    add(var_1, var_1, var_0);
    partyMemberCheck(var_0, baofu);
    add(var_1, var_1, var_0);
    partyMemberCheck(var_0, nanjo);
    add(var_1, var_1, var_0);
    partyMemberCheck(var_0, elly);
    add(var_1, var_1, var_0);
    boutrange(var_1, 0, 4, label_14);
    li(var_0, 0);
    b(label_19);
  label_14:
    ref_14 = dialogAlloc();
    ref_15 = msgShow(msg_0);
/***************************************
パーティの人数が四人を超えています。
このままじゃハングします。
金田・片岡に連絡してください。
[wait][clear]
***************************************/
    wait(ref_15);
    dialogFree(ref_14);
    b(label_19);
  label_19:
    partyMemberCheck(var_0, ulala);
    bez(var_0, label_1f);
    ref_1b = spriteLoad(sprite_6);
    wait(ref_1b);
    unitSpawn(ulala, sprite_6, 140, 0, -760, east, none);
    unitTriggerSet(ulala, B_URARATI, 255, 1);
  label_1f:
    partyMemberCheck(var_0, katsuya);
    bez(var_0, label_25);
    ref_21 = spriteLoad(sprite_d);
    wait(ref_21);
    unitSpawn(katsuya, sprite_d, 600, 0, -1200, south, none);
    unitTriggerSet(katsuya, B_KATUYYY, 255, 1);
  label_25:
    partyMemberCheck(var_0, baofu);
    bez(var_0, label_2b);
    ref_27 = spriteLoad(sprite_13);
    wait(ref_27);
    unitSpawn(baofu, sprite_13, 1340, 0, -1240, east, none);
    unitTriggerSet(baofu, B_PAO, 255, 1);
  label_2b:
    partyMemberCheck(var_0, nanjo);
    bez(var_0, label_31);
    ref_2d = spriteLoad(sprite_1f);
    wait(ref_2d);
    unitSpawn(nanjo, sprite_1f, 1110, 0, -580, south, none);
    unitTriggerSet(nanjo, B_NANJ, 255, 1);
  label_31:
    partyMemberCheck(var_0, elly);
    bez(var_0, label_37);
    ref_33 = spriteLoad(sprite_23);
    wait(ref_33);
    unitSpawn(elly, sprite_23, 1020, 0, -860, east, none);
    unitTriggerSet(elly, B_ERI, 255, 1);
  label_37:
    ref_37 = spriteLoad(sprite_76);
    wait(ref_37);
    unitSpawn(matsuoka, sprite_76, 990, 0, -390, east, none);
    unitTriggerSet(matsuoka, MATUOKA, 255, 1);
    ref_3b = spriteLoad(sprite_e7);
    wait(ref_3b);
    unitSpawn(npc1, sprite_e7, 250, 0, -440, north, none);
    unitTriggerSet(npc1, MAN1, 255, 1);
    unitSpawn(npc2, sprite_e7, 600, 0, -800, east, none);
    unitTriggerSet(npc2, MAN2, 255, 1);
    ref_41 = spriteLoad(sprite_0);
    wait(ref_41);
    ref_43 = spriteLoad(sprite_2);
    wait(ref_43);
    playerInit(north);
    controlDisable();
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    unitIdleOnAll();
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

function B_URARATI()
{
    controlDisable();
    unitFacePlayer(ulala);
    ref_51 = bustupLoad(bustup_17);
    bustupWait(ref_51);
    ref_53 = bustupAlloc(ref_51, left, rgb(0,0,0));
    bustupFade(ref_53, rgb(128,0,0), 30);
    ref_55 = dialogAlloc();
    ref_56 = msgShow(msg_1);
/***************************************
[color(yellow)]うらら[color(white)]
[tab]しっかし立派な部屋よねぇ～
[tab]私もこんな部屋で暮らしてみたいけど…
[tab]こりゃ毎日の掃除が大変だわ！
[wait][clear]
***************************************/
    unitAnimationPlay(ulala, animation_2d, 1);
    wait(ref_56);
    unitAnimationPlay(ulala, animation_a, 1);
    dialogFree(ref_55);
    ref_5b = bustupFade(ref_53, rgb(0,0,0), 10);
    bustupWait(ref_5b);
    bustupFree(ref_53);
    unitRestoreFacing(ulala);
    b(label_60);
  label_60:
    controlEnable();
}

