function MAN1()
{
    controlDisable();
    unitFacePlayer(npc1);
    ref_c7 = dialogAlloc();
    ref_c8 = msgShow(msg_8);
/***************************************
[color(yellow)]私設調査員[color(white)]
[tab]このモニターですか？
[tab]これには株価の動向を表示しています。
[tab]…日本？[tab]いえ、世界の株価情報です。
[wait][clear]
***************************************/
    unitAnimationPlay(npc1, animation_24, 1);
    wait(ref_c8);
    ref_cb = msgShow(msg_9);
/***************************************
[color(yellow)]私設調査員[color(white)]
[tab]…大きな動きですか？
[tab]先程、ヨーロッパの油田発掘・調査会社の株価が
[tab]急落しました。日本企業が関係している様です。
[wait][clear]
***************************************/
    unitAnimationPlay(npc1, animation_24, 1);
    wait(ref_cb);
    unitAnimationPlay(npc1, animation_0, 1);
    dialogFree(ref_c7);
    unitRestoreFacing(npc1);
    b(label_d2);
  label_d2:
    controlEnable();
}

