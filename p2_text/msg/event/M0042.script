function DOORBOX()
{
    controlDisable();
    sndMusicPlay(sound_3087, 127);
    objAnimRotate(obj_8, 0, -70, 0, 30, 0);
    objAnimRotate(obj_49, 0, 70, 0, 30, 0);
    objAnimWait(obj_8);
    objAnimWait(obj_49);
    call(GOOUT);
}

function GOOUT()
{
    bitClear(MBIT_EXITBIT);
    mapLoad(narumi, 33, 4);
}
