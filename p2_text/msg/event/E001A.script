    objAnimWait(obj_0);
    objAnimWait(obj_1);
    unitWait(baofu);
    unitMove(baofu, -50, -1700, fade, fast);
    unitWait(baofu);
}

function URARAMOVE2()
{
    unitMove(ulala, 130, -1150, face_west, fast);
    unitWait(ulala);
    unitMove(ulala, 130, -1700, face_north, fast);
    unitWait(ulala);
    unitMove(ulala, -50, -1700, fade, fast);
    unitWait(ulala);
}
