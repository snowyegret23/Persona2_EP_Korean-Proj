function KATUYAMOVE()
{
    unitMove(katsuya, 50, -1550, face_north, fast);
    unitWait(katsuya);
    unitFace(katsuya, west);
    unitWait(katsuya);
    unitAnimationPlay(katsuya, animation_1, 1);
    unitWait(katsuya);
}

function PAOFUMOVE()
{
    unitMove(baofu, 110, -1350, face_north, fast);
    unitWait(baofu);
    unitFace(baofu, west);
    unitWait(baofu);
    unitAnimationPlay(baofu, animation_0, 1);
    unitWait(baofu);
}

function URARAMOVE()
{
    unitMove(ulala, 80, -1150, face_north, fast);
    unitWait(ulala);
    unitFace(ulala, west);
    unitWait(ulala);
    unitAnimationPlay(ulala, animation_1f, 1);
    unitWait(ulala);
}

function PAOFUMOVE2()
{
    unitMove(baofu, 110, -1700, face_north, fast);
    unitWait(baofu);
    unitMove(baofu, 50, -1700, face_east, fast);
    unitWait(baofu);
