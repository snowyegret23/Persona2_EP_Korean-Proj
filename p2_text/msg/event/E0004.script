    wait(ref_1da);
    dialogFree(ref_1d6);
    unitAnimationPlay(enemy1, animation_0, 1);
    unitWait(enemy1);
    bitSet(EBIT_JOHO2);
    unitRestoreFacing(enemy1);
    controlEnable();
}

