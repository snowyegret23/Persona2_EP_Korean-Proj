    bustupFade(ref_112, rgb(128,0,0), 30);
    ref_114 = dialogChoiceAlloc();
    ref_115 = msgShow(msg_4);
/***************************************
[tab]アタシが文句言ってやるよ！！
[choice(2)]ありがとうユッキー、私なら大丈夫だから…
レッツ・ポジティブシンキング！へっちゃらよ
[end_choice][clear]
***************************************/
    sync();
    wait(ref_115);
    dialogFree(ref_114);
    ref_119 = bustupFade(ref_112, rgb(0,0,0), 10);
    bustupWait(ref_119);
    bustupFree(ref_112);
