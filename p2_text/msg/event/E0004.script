    unitSpawn(enemy3, sprite_bd, 1125, 0, -990, east, none);
    unitPalette(enemy3, 1);
    unitSpawn(enemy4, sprite_c1, 113, 0, -611, east, none);
    unitSpawn(enemy5, sprite_c2, 540, 0, -1220, east, none);
    unitPalette(enemy5, 1);
    unitAnimationPlay(enemy5, animation_28, 1);
    unitRevolveAnimationPlay(enemy5, animrevolve_2);
    objCollisionLink(collision_5, coll_6, obj_32);
    objCollisionLink(collision_5, coll_4, obj_32);
    objAnimTranslate(obj_32, 50, 0, 0, 5);
    objAnimWait(obj_32);
    unitSpawn(enemy6, sprite_c0, 780, 0, -650, west, none);
    unitPalette(enemy6, 1);
    unitAnimationPlay(enemy6, animation_28, 1);
    unitRevolveAnimationPlay(enemy6, animrevolve_1);
    objCollisionLink(collision_5, coll_1, obj_2d);
    objCollisionLink(collision_5, coll_0, obj_2d);
    objAnimTranslate(obj_2d, -30, 0, 0, 5);
    objAnimWait(obj_2d);
    unitSpawn(enemy7, sprite_c0, 1020, 0, -540, east, none);
    unitPalette(enemy7, 2);
    unitAnimationPlay(enemy7, animation_28, 1);
    unitRevolveAnimationPlay(enemy7, animrevolve_1);
    objCollisionLink(collision_5, coll_3, obj_36);
    objCollisionLink(collision_5, coll_2, obj_36);
    objAnimTranslate(obj_36, 30, 0, 0, 5);
    objAnimWait(obj_36);
    unitTriggerSet(yukino, YUKINO, 255, 1);
    unitTriggerSet(fujii, FUJII, 255, 1);
    unitTriggerSet(enemy1, ENEMY1, 255, 1);
    unitTriggerSet(enemy2, ENEMY2, 255, 1);
    unitTriggerSet(enemy3, ENEMY3, 255, 1);
    unitTriggerSet(enemy4, ENEMY4, 255, 1);
    unitTriggerSet(enemy5, ENEMY5, 255, 1);
    unitTriggerSet(enemy6, ENEMY6, 255, 1);
    unitTriggerSet(enemy7, ENEMY7, 255, 1);
    envTriggerSet(ENEMY5, 14, 1, collision_5, coll_6);
    envTriggerSet(ENEMY5, 14, 1, collision_5, coll_4);
    envTriggerSet(ENEMY6, 224, 1, collision_5, coll_1);
    envTriggerSet(ENEMY6, 224, 1, collision_5, coll_0);
    envTriggerSet(ENEMY7, 14, 1, collision_5, coll_3);
    envTriggerSet(ENEMY7, 14, 1, collision_5, coll_2);
    envTriggerSet(ELE, 56, 1, line, coll_b);
    envTriggerSet(HENSHU, 131, 1, line, coll_1);
    envTriggerSet(KAIDAN, 224, 1, line, coll_15);
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    screenFadeInner(rgb(0,0,0), 6, true);
    screenFadeOuter(rgb(0,0,0), 6, true);
    screenEffectUnknown();
    screenFadeWait(inner);
    screenFadeWait(outer);
    delayClear();
    delayWait(60);
    unitAnimationPlay(yukino, animation_2d, 1);
    ref_71 = bustupLoad(bustup_11a);
    bustupWait(ref_71);
    ref_73 = bustupAlloc(ref_71, right, rgb(0,0,0));
    bustupFade(ref_73, rgb(128,0,0), 30);
    ref_75 = dialogAlloc();
    ref_76 = msgShow(msg_0);
/***************************************
[color(yellow)]ゆきの[color(white)]
[tab]舞耶さん、芹沢さんって人から電話ありましたよ。
[tab]受付に迎えに来るって言ってたけど…
[tab]来たら内線あるんじゃないかな？
[sync][wait][clear]
***************************************/
    unitAnimationPlay(maya, animation_1, 1);
    delayClear();
    delayWait(8);
    unitAnimationPlay(maya, animation_2, 1);
    sync();
    wait(ref_76);
    unitAnimationPlay(yukino, animation_a, 1);
    ref_7e = msgShow(msg_1);
/***************************************
[color(yellow)]黛[tab]ゆきの（まゆずみ[tab]ゆきの）[color(white)]
[color(green)][tab]舞耶の相棒だったカメラマン（見習い）。
[tab]本来はキスメット出版の社員ではなく、
[tab]関係者の藤井が雇うバイト助手。[color(white)]
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_7e);
    unitAnimationPlay(yukino, animation_2d, 1);
    ref_82 = msgShow(msg_2);
/***************************************
[color(yellow)]ゆきの[color(white)]
[tab]そう言えば、お見合いパーティ行くんでしたっけ？
[tab]アタシら、土日もへったくれもないからねぇ…
[tab]たまには、思い切り羽伸ばしてくるといいよ。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_82);
    dialogFree(ref_75);
    ref_86 = bustupFade(ref_73, rgb(0,0,0), 10);
    bustupWait(ref_86);
    bustupFree(ref_73);
    unitAnimationPlay(yukino, animation_a, 1);
    bitSet(EBIT_E0004_B);
    delayClear();
    delayWait(60);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 4, false);
    screenFadeOuter(rgb(255,255,255), 4, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    ref_93 = cameraLookAtUnit(maya, 0, 1);
    wait(ref_93);
    unitDespawn(maya, none);
    playerInit(south);
    controlDisable();
    unitSpawn(yukino, sprite_35, 1310, 0, -240, south, none);
    unitSpawn(fujii, sprite_6b, 1310, 0, -130, north, none);
    unitIdleOnAll();
    unitIdleOff(fujii);
    unitIdleOff(enemy5);
    unitIdleOff(enemy6);
    unitIdleOff(enemy7);
    delayClear();
    delayWait(60);
    screenEffectUnknown();
    screenFadeInner(rgb(0,0,0), 4, true);
    screenFadeOuter(rgb(0,0,0), 4, true);
    screenFadeWait(inner);
    screenFadeWait(outer);
    controlEnable();
}

