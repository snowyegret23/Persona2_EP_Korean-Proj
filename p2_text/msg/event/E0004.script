    bustupFade(ref_133, rgb(128,0,0), 30);
    ref_135 = dialogAlloc();
    ref_136 = msgShow(msg_5);
/***************************************
[color(yellow)]ゆきの[color(white)]
[tab]アタシとのコンビも解消なんて、
[tab]なんて見え透いた嫌がらせだい…
[tab]負けちゃダメだよ、舞耶さん！
[sync][wait][clear]
***************************************/
