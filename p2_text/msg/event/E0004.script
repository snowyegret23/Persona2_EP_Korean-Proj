function START()
{
    screenEffectInit();
    screenFade(160, 120, rgb(255,255,255), rgb(255,255,255), sub);
    disableMap();
    sndIdGet(var_0);
    bne(var_0, -1, label_9);
    ref_5 = sndLoad(sound_3035);
    wait(ref_5);
    sndMusicPlay(sound_3035, 127);
    b(label_a);
  label_9:
    b(label_a);
  label_a:
    objCollisionLink(collision_2, coll_e, obj_4d);
    objVisible(obj_4d, false);
    objVisible(obj_a9, false);
    ref_d = spriteLoad(sprite_0);
    wait(ref_d);
    ref_f = spriteLoad(sprite_2);
    wait(ref_f);
    ref_11 = spriteLoad(sprite_35);
    wait(ref_11);
    ref_13 = spriteLoad(sprite_6b);
    wait(ref_13);
    ref_15 = spriteLoad(sprite_c0);
    wait(ref_15);
    ref_17 = spriteLoad(sprite_c1);
    wait(ref_17);
    ref_19 = spriteLoad(sprite_c2);
    wait(ref_19);
    ref_1b = spriteLoad(sprite_c3);
    wait(ref_1b);
    ref_1d = spriteLoad(sprite_ba);
    wait(ref_1d);
    ref_1f = spriteLoad(sprite_bb);
    wait(ref_1f);
    ref_21 = spriteLoad(sprite_bd);
    wait(ref_21);
    bitGet(var_1, EBIT_E0004_B);
    bne(var_1, 0, label_28);
    ref_25 = call(KYOUSEI);
    wait(ref_25);
    b(label_2c);
  label_28:
    bne(var_1, 1, label_2c);
    ref_29 = call(FREE);
    wait(ref_29);
    b(label_2c);
  label_2c:
}

function KYOUSEI()
{
    cameraSet(southwest, 300, 0, -1750);
    objAnimTranslate(obj_2b, -50, 0, 0, 5);
    objAnimWait(obj_2b);
    objAnimTranslate(obj_38, -50, 0, 0, 5);
    objAnimWait(obj_38);
    unitSpawn(maya, sprite_0, 300, 0, -1750, north, none);
    unitFace(maya, south);
    unitSpawn(yukino, sprite_35, 149, 0, -1735, west, none);
    unitAnimationPlay(yukino, animation_0, 1);
    unitSpawn(fujii, sprite_6b, 135, 0, -1592, west, none);
    unitAnimationPlay(fujii, animation_1, 1);
    unitSpawn(enemy1, sprite_c0, 1414, 0, -464, south, none);
    unitSpawn(enemy2, sprite_bd, 724, 0, -1298, west, none);
