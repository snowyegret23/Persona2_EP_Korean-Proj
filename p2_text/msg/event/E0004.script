function ELE()
{
    controlDisable();
    bitGet(var_3, EBIT_RESEERVE_0016);
    bnz(var_3, label_2bb);
    bitGet(var_3, EBIT_FUJII);
    bez(var_3, label_2c9);
    bitGet(var_3, EBIT_JOHO1);
    bez(var_3, label_2c9);
    bitGet(var_3, EBIT_JOHO2);
    bez(var_3, label_2c9);
    bitGet(var_3, EBIT_JOHO3);
    bez(var_3, label_2c9);
    bitGet(var_3, EBIT_JOHO4);
    bez(var_3, label_2c9);
    bitGet(var_3, EBIT_JOHO5);
    bez(var_3, label_2c9);
    bitGet(var_3, EBIT_JOHO6);
    bez(var_3, label_2c9);
    bitGet(var_3, EBIT_JOHO7);
    bez(var_3, label_2c9);
    unitFacePlayer(yukino);
    unitAnimationPlay(yukino, animation_2d, 1);
    ref_2a1 = bustupLoad(bustup_11a);
    bustupWait(ref_2a1);
    ref_2a3 = bustupAlloc(ref_2a1, right, rgb(0,0,0));
    bustupFade(ref_2a3, rgb(128,0,0), 30);
    ref_2a5 = dialogAlloc();
    ref_2a6 = msgShow(msg_30);
/***************************************
[color(yellow)]ゆきの[color(white)]
[tab]舞耶さん、今さっき内線あったよ。
[tab]芹沢さん、受付に来てるって。
[sync][wait][clear]
***************************************/
    playerConvertToUnit(maya, sprite_0, north);
    playerHide();
    unitFaceUnit(maya, yukino);
    sync();
    wait(ref_2a6);
    dialogFree(ref_2a5);
    ref_2ad = bustupFade(ref_2a3, rgb(0,0,0), 10);
    bustupWait(ref_2ad);
    bustupFree(ref_2a3);
    unitAnimationPlay(yukino, animation_a, 1);
    delayClear();
    delayWait(60);
    unitAnimationPlay(maya, animation_24, 1);
    unitWait(maya);
    delayClear();
    delayWait(60);
    unitFace(maya, south);
    unitRestoreFacing(yukino);
    bitSet(EBIT_RESEERVE_0016);
    b(label_2bb);
  label_2bb:
    sndMusicPlay(sound_30a7, 127);
    objAnimTranslate(obj_13, 100, 0, 0, 60);
    objAnimTranslate(obj_14, -200, 0, 0, 60);
    delayClear();
    delayWait(30);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    bitSet(EBIT_E1100);
    eventLoad(event_9a);
    b(label_2db);
  label_2c9:
    unitFacePlayer(yukino);
    unitAnimationPlay(yukino, animation_2d, 1);
    ref_2cb = bustupLoad(bustup_11a);
    bustupWait(ref_2cb);
    ref_2cd = bustupAlloc(ref_2cb, right, rgb(0,0,0));
    bustupFade(ref_2cd, rgb(128,0,0), 30);
    ref_2cf = dialogAlloc();
    ref_2d0 = msgShow(msg_31);
/***************************************
[color(yellow)]ゆきの[color(white)]
[tab]舞耶さん、まだ内線無いし、
[tab]もう少しゆっくりしててもいいんじゃないかい？
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_2d0);
    dialogFree(ref_2cf);
    ref_2d4 = bustupFade(ref_2cd, rgb(0,0,0), 10);
    bustupWait(ref_2d4);
    bustupFree(ref_2cd);
    unitAnimationPlay(yukino, animation_a, 1);
    unitRestoreFacing(yukino);
    controlEnable();
    b(label_2db);
  label_2db:
}

function HENSHU()
{
    controlDisable();
    objAnimRotate(obj_15, 0, 80, 0, 60, 0);
    sndMusicPlay(sound_30a8, 127);
    delayClear();
    delayWait(30);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    eventLoad(event_98);
}

