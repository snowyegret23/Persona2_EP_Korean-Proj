    wait(ref_207);
    dialogFree(ref_1f6);
    unitAnimationPlay(enemy3, animation_0, 1);
    unitWait(enemy3);
    bitSet(EBIT_JOHO3);
    unitRestoreFacing(enemy3);
    controlEnable();
}

