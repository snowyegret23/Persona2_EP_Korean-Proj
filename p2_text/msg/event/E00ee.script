    ref_60 = dialogAlloc();
    ref_61 = msgShow(msg_7);
/***************************************
[color(yellow)]詩織[color(white)]
[tab]銃刀法違反で現行犯逮捕します！
[tab]手を頭の後ろで組んで、膝を突いて！
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_61);
    dialogFree(ref_60);
    ref_65 = bustupFade(ref_5e, rgb(0,0,0), 10);
