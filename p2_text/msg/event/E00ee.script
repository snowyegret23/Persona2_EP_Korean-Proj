    bustupFree(ref_48);
    unitAnimationPlay(tatsuya, animation_a, 1);
    unitWait(tatsuya);
    delayClear();
    delayWait(30);
    sndMusicPlay(sound_31cf, 127);
    ref_57 = dialogAlloc();
    ref_58 = msgShow(msg_6);
/***************************************
影はわずかの間硬直したように動かなかったが、
観念したのかすぐ凶器を手放した。
私は床に落ちた凶器を蹴り飛ばし、
銃を突きつけたまま喚き続けた。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_58);
    dialogFree(ref_57);
    ref_5c = bustupLoad(bustup_12b);
    bustupWait(ref_5c);
