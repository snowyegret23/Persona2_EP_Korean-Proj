    unitAnimationPlay(tatsuya, animation_e, 1);
    unitWait(tatsuya);
    delayClear();
    delayWait(60);
    ref_42 = msgShow(msg_4);
/***************************************
[color(yellow)]影[color(white)]
[tab]…宮代[tab]詩織、だな。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_42);
    dialogFree(ref_3b);
    ref_46 = bustupLoad(bustup_12b);
