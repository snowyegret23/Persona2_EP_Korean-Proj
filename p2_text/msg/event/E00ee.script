    ref_20 = dialogAlloc();
    ref_21 = msgShow(msg_0);
/***************************************
入り口が静かに開き、照明を落とした
薄暗いダンスフロアに長身の人影が入ってきた。
[wait][clear]
***************************************/
    wait(ref_21);
    ref_23 = msgShow(msg_1);
/***************************************
手に反った棒状の武器を携行している。
刀のようだ。
５０１号に殺された被害者数人の成傷器痕と一致する。
[sync][wait][clear]
***************************************/
    sync();
    wait(ref_23);
    dialogFree(ref_20);
    unitFace(unit_73, south);
    ref_28 = unitMove(unit_73, 550, -1500, face_north, fast);
    unitAnimationPlay(unit_73, animation_5, 1);
