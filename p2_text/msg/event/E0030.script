function ODOROKI()
{
    unitAnimationHold(makimura, animation_1c, 60);
    unitAnimationPlay(tatsuya, animation_1b, 1);
    unitAnimationHold(lisa, animation_21, 60);
    unitAnimationHold(eikichi, animation_21, 60);
    unitAnimationHold(maya, animation_21, 60);
    unitAnimationPlay(yukino, animation_1b, 1);
    unitWait(makimura);
    unitWait(tatsuya);
    unitWait(lisa);
    unitWait(eikichi);
    unitWait(maya);
    unitWait(yukino);
    unitAnimationPlay(makimura, animation_0, 1);
}
