function DOORBOX()
{
    controlDisable();
    sndMusicPlay(sound_3076, 127);
    objAnimRotate(obj_17, 0, 70, 0, 30, 0);
    objAnimRotate(obj_16, 0, -70, 0, 30, 0);
    objAnimWait(obj_16);
    objAnimWait(obj_17);
    call(GOOUT);
}

function warp1()
{
    call(DOORBOX);
}

function GOOUT()
{
    bitClear(MBIT_EXITBIT);
    mapLoad(rengedai, 0, 0);
}

function HA_SHOP_EXPLAIN_0()
{
    choiceSetResult(2);
