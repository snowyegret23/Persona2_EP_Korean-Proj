    bitGet(var_0, MBIT_ETEHENNISHU);
    bitGet(var_1, MBIT_ETEHENNISHU_2);
    add(var_1, var_1, var_0);
    bne(var_1, 0, label_16);
    rand(var_0, 1);
    bne(var_0, 0, label_13);
    bitSet(MBIT_ETEHENNISHU_2);
    b(label_15);
  label_13:
    bitSet(MBIT_ETEHENNISHU);
    b(label_15);
  label_15:
    b(label_18);
  label_16:
    bne(var_1, 1, label_18);
