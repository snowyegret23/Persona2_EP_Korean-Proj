    dialogFree(ref_33);
    b(label_38);
  label_38:
    bitGet(var_0, EBIT_E009F);
    bnz(var_0, label_3d);
    bitGet(var_0, EBIT_E008C);
    bez(var_0, label_43);
    bnz(var_0, label_3f);
  label_3d:
    partyMemberCheck(var_0, tatsuya);
    bez(var_0, label_43);
  label_3f:
