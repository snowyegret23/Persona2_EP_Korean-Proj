    unitTriggerSet(tatsuya, B_TATU, 255, 1);
  label_43:
    bitGet(var_0, EBIT_E009F);
    bnz(var_0, label_56);
    bitGet(var_0, MBIT_HI_NANJOTOUJO);
    bne(var_0, 0, label_4e);
