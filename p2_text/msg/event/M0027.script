    ref_71c = msgShow(msg_96);
/***************************************
[color(yellow)]エステティシャン[color(white)]
[tab]何について聞きたいのかしら？
[choice(3)][if_all(MBIT_KE_ETEESTHE)]エステティック
回復
やめる
[end_choice][clear]
***************************************/
    wait(ref_71c);
    dialogFree(ref_71b);
    choiceGetResult(var_0);
