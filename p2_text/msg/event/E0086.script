    dialogFree(ref_1d4);
    ref_1e1 = bustupFade(ref_1d2, rgb(0,0,0), 10);
    bustupWait(ref_1e1);
    bustupFree(ref_1d2);
    ref_1e4 = bustupLoad(bustup_51);
    bustupWait(ref_1e4);
    ref_1e6 = bustupAlloc(ref_1e4, right, rgb(0,0,0));
    bustupFade(ref_1e6, rgb(128,0,0), 30);
    ref_1e8 = dialogAlloc();
    ref_1e9 = msgShow(msg_21);
/***************************************
[color(yellow)]神取[color(white)]
[tab]わかった…
[tab]では私の相手は、特異点の少年に頼もうか。
[sync][wait][clear]
***************************************/
    ref_1ea = sndVoicePlay(sound_70, 127);
    sndWaitStart();
    wait(ref_1ea);
    sync();
    wait(ref_1e9);
    dialogFree(ref_1e8);
    ref_1f0 = bustupFade(ref_1e6, rgb(0,0,0), 10);
    bustupWait(ref_1f0);
    bustupFree(ref_1e6);
    ref_1f3 = bustupLoad(bustup_53);
    bustupWait(ref_1f3);
    ref_1f5 = bustupAlloc(ref_1f3, right, rgb(0,0,0));
    bustupFade(ref_1f5, rgb(128,0,0), 30);
    ref_1f7 = dialogAlloc();
    ref_1f8 = msgShow(msg_22);
/***************************************
[color(yellow)]千鶴[color(white)]
[tab]この前の借り、返させてもらうわよ。
[sync][wait][clear]
***************************************/
    ref_1f9 = sndVoicePlay(sound_a5, 127);
    sndWaitStart();
    unitAnimationPlay(unit_15, animation_54, 1);
    wait(ref_1f9);
    sync();
    wait(ref_1f8);
    dialogFree(ref_1f7);
    ref_200 = bustupFade(ref_1f5, rgb(0,0,0), 10);
    bustupWait(ref_200);
    bustupFree(ref_1f5);
    ref_203 = bustupLoad(bustup_40);
    bustupWait(ref_203);
    ref_205 = bustupAlloc(ref_203, left, rgb(0,0,0));
    bustupFade(ref_205, rgb(128,0,0), 30);
    ref_207 = dialogAlloc();
    ref_208 = msgShow(msg_23);
/***************************************
[color(yellow)]エリー[color(white)]
[tab]哀しい目…貴方…

***************************************/
    ref_209 = sndVoicePlay(sound_60, 127);
    sndWaitStart();
    wait(ref_208);
    ref_20c = msgShow(msg_24);
/***************************************
[tab]わかりました…正々堂々お相手いたしますわ。
[sync][wait][clear]
***************************************/
    delayClear();
    delayWait(150);
    unitAnimationHold(elly, animation_12, -1);
    wait(ref_209);
    sync();
    wait(ref_20c);
    dialogFree(ref_207);
    ref_214 = bustupFade(ref_205, rgb(0,0,0), 10);
    bustupWait(ref_214);
    bustupFree(ref_205);
    sndMusicPlay(sound_3239, 127);
    encounterLoad(encounter_12);
}

