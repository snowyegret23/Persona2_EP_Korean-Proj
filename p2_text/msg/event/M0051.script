}

function SAGI()
{
    controlDisable();
    unitFacePlayer(makimura);
    ref_ec = bustupLoad(bustup_d4);
    bustupWait(ref_ec);
    ref_ee = bustupAlloc(ref_ec, right, rgb(0,0,0));
    bustupFade(ref_ee, rgb(128,0,0), 30);
    ref_f0 = dialogAlloc();
    ref_f1 = msgShow(msg_9);
/***************************************
[color(yellow)]牧村[color(white)]
[tab]この刑事さん、本当に男なのか？
[tab]本当の男だったら、
[tab]この俺の気持ち…わかるハズだ！！
[wait][clear]
***************************************/
    unitAnimationPlay(makimura, animation_24, 1);
    wait(ref_f1);
    unitAnimationPlay(makimura, animation_0, 1);
    dialogFree(ref_f0);
    ref_f6 = bustupFade(ref_ee, rgb(0,0,0), 10);
    bustupWait(ref_f6);
    bustupFree(ref_ee);
    unitRestoreFacing(makimura);
    controlEnable();
}

function B_URARATI()
{
    ref_fc = dialogAlloc();
    ref_fd = msgShow(msg_10);
/***************************************
[tab]いないハズですよ！？
[tab]（かたおか）
[wait][clear]
***************************************/
    wait(ref_fd);
    dialogFree(ref_fc);
}

function DOORBOX()
{
    controlDisable();
    sndMusicPlay(sound_3092, 127);
    objAnimRotate(obj_f, 0, 80, 0, 30, 0);
    objAnimRotate(obj_10, 0, -80, 0, 30, 0);
    objAnimWait(obj_f);
    objAnimWait(obj_10);
    screenEffectInit();
    screenFade(160, 120, rgb(0,0,0), rgb(0,0,0), sub);
    screenFadeInner(rgb(255,255,255), 6, false);
    screenFadeOuter(rgb(255,255,255), 6, false);
    screenFadeWait(inner);
    screenFadeWait(outer);
    dngLoad2(gold-8);
}

