function B_KATUYYY()
{
    controlDisable();
    bitSet(LBIT_0001);
    unitFacePlayer(katsuya);
    ref_86 = bustupLoad(bustup_21);
    bustupWait(ref_86);
    ref_88 = bustupAlloc(ref_86, left, rgb(0,0,0));
    bustupFade(ref_88, rgb(128,0,0), 30);
    ref_8a = dialogAlloc();
    ref_8b = msgShow(msg_0);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]犯罪者の心理と言うものを
[tab]探ってみようと思ったのだが…
[tab]彼のはただの言い訳だったよ。
[wait][clear]
***************************************/
    unitAnimationHold(katsuya, animation_1d, -1);
    wait(ref_8b);
    bitGet(var_0, LBIT_0000);
    bne(var_0, 0, label_91);
    b(label_96);
  label_91:
    bne(var_0, 1, label_96);
    ref_92 = msgShow(msg_1);
/***************************************
[color(yellow)]克哉[color(white)]
[tab]…え？[tab]バーベル！？
[tab]何かと見間違えたんじゃないのかい？
[wait][clear]
***************************************/
    unitAnimationHold(katsuya, animation_1a, -1);
    wait(ref_92);
    b(label_96);
  label_96:
    unitAnimationPlay(katsuya, animation_a, 1);
    dialogFree(ref_8a);
    ref_98 = bustupFade(ref_88, rgb(0,0,0), 10);
    bustupWait(ref_98);
    bustupFree(ref_88);
    unitRestoreFacing(katsuya);
    controlEnable();
    bitClear(LBIT_0001);
    call(KATUYA00);
}

function B_PAO()
{
    controlDisable();
    unitFacePlayer(baofu);
    ref_a2 = bustupLoad(bustup_2d);
    bustupWait(ref_a2);
    ref_a4 = bustupAlloc(ref_a2, left, rgb(0,0,0));
    bustupFade(ref_a4, rgb(128,0,0), 30);
    bitGet(var_0, EBIT_GETKEY2);
    bne(var_0, 0, label_af);
    ref_a8 = dialogAlloc();
    ref_a9 = msgShow(msg_2);
/***************************************
[color(yellow)]パオフゥ[color(white)]
[tab]その姉ちゃん、鍵持ってなかったんだろ？
[tab]…さっさと行こうや。
[wait][clear]
***************************************/
    unitAnimationPlay(baofu, animation_1a, 1);
    wait(ref_a9);
    unitAnimationPlay(baofu, animation_a, 1);
    dialogFree(ref_a8);
    b(label_b7);
  label_af:
    bne(var_0, 1, label_b7);
    ref_b0 = dialogAlloc();
    ref_b1 = msgShow(msg_3);
/***************************************
[color(yellow)]パオフゥ[color(white)]
[tab]ここに用はねぇだろ？[tab]さっさと行こうや。
[tab]…あぁ？[tab]芹沢が心配かって？
[tab]つまんねぇ事ぁ、早く片付けてぇだけだよ…
[wait][clear]
***************************************/
    unitAnimationPlay(baofu, animation_2d, 1);
    wait(ref_b1);
    unitAnimationPlay(baofu, animation_a, 1);
    dialogFree(ref_b0);
    b(label_b7);
  label_b7:
    ref_b7 = bustupFade(ref_a4, rgb(0,0,0), 10);
    bustupWait(ref_b7);
    bustupFree(ref_a4);
    unitRestoreFacing(baofu);
    controlEnable();
}

function STAFF()
{
    controlDisable();
    bitGet(var_0, EBIT_GETKEY2);
    bne(var_0, 0, label_de);
    bitGet(var_0, LBIT_0005);
    bne(var_0, 0, label_d2);
    bitSet(LBIT_0005);
    unitFacePlayer(unit_58);
    ref_c4 = dialogAlloc();
    ref_c5 = msgShow(msg_4);
/***************************************
[color(yellow)]女性スタッフ[color(white)]
[tab]はい？[tab]ボクシングジムの鍵ですか？
[tab]私は持ってませんけど…
[tab]あっ、持ってるのは先輩ですよ！
[wait][clear]
***************************************/
    unitAnimationPlay(unit_58, animation_24, 1);
    wait(ref_c5);
    ref_c8 = msgShow(msg_5);
/***************************************
[color(yellow)]女性スタッフ[color(white)]
[tab]…居場所ですか？
[tab]う～ん、あの人のことだから…
[wait][clear]
***************************************/
    unitAnimationPlay(unit_58, animation_24, 1);
    wait(ref_c8);
    ref_cb = msgShow(msg_6);
/***************************************
[color(yellow)]女性スタッフ[color(white)]
[tab]更衣室にいたりして！？
[tab]女性用のスタッフルームとか！？
[tab]…きゃははは！
[wait][clear]
***************************************/
    unitAnimationPlay(unit_58, animation_1d, 1);
    wait(ref_cb);
    unitAnimationPlay(unit_58, animation_0, 1);
    dialogFree(ref_c4);
    unitRestoreFacing(unit_58);
    b(label_dd);
  label_d2:
    bne(var_0, 1, label_dd);
    bitClear(LBIT_0005);
    unitFacePlayer(unit_58);
    ref_d5 = dialogAlloc();
    ref_d6 = msgShow(msg_7);
/***************************************
[color(yellow)]女性スタッフ[color(white)]
[tab]はい？[tab]バーベル…ですか？
[tab]ここには置いてませんけど…
[wait][clear]
***************************************/
    unitAnimationPlay(unit_58, animation_24, 1);
    wait(ref_d6);
    unitAnimationPlay(unit_58, animation_0, 1);
    dialogFree(ref_d5);
    unitRestoreFacing(unit_58);
    b(label_dd);
  label_dd:
    b(label_e8);
  label_de:
    bne(var_0, 1, label_e8);
    unitFacePlayer(unit_58);
    ref_e0 = dialogAlloc();
    ref_e1 = msgShow(msg_8);
/***************************************
[color(yellow)]女性スタッフ[color(white)]
[tab]はい！？
[tab]あの先輩、ホントに更衣室にいたんですか？
[tab]…やだ、キモチ悪い。
[wait][clear]
***************************************/
    unitAnimationPlay(unit_58, animation_24, 1);
    wait(ref_e1);
    unitAnimationPlay(unit_58, animation_0, 1);
    dialogFree(ref_e0);
    unitRestoreFacing(unit_58);
    b(label_e8);
  label_e8:
